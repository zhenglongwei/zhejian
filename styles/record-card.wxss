/**
 * 列表记录卡片 — album-card / lead-card / authorization-card 共用布局
 */
.record-card__inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.record-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
}

.record-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  flex: 1;
  min-width: 0;
}

.record-card__head-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.record-card__share-btn {
  margin: 0;
  padding: 0;
  font-size: var(--font-caption);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: transparent;
  line-height: 1.4;
}

.record-card__share-btn::after {
  border: none;
}

.record-card__time {
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.record-card__service {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.record-card__meta {
  color: var(--color-text-secondary);
}

.record-card__actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}
