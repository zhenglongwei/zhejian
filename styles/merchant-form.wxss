/**
 * 商家端表单共用样式（入驻 / 案例创建 / 服务上架）
 */

.merchant-form-page {
  padding-top: var(--space-md);
  padding-bottom: var(--page-fixed-clearance);
}

.merchant-form__section {
  margin-top: var(--space-lg);
}

.merchant-form__label {
  display: block;
  margin-bottom: var(--space-sm);
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.merchant-form__label--sub {
  margin-top: var(--space-md);
}

.merchant-form__switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-sm);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-form__hint-inline {
  display: block;
  margin-top: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.merchant-form__picker,
.merchant-form__input,
.merchant-form__textarea {
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-form__textarea {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}

.merchant-form__readonly {
  display: block;
  padding: var(--space-md);
  color: var(--color-text-primary);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-form__row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.merchant-form__input--half {
  flex: 1;
}

.merchant-form__price-preview {
  margin-top: var(--space-sm);
}

.merchant-form__notice {
  margin-top: var(--space-sm);
}

.merchant-form__hint {
  margin-top: var(--space-lg);
  color: var(--color-text-secondary);
}

.merchant-form__spacer {
  height: var(--space-xl);
}

.merchant-form__chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.merchant-form__chip {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-full);
  font-size: var(--font-caption);
  background-color: var(--color-bg-muted);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

.merchant-form__chip--on {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.merchant-form__chip:active {
  opacity: 0.72;
}

.merchant-form__custom-line {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-form__custom-label {
  flex-shrink: 0;
  color: var(--color-text-secondary);
}

.merchant-form__custom-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background-color: transparent;
  border: none;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
}

.merchant-form__hint-inline {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.merchant-form__suggest {
  margin-top: var(--space-sm);
  padding: var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-form__suggest-empty {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.merchant-list__scroll-pad {
  padding-bottom: var(--page-fixed-clearance);
}

.merchant-list-fab {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--space-md) var(--page-padding-x);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, var(--color-bg-page) 40%);
  box-sizing: border-box;
}
