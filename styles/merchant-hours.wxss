.merchant-hours__hint {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
}

.merchant-hours__presets {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.merchant-hours__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-hours__row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__row--closed {
  background-color: var(--color-bg-muted);
}

.merchant-hours__day {
  flex-shrink: 0;
  width: 72rpx;
  font-size: var(--font-caption);
  color: var(--color-text-primary);
}

.merchant-hours__status {
  flex-shrink: 0;
  min-width: 72rpx;
  padding: var(--space-xs) var(--space-sm);
  text-align: center;
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__status--open {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  border-color: var(--color-primary);
}

.merchant-hours__times {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-xs);
  min-width: 0;
}

.merchant-hours__time {
  min-width: 112rpx;
  padding: var(--space-xs) var(--space-sm);
  text-align: center;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__sep {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-caption);
}

.merchant-hours__closed-tip {
  flex: 1;
  text-align: right;
  color: var(--color-text-tertiary);
}

.merchant-hours__remark {
  margin-top: var(--space-md);
}

.merchant-hours__preview {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__preview-label {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-hours__preview-value {
  display: block;
  color: var(--color-text-primary);
  line-height: 1.5;
  word-break: break-all;
}
