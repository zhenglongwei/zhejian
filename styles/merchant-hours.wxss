.merchant-hours__hint {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
}

.merchant-hours__daily {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__daily-label {
  flex-shrink: 0;
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

.merchant-hours__daily-times {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.merchant-hours__time {
  min-width: 112rpx;
  padding: var(--space-xs) var(--space-sm);
  text-align: center;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__sep {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-caption);
}

.merchant-hours__closures {
  margin-top: var(--space-md);
}

.merchant-hours__closures-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.merchant-hours__add {
  font-size: var(--font-caption);
  color: var(--color-primary);
}

.merchant-hours__closure-empty {
  display: block;
  padding: var(--space-md);
  color: var(--color-text-tertiary);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--color-border);
}

.merchant-hours__closure-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-xs);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__closure-text {
  flex: 1;
  min-width: 0;
  color: var(--color-text-primary);
  font-size: var(--font-caption);
}

.merchant-hours__closure-remove {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-caption);
}

.merchant-hours__closure-form {
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__closure-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.merchant-hours__closure-label {
  flex-shrink: 0;
  width: 72rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
}

.merchant-hours__date {
  flex: 1;
  min-width: 0;
  padding: var(--space-sm) var(--space-md);
  text-align: center;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__closure-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-hours__preview {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-hours__preview-label {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-hours__preview-value {
  display: block;
  color: var(--color-text-primary);
  line-height: 1.5;
  word-break: break-all;
}
