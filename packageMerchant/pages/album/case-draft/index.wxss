.case-draft__toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: var(--space-sm);
}

.case-draft__hint {
  display: block;
  margin-top: var(--space-sm);
  margin-bottom: var(--space-md);
}

.case-draft__mask-tip {
  display: block;
  margin-top: var(--space-sm);
}

.case-draft__section-media {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.case-draft__label {
  display: block;
  margin: var(--space-md) 0 var(--space-xs);
  color: var(--color-text-secondary);
}

.case-draft__input {
  box-sizing: border-box;
  width: 100%;
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background: var(--color-bg-elevated, #fff);
}

.case-draft__section {
  margin-top: var(--space-md);
}

.case-draft__section-title {
  display: block;
  margin-bottom: var(--space-sm);
  font-weight: 600;
}

.case-draft__textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 160rpx;
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-body);
  line-height: 1.6;
  color: var(--color-text-primary);
  background: var(--color-bg-elevated, #fff);
}

.case-draft__media {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-top: var(--space-md);
}

.case-draft__media-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.case-draft__thumb {
  width: 100%;
  height: 280rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-muted, #f5f5f5);
}

.case-draft__actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin: var(--space-lg) 0 calc(var(--space-xl) + env(safe-area-inset-bottom));
}
