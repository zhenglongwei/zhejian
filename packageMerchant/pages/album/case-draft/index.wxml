<view class="page merchant-album-page case-draft page-content">
  <block wx:if="{{status === 'loading'}}">
    <ui-skeleton rows="{{5}}" title="{{true}}" />
  </block>

  <block wx:elif="{{status === 'error'}}">
    <ui-empty title="无法加载案例稿" description="{{errorMessage}}" actionText="重试" bind:action="onRetry" />
  </block>

  <block wx:else>
    <ui-compliance-notice type="displayDisclaimer" />

    <ui-card shadow="{{true}}" padding="{{true}}">
      <text class="text-h3">公开案例稿</text>
      <text class="text-caption text-secondary case-draft__hint">
        正文属于门店服务内容，车主端只读展示。公开不写金额；配图可删不可旁路加图。
      </text>
      <text class="text-caption case-draft__label">标题</text>
      <input
        class="case-draft__input"
        value="{{title}}"
        disabled="{{!editable}}"
        maxlength="80"
        bindinput="onTitleInput"
        placeholder="地域｜车型｜项目"
      />
    </ui-card>

    <ui-card
      wx:for="{{sections}}"
      wx:key="key"
      shadow="{{true}}"
      padding="{{true}}"
      class="case-draft__section"
    >
      <text class="text-body case-draft__section-title">{{item.title}}</text>
      <textarea
        class="case-draft__textarea"
        value="{{item.body}}"
        disabled="{{!editable}}"
        maxlength="600"
        auto-height
        data-key="{{item.key}}"
        bindinput="onSectionInput"
        placeholder="根据节点备注生成，可修订；勿写金额"
      />
    </ui-card>

    <ui-card shadow="{{true}}" padding="{{true}}">
      <text class="text-h3">脱敏配图</text>
      <text class="text-caption text-secondary">仅公开池脱敏图；可移除，不可从手机另加。</text>
      <view class="case-draft__media" wx:if="{{media.length}}">
        <view
          class="case-draft__media-item"
          wx:for="{{media}}"
          wx:for-item="item"
          wx:for-index="mIndex"
          wx:key="mIndex"
        >
          <image class="case-draft__thumb" src="{{item.maskedUrl}}" mode="aspectFill" />
          <text class="text-caption">{{item.caption || item.nodeId}}</text>
          <ui-button
            wx:if="{{editable}}"
            type="ghost"
            size="sm"
            data-node-id="{{item.nodeId}}"
            data-idx="{{item.idx}}"
            bind:btntap="onRemoveMedia"
          >移除</ui-button>
        </view>
      </view>
      <text wx:else class="text-caption text-secondary">暂无可用公开配图（完工后脱敏完成会自动嵌入）</text>
    </ui-card>

    <view class="case-draft__actions" wx:if="{{editable}}">
      <ui-button type="secondary" block loading="{{saving}}" bind:btntap="onSaveDraft">保存草稿</ui-button>
      <ui-button type="primary" block loading="{{saving}}" bind:btntap="onConfirmDraft">确认案例稿</ui-button>
    </view>
  </block>
</view>
