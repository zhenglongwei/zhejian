@import '../../../../styles/merchant-form.wxss';
@import '../../../../styles/merchant-album.wxss';

.merchant-album-edit__pad {
  padding-top: var(--space-md);
}

.merchant-album-edit__shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.merchant-album-edit__scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.merchant-album-edit__bottom {
  flex-shrink: 0;
  background-color: var(--color-bg-album);
  border-top: 1rpx solid var(--color-album-frame-line);
  box-shadow: none;
}

.merchant-album-edit__bottom-inner {
  display: flex;
  align-items: stretch;
  gap: var(--space-md);
  padding: var(--space-sm) var(--page-padding-x);
  box-sizing: border-box;
}

.merchant-album-edit__bottom-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  line-height: inherit;
}

.merchant-album-edit__bottom-btn::after {
  border: none;
}

.merchant-album-edit__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.merchant-album-edit__head-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  flex: 1;
  min-width: 0;
}

.merchant-album-edit__template-switch {
  display: flex;
  flex-shrink: 0;
  align-items: stretch;
  overflow: hidden;
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  background-color: var(--color-primary-light);
}

.merchant-album-edit__template-switch-action {
  display: flex;
  align-items: center;
  min-height: 56rpx;
  padding: 0 var(--space-md);
  box-sizing: border-box;
}

.merchant-album-edit__template-switch-text {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}

.merchant-album-edit__template-switch-divider {
  flex-shrink: 0;
  align-self: stretch;
  width: 1rpx;
  background-color: var(--color-primary);
  opacity: 0.28;
}

.merchant-album-edit__template-switch-help {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  min-height: 56rpx;
  box-sizing: border-box;
}

.merchant-album-edit__template-switch-help-icon {
  color: var(--color-primary);
  font-size: var(--font-caption);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
}

.merchant-album-edit__head-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.merchant-album-edit__meta {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.merchant-album-edit__meta-row {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
}

.merchant-album-edit__meta-label {
  flex-shrink: 0;
  width: 72rpx;
  padding-top: 18rpx;
  color: var(--color-text-secondary);
}

.merchant-album-edit__meta-fields {
  display: flex;
  flex: 1;
  gap: var(--space-sm);
  min-width: 0;
}

.merchant-album-edit__meta-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: var(--space-xs);
  min-width: 0;
}

.merchant-album-edit__meta-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 var(--space-md);
  box-sizing: border-box;
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  background-color: var(--color-album-frame-inner);
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

.merchant-album-edit__owner-input {
  width: 100%;
}

.merchant-album-edit__owner-link {
  align-self: flex-start;
}

.merchant-album-edit__owner-value {
  padding-top: 8rpx;
  color: var(--color-text-primary);
}

.merchant-album-edit__owner-test-tip {
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.merchant-album-edit__insp {
  margin-bottom: var(--space-md);
}

.merchant-album-edit__insp-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  min-height: 72rpx;
}

.merchant-album-edit__insp-toggle-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.merchant-album-edit__insp-toggle-title-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-xs);
}

.merchant-album-edit__insp-title {
  font-weight: var(--font-weight-medium);
}

.merchant-album-edit__insp-summary {
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.merchant-album-edit__insp-chevron {
  flex-shrink: 0;
  color: var(--color-primary);
}

.merchant-album-edit__insp-hint {
  display: block;
  color: var(--color-text-secondary);
  margin-top: var(--space-sm);
  margin-bottom: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--color-album-frame-line);
  line-height: 1.5;
}

.merchant-album-edit__insp-modal {
  position: fixed;
  inset: 0;
  z-index: var(--z-popup);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.merchant-album-edit__insp-modal-mask {
  position: absolute;
  inset: 0;
  background-color: var(--color-mask);
}

.merchant-album-edit__insp-modal-panel {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md) var(--page-padding-x);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  background-color: var(--color-bg-card);
  max-height: 75vh;
}

.merchant-album-edit__insp-modal-title {
  display: block;
}

.merchant-album-edit__insp-modal-intro {
  display: block;
  line-height: 1.5;
}

.merchant-album-edit__insp-modal-list {
  max-height: 36vh;
  margin: var(--space-xs) 0;
}

.merchant-album-edit__insp-modal-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
  background-color: var(--color-bg-muted);
  margin-bottom: var(--space-xs);
}

.merchant-album-edit__insp-modal-item-tag {
  color: var(--color-text-secondary);
}

.merchant-album-edit__insp-modal-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding-top: var(--space-xs);
}

.merchant-album-edit__insp-modal-skip {
  display: block;
  text-align: center;
  padding: var(--space-xs) 0;
}

.merchant-album-edit__tabs {
  margin: var(--space-md) 0 var(--space-sm);
}

.merchant-album-edit__shoot-common {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  background: var(--color-bg-muted);
  border: 1rpx solid var(--color-border);
}

.merchant-album-edit__shoot-common-label {
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.merchant-album-edit__shoot-common-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.merchant-album-edit__shoot-common-tag {
  padding: 4rpx var(--space-sm);
  border-radius: var(--radius-full);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
}

.merchant-album-edit__plan,
.merchant-album-edit__parts {
  margin-top: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-album-edit__plan-label {
  display: block;
  margin-top: var(--space-md);
  margin-bottom: var(--space-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.merchant-album-edit__plan-hint {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.merchant-album-edit__parts-hint,
.merchant-album-edit__owner-test-tip {
  color: var(--color-text-secondary);
}

.merchant-album-edit__parts-list {
  display: block;
}

.merchant-album-edit__part-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-album-frame-line);
  background-color: var(--color-album-frame-inner);
}

.merchant-album-edit__part-form-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.merchant-album-edit__plan-parts {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.merchant-album-edit__plan-parts-head {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.merchant-album-edit__wizard-actions {
  margin-top: var(--space-sm);
}

.merchant-album-edit__plan-part-row {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
}

.merchant-album-edit__plan-part-meta {
  align-items: center;
}

.merchant-album-edit__warn {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-album-active-light);
}

.merchant-album-edit__parse-hint {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
}

.merchant-album-edit__extra-sop {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  background: var(--color-warning-light);
}

.merchant-album-edit__extra-sop-text {
  color: var(--color-text-secondary);
}

.merchant-album-edit__extra-sop-link {
  align-self: flex-start;
}

.merchant-album-edit__wizard-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-album-edit__parts-node {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-album-edit__parts-node-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-album-edit__parts-head-actions {
  display: flex;
  flex-shrink: 0;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-sm);
}

.merchant-album-edit__parts-add-link {
  padding: 4rpx 0;
  line-height: var(--font-caption-lh);
}

.merchant-album-edit__parts-node-title {
  flex: 1;
  min-width: 0;
}

.merchant-album-edit__parts-ocr {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  background-color: var(--color-info-light);
}

.merchant-album-edit__parts-ocr.is-loading {
  opacity: 0.7;
}

.merchant-album-edit__parts-ocr-text {
  font-size: var(--font-caption);
  line-height: var(--font-caption-lh);
  color: var(--color-info);
}

.merchant-album-edit__wizard-head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-album-edit__wizard-head-row:active {
  opacity: 0.85;
}

.merchant-album-edit__wizard-title {
  flex: 1;
  min-width: 0;
}

.merchant-album-edit__wizard-remove {
  flex-shrink: 0;
  padding: var(--space-xs) 0 var(--space-xs) var(--space-sm);
  color: var(--color-danger);
}

.merchant-album-edit__wizard-fields {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.merchant-album-edit__wizard-photo {
  width: 100%;
}

.merchant-album-edit__wizard-uploader {
  width: 100%;
  display: block;
}

.merchant-album-edit__wizard-uploader .image-uploader {
  width: 100%;
  grid-template-columns: repeat(3, minmax(var(--size-album-list-thumb), 1fr));
}

.merchant-album-edit__wizard-uploader .image-uploader__item,
.merchant-album-edit__wizard-uploader .image-uploader__add {
  min-height: var(--size-album-list-thumb);
}

.merchant-album-edit__wizard-ocr-row {
  width: 100%;
  display: flex;
}

.merchant-album-edit__wizard-ocr-slot {
  width: calc((100% - var(--space-xs) * 2) / 3);
  margin-top: var(--space-xs);
  display: flex;
  justify-content: center;
  align-items: center;
}

.merchant-album-edit__wizard-ocr-text.is-loading {
  opacity: 0.7;
}

.merchant-album-edit__wizard-fields .merchant-form__picker.is-placeholder {
  color: var(--color-text-tertiary);
}

.merchant-album-edit__wizard-fields .merchant-form__picker.is-locked {
  color: var(--color-text-primary);
  background: var(--color-bg-muted);
}

.merchant-album-edit__type-tip {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-top: calc(-1 * var(--space-xs));
}

.merchant-album-edit__owner-verify-title {
  display: block;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.merchant-album-edit__owner-verify-hint {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.merchant-album-edit__owner-verify-guide {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.merchant-album-edit__verify-radio-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.merchant-album-edit__verify-option {
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-bg-muted);
  overflow: hidden;
}

.merchant-album-edit__verify-option.is-checked {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}

.merchant-album-edit__verify-radio-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
}

.merchant-album-edit__verify-radio-item:active {
  opacity: 0.85;
}

.merchant-album-edit__verify-option-body {
  padding: 0 var(--space-md) var(--space-md);
  margin-left: calc(32rpx + var(--space-sm));
}

.merchant-album-edit__verify-radio-dot {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  margin-top: 4rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchant-album-edit__verify-option.is-checked .merchant-album-edit__verify-radio-dot {
  border-color: var(--color-primary);
}

.merchant-album-edit__verify-radio-dot-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
}

.merchant-album-edit__verify-radio-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.merchant-album-edit__verify-radio-label {
  line-height: 1.4;
}

.merchant-album-edit__verify-radio-desc {
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.merchant-album-edit__owner-verify-input {
  width: 100%;
  min-height: 140rpx;
  padding: var(--space-sm) var(--space-md);
  box-sizing: border-box;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-card);
}

.merchant-album-edit__wizard-row.is-open {
  border-color: var(--color-primary);
}

.merchant-album-edit__wizard-row {
  margin-top: var(--space-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.merchant-album-edit__wizard-row.is-done {
  border-color: var(--color-primary);
}

.merchant-album-edit__parts-upload-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  min-height: var(--size-album-list-card-min-height);
  padding: var(--space-lg) var(--space-md);
  box-sizing: border-box;
  border: 2rpx dashed var(--color-album-frame-line);
  border-radius: var(--radius-album-list-thumb);
  background: var(--color-album-frame-inner);
}

.merchant-album-edit__parts-upload-cta--hover {
  opacity: 0.88;
}

.merchant-album-edit__parts-upload-cta.is-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.merchant-album-edit__parts-upload-icon {
  width: 56rpx;
  height: 56rpx;
}

.merchant-album-edit__parts-upload-title {
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.merchant-album-edit__parts-upload-desc {
  text-align: center;
  line-height: 1.5;
}

.merchant-album-edit__parts-empty {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4rpx;
  padding: var(--space-xs) 0;
}

.merchant-album-edit__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
}

.merchant-album-edit__code-picker {
  position: fixed;
  inset: 0;
  z-index: var(--z-popup);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.merchant-album-edit__code-picker-mask {
  position: absolute;
  inset: 0;
  background-color: var(--color-mask);
}

.merchant-album-edit__code-picker-panel {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md) var(--page-padding-x);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  background-color: var(--color-bg-card);
  max-height: 70vh;
}

.merchant-album-edit__code-picker-title {
  display: block;
}

.merchant-album-edit__code-picker-hint {
  display: block;
  line-height: 1.5;
}

.merchant-album-edit__code-picker-list {
  max-height: 48vh;
  margin: var(--space-xs) 0;
}

.merchant-album-edit__code-picker-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
  background-color: var(--color-bg-muted);
  margin-bottom: var(--space-xs);
}

.merchant-album-edit__code-picker-item:active {
  background-color: var(--color-primary-light);
  border-color: var(--color-primary);
}

.merchant-album-edit__code-picker-snippet {
  line-height: 1.4;
}

.merchant-album-edit__optimize-card {
  margin-top: var(--space-3);
}

.merchant-album-edit__optimize-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  margin-bottom: var(--space-2);
}

.merchant-album-edit__optimize-hint {
  display: block;
  margin-bottom: var(--space-3);
}
