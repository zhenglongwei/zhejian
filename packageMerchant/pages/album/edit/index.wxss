@import '../../../../styles/merchant-form.wxss';
@import '../../../../styles/merchant-album.wxss';

.merchant-album-edit__pad {
  padding-top: var(--space-md);
}

.merchant-album-edit__shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.merchant-album-edit__scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.merchant-album-edit__bottom {
  flex-shrink: 0;
  background-color: var(--color-bg-album);
  border-top: 1rpx solid var(--color-album-frame-line);
  box-shadow: none;
}

.merchant-album-edit__bottom-inner {
  display: flex;
  align-items: stretch;
  gap: var(--space-md);
  padding: var(--space-sm) var(--page-padding-x);
  box-sizing: border-box;
}

.merchant-album-edit__bottom-btn {
  flex: 1;
  min-width: 0;
  margin: 0;
  line-height: inherit;
}

.merchant-album-edit__bottom-btn::after {
  border: none;
}

.merchant-album-edit__vehicle-hint {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
}

.merchant-album-edit__vehicle-row {
  margin-top: var(--space-xs);
}

.merchant-album-edit__ocr-row {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.merchant-album-edit__ocr-hint {
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.merchant-album-edit__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.merchant-album-edit__head-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  flex: 1;
  min-width: 0;
}

.merchant-album-edit__head-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.merchant-album-edit__switch {
  flex-shrink: 0;
  padding-top: var(--space-xs);
}

.merchant-album-edit__switch-hint {
  display: block;
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-sm);
}

.merchant-album-edit__progress {
  margin-bottom: var(--space-sm);
  color: var(--color-text-secondary);
}

.merchant-album-edit__geo {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.merchant-album-edit__geo-text {
  flex: 1;
  min-width: 0;
  color: var(--color-text-secondary);
}

.merchant-album-edit__tabs {
  margin: var(--space-md) 0;
}

.merchant-album-edit__plan,
.merchant-album-edit__parts {
  margin-top: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-album-edit__plan-label,
.merchant-album-edit__parts-hint,
.merchant-album-edit__owner-hint,
.merchant-album-edit__owner-phone,
.merchant-album-edit__owner-share-tip,
.merchant-album-edit__owner-test-tip {
  color: var(--color-text-secondary);
}

.merchant-album-edit__owner,
.merchant-album-edit__owner-hint,
.merchant-album-edit__owner-phone {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-album-edit__owner-share-tip {
  color: var(--color-primary);
}

.merchant-album-edit__parts-list {
  display: block;
}

.merchant-album-edit__part-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-album-frame-line);
  background-color: var(--color-album-frame-inner);
}

.merchant-album-edit__part-form-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.merchant-album-edit__plan-parts {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.merchant-album-edit__plan-parts-head {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.merchant-album-edit__plan-parts-actions,
.merchant-album-edit__plan-parts-foot,
.merchant-album-edit__wizard-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.merchant-album-edit__plan-part-row {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
}

.merchant-album-edit__plan-part-meta {
  align-items: center;
}

.merchant-album-edit__warn {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-album-active-light);
}

.merchant-album-edit__parse-hint {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
}

.merchant-album-edit__wizard-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-album-edit__wizard-row {
  margin-top: var(--space-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.merchant-album-edit__wizard-row.is-done {
  border-color: var(--color-primary);
}

.merchant-album-edit__wizard-summary-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: var(--space-sm);
}

.merchant-album-edit__wizard-remove {
  color: var(--color-danger);
}

.merchant-album-edit__parts-empty {
  padding: var(--space-md) 0;
}

.merchant-album-edit__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
}
