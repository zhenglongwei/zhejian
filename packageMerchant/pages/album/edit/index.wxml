<view class="page merchant-album-page merchant-album-edit">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content merchant-album-edit__pad">
      <ui-skeleton rows="{{3}}" title="{{true}}" />
      <ui-skeleton rows="{{6}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty title="无法加载服务相册" description="{{errorMessage}}" actionText="重试" bind:action="onRetry" />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="merchant-album-edit__shell">
      <scroll-view scroll-y class="merchant-album-edit__scroll" show-scrollbar="{{false}}" scroll-into-view="{{inspScrollIntoView}}">
        <view class="page-content merchant-album-edit__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="merchant-album-edit__head">
          <view class="merchant-album-edit__head-main">
            <text class="text-h3">{{detail.serviceName}}</text>
            <view class="merchant-album-edit__head-tags">
              <ui-tag variant="{{statusVariant}}" text="{{statusLabel}}" />
              <ui-tag wx:if="{{templateName}}" variant="info" text="{{templateName}}" />
            </view>
          </view>
          <view
            wx:if="{{canSwitchTemplate && templateOptions.length}}"
            class="merchant-album-edit__template-switch"
          >
            <picker
              mode="selector"
              range="{{templateOptions}}"
              range-key="name"
              value="{{templatePickerIndex}}"
              disabled="{{switching || saving || completing}}"
              bindchange="onTemplateChange"
            >
              <view class="merchant-album-edit__template-switch-action">
                <text class="merchant-album-edit__template-switch-text text-caption">切换模板</text>
              </view>
            </picker>
            <view class="merchant-album-edit__template-switch-divider" aria-hidden="true" />
            <view
              class="merchant-album-edit__template-switch-help"
              aria-role="button"
              aria-label="切换模板说明"
              catchtap="onTemplateSwitchHelp"
            >
              <text class="merchant-album-edit__template-switch-help-icon">?</text>
            </view>
          </view>
        </view>

        <view class="merchant-album-edit__meta">
          <view class="merchant-album-edit__meta-row">
            <text class="merchant-album-edit__meta-label text-caption">车型</text>
            <view class="merchant-album-edit__meta-fields">
              <input
                class="merchant-album-edit__meta-input"
                placeholder="品牌 *"
                value="{{vehicleBrand}}"
                disabled="{{saving || completing || switching}}"
                data-field="vehicleBrand"
                bindinput="onVehicleInput"
              />
              <input
                class="merchant-album-edit__meta-input"
                placeholder="车系 *"
                value="{{vehicleSeries}}"
                disabled="{{saving || completing || switching}}"
                data-field="vehicleSeries"
                bindinput="onVehicleInput"
              />
            </view>
          </view>

          <view class="merchant-album-edit__meta-row">
            <text class="merchant-album-edit__meta-label text-caption">车主</text>
            <view class="merchant-album-edit__meta-body">
              <text
                wx:if="{{hasOwner && detail.userPhoneDisplay}}"
                class="text-body merchant-album-edit__owner-value"
              >{{detail.userPhoneDisplay}}</text>
              <block wx:elif="{{!hasOwner}}">
                <text
                  class="text-link text-body merchant-album-edit__owner-link"
                  bindtap="onInviteOwnerScan"
                >请车主扫码关联</text>
                <block wx:if="{{allowTestOwnerPhone}}">
                  <input
                    class="merchant-album-edit__meta-input merchant-album-edit__owner-input"
                    type="number"
                    maxlength="11"
                    placeholder="测试手填手机号"
                    value="{{ownerPhoneInput}}"
                    disabled="{{saving || completing || switching}}"
                    bindinput="onOwnerPhoneInput"
                  />
                  <text class="text-caption merchant-album-edit__owner-test-tip">填写后点击底部「保存」即可关联</text>
                </block>
              </block>
              <text wx:else class="text-caption text-secondary">未关联</text>
            </view>
          </view>
        </view>
      </ui-card>

      <ui-card
        wx:if="{{showContentOptimizeEntry}}"
        shadow="{{true}}"
        padding="{{true}}"
        class="merchant-album-edit__optimize-card"
      >
        <view class="merchant-album-edit__optimize-head">
          <text class="text-h3">内容优化</text>
          <ui-tag variant="info" text="授权前" />
        </view>
        <text class="text-caption text-secondary merchant-album-edit__optimize-hint">
          优化案例摘要与节点说明，提升公开展示质量；不修改图片与价格事实。
        </text>
        <ui-button type="secondary" block bind:btntap="onOpenContentOptimize">进入内容优化</ui-button>
      </ui-card>

      <view wx:if="{{merchantInspPanels.length}}" id="merchant-insp-section" class="merchant-album-edit__insp">
        <ui-card shadow="{{true}}" padding="{{true}}">
          <view
            class="merchant-album-edit__insp-toggle"
            bindtap="onToggleMerchantInsp"
            aria-role="button"
            aria-expanded="{{merchantInspExpanded}}"
            aria-label="留痕自检"
          >
            <view class="merchant-album-edit__insp-toggle-main">
              <view class="merchant-album-edit__insp-toggle-title-row">
                <text class="text-body merchant-album-edit__insp-title">留痕自检</text>
                <ui-tag
                  wx:if="{{merchantInspCriticalMissing.length}}"
                  variant="warning"
                  text="缺必留"
                />
              </view>
              <text class="text-caption merchant-album-edit__insp-summary">
                {{merchantInspSummary.done}}/{{merchantInspSummary.total}} 已留
                <text wx:if="{{merchantInspCriticalMissing.length}}"> · 缺 {{merchantInspCriticalMissing.length}} 项必留</text>
                <text wx:elif="{{merchantInspSummary.missing}}"> · 缺 {{merchantInspSummary.missing}} 项</text>
              </text>
            </view>
            <text class="text-caption merchant-album-edit__insp-chevron">{{merchantInspExpanded ? '收起' : '展开'}}</text>
          </view>
          <block wx:if="{{merchantInspExpanded}}">
            <text class="text-caption merchant-album-edit__insp-hint">{{merchantInspHint}}</text>
            <album-inspection-matrix
              wx:for="{{merchantInspPanels}}"
              wx:key="id"
              wx:for-item="panel"
              title="{{panel.title}}"
              layout="inventory"
              rows="{{panel.rows}}"
              importance-column-label="{{merchantInspColumnLabel}}"
              compact="{{true}}"
              bind:preview="onInspPreviewImage"
            />
          </block>
        </ui-card>
      </view>

      <view class="merchant-album-edit__tabs">
        <ui-tabs
          tabs="{{stageTabs}}"
          activeKey="{{stageTabs[stageIndex].key}}"
          scrollable="{{true}}"
          bind:change="onStageTabChange"
        />
      </view>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <block wx:if="{{isComparePairStage}}">
          <album-evidence-slots
            wx:if="{{showStageEvidenceSlots}}"
            items="{{stageEvidenceSlots}}"
            disabled="{{saving || completing || switching}}"
            uploadHint="{{nodes[stageIndex].publicUploadHint || uploadPrivacyHint}}"
            bind:change="onEvidenceSlotsChange"
          />
          <album-compare-pair-editor
            title="{{nodes[stageIndex].title}}"
            description="{{nodes[stageIndex].description}}"
            photoTips="{{nodes[stageIndex].photoTips}}"
            compareHint="{{nodes[stageIndex].compareGuidance}}"
            requiredLevelLabel="{{nodes[stageIndex].requiredLevelLabel}}"
            requiredLevelVariant="{{nodes[stageIndex].requiredLevelVariant}}"
            note="{{nodes[stageIndex].note}}"
            notePlaceholder="{{nodes[stageIndex].notePlaceholder}}"
            uploadHint="{{nodes[stageIndex].publicUploadHint || uploadPrivacyHint}}"
            pairRows="{{comparePairRows}}"
            disabled="{{saving || completing || switching}}"
            bind:rowschange="onCompareRowsChange"
            bind:notechange="onCompareNoteChange"
            bind:syncfromassessment="onSyncCompareFromAssessment"
          />
        </block>
        <block wx:elif="{{isPartsStage}}">
          <view class="merchant-album-edit__parts-node">
            <view class="merchant-album-edit__parts-node-head">
              <text class="text-h3 merchant-album-edit__parts-node-title">{{nodes[stageIndex].title}}</text>
              <view class="merchant-album-edit__parts-head-actions">
                <view
                  class="merchant-album-edit__parts-ocr {{planOcrLoading ? 'is-loading' : ''}}"
                  bindtap="onRunPlanQuoteOcr"
                >
                  <text class="merchant-album-edit__parts-ocr-text">{{planOcrLoading ? '识别中…' : 'OCR 辅助录入（报价/定损/结算）'}}</text>
                </view>
                <text
                  class="text-caption text-link merchant-album-edit__parts-add-link"
                  bindtap="onAddPartRow"
                >添加配件</text>
              </view>
            </view>
            <text class="text-caption merchant-album-edit__parts-hint">{{nodes[stageIndex].photoTips}}</text>
            <view class="merchant-album-edit__extra-sop">
              <text class="text-caption merchant-album-edit__extra-sop-text">{{extraPartSopStage4Hint}}</text>
              <text class="text-caption text-link merchant-album-edit__extra-sop-link" bindtap="onExtraPartSopHelp">{{extraPartSopLink}}</text>
            </view>
            <view wx:if="{{planParseHint}}" class="merchant-album-edit__parse-hint">
              <text class="text-caption">{{planParseHint}}</text>
            </view>

            <view class="merchant-album-edit__owner-verify-guide">
              <text class="text-body merchant-album-edit__owner-verify-title">{{partVerifyGuideTitle}}</text>
              <text class="text-caption merchant-album-edit__owner-verify-hint">{{partVerifyGuideHint}}</text>
              <view class="merchant-album-edit__verify-radio-group" role="radiogroup">
                <view
                  class="merchant-album-edit__verify-radio-item {{partVerifyGuideMode === 'text' ? 'is-checked' : ''}}"
                  data-mode="text"
                  bindtap="onPartVerifyGuideModeTap"
                  aria-role="radio"
                  aria-checked="{{partVerifyGuideMode === 'text'}}"
                >
                  <view class="merchant-album-edit__verify-radio-dot" aria-hidden="true">
                    <view wx:if="{{partVerifyGuideMode === 'text'}}" class="merchant-album-edit__verify-radio-dot-inner" />
                  </view>
                  <view class="merchant-album-edit__verify-radio-copy">
                    <text class="text-body merchant-album-edit__verify-radio-label">{{partVerifyGuideModeTextTitle}}</text>
                    <text class="text-caption merchant-album-edit__verify-radio-desc">{{partVerifyGuideModeTextDesc}}</text>
                  </view>
                </view>
                <view
                  class="merchant-album-edit__verify-radio-item {{partVerifyGuideMode === 'informed' ? 'is-checked' : ''}}"
                  data-mode="informed"
                  bindtap="onPartVerifyGuideModeTap"
                  aria-role="radio"
                  aria-checked="{{partVerifyGuideMode === 'informed'}}"
                >
                  <view class="merchant-album-edit__verify-radio-dot" aria-hidden="true">
                    <view wx:if="{{partVerifyGuideMode === 'informed'}}" class="merchant-album-edit__verify-radio-dot-inner" />
                  </view>
                  <view class="merchant-album-edit__verify-radio-copy">
                    <text class="text-body merchant-album-edit__verify-radio-label">{{partVerifyGuideModeInformedTitle}}</text>
                    <text class="text-caption merchant-album-edit__verify-radio-desc">{{partVerifyGuideModeInformedDesc}}</text>
                  </view>
                </view>
              </view>
              <textarea
                wx:if="{{partVerifyGuideMode === 'text'}}"
                class="merchant-album-edit__owner-verify-input text-body"
                placeholder="{{partVerifyGuidePlaceholder}}"
                value="{{partVerifyGuideText}}"
                maxlength="1000"
                bindinput="onPartVerifyGuideInput"
              />
            </view>

            <view
              class="merchant-album-edit__parts-upload-cta {{saving || completing || switching ? 'is-disabled' : ''}}"
              bindtap="onAddPartByPhotos"
              hover-class="merchant-album-edit__parts-upload-cta--hover"
              hover-stay-time="80"
            >
              <image
                class="merchant-album-edit__parts-upload-icon"
                src="/assets/icon/add.png"
                mode="aspectFit"
              />
              <text class="text-body merchant-album-edit__parts-upload-title">
                {{partWizardRows.length ? '继续添加配件凭证' : '上传配件凭证图'}}
              </text>
              <text class="text-caption text-secondary merchant-album-edit__parts-upload-desc">
                包装 / 编码 / 实物，选图后填写本项信息
              </text>
            </view>

            <view
              wx:for="{{partWizardRows}}"
              wx:key="planPartId"
              class="merchant-album-edit__wizard-row {{item.done ? 'is-done' : ''}} {{activeWizardIndex === index ? 'is-open' : ''}}"
            >
              <view class="merchant-album-edit__wizard-head-row" data-index="{{index}}" bindtap="onToggleWizardRow">
                <text class="merchant-album-edit__wizard-title text-body">{{item.done ? '✓' : '○'}} {{item.partName || item.planName}}</text>
                <text class="text-caption merchant-album-edit__wizard-remove" data-index="{{index}}" catchtap="onRemovePartRow">删除</text>
              </view>
              <block wx:if="{{activeWizardIndex === index}}">
                <view class="merchant-album-edit__wizard-fields">
                  <view class="merchant-album-edit__wizard-photo">
                    <ui-image-uploader
                      class="merchant-album-edit__wizard-uploader"
                      images="{{item.photos}}"
                      maxCount="{{3}}"
                      data-index="{{index}}"
                      bind:change="onWizardPhotosChange"
                    />
                    <view class="merchant-album-edit__wizard-ocr-row">
                      <view class="merchant-album-edit__wizard-ocr-slot">
                        <text
                          class="text-caption text-link merchant-album-edit__wizard-ocr-text {{partLabelOcrLoading ? 'is-loading' : ''}}"
                          data-index="{{index}}"
                          bindtap="onRunPartLabelOcr"
                        >{{partLabelOcrLoading ? '识别中…' : '识别编码'}}</text>
                      </view>
                    </view>
                  </view>
                  <input
                    class="merchant-form__input"
                    placeholder="配件名称 *"
                    value="{{item.partName}}"
                    data-index="{{index}}"
                    data-field="partName"
                    bindinput="onWizardInput"
                  />
                  <block wx:if="{{item.typeLocked}}">
                    <view class="merchant-form__picker is-locked" catchtap="onLockedPartTypeTap">{{item.partType}}</view>
                    <text class="text-caption merchant-album-edit__type-tip">{{merchantPartTypeLockedTip}}</text>
                  </block>
                  <block wx:else>
                    <picker mode="selector" range="{{partTypeList}}" value="{{item.partTypeIndex}}" data-index="{{index}}" bindchange="onWizardTypeChange">
                      <view class="merchant-form__picker {{item.partType ? '' : 'is-placeholder'}}">{{item.partType || '请选择类型'}}</view>
                    </picker>
                    <text class="text-caption merchant-album-edit__type-tip">{{merchantPartTypeManualTip}}</text>
                  </block>
                  <input class="merchant-form__input" placeholder="品牌" value="{{item.partBrand}}" data-index="{{index}}" data-field="partBrand" bindinput="onWizardInput" />
                  <input class="merchant-form__input" placeholder="编码" value="{{item.partCode}}" data-index="{{index}}" data-field="partCode" bindinput="onWizardInput" />
                  <ui-button type="primary" size="sm" data-index="{{index}}" bind:btntap="onSaveWizardRow">保存本项</ui-button>
                </view>
              </block>
            </view>

            <view wx:if="{{!partWizardRows.length}}" class="merchant-album-edit__parts-empty">
              <text class="text-caption text-secondary">也可先</text>
              <text class="text-caption text-link" bindtap="onAddPartRow">手工添加空项</text>
              <text class="text-caption text-secondary">，或用上方 OCR 从报价单识别</text>
            </view>
          </view>
        </block>
        <block wx:else>
          <album-evidence-slots
            wx:if="{{showStageEvidenceSlots}}"
            items="{{stageEvidenceSlots}}"
            disabled="{{saving || completing || switching}}"
            uploadHint="{{nodes[stageIndex].publicUploadHint || planStageUploadHint}}"
            bind:change="onEvidenceSlotsChange"
          />
          <album-old-part-traces
            wx:if="{{showOldPartTraces}}"
            traces="{{oldPartTraces}}"
            partOptions="{{oldPartPartOptions}}"
            introHint="{{oldPartIntroHint}}"
            disabled="{{saving || completing || switching}}"
            uploadHint="{{nodes[stageIndex].publicUploadHint || uploadPrivacyHint}}"
            bind:change="onOldPartTracesChange"
          />
          <ui-album-node
            wx:if="{{showStageProcessUploader}}"
            mode="edit"
            title="{{nodes[stageIndex].title}}"
            description="{{nodes[stageIndex].description}}"
            photoTips="{{nodes[stageIndex].photoTips}}"
            compareGuidance="{{nodes[stageIndex].compareGuidance}}"
            requiredLevelLabel="{{nodes[stageIndex].requiredLevelLabel}}"
            requiredLevelVariant="{{nodes[stageIndex].requiredLevelVariant}}"
            note="{{nodes[stageIndex].note}}"
            notePlaceholder="{{nodes[stageIndex].notePlaceholder}}"
            images="{{nodes[stageIndex].images}}"
            uploadHint="{{nodes[stageIndex].publicUploadHint || uploadPrivacyHint}}"
            data-index="{{stageIndex}}"
            bind:imageschange="onNodeImages"
            bind:notechange="onNodeNoteChange"
          />
          <ui-album-node
            wx:elif="{{!showStageEvidenceSlots}}"
            mode="edit"
            title="{{nodes[stageIndex].title}}"
            description="{{nodes[stageIndex].description}}"
            photoTips="{{nodes[stageIndex].photoTips}}"
            compareGuidance="{{nodes[stageIndex].compareGuidance}}"
            requiredLevelLabel="{{nodes[stageIndex].requiredLevelLabel}}"
            requiredLevelVariant="{{nodes[stageIndex].requiredLevelVariant}}"
            note="{{nodes[stageIndex].note}}"
            notePlaceholder="{{nodes[stageIndex].notePlaceholder}}"
            images="{{nodes[stageIndex].images}}"
            uploadHint="{{nodes[stageIndex].publicUploadHint || planStageUploadHint}}"
            data-index="{{stageIndex}}"
            bind:imageschange="onNodeImages"
            bind:notechange="onNodeNoteChange"
          />
          <view wx:if="{{isPlanStage}}" class="merchant-album-edit__extra-sop">
            <text class="text-caption merchant-album-edit__extra-sop-text">{{extraPartSopStage3Hint}}</text>
            <text class="text-caption text-link merchant-album-edit__extra-sop-link" bindtap="onExtraPartSopHelp">{{extraPartSopLink}}</text>
          </view>
        </block>

        <block wx:if="{{stages[stageIndex].id === 'stage_6'}}">
          <view class="merchant-album-edit__plan">
            <text class="merchant-album-edit__plan-label text-h3">最终费用</text>
            <text class="text-caption merchant-album-edit__plan-hint">{{planAmountHint}}</text>
            <input
              class="merchant-form__input"
              type="number"
              placeholder="请输入本次实际费用"
              value="{{planAmount}}"
              disabled="{{saving || completing || switching}}"
              data-field="planAmount"
              bindinput="onPlanInput"
            />
            <ui-price-display
              wx:if="{{pricePreview.amount}}"
              mode="fixed"
              amount="{{pricePreview.amount}}"
              showSuffix="{{false}}"
              showDisclaimer="{{false}}"
            />
          </view>
        </block>
      </ui-card>
        </view>
      </scroll-view>

      <view class="merchant-album-edit__bottom safe-bottom">
        <view class="merchant-album-edit__bottom-inner">
          <button
            class="btn btn--secondary btn--block merchant-album-edit__bottom-btn"
            loading="{{saving}}"
            catchtap="onSave"
          >保存</button>
          <button
            wx:if="{{showBottomPrimary}}"
            class="btn btn--primary btn--block merchant-album-edit__bottom-btn"
            catchtap="onComplete"
          >{{bottomPrimaryText}}</button>
        </view>
      </view>
    </view>
  </block>

  <view
    wx:if="{{inspCompleteModalVisible}}"
    class="merchant-album-edit__insp-modal"
    catchtouchmove="noop"
  >
    <view class="merchant-album-edit__insp-modal-mask" bindtap="onCloseInspCompleteModal" />
    <view class="merchant-album-edit__insp-modal-panel safe-bottom">
      <text class="merchant-album-edit__insp-modal-title text-h3">{{inspCompleteModalTitle}}</text>
      <text class="merchant-album-edit__insp-modal-intro text-caption text-secondary">{{inspCompleteModalIntro}}</text>
      <scroll-view scroll-y class="merchant-album-edit__insp-modal-list" show-scrollbar="{{false}}">
        <view
          wx:for="{{merchantInspMissingItems}}"
          wx:key="id"
          class="merchant-album-edit__insp-modal-item"
        >
          <text class="text-caption merchant-album-edit__insp-modal-item-tag">{{item.panelTitle}} · {{item.importanceLabel}}</text>
          <text class="text-body">{{item.label}}</text>
        </view>
      </scroll-view>
      <view class="merchant-album-edit__insp-modal-actions">
        <ui-button type="primary" block bind:btntap="onInspCompleteModalViewChecklist">留痕自检</ui-button>
        <ui-button type="secondary" block bind:btntap="onCloseInspCompleteModal">先补传</ui-button>
        <text class="text-link text-caption merchant-album-edit__insp-modal-skip" bindtap="onInspCompleteModalProceedAnyway">仍要完工</text>
      </view>
    </view>
  </view>

  <view
    wx:if="{{partCodePickerVisible}}"
    class="merchant-album-edit__code-picker"
    catchtouchmove="noop"
  >
    <view class="merchant-album-edit__code-picker-mask" bindtap="onClosePartCodePicker" />
    <view class="merchant-album-edit__code-picker-panel safe-bottom">
      <text class="merchant-album-edit__code-picker-title text-h3">选择配件编码</text>
      <text class="merchant-album-edit__code-picker-hint text-caption text-secondary">已按顺序识别 {{partCodePickerImageCount}} 张凭证图，请选择正确编码</text>
      <scroll-view scroll-y class="merchant-album-edit__code-picker-list" show-scrollbar="{{false}}">
        <view
          wx:for="{{partCodeCandidates}}"
          wx:key="pickerKey"
          class="merchant-album-edit__code-picker-item"
          data-index="{{index}}"
          bindtap="onPickPartCodeCandidate"
        >
          <text class="text-body">{{item.displayLabel}}</text>
          <text wx:if="{{item.snippet && item.snippet !== item.partCode}}" class="text-caption text-secondary merchant-album-edit__code-picker-snippet">{{item.snippet}}</text>
        </view>
      </scroll-view>
      <ui-button type="secondary" size="sm" block="{{true}}" bind:btntap="onClosePartCodePicker">取消</ui-button>
    </view>
  </view>
</view>
