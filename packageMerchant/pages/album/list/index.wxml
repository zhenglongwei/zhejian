<view class="page album-list">
  <view class="album-list__tabs page-content">
    <ui-tabs tabs="{{statusTabs}}" activeKey="{{tab}}" bind:change="onTabChange" />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content">
      <ui-skeleton wx:for="{{[1,2]}}" wx:key="*this" rows="{{3}}" />
    </view>
  </block>
  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty title="加载失败" description="{{errorMessage}}" actionText="重试" bind:action="onRetry" />
    </view>
  </block>
  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty title="暂无案例" description="创建历史案例并提交审核" actionText="新建" bind:action="onCreate" />
    </view>
  </block>
  <block wx:else>
    <view class="page-content album-list__items merchant-list__scroll-pad">
      <ui-case-card
        wx:for="{{list}}"
        wx:key="id"
        caseId="{{item.id}}"
        caseSource="{{item.caseSource}}"
        tags="{{item.cardTags}}"
        coverImage="{{item.coverImage}}"
        title="{{item.title}}"
        serviceName="{{item.serviceName}}"
        summary="{{item.summary}}"
        priceMode="{{item.priceMode}}"
        minAmount="{{item.minAmount}}"
        maxAmount="{{item.maxAmount}}"
        showStoreName="{{false}}"
        muted="{{true}}"
      />
    </view>
  </block>
  <view class="merchant-list-fab page-content">
    <ui-button type="primary" bind:tap="onCreate">新建历史案例</ui-button>
  </view>
</view>
