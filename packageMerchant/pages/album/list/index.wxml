<view class="page merchant-album-page merchant-album-list">
  <ui-list-page-shell
    tabs="{{statusTabs}}"
    activeKey="{{tab}}"
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    bodyClearance="{{true}}"
    emptyTitle="暂无服务相册"
    emptyDescription="为线下服务创建服务相册，记录六阶段过程与配件信息"
    emptyActionText="新建服务相册"
    emptyTheme="album"
    skeletonTheme="album"
    skeletonVariant="album-card"
    bind:tabchange="onTabChange"
    bind:retry="onRetry"
    bind:emptyaction="onCreate"
  >
    <ui-album-card
      wx:for="{{list}}"
      wx:key="albumId"
      item="{{item}}"
      audience="merchant"
      bind:tap="onCardTap"
    />
    <view slot="footer" class="merchant-list-fab page-content">
      <ui-button type="primary" bind:btntap="onCreate">新建服务相册</ui-button>
    </view>
  </ui-list-page-shell>
</view>
