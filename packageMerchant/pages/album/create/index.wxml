<view class="page merchant-album-page album-create page-content merchant-form-page">
  <ui-privacy-banner scene="albumMerchant" />

  <block wx:if="{{status === 'loading'}}">
    <ui-skeleton rows="{{5}}" title="{{true}}" />
  </block>

  <block wx:else>
    <view class="merchant-form__section">
      <text class="merchant-form__label">所属门店</text>
      <text class="merchant-form__readonly">{{storeName}}</text>
    </view>

    <view class="merchant-form__section album-create__service-section">
      <text class="merchant-form__label">服务项目（必填）</text>
      <input
        class="merchant-form__input album-create__service-input"
        placeholder="点击输入，可选择常见服务或直接填写"
        value="{{form.serviceName}}"
        maxlength="{{16}}"
        bindfocus="onServiceFocus"
        bindblur="onServiceBlur"
        bindinput="onServiceInput"
      />
      <view
        wx:if="{{serviceSuggestVisible && serviceSuggestTags.length}}"
        class="album-create__suggest"
      >
        <text class="album-create__suggest-label text-caption">常见服务</text>
        <view class="album-create__suggest-chips">
          <view
            wx:for="{{serviceSuggestTags}}"
            wx:key="name"
            class="album-create__chip {{item.selected ? 'album-create__chip--on' : ''}}"
            data-name="{{item.name}}"
            catchtap="onPickServiceSuggest"
          >{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="merchant-form__section">
      <text class="merchant-form__label">车型（必填，公开时将脱敏）</text>
      <view class="merchant-form__row">
        <input
          class="merchant-form__input merchant-form__input--half"
          placeholder="品牌 *"
          value="{{form.vehicleBrand}}"
          data-field="vehicleBrand"
          bindinput="onInput"
        />
        <input
          class="merchant-form__input merchant-form__input--half"
          placeholder="车系 *"
          value="{{form.vehicleSeries}}"
          data-field="vehicleSeries"
          bindinput="onInput"
        />
      </view>
    </view>

    <view class="merchant-form__section">
      <text class="text-caption album-create__scan-hint">创建后将立即展示车主扫码页，须车主扫码并确认隐私说明后方可上传过程图。手机号由车主本人授权，商家不可代填。</text>
    </view>
  </block>

  <view class="merchant-form__spacer" />
  <ui-fixed-bottom-bar>
    <ui-button
      type="primary"
      slot="right"
      loading="{{submitting}}"
      disabled="{{status === 'loading'}}"
      bind:btntap="onSubmit"
    >创建并请车主扫码</ui-button>
  </ui-fixed-bottom-bar>
</view>
