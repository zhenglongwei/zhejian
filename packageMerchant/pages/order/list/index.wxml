<view class="page merchant-order-page">
  <view class="merchant-order-page__tabs page-content">
    <ui-tabs
      tabs="{{tabs}}"
      activeKey="{{activeTab}}"
      scrollable="{{true}}"
      bind:change="onTabChange"
    />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content merchant-order-page__list">
      <ui-skeleton wx:for="{{[1,2,3]}}" wx:key="*this" rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthorized'}}">
    <view class="page-content">
      <ui-empty
        title="请先完成商家入驻"
        description="入驻审核通过后可管理订单与履约"
        actionText="前往工作台"
        bind:action="onGoWorkbench"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="暂无相关订单"
        description="新订单将出现在待接单列表中"
        actionText="刷新"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-order-page__list">
      <ui-order-card
        wx:for="{{list}}"
        wx:key="id"
        item="{{item}}"
        audience="merchant"
        bind:tap="onCardTap"
        bind:action="onPrimaryAction"
      />
    </view>
  </block>
</view>
