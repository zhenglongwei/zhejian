<view class="page merchant-order-complete merchant-form-page">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content">
      <ui-skeleton rows="{{5}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法提交完工"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-order-complete__body merchant-order-complete--with-bar">
      <view wx:if="{{showEmptyAlbumTip}}" class="notice notice--primary">
        上传维修过程图片有助于用户理解维修过程，也能提升门店透明度和案例曝光。
      </view>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="merchant-form__section">
          <text class="merchant-form__label">维修说明 *</text>
          <textarea
            class="merchant-form__textarea"
            placeholder="简要说明本次维修内容"
            value="{{form.repairSummary}}"
            data-field="repairSummary"
            bindinput="onInput"
          />
        </view>

        <view class="merchant-form__section">
          <text class="merchant-form__label">配件说明</text>
          <textarea
            class="merchant-form__textarea"
            placeholder="更换配件、品牌、规格（可选）"
            value="{{form.partsSummary}}"
            data-field="partsSummary"
            bindinput="onInput"
          />
        </view>

        <view class="merchant-form__section">
          <text class="merchant-form__label">价格说明{{needPriceNote ? ' *' : ''}}</text>
          <textarea
            class="merchant-form__textarea"
            placeholder="{{priceNotePlaceholder}}"
            value="{{form.priceNote}}"
            data-field="priceNote"
            bindinput="onInput"
          />
          <view wx:if="{{needPriceNote}}" class="merchant-order-complete__notice">
            <ui-compliance-notice type="{{priceComplianceType}}" />
          </view>
        </view>

        <view class="merchant-form__section">
          <text class="merchant-form__label">质保说明</text>
          <textarea
            class="merchant-form__textarea"
            placeholder="门店承诺或平台规则（可选）"
            value="{{form.warrantyNote}}"
            data-field="warrantyNote"
            bindinput="onInput"
          />
        </view>

        <ui-checkbox-row
          checked="{{form.generateCaseDraft}}"
          label="完工后生成案例草稿（可选）"
          bind:change="onDraftChange"
        />
        <view wx:if="{{form.generateCaseDraft}}" class="merchant-order-complete__draft-notice">
          <ui-compliance-notice
            text="案例草稿需用户授权后方可公开；公开版将自动脱敏车牌、手机号等信息，不含完整订单与实际支付金额。"
          />
        </view>
      </ui-card>
    </view>

    <ui-fixed-bottom-bar safeArea="{{true}}">
      <ui-button
        slot="right"
        type="primary"
        loading="{{submitting}}"
        bind:tap="onSubmit"
      >提交完工</ui-button>
    </ui-fixed-bottom-bar>
  </block>
</view>
