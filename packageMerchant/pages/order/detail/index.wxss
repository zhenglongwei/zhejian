.merchant-order-detail {
  padding-bottom: var(--space-xl);
}

.merchant-order-detail--with-bar .merchant-order-detail__body {
  padding-bottom: var(--page-fixed-clearance);
}

.merchant-order-detail__pad {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.merchant-order-detail__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.merchant-order-detail__status-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md) 0 var(--space-xs);
}

.merchant-order-detail__hint {
  color: var(--color-text-secondary);
}

.merchant-order-detail__section-title {
  display: block;
  margin-bottom: var(--space-md);
  color: var(--color-text-primary);
}

.merchant-order-detail__price {
  margin-top: var(--space-md);
}

.merchant-order-detail__notice {
  margin-top: var(--space-sm);
}

.merchant-order-detail__inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-order-detail__album-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.merchant-order-detail__album-head .merchant-order-detail__section-title {
  margin-bottom: 0;
}

.merchant-order-detail__album-hint {
  display: block;
  color: var(--color-text-secondary);
}

.merchant-order-detail__album-privacy {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-order-detail__album-entry {
  margin-top: var(--space-sm);
}

.merchant-order-detail__album-link {
  color: var(--color-primary);
}

.merchant-order-detail__log-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.merchant-order-detail__log-item:last-child {
  border-bottom: none;
}

.merchant-order-detail__log-meta {
  color: var(--color-text-tertiary);
}
