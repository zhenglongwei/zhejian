<view class="page merchant-review-list">
  <ui-tabs
    tabs="{{tabs}}"
    activeKey="{{activeTab}}"
    bind:change="onTabChange"
  />

  <block wx:if="{{status === 'loading'}}">
    <view class="merchant-review-list__pad page-content">
      <ui-skeleton wx:for="{{skeletonItems}}" wx:key="*this" rows="{{3}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty title="{{emptyTitle}}" description="{{emptyDescription}}" />
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-review-list__body">
      <ui-card
        wx:for="{{list}}"
        wx:key="id"
        shadow="{{true}}"
        padding="{{true}}"
        data-id="{{item.id}}"
        bindtap="onOpenDetail"
      >
        <view class="merchant-review-list__head">
          <text class="text-h3">{{item.serviceName}}</text>
          <text class="text-caption">维修 {{item.repairScore}} · 记录 {{item.albumScore}}</text>
        </view>
        <text class="text-caption text-secondary">{{item.ownerHint}} · {{item.createdAt}}</text>
        <text wx:if="{{item.contentPreview}}" class="text-body merchant-review-list__preview">
          {{item.contentPreview}}
        </text>
        <view class="merchant-review-list__tags">
          <ui-tag wx:if="{{item.authorizePublic}}" variant="info" text="已授权公开" />
          <ui-tag wx:if="{{item.hasReply}}" variant="success" text="已回复" />
          <ui-tag wx:else variant="warning" text="待回复" />
        </view>
      </ui-card>
    </view>
  </block>
</view>
