.merchant-review-list__pad,
.merchant-review-list__body {
  padding: var(--space-md) var(--page-padding-x) var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.merchant-review-list__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
}

.merchant-review-list__preview {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
}

.merchant-review-list__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}
