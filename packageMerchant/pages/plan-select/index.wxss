.plan-select {
  min-height: 100vh;
  padding-bottom: var(--page-fixed-clearance);
  box-sizing: border-box;
}

.plan-select__top {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding-top: var(--space-sm);
}

.plan-select__folio {
  margin: 0 calc(-1 * var(--page-padding-x));
  padding: var(--space-xl) var(--page-padding-x) var(--space-lg);
}

.plan-select__folio-inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.plan-select__title {
  color: var(--color-text-primary);
}

.plan-select__sub {
  line-height: var(--font-body-lh);
}

.plan-select__panel {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.plan-select__summary {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.plan-select__summary-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.plan-select__price {
  color: var(--color-text-primary);
}

.plan-select__table {
  display: flex;
  flex-direction: column;
}

.plan-select__tr {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.plan-select__tr--head {
  padding-top: 0;
}

.plan-select__tr:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.plan-select__th,
.plan-select__td {
  flex: 1.4;
  color: var(--color-text-secondary);
  line-height: var(--font-body-lh);
}

.plan-select__th--value,
.plan-select__td--value {
  flex: 1;
  text-align: right;
  color: var(--color-text-primary);
}

.plan-select__th {
  color: var(--color-text-tertiary);
}

.plan-select__consent {
  margin-top: var(--space-xs);
}

.plan-select__action {
  margin-top: var(--space-sm);
}
