<ui-tool-page-shell showBand="{{false}}" showCompliance="{{false}}">
  <view class="plan-select bg-album">
    <view class="page-content plan-select__top">
      <view class="plan-select__folio surface-album-folio">
        <view class="plan-select__folio-inner">
          <text class="plan-select__title text-h2">{{hero.title}}</text>
          <text class="plan-select__sub text-caption text-secondary">{{hero.subtitle}}</text>
        </view>
      </view>

      <view class="plan-select__panel surface-album-panel">
        <view class="plan-select__summary">
          <view class="plan-select__summary-row">
            <text class="text-h3">{{summary.name}}</text>
            <ui-tag variant="success" text="当前方案" />
          </view>
          <text class="plan-select__price text-h2">{{summary.priceLabel}}</text>
          <text class="text-caption text-secondary">{{summary.trialLabel}}</text>
        </view>

        <view class="surface-album-inset-divider" />

        <view class="plan-select__table">
          <view class="plan-select__tr plan-select__tr--head">
            <text class="plan-select__th text-caption">项目</text>
            <text class="plan-select__th plan-select__th--value text-caption">说明</text>
          </view>
          <view wx:for="{{rows}}" wx:key="item" class="plan-select__tr">
            <text class="plan-select__td text-caption">{{item.item}}</text>
            <text class="plan-select__td plan-select__td--value text-caption">{{item.value}}</text>
          </view>
        </view>
      </view>

      <view class="plan-select__panel surface-album-panel">
        <text class="text-caption text-secondary">{{footer}}</text>
        <text class="text-caption text-link plan-select__link" bindtap="onOpenAgreement">查看《套餐与工具服务协议》</text>
        <view class="plan-select__action">
          <ui-button type="primary" block loading="{{submitting}}" bind:btntap="onConfirm">{{cta}}</ui-button>
        </view>
      </view>
    </view>
  </view>
</ui-tool-page-shell>
