<view class="page message-list">
  <ui-list-page-shell
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    emptyTitle="暂无消息"
    emptyDescription="新线索、授权与审核结果会在这里通知你"
    unauthTitle="请先登录"
    unauthDescription="登录商家账号后可查看工作台消息"
    bind:retry="onRetry"
    bind:unauthaction="onGoLogin"
  >
    <view slot="intro" wx:if="{{isLoggedIn}}" class="message-list__subscribe">
      <view class="message-list__subscribe-text">
        <text class="text-body">微信通知</text>
        <text class="text-caption">每次点击授权可接收 1 条微信通知，重要操作前请再次授权</text>
      </view>
      <ui-button type="secondary" size="sm" bind:btntap="onSubscribeWechat">开启微信通知</ui-button>
    </view>
    <view wx:if="{{unreadCount > 0 && status === 'normal'}}" class="message-list__toolbar">
      <text class="text-caption">未读 {{unreadCount}} 条</text>
      <text class="text-link text-caption" bindtap="onMarkAllRead">全部已读</text>
    </view>
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="message-list__item {{item.read ? 'message-list__item--read' : ''}}"
      data-id="{{item.id}}"
      data-path="{{item.jumpPath}}"
      bindtap="onItemTap"
    >
      <view class="message-list__head">
        <text class="text-body message-list__title">{{item.title}}</text>
        <text wx:if="{{!item.read}}" class="message-list__dot"></text>
      </view>
      <text class="text-caption message-list__content">{{item.content}}</text>
      <text class="text-caption message-list__time">{{item.createdAt}}</text>
    </view>
  </ui-list-page-shell>
</view>
