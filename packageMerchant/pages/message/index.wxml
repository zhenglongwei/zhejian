<view class="page message-list bg-album">
  <ui-list-page-shell
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    emptyTheme="album"
    emptyTitle="暂无消息"
    emptyDescription="新线索、授权与审核结果会在这里通知你"
    unauthTitle="请先登录"
    unauthDescription="登录商家账号后可查看工作台消息"
    bind:retry="onRetry"
    bind:unauthaction="onGoLogin"
  >
    <view slot="intro" wx:if="{{isLoggedIn}}">
      <ui-message-subscribe-banner bind:subscribe="onSubscribeWechat" />
    </view>
    <view wx:if="{{unreadCount > 0 && status === 'normal'}}" class="message-list__toolbar">
      <text class="text-caption">未读 {{unreadCount}} 条</text>
      <text class="text-link text-caption" bindtap="onMarkAllRead">全部已读</text>
    </view>
    <ui-message-card
      wx:for="{{list}}"
      wx:key="id"
      messageId="{{item.id}}"
      title="{{item.title}}"
      content="{{item.content}}"
      time="{{item.createdAt}}"
      read="{{item.read}}"
      jumpPath="{{item.jumpPath}}"
      bind:tap="onItemTap"
    />
  </ui-list-page-shell>
</view>
