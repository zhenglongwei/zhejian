<view class="page merchant-store-edit page-content merchant-form-page" wx:if="{{status === 'loading'}}">
  <ui-skeleton rows="{{6}}" title="{{true}}" />
</view>

<view class="page merchant-store-edit page-content merchant-form-page" wx:elif="{{status === 'forbidden'}}">
  <ui-empty
    title="仅主账号可编辑"
    description="门店资料变更需由店铺管理员操作"
    actionText="返回工作台"
    bind:action="onBackWorkbench"
  />
</view>

<view class="page merchant-store-edit page-content merchant-form-page" wx:elif="{{status === 'normal'}}">
  <ui-compliance-notice type="history" text="本页可改两类信息：标注「即时生效」的保存后立即对外展示；标注「须审核」的需运营通过后才更新公开页，审核期间仍显示上一版。" />

  <!-- ① 基础展示：即时生效 -->
  <view class="merchant-store-edit__panel">
    <text class="merchant-store-edit__panel-title text-h3">基础展示</text>
    <text class="merchant-store-edit__panel-hint text-caption">即时生效。电话、营业时间、简介保存后立即对用户端与 H5 生效。</text>

    <view class="merchant-form__section">
      <text class="merchant-form__label">门店电话 *</text>
      <input class="merchant-form__input" type="number" placeholder="用户咨询拨打" value="{{form.storePhone}}" data-field="storePhone" bindinput="onInput" />
    </view>

    <view class="merchant-form__section">
      <text class="merchant-form__label">营业时间 *</text>
      <text class="text-caption merchant-hours__hint">点击时间可修改每日营业时段；长假可添加临时休息。</text>

      <view class="merchant-hours__daily">
        <text class="merchant-hours__daily-label">每日营业</text>
        <view class="merchant-hours__daily-times">
          <picker mode="time" value="{{businessHoursDaily.start}}" data-field="start" bindchange="onDailyTimeChange">
            <view class="merchant-hours__time">{{businessHoursDaily.start || '09:00'}}</view>
          </picker>
          <text class="merchant-hours__sep">至</text>
          <picker mode="time" value="{{businessHoursDaily.end}}" data-field="end" bindchange="onDailyTimeChange">
            <view class="merchant-hours__time">{{businessHoursDaily.end || '18:00'}}</view>
          </picker>
        </view>
      </view>

      <view class="merchant-hours__closures">
        <view class="merchant-hours__closures-head">
          <text class="merchant-form__label merchant-form__label--sub">临时休息</text>
          <text class="merchant-hours__add" bindtap="onToggleClosureForm">{{showClosureForm ? '收起' : '+ 添加'}}</text>
        </view>

        <view wx:if="{{showClosureForm}}" class="merchant-hours__closure-form">
          <view class="merchant-hours__closure-row">
            <text class="merchant-hours__closure-label">开始</text>
            <picker mode="date" value="{{closureDraft.startDate}}" data-field="startDate" bindchange="onClosureDraftDateChange">
              <view class="merchant-hours__date">{{closureDraft.startDate || '选择日期'}}</view>
            </picker>
          </view>
          <view class="merchant-hours__closure-row">
            <text class="merchant-hours__closure-label">结束</text>
            <picker mode="date" value="{{closureDraft.endDate}}" data-field="endDate" bindchange="onClosureDraftDateChange">
              <view class="merchant-hours__date">{{closureDraft.endDate || '选择日期'}}</view>
            </picker>
          </view>
          <input
            class="merchant-form__input"
            placeholder="说明（选填），如：春节、国庆"
            value="{{closureDraft.note}}"
            bindinput="onClosureDraftNoteInput"
          />
          <view class="merchant-hours__closure-actions">
            <ui-button type="secondary" size="sm" bind:btntap="onCancelClosureForm">取消</ui-button>
            <ui-button type="primary" size="sm" bind:btntap="onConfirmClosure">确认</ui-button>
          </view>
        </view>

        <text wx:if="{{!businessHoursClosures.length && !showClosureForm}}" class="merchant-hours__closure-empty text-caption">暂无临时休息；非营业时段用户端将显示「休息中」</text>

        <view
          wx:for="{{businessHoursClosures}}"
          wx:key="id"
          class="merchant-hours__closure-item"
        >
          <text class="merchant-hours__closure-text">{{item.displayText}}</text>
          <text class="merchant-hours__closure-remove" data-id="{{item.id}}" bindtap="onRemoveClosure">删除</text>
        </view>
      </view>

      <view class="merchant-hours__preview">
        <text class="merchant-hours__preview-label text-caption">用户端展示文案</text>
        <text class="merchant-hours__preview-value text-body">{{businessHoursPreview || '请设置营业时间'}}</text>
      </view>
    </view>

    <view class="merchant-form__section">
      <text class="merchant-form__label">门店简介</text>
      <textarea class="merchant-form__textarea" placeholder="选填，用户端门店详情展示" value="{{form.intro}}" data-field="intro" bindinput="onInput" maxlength="500" />
    </view>
  </view>

  <!-- ② 擅长服务：即时生效 -->
  <view class="merchant-store-edit__panel">
    <text class="merchant-store-edit__panel-title text-h3">擅长服务 *</text>
    <text class="merchant-store-edit__panel-hint text-caption">即时生效。可点选预设，也可自定义添加。</text>
    <view class="merchant-form__section">
      <view class="merchant-onboard__chips">
        <view
          wx:for="{{serviceTags}}"
          wx:key="name"
          class="merchant-onboard__chip {{item.selected ? 'merchant-onboard__chip--on' : ''}}"
          data-name="{{item.name}}"
          bindtap="onToggleService"
        >{{item.name}}</view>
      </view>
      <view class="merchant-onboard__custom-line">
        <text class="merchant-onboard__custom-label text-body">自定义</text>
        <input
          class="merchant-onboard__custom-input"
          value="{{customServiceInput}}"
          maxlength="16"
          confirm-type="done"
          placeholder="输入后回车添加"
          bindinput="onCustomServiceInput"
          bindblur="onCustomServiceCommit"
          bindconfirm="onCustomServiceCommit"
        />
      </view>
    </view>
  </view>

  <!-- ③ 门店照片：即时生效 -->
  <view class="merchant-store-edit__panel">
    <text class="merchant-store-edit__panel-title text-h3">门店照片</text>
    <text class="merchant-store-edit__panel-hint text-caption">即时生效。门头、工位、接待区保存后立即进入用户端轮播；品牌授权请到下方「须审核」区块维护。</text>

    <view class="merchant-form__section">
      <text class="merchant-form__label">门头照片 *</text>
      <view class="merchant-onboard__photo-slot" bindtap="onPickFacade">
        <image wx:if="{{form.facadePhotoUrl}}" class="merchant-onboard__photo" src="{{form.facadePhotoUrl}}" mode="aspectFill" />
        <text wx:else class="text-caption">点击上传</text>
      </view>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">工位照片 *（至少 1 张，最多 6 张）</text>
      <text class="text-caption merchant-store-edit__field-tip">预览轮播会展示：门头 + 工位 + 接待区 + 已审设备实景。</text>
      <view class="merchant-onboard__photo-grid">
        <view
          wx:for="{{form.workshopPhotoUrls}}"
          wx:key="index"
          class="merchant-onboard__photo-wrap"
        >
          <image class="merchant-onboard__photo" src="{{item}}" mode="aspectFill" />
          <text class="merchant-onboard__photo-del" data-index="{{index}}" catchtap="onRemoveWorkshop">×</text>
        </view>
        <view
          wx:if="{{form.workshopPhotoUrls.length < 6}}"
          class="merchant-onboard__photo-slot merchant-onboard__photo-slot--add"
          bindtap="onPickWorkshop"
        >
          <text class="text-caption merchant-store-edit__photo-add-text">添加工位</text>
        </view>
      </view>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">接待区照片（最多 6 张）</text>
      <view class="merchant-onboard__photo-grid">
        <view
          wx:for="{{form.receptionPhotoUrls}}"
          wx:key="index"
          class="merchant-onboard__photo-wrap"
        >
          <image class="merchant-onboard__photo" src="{{item}}" mode="aspectFill" />
          <text class="merchant-onboard__photo-del" data-index="{{index}}" catchtap="onRemoveReception">×</text>
        </view>
        <view
          wx:if="{{form.receptionPhotoUrls.length < 6}}"
          class="merchant-onboard__photo-slot merchant-onboard__photo-slot--add"
          bindtap="onPickReception"
        >
          <text class="text-caption merchant-store-edit__photo-add-text">添加接待区</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ④ 能力边界：即时 + 须审 -->
  <view class="merchant-store-edit__panel">
    <text class="merchant-store-edit__panel-title text-h3">能力与边界</text>
    <text class="merchant-store-edit__panel-hint text-caption">本区含即时字段与须审字段，请按下方标注区分；虚假信息可能被举报与事后处理。</text>

    <view wx:if="{{capabilityReviewStatus === 'pending'}}" class="merchant-store-edit__banner merchant-store-edit__banner--pending">
      <text class="text-caption">有须审项正在审核中（技师 / 设备 / 品牌授权）。通过前，用户端与 H5 仍显示上一版已通过内容。</text>
    </view>
    <view wx:if="{{capabilityReviewStatus === 'rejected'}}" class="merchant-store-edit__banner merchant-store-edit__banner--reject">
      <text class="text-caption">能力变更已驳回：{{capabilityRejectReason || '请修改后重新提交'}}</text>
    </view>

    <view class="merchant-store-edit__subhead">
      <text class="merchant-store-edit__subhead-title text-body">即时生效</text>
      <text class="merchant-store-edit__subhead-hint text-caption">保存后立即对外展示</text>
    </view>

    <view class="merchant-form__section">
      <text class="merchant-form__label">擅长品牌</text>
      <input
        class="merchant-form__input"
        placeholder="如：宝马、奥迪、本田（顿号分隔）"
        value="{{form.specialtyBrandsText}}"
        data-field="specialtyBrandsText"
        bindinput="onInput"
      />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">暂不承接</text>
      <input
        class="merchant-form__input"
        placeholder="如：大型货车、改装车"
        value="{{form.notAcceptingText}}"
        data-field="notAcceptingText"
        bindinput="onInput"
      />
    </view>

    <view class="merchant-store-edit__subhead merchant-store-edit__subhead--review">
      <text class="merchant-store-edit__subhead-title text-body">须审核后生效</text>
      <text class="merchant-store-edit__subhead-hint text-caption">保存后提交运营审核；通过前公开页不更新这些内容</text>
    </view>

    <view class="merchant-form__section">
      <text class="merchant-form__label">品牌授权证明（最多 8 个品牌）</text>
      <text class="text-caption merchant-store-edit__field-tip">每个品牌单独上传证明图并选择有效期；过期后该品牌授权不再对外展示。</text>
      <view
        wx:for="{{form.brandAuthItems}}"
        wx:key="id"
        class="merchant-store-edit__brand-card"
      >
        <input
          class="merchant-form__input"
          placeholder="品牌名称 *，如：宝马"
          value="{{item.brandName}}"
          data-index="{{index}}"
          data-field="brandName"
          bindinput="onBrandAuthInput"
        />
        <picker
          mode="date"
          value="{{item.validUntil}}"
          data-index="{{index}}"
          bindchange="onBrandAuthDateChange"
        >
          <view class="merchant-form__picker merchant-store-edit__auth-date {{item.validUntil ? '' : 'merchant-form__picker--placeholder'}}">
            {{item.validUntil || '选择授权有效期 *'}}
          </view>
        </picker>
        <view class="merchant-store-edit__brand-media">
          <image
            wx:if="{{item.imageUrl}}"
            class="merchant-store-edit__eq-thumb"
            src="{{item.imageUrl}}"
            mode="aspectFill"
          />
          <view
            class="merchant-onboard__photo-slot merchant-onboard__photo-slot--add merchant-store-edit__eq-pick"
            data-index="{{index}}"
            bindtap="onPickBrandAuthImage"
          >
            <text class="text-caption">{{item.imageUrl ? '更换证明' : '上传证明'}}</text>
          </view>
          <text
            wx:if="{{item.imageUrl}}"
            class="merchant-store-edit__eq-clear text-caption"
            data-index="{{index}}"
            bindtap="onClearBrandAuthImage"
          >清除图片</text>
        </view>
        <text class="merchant-store-edit__tech-remove text-caption" data-index="{{index}}" bindtap="onRemoveBrandAuth">删除该品牌授权</text>
      </view>
      <view wx:if="{{form.brandAuthItems.length < 8}}" class="merchant-store-edit__add-tech">
        <ui-button type="secondary" size="sm" bind:btntap="onAddBrandAuth">添加品牌授权</ui-button>
      </view>
    </view>

    <view class="merchant-form__section">
      <text class="merchant-form__label">设备/场</text>
      <text class="text-caption merchant-store-edit__field-tip">标签与实景图均须审核通过后，才出现在用户端/H5；实景图审核通过后可进入环境轮播。</text>
      <view class="merchant-onboard__chips">
        <view
          wx:for="{{equipmentTagViews}}"
          wx:key="name"
          class="merchant-onboard__chip {{item.selected ? 'merchant-onboard__chip--on' : ''}}"
          data-name="{{item.name}}"
          bindtap="onToggleEquipment"
        >{{item.name}}</view>
      </view>
      <view class="merchant-onboard__custom-line">
        <text class="merchant-onboard__custom-label text-body">自定义</text>
        <input
          class="merchant-onboard__custom-input"
          value="{{customEquipmentInput}}"
          maxlength="16"
          confirm-type="done"
          placeholder="输入后回车添加"
          bindinput="onCustomEquipmentInput"
          bindblur="onCustomEquipmentCommit"
          bindconfirm="onCustomEquipmentCommit"
        />
      </view>
      <view wx:if="{{form.equipmentTags.length}}" class="merchant-store-edit__eq-list">
        <text class="text-caption">已选设备可挂实景图</text>
        <view
          wx:for="{{form.equipmentTags}}"
          wx:key="id"
          class="merchant-store-edit__eq-row"
        >
          <text class="merchant-store-edit__eq-label text-body">{{item.label}}</text>
          <view class="merchant-store-edit__eq-media">
            <image
              wx:if="{{item.imageUrl}}"
              class="merchant-store-edit__eq-thumb"
              src="{{item.imageUrl}}"
              mode="aspectFill"
              data-index="{{index}}"
              bindtap="onPreviewEquipmentImage"
            />
            <view
              class="merchant-onboard__photo-slot merchant-onboard__photo-slot--add merchant-store-edit__eq-pick"
              data-index="{{index}}"
              bindtap="onPickEquipmentImage"
            >
              <text class="text-caption">{{item.imageUrl ? '更换' : '上传实景'}}</text>
            </view>
            <text
              wx:if="{{item.imageUrl}}"
              class="merchant-store-edit__eq-clear text-caption"
              data-index="{{index}}"
              bindtap="onClearEquipmentImage"
            >清除</text>
          </view>
        </view>
      </view>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">技师公示</text>
      <text class="text-caption merchant-store-edit__field-tip">须审核通过后才在用户端/H5 展示技师信息。</text>
      <view wx:for="{{form.technicians}}" wx:key="id" class="merchant-store-edit__tech-card">
        <input class="merchant-form__input" placeholder="称呼 *" value="{{item.name}}" data-index="{{index}}" data-field="name" bindinput="onTechInput" />
        <input class="merchant-form__input" placeholder="主修/角色" value="{{item.role}}" data-index="{{index}}" data-field="role" bindinput="onTechInput" />
        <view class="merchant-form__row">
          <input class="merchant-form__input merchant-form__input--half" placeholder="年限" value="{{item.years}}" data-index="{{index}}" data-field="years" bindinput="onTechInput" />
          <input class="merchant-form__input merchant-form__input--half" placeholder="资质标签" value="{{item.credentialsText}}" data-index="{{index}}" data-field="credentialsText" bindinput="onTechInput" />
        </view>
        <view class="merchant-store-edit__tech-media">
          <text class="text-caption merchant-store-edit__tech-media-label">头像</text>
          <view class="merchant-store-edit__brand-media">
            <image
              wx:if="{{item.avatarUrl}}"
              class="merchant-store-edit__eq-thumb"
              src="{{item.avatarUrl}}"
              mode="aspectFill"
              data-url="{{item.avatarUrl}}"
              data-index="{{index}}"
              bindtap="onPreviewTechImage"
            />
            <view
              class="merchant-onboard__photo-slot merchant-onboard__photo-slot--add merchant-store-edit__eq-pick"
              data-index="{{index}}"
              bindtap="onPickTechAvatar"
            >
              <text class="text-caption">{{item.avatarUrl ? '更换头像' : '上传头像'}}</text>
            </view>
            <text
              wx:if="{{item.avatarUrl}}"
              class="merchant-store-edit__eq-clear text-caption"
              data-index="{{index}}"
              bindtap="onClearTechAvatar"
            >清除</text>
          </view>
        </view>
        <view class="merchant-store-edit__tech-media">
          <text class="text-caption merchant-store-edit__tech-media-label">资质证明（选填，最多 6 张）</text>
          <view class="merchant-onboard__photo-grid">
            <view
              wx:for="{{item.credentialPhotoUrls}}"
              wx:for-item="photo"
              wx:for-index="photoIndex"
              wx:key="photoIndex"
              class="merchant-onboard__photo-wrap"
            >
              <image
                class="merchant-onboard__photo"
                src="{{photo}}"
                mode="aspectFill"
                data-url="{{photo}}"
                data-index="{{index}}"
                bindtap="onPreviewTechImage"
              />
              <text
                class="merchant-onboard__photo-del"
                data-index="{{index}}"
                data-photo-index="{{photoIndex}}"
                catchtap="onRemoveTechCredential"
              >×</text>
            </view>
            <view
              wx:if="{{!item.credentialPhotoUrls || item.credentialPhotoUrls.length < 6}}"
              class="merchant-onboard__photo-slot merchant-onboard__photo-slot--add"
              data-index="{{index}}"
              bindtap="onPickTechCredential"
            >
              <text class="text-caption merchant-store-edit__photo-add-text">添加证明</text>
            </view>
          </view>
        </view>
        <text class="merchant-store-edit__tech-remove text-caption" data-index="{{index}}" bindtap="onRemoveTech">删除该技师</text>
      </view>
      <view class="merchant-store-edit__add-tech">
        <ui-button type="secondary" size="sm" bind:btntap="onAddTech">添加技师</ui-button>
      </view>
    </view>
  </view>

  <!-- ⑤ 只读基本资料 -->
  <view class="merchant-store-edit__panel merchant-store-edit__panel--muted">
    <text class="merchant-store-edit__panel-title text-h3">基本资料（只读）</text>
    <text class="merchant-store-edit__panel-hint text-caption">主体、资质、名称与地址变更请联系平台运营。</text>
    <view class="merchant-store-edit__readonly-row">
      <text class="merchant-store-edit__readonly-label">门店名称</text>
      <text class="merchant-store-edit__readonly-value">{{basic.storeName}}</text>
    </view>
    <view class="merchant-store-edit__readonly-row">
      <text class="merchant-store-edit__readonly-label">门店地址</text>
      <text class="merchant-store-edit__readonly-value">{{basic.address}}</text>
    </view>
    <view class="merchant-store-edit__readonly-row">
      <text class="merchant-store-edit__readonly-label">主体名称</text>
      <text class="merchant-store-edit__readonly-value">{{basic.legalName}}</text>
    </view>
    <view class="merchant-store-edit__readonly-row">
      <text class="merchant-store-edit__readonly-label">信用代码</text>
      <text class="merchant-store-edit__readonly-value">{{basic.creditCode}}</text>
    </view>
    <view class="merchant-store-edit__readonly-row">
      <text class="merchant-store-edit__readonly-label">负责人</text>
      <text class="merchant-store-edit__readonly-value">{{basic.contactName}}</text>
    </view>
    <view class="merchant-store-edit__readonly-row">
      <text class="merchant-store-edit__readonly-label">负责人手机</text>
      <text class="merchant-store-edit__readonly-value">{{basic.phone}}</text>
    </view>
    <view class="merchant-store-edit__readonly-row">
      <text class="merchant-store-edit__readonly-label">基础资质</text>
      <text class="merchant-store-edit__readonly-value">{{basic.qualificationTypeLabel}}</text>
    </view>
    <view class="merchant-store-edit__readonly-row" wx:if="{{basic.newEnergyEnabled}}">
      <text class="merchant-store-edit__readonly-label">新能源专项</text>
      <text class="merchant-store-edit__readonly-value">{{basic.newEnergyTypeLabel}}</text>
    </view>
    <view class="merchant-store-edit__readonly-photos" wx:if="{{basic.licensePhotoUrl || basic.qualificationPhotoUrl || basic.newEnergyPhotoUrl}}">
      <image wx:if="{{basic.licensePhotoUrl}}" class="merchant-store-edit__readonly-photo" src="{{basic.licensePhotoUrl}}" mode="aspectFill" />
      <image wx:if="{{basic.qualificationPhotoUrl}}" class="merchant-store-edit__readonly-photo" src="{{basic.qualificationPhotoUrl}}" mode="aspectFill" />
      <image wx:if="{{basic.newEnergyPhotoUrl}}" class="merchant-store-edit__readonly-photo" src="{{basic.newEnergyPhotoUrl}}" mode="aspectFill" />
    </view>
  </view>

  <view class="merchant-form__spacer" />
  <ui-fixed-bottom-bar>
    <ui-button type="secondary" size="sm" slot="left" bind:btntap="onShareStore">分享门店</ui-button>
    <ui-button type="secondary" size="sm" slot="left" bind:btntap="onPreview">预览主页</ui-button>
    <ui-button type="primary" slot="right" loading="{{submitting}}" bind:btntap="onSave">保存</ui-button>
  </ui-fixed-bottom-bar>
</view>
