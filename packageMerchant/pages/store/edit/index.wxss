@import '../../../../styles/merchant-form.wxss';
@import '../../../../styles/merchant-hours.wxss';
@import '../../onboarding/index.wxss';

.merchant-store-edit__panel {
  margin-top: var(--space-lg);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
}

.merchant-store-edit__panel--muted {
  background-color: var(--color-bg-muted);
}

.merchant-store-edit__panel-title {
  display: block;
  color: var(--color-text-primary);
}

.merchant-store-edit__panel-hint {
  display: block;
  margin-top: var(--space-xs);
  margin-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.merchant-store-edit__banner {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
}

.merchant-store-edit__banner--pending {
  background-color: var(--color-bg-muted);
  border: 1rpx solid var(--color-border);
}

.merchant-store-edit__banner--reject {
  background-color: var(--color-bg-muted);
  border: 1rpx solid var(--color-danger, var(--color-border));
}

.merchant-store-edit__field-tip {
  display: block;
  margin-top: var(--space-xs);
  margin-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
}

.merchant-store-edit__photo-add-text {
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.4;
}

.merchant-onboard__photo-wrap {
  overflow: hidden;
  flex-shrink: 0;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-muted);
}

.merchant-onboard__photo-slot--add {
  flex-shrink: 0;
}

.merchant-store-edit__auth-date {
  margin-top: var(--space-sm);
}

.merchant-store-edit__tech-card {
  margin-top: var(--space-sm);
  padding: var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-store-edit__tech-card .merchant-form__input {
  margin-top: var(--space-xs);
}

.merchant-store-edit__tech-card .merchant-form__row {
  margin-top: var(--space-xs);
}

.merchant-store-edit__years-field {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  min-width: 0;
}

.merchant-store-edit__years-input {
  flex: 1;
  min-width: 0;
}

.merchant-store-edit__years-unit {
  flex-shrink: 0;
  color: var(--color-text-secondary);
  padding-right: var(--space-xs);
}

.merchant-store-edit__tech-media {
  margin-top: var(--space-sm);
}

.merchant-store-edit__tech-media-label {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-secondary);
}

.merchant-store-edit__tech-remove {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-tertiary);
  text-align: right;
}

.merchant-store-edit__eq-list {
  margin-top: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-store-edit__eq-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-store-edit__eq-label {
  flex: 1;
  min-width: 0;
}

.merchant-store-edit__eq-media {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.merchant-store-edit__eq-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  background-color: var(--color-bg-page);
}

.merchant-store-edit__eq-pick {
  width: auto;
  min-width: 120rpx;
  height: 72rpx;
  padding: 0 var(--space-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchant-store-edit__eq-clear {
  color: var(--color-text-tertiary);
}

.merchant-store-edit__subhead {
  margin-top: var(--space-lg);
  padding: var(--space-sm) var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-store-edit__subhead--review {
  margin-top: var(--space-xl);
  border-color: var(--color-border);
  background-color: var(--color-bg-page);
}

.merchant-store-edit__subhead-title {
  display: block;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.merchant-store-edit__subhead-hint {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.merchant-store-edit__brand-card {
  margin-top: var(--space-sm);
  padding: var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.merchant-store-edit__brand-card .merchant-form__input {
  margin-top: var(--space-xs);
}

.merchant-store-edit__brand-media {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-top: var(--space-sm);
  flex-wrap: wrap;
}

.merchant-store-edit__readonly-row {
  display: flex;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.merchant-store-edit__readonly-row:last-of-type {
  border-bottom: none;
}

.merchant-store-edit__readonly-label {
  flex-shrink: 0;
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
}

.merchant-store-edit__readonly-value {
  flex: 1;
  text-align: right;
  color: var(--color-text-primary);
  font-size: var(--font-caption);
  word-break: break-all;
}

.merchant-store-edit__readonly-photos {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.merchant-store-edit__readonly-photo {
  width: 160rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
}
