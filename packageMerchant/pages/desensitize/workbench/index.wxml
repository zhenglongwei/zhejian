<view class="page desensitize-page page-content">
  <block wx:if="{{status === 'loading'}}">
    <ui-skeleton rows="{{4}}" title />
  </block>

  <block wx:elif="{{status === 'error'}}">
    <ui-empty
      title="加载失败"
      description="{{errorMessage}}"
      actionText="重试"
      bind:action="onRetryLoad"
    />
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <ui-empty
      title="暂无待脱敏图片"
      description="请返回案例编辑页上传过程图"
      actionText="返回编辑"
      bind:action="onBackEdit"
    />
  </block>

  <block wx:else>
    <ui-privacy-banner scene="desensitize" />
    <ui-compliance-notice type="history" />
    <ui-compliance-notice type="desensitize" />
    <ui-compliance-notice type="desensitizeGuide" />
    <view wx:if="{{needPreviewHint}}" class="desensitize-page__preview-hint text-caption">
      请逐张点开右侧脱敏图预览，确认后再提交。
    </view>
    <ui-desensitize-workbench
      items="{{workbenchItems}}"
      processedCount="{{stats.processed}}"
      totalCount="{{stats.total}}"
      failedCount="{{stats.failed}}"
      liabilityText="{{liabilityText}}"
      liabilityAccepted="{{liabilityAccepted}}"
      bind:liabilitychange="onLiabilityChange"
      bind:preview="onPreview"
      bind:retry="onRetryAsset"
    />
    <view class="desensitize-page__spacer" />
    <ui-fixed-bottom-bar>
      <view slot="left" class="desensitize-page__bar-left">
        <ui-button
          type="primary"
          size="sm"
          loading="{{autoMaskLoading}}"
          bind:tap="onAutoMask"
        >一键 AI 脱敏</ui-button>
        <ui-button
          type="ghost"
          size="sm"
          disabled="{{true}}"
          bind:tap="onManualMask"
        >手工打码</ui-button>
      </view>
      <ui-button
        type="secondary"
        slot="right"
        loading="{{confirmLoading}}"
        disabled="{{!canConfirm || !liabilityAccepted}}"
        bind:tap="onConfirm"
      >{{confirmLabelShort}}</ui-button>
    </ui-fixed-bottom-bar>
  </block>
</view>
