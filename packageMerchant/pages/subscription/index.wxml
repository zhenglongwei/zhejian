<ui-tool-page-shell showBand="{{false}}" showCompliance="{{false}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="merchant-sub__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="merchant-sub__gate">
      <ui-empty
        theme="album"
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="merchant-sub">
      <view class="merchant-sub__folio surface-album-folio">
        <view class="merchant-sub__folio-main">
          <view class="merchant-sub__folio-row">
            <ui-plan-tier-badge
              plan="{{subscription.plan}}"
              text="{{currentHero.tierLabel}}"
              size="lg"
            />
            <ui-tag variant="{{publicIndexTag.variant}}" text="{{publicIndexTag.text}}" />
          </view>
          <text wx:if="{{currentHero.planLabel}}" class="text-body text-secondary">{{currentHero.planLabel}}</text>
          <text class="text-caption text-tertiary merchant-sub__folio-hint">相册工具永久免费；收录套餐到期不会自动扣款，需手动支付</text>
        </view>
      </view>

      <view class="merchant-sub__main surface-album-panel">
        <view class="merchant-sub__status">
          <view class="merchant-sub__status-row">
            <text class="text-caption text-secondary merchant-sub__status-label">当前套餐</text>
            <text class="text-body merchant-sub__status-value">{{planStatus.currentTierLabel}}<text wx:if="{{planStatus.currentPlanLabel}}" class="text-caption text-secondary"> · {{planStatus.currentPlanLabel}}</text></text>
          </view>
          <view wx:if="{{planStatus.expiresAtDisplay}}" class="merchant-sub__status-row">
            <text class="text-caption text-secondary merchant-sub__status-label">用到</text>
            <text class="text-body merchant-sub__status-value">{{planStatus.expiresAtDisplay}}</text>
          </view>
          <view class="merchant-sub__status-row">
            <text class="text-caption text-secondary merchant-sub__status-label">到期后</text>
            <text class="text-body merchant-sub__status-value">{{planStatus.nextTierLabel}}</text>
          </view>
        </view>

        <block wx:if="{{renewalNotice.show}}">
          <view class="surface-album-inset-divider" />
          <view wx:if="{{renewalNotice.canPay}}" class="merchant-sub__consent">
            <ui-checkbox-row checked="{{payConsent}}" bind:toggle="onTogglePayConsent">
              <text class="text-caption">{{payConsentText}}</text>
            </ui-checkbox-row>
            <text class="text-caption text-tertiary merchant-sub__consent-link" bindtap="onOpenSubscriptionAgreement">查看《套餐与公域收录服务协议》</text>
          </view>
          <view class="merchant-sub__renewal merchant-sub__renewal--{{renewalNotice.level}}">
            <text class="text-body merchant-sub__renewal-text">{{renewalNotice.message}}</text>
            <view wx:if="{{renewalNotice.canPay}}" class="merchant-sub__action">
              <ui-button
                type="primary"
                size="sm"
                loading="{{paying}}"
                disabled="{{paying}}"
                bind:btntap="onRenew"
              >支付续费一年</ui-button>
            </view>
            <ui-message-subscribe-banner
              title="到期前微信提醒你"
              description="不会自动扣款；开启后可在到期前收到续费提醒"
              buttonText="开启提醒"
              bind:subscribe="onSubscribeRenewNotice"
            />
          </view>
        </block>

        <block wx:if="{{planStatus.hasPendingChange}}">
          <view class="surface-album-inset-divider" />
          <text class="text-caption text-secondary merchant-sub__hint">已预约变更。想改选其他套餐，请先取消本次预约。</text>
          <view class="merchant-sub__action">
            <ui-button
              type="secondary"
              size="sm"
              loading="{{paying}}"
              disabled="{{paying}}"
              bind:btntap="onCancelPending"
            >取消预约变更</ui-button>
          </view>
        </block>

        <view class="surface-album-inset-divider" />

        <view class="merchant-sub__section-head">
          <text class="merchant-sub__section-title text-h3">开通后能帮你什么</text>
        </view>
        <view class="merchant-sub__benefits">
          <view
            wx:for="{{gateBenefits}}"
            wx:key="*this"
            class="merchant-sub__benefit"
          >
            <text class="merchant-sub__benefit-dot" aria-hidden="true" />
            <text class="text-caption text-secondary">{{item}}</text>
          </view>
        </view>

        <view class="surface-album-inset-divider" />

        <view class="merchant-sub__section-head">
          <text class="merchant-sub__section-title text-h3">套餐介绍</text>
          <text wx:if="{{planStatus.canScheduleChange}}" class="text-caption text-tertiary">点选免费版可预约到期后切换；标准版首购可享 6 个月免费试用</text>
          <text wx:elif="{{planStatus.hasPendingChange}}" class="text-caption text-tertiary">已有预约时不可改选，请先取消预约</text>
        </view>

        <view class="merchant-sub__plan-list">
          <view
            wx:for="{{plans}}"
            wx:key="plan"
            class="merchant-sub__plan surface-record-card {{item.isCurrentPlan ? 'merchant-sub__plan--current' : ''}} {{item.isNextPlan ? 'merchant-sub__plan--next' : ''}} {{selectedPlan === item.plan ? 'merchant-sub__plan--selected' : ''}} {{item.selectable ? 'merchant-sub__plan--selectable' : ''}}"
            data-plan="{{item.plan}}"
            bindtap="onSelectPlan"
          >
            <view class="merchant-sub__plan-head">
              <view class="merchant-sub__plan-title">
                <ui-plan-tier-badge plan="{{item.plan}}" text="{{item.tierLabel}}" size="md" />
                <text class="text-body merchant-sub__plan-name">{{item.name}}</text>
              </view>
              <view class="merchant-sub__plan-tags">
                <ui-tag wx:if="{{item.trialEligible}}" variant="success" text="免费试用" />
                <ui-tag wx:if="{{item.isCurrentPlan}}" variant="info" text="当前" />
                <ui-tag wx:elif="{{item.isNextPlan}}" variant="warning" text="到期后" />
              </view>
            </view>

            <view class="merchant-sub__price-row">
              <text class="text-price">¥{{item.priceAmount}}</text>
              <text class="text-caption text-secondary">{{item.priceSuffix}}</text>
              <text wx:if="{{item.priceShowTrial}}" class="text-caption text-tertiary merchant-sub__price-list">¥{{item.priceListAmount}}/年</text>
            </view>
            <text wx:if="{{item.priceNote}}" class="text-caption text-tertiary">{{item.priceNote}}</text>

            <view class="merchant-sub__features">
              <view
                wx:for="{{item.highlights}}"
                wx:for-item="line"
                wx:key="*this"
                class="merchant-sub__feature"
              >
                <text class="merchant-sub__feature-dot" aria-hidden="true" />
                <text class="text-caption text-secondary">{{line}}</text>
              </view>
            </view>
          </view>
        </view>

        <block wx:if="{{selectionAction}}">
          <view wx:if="{{showPayConsent}}" class="merchant-sub__consent">
            <ui-checkbox-row checked="{{payConsent}}" bind:toggle="onTogglePayConsent">
              <text class="text-caption">{{payConsentText}}</text>
            </ui-checkbox-row>
            <text class="text-caption text-tertiary merchant-sub__consent-link" bindtap="onOpenSubscriptionAgreement">查看《套餐与公域收录服务协议》</text>
          </view>
          <view class="merchant-sub__action">
            <ui-button
              type="{{selectionAction.type === 'schedule' ? 'secondary' : 'primary'}}"
              size="sm"
              loading="{{paying}}"
              disabled="{{paying}}"
              bind:btntap="onConfirmSelection"
            >{{selectionAction.label}}</ui-button>
          </view>
        </block>
      </view>
    </view>
  </block>
</ui-tool-page-shell>
