<ui-tool-page-shell showBand="{{false}}" showCompliance="{{false}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="merchant-sub__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="merchant-sub__gate">
      <ui-empty
        theme="album"
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="merchant-sub page-content">
      <view class="merchant-sub__hero surface-album-panel">
        <text class="text-album-frame-page">当前方案</text>
        <text class="text-h2 merchant-sub__tier-name">{{subscription.tierLabel}}</text>
        <text class="text-caption text-secondary">
          {{subscription.publicIndex ? '公域收录已开通' : '仅私域 / 微信内流通'}}
        </text>
        <text wx:if="{{subscription.expiresAtDisplay}}" class="text-caption text-tertiary">
          有效期至 {{subscription.expiresAtDisplay}}
        </text>
        <text wx:elif="{{subscription.remainingCreditCents > 0}}" class="text-caption text-tertiary">
          剩余权益约 ¥{{subscription.remainingCreditYuan}}（按天折算）
        </text>
        <text wx:if="{{subscription.pendingPlanLabel}}" class="text-caption text-warning">
          已预约：{{subscription.pendingEffectiveAtDisplay}} 后切换为 {{subscription.pendingPlanLabel}}
        </text>
        <text wx:if="{{paymentTestMode}}" class="text-caption merchant-sub__test-hint">
          当前为支付联调：实付按测试价扣款，套餐权益不变
        </text>
      </view>

      <view class="merchant-sub__section-head">
        <text class="text-h3">选择方案</text>
        <text class="text-caption text-tertiary">点击对比后，在底部确认切换</text>
      </view>

      <view class="merchant-sub__plans">
        <view
          wx:for="{{plans}}"
          wx:key="plan"
          class="merchant-sub__plan surface-album-panel {{item.isSelected ? 'merchant-sub__plan--selected' : ''}} {{item.isCurrentPlan ? 'merchant-sub__plan--current' : ''}}"
          data-plan="{{item.plan}}"
          bindtap="onSelectPlan"
        >
          <view class="merchant-sub__plan-head">
            <view class="merchant-sub__plan-title-wrap">
              <text class="text-h3 merchant-sub__plan-name">{{item.tierLabel}}</text>
              <text wx:if="{{item.isCurrentPlan}}" class="merchant-sub__badge text-caption">当前</text>
              <text wx:elif="{{item.isPendingPlan}}" class="merchant-sub__badge merchant-sub__badge--pending text-caption">已预约</text>
            </view>
            <view class="merchant-sub__plan-radio {{item.isSelected ? 'merchant-sub__plan-radio--on' : ''}}" aria-hidden="true" />
          </view>
          <text class="text-body merchant-sub__price">{{item.priceLabel}}</text>
          <view class="merchant-sub__highlights">
            <text
              wx:for="{{item.highlights}}"
              wx:for-item="line"
              wx:key="*this"
              class="text-caption text-secondary merchant-sub__line"
            >· {{line}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{selectedQuoteSummary && !isCurrentSelection}}" class="merchant-sub__quote-panel surface-album-panel">
        <view wx:if="{{showFeeBreakdown}}" class="merchant-sub__fee-breakdown">
          <view wx:if="{{selectedRefundYuan && selectedRefundYuan !== '0.00'}}" class="merchant-sub__fee-row">
            <text class="text-caption text-secondary">原方案退回</text>
            <text class="text-body">¥{{selectedRefundYuan}}</text>
          </view>
          <view class="merchant-sub__fee-row">
            <text class="text-caption text-secondary">新方案支付</text>
            <text class="text-body merchant-sub__fee-pay">¥{{selectedPayYuan}}</text>
          </view>
        </view>
        <text class="text-caption text-tertiary">{{selectedQuoteSummary}}</text>
      </view>

      <ui-compliance-notice type="history" text="{{disclaimer}}" />
    </view>

    <ui-fixed-bottom-bar safeArea="{{true}}">
      <view class="merchant-sub__footer">
        <view class="merchant-sub__footer-price">
          <text class="text-caption text-tertiary">已选</text>
          <text class="text-body merchant-sub__footer-price-value">{{selectedPriceLabel}}</text>
        </view>
        <ui-button
          type="primary"
          block
          loading="{{paying}}"
          disabled="{{actionDisabled}}"
          bind:btntap="onConfirmSwitch"
        >{{actionLabel}}</ui-button>
      </view>
    </ui-fixed-bottom-bar>
  </block>
</ui-tool-page-shell>
