.merchant-sub__pad {
  padding: var(--space-md) var(--page-padding-x);
}

.merchant-sub__gate {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: var(--space-xl) var(--page-padding-x);
  box-sizing: border-box;
}

.merchant-sub {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-sm);
  padding-bottom: var(--space-md);
  background-color: var(--color-bg-album);
}

.merchant-sub__folio {
  margin: 0 calc(-1 * var(--page-padding-x));
  padding: var(--space-lg) var(--page-padding-x);
}

.merchant-sub__folio-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-sub__folio-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-sub__folio-hint {
  display: block;
  margin-top: var(--space-xs);
}

.merchant-sub__main {
  display: flex;
  flex-direction: column;
}

.merchant-sub__status {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-sub__status-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
}

.merchant-sub__status-label {
  flex: 0 0 128rpx;
}

.merchant-sub__status-value {
  flex: 1;
  min-width: 0;
  color: var(--color-text-primary);
  line-height: var(--font-body-lh);
}

.merchant-sub__renewal {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background-color: var(--color-bg-muted);
}

.merchant-sub__renewal--warning {
  background-color: var(--color-bg-muted);
}

.merchant-sub__renewal--urgent .merchant-sub__renewal-text {
  color: var(--color-warning);
}

.merchant-sub__renewal-text {
  color: var(--color-text-primary);
  line-height: var(--font-body-lh);
}

.merchant-sub__hint {
  display: block;
  line-height: var(--font-body-lh);
}

.merchant-sub__action {
  display: flex;
  justify-content: center;
  padding-top: var(--space-xs);
}

.merchant-sub__section-head {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.merchant-sub__section-title {
  color: var(--color-text-primary);
}

.merchant-sub__benefits {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-sub__benefit {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
}

.merchant-sub__benefit-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-frame-corner);
}

.merchant-sub__plan-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-sub__plan {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  transition: border-color 0.15s ease;
}

.merchant-sub__plan--current {
  background-color: var(--color-bg-muted);
}

.merchant-sub__plan--next {
  border-color: var(--color-warning);
}

.merchant-sub__plan--selectable:active {
  opacity: 0.85;
}

.merchant-sub__plan--selected {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-card-soft);
}

.merchant-sub__plan-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-sub__plan-title {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  flex: 1;
  min-width: 0;
}

.merchant-sub__plan-name {
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.merchant-sub__plan-tags {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.merchant-sub__price-row {
  display: flex;
  align-items: baseline;
  gap: var(--space-xs);
  flex-wrap: wrap;
}

.merchant-sub__price-list {
  text-decoration: line-through;
}

.merchant-sub__features {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-sub__feature {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
}

.merchant-sub__feature-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-frame-corner);
}
