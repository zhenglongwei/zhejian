.merchant-sub__consent {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.merchant-sub__consent--spaced {
  margin-top: var(--space-md);
  margin-bottom: 0;
}

.merchant-sub__pad {
  padding: var(--space-md) var(--page-padding-x);
}

.merchant-sub__gate {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: var(--space-xl) var(--page-padding-x);
  box-sizing: border-box;
}

.merchant-sub {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-sm);
  padding-bottom: var(--space-md);
  background-color: var(--color-bg-album);
}

.merchant-sub__folio {
  margin: 0 calc(-1 * var(--page-padding-x));
  padding: var(--space-lg) var(--page-padding-x);
}

.merchant-sub__folio-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-sub__folio-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-sub__folio-title {
  color: var(--color-text-primary);
}

.merchant-sub__main {
  display: flex;
  flex-direction: column;
}

.merchant-sub__status {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-sub__status-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
}

.merchant-sub__status-label {
  flex: 0 0 128rpx;
}

.merchant-sub__status-value {
  flex: 1;
  min-width: 0;
  color: var(--color-text-primary);
  line-height: var(--font-body-lh);
}

.merchant-sub__renewal {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background-color: var(--color-bg-muted);
}

.merchant-sub__renewal--urgent .merchant-sub__renewal-text {
  color: var(--color-warning);
}

.merchant-sub__renewal-text {
  color: var(--color-text-primary);
  line-height: var(--font-body-lh);
}

.merchant-sub__hint {
  display: block;
  line-height: var(--font-body-lh);
}

.merchant-sub__action {
  display: flex;
  justify-content: center;
  padding-top: var(--space-xs);
}

.merchant-sub__action--block {
  margin-top: var(--space-md);
}

.merchant-sub__summary {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-sub__summary-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.merchant-sub__price {
  color: var(--color-text-primary);
}

.merchant-sub__table {
  display: flex;
  flex-direction: column;
}

.merchant-sub__tr {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.merchant-sub__tr--head {
  padding-top: 0;
}

.merchant-sub__tr:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.merchant-sub__th,
.merchant-sub__td {
  flex: 1.4;
  color: var(--color-text-secondary);
  line-height: var(--font-body-lh);
}

.merchant-sub__th--value,
.merchant-sub__td--value {
  flex: 1;
  text-align: right;
  color: var(--color-text-primary);
}

.merchant-sub__th {
  color: var(--color-text-tertiary);
}
