.merchant-sub__pad {
  padding: var(--space-md) var(--page-padding-x);
}

.merchant-sub__gate {
  padding: var(--space-xl) var(--page-padding-x);
}

.merchant-sub {
  padding: var(--space-md) var(--page-padding-x) var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.merchant-sub__hero {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-sub__tier-name {
  color: var(--color-text-primary);
}

.merchant-sub__plans {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.merchant-sub__plan {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-sub__plan--current {
  border-color: var(--color-album-frame-corner);
}

.merchant-sub__plan-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-sub__plan-name {
  flex: 1;
  min-width: 0;
  color: var(--color-text-primary);
}

.merchant-sub__price {
  flex-shrink: 0;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.merchant-sub__highlights {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-xs);
}

.merchant-sub__line {
  display: block;
}

.merchant-sub__quote {
  display: block;
}

.merchant-sub__test-hint {
  color: var(--color-warning);
}
