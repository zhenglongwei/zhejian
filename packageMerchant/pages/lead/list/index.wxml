<view class="page merchant-lead-list">
  <ui-list-page-shell
    tabs="{{tabs}}"
    activeKey="{{activeTab}}"
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    emptyTitle="{{emptyTitle}}"
    emptyDescription="{{emptyDescription}}"
    bind:tabchange="onTabChange"
    bind:retry="onRetry"
  >
    <block wx:if="{{status === 'normal'}}">
      <ui-lead-card
        wx:for="{{list}}"
        wx:key="id"
        item="{{item}}"
        audience="merchant"
        bind:tap="onCardTap"
        bind:action="onCardAction"
      />
    </block>
  </ui-list-page-shell>
</view>
