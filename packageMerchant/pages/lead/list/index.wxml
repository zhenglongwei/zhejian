<view class="page merchant-lead-list bg-album">
  <view class="page-content merchant-lead-list__tabs">
    <ui-tabs tabs="{{tabs}}" activeKey="{{activeTab}}" bind:change="onTabChange" />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content merchant-lead-list__body">
      <ui-skeleton wx:for="{{skeletonItems}}" wx:key="*this" rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content merchant-lead-list__state">
      <ui-empty
        theme="album"
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content merchant-lead-list__state">
      <ui-empty
        theme="album"
        title="{{emptyTitle}}"
        description="{{emptyDescription}}"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-lead-list__body">
      <ui-lead-card
        wx:for="{{list}}"
        wx:key="id"
        item="{{item}}"
        audience="merchant"
        bind:tap="onCardTap"
        bind:action="onCardAction"
      />
    </view>
  </block>
</view>
