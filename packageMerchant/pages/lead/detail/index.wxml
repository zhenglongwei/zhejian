<view class="page record-detail-page">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content record-detail__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content">
      <ui-lead-detail-body
        title="{{lead.displayServiceName || lead.serviceName || '门店留言'}}"
        status="{{lead.status}}"
        statusLabel="{{lead.statusLabel}}"
        detailRows="{{detailRows}}"
        description="{{lead.description}}"
        images="{{lead.images}}"
        imageComplianceType="consultImageMerchant"
        footerComplianceType="consultMerchant"
      />
    </view>

    <ui-fixed-bottom-bar
      leftActions="{{leftActions}}"
      bind:leftaction="onLeftAction"
    >
      <ui-button
        wx:if="{{showPrimaryAction}}"
        type="primary"
        disabled="{{acting}}"
        bind:tap="onPrimaryAction"
      >{{primaryActionText}}</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-bottom-sheet
    visible="{{showClosePanel}}"
    title="填写关闭说明"
    hint="选择「其他」时须说明原因"
    showTextarea="{{true}}"
    textareaValue="{{closeNote}}"
    textareaPlaceholder="请简要说明关闭原因"
    confirmText="确认关闭"
    cancelText="取消"
    confirmDisabled="{{acting}}"
    loading="{{acting}}"
    bind:close="onCancelClosePanel"
    bind:cancel="onCancelClosePanel"
    bind:confirm="onSubmitClosePanel"
    bind:input="onCloseNoteInput"
  />
</view>
