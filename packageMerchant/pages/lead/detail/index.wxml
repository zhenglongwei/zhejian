<view class="page record-detail-page">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content record-detail__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content">
      <ui-lead-detail-body
        title="{{lead.displayServiceName || lead.serviceName || '门店留言'}}"
        status="{{lead.status}}"
        statusLabel="{{lead.statusLabel}}"
        detailRows="{{detailRows}}"
        description="{{lead.description}}"
        images="{{lead.images}}"
        imageComplianceType="consultImageMerchant"
        footerComplianceType="consultMerchant"
      />

      <view wx:if="{{canEditContactNote}}" class="lead-detail__note card">
        <text class="lead-detail__note-title text-h3">联系备注</text>
        <text class="text-caption lead-detail__note-hint">仅商家可见，便于记录沟通情况</text>
        <textarea
          class="lead-detail__note-input"
          value="{{contactNoteDraft}}"
          placeholder="选填，如：已电话沟通，约定周三到店"
          maxlength="200"
          bindinput="onContactNoteInput"
        />
        <ui-button type="secondary" size="sm" disabled="{{acting}}" bind:btntap="onSaveContactNote">保存备注</ui-button>
      </view>
    </view>

    <ui-fixed-bottom-bar
      leftActions="{{leftActions}}"
      bind:leftaction="onLeftAction"
    >
      <ui-button
        wx:if="{{showPrimaryAction}}"
        type="primary"
        disabled="{{acting}}"
        bind:btntap="onPrimaryAction"
      >{{primaryActionText}}</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-bottom-sheet
    visible="{{showContactPanel}}"
    title="标记已联系"
    hint="可选填联系备注，便于后续跟进"
    showTextarea="{{true}}"
    textareaValue="{{contactNoteDraft}}"
    textareaPlaceholder="如：已电话沟通，约定周三到店"
    confirmText="确认已联系"
    cancelText="取消"
    confirmDisabled="{{acting}}"
    loading="{{acting}}"
    bind:close="onCancelContactPanel"
    bind:cancel="onCancelContactPanel"
    bind:confirm="onSubmitContactPanel"
    bind:input="onContactNoteInput"
  />

  <ui-bottom-sheet
    visible="{{showClosePanel}}"
    title="填写关闭说明"
    hint="选择「其他」时须说明原因"
    showTextarea="{{true}}"
    textareaValue="{{closeNote}}"
    textareaPlaceholder="请简要说明关闭原因"
    confirmText="确认关闭"
    cancelText="取消"
    confirmDisabled="{{acting}}"
    loading="{{acting}}"
    bind:close="onCancelClosePanel"
    bind:cancel="onCancelClosePanel"
    bind:confirm="onSubmitClosePanel"
    bind:input="onCloseNoteInput"
  />
</view>
