@import '../../../styles/merchant-form.wxss';

.merchant-onboard {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  min-height: 100vh;
  padding-top: var(--space-sm);
  padding-bottom: var(--page-fixed-clearance);
  box-sizing: border-box;
}

.merchant-onboard__top {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-onboard__folio {
  margin: 0 calc(-1 * var(--page-padding-x));
  padding: var(--space-xl) var(--page-padding-x) var(--space-lg);
}

.merchant-onboard__folio-inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-onboard__title {
  color: var(--color-text-primary);
}

.merchant-onboard__sub {
  line-height: var(--font-body-lh);
}

.merchant-onboard__panel {
  display: flex;
  flex-direction: column;
}

.merchant-onboard__section-head {
  margin-bottom: var(--space-sm);
}

.merchant-onboard__panel-title {
  color: var(--color-text-primary);
}

.merchant-onboard__benefits {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.merchant-onboard__benefit {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
}

.merchant-onboard__benefit-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-frame-corner);
}

.merchant-onboard__benefit-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  flex: 1;
  min-width: 0;
}

.merchant-onboard__benefit-title {
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.merchant-onboard__benefit-desc {
  line-height: 1.5;
}

.merchant-onboard__notices {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-onboard__actions {
  margin-top: var(--space-md);
}

.merchant-onboard__reject {
  color: var(--color-warning);
}

.merchant-onboard__form {
  padding-top: 0;
}

.merchant-onboard__optional-hint {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-onboard__chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.merchant-onboard__chip {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-full);
  font-size: var(--font-caption);
  background-color: var(--color-bg-muted);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

.merchant-onboard__chip--on {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.merchant-onboard__chip:active {
  opacity: 0.72;
}

.merchant-onboard__custom-line {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-onboard__custom-label {
  flex-shrink: 0;
  color: var(--color-text-secondary);
}

.merchant-onboard__custom-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background-color: transparent;
  border: none;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
}

.merchant-onboard__agree {
  margin-top: var(--space-md);
}

.merchant-onboard__agree-link {
  color: var(--color-primary);
}

.merchant-onboard__section-title {
  display: block;
  margin-top: var(--space-xl);
  margin-bottom: var(--space-sm);
  color: var(--color-text-primary);
}

.merchant-onboard__address-picker {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  color: var(--color-text-primary);
}

.merchant-onboard__address-picker--empty {
  color: var(--color-text-tertiary);
}

.merchant-onboard__address-picker--active {
  opacity: 0.72;
}

.merchant-onboard__address-text {
  flex: 1;
  line-height: 1.5;
  word-break: break-all;
}

.merchant-onboard__photo-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--color-border);
  background-color: var(--color-bg-muted);
  overflow: hidden;
}

.merchant-onboard__license-first {
  margin-bottom: var(--space-md);
}

.merchant-onboard__photo-slot--license {
  width: 100%;
  height: 320rpx;
  margin-top: var(--space-sm);
}

.merchant-onboard__photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  padding: var(--space-md);
  text-align: center;
}

.merchant-onboard__photo-placeholder-title {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.merchant-onboard__ocr-hint {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.merchant-onboard__photo-slot--add {
  border-style: dashed;
}

.merchant-onboard__photo {
  width: 100%;
  height: 100%;
}

.merchant-onboard__photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.merchant-onboard__photo-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.merchant-onboard__photo-del {
  position: absolute;
  top: 4rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: var(--radius-full);
  background-color: rgba(0, 0, 0, 0.45);
  color: var(--color-text-inverse);
  font-size: 28rpx;
}
