@import '../../../styles/merchant-form.wxss';

.merchant-onboard__hero {
  padding: var(--space-lg) 0 var(--space-md);
}

.merchant-onboard__sub {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
}

.merchant-onboard__form {
  margin-top: var(--space-md);
}

.merchant-onboard__chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.merchant-onboard__chip {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-full);
  font-size: var(--font-caption);
  background-color: var(--color-bg-muted);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

.merchant-onboard__chip--on {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.merchant-onboard__chip:active {
  opacity: 0.72;
}

.merchant-onboard__custom-line {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-onboard__custom-label {
  flex-shrink: 0;
  color: var(--color-text-secondary);
}

.merchant-onboard__custom-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background-color: transparent;
  border: none;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
}

.merchant-onboard__agree {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-onboard__actions {
  margin-top: var(--space-xl);
}

.merchant-onboard__reject {
  margin-top: var(--space-md);
  color: var(--color-warning);
}
