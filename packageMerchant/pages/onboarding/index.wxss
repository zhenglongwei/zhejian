@import '../../../styles/merchant-form.wxss';
@import '../../../styles/merchant-hours.wxss';

.merchant-onboard__hero {
  padding: var(--space-lg) 0 var(--space-md);
}

.merchant-onboard__sub {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
}

.merchant-onboard__values {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.merchant-onboard__value-item {
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background-color: var(--color-bg-muted);
}

.merchant-onboard__value-title {
  display: block;
  margin-bottom: var(--space-xs);
}

.merchant-onboard__value-desc {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.merchant-onboard__optional-hint {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-onboard__form {
  margin-top: var(--space-md);
}

.merchant-onboard__chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.merchant-onboard__chip {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-full);
  font-size: var(--font-caption);
  background-color: var(--color-bg-muted);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
}

.merchant-onboard__chip--on {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.merchant-onboard__chip:active {
  opacity: 0.72;
}

.merchant-onboard__custom-line {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-onboard__custom-label {
  flex-shrink: 0;
  color: var(--color-text-secondary);
}

.merchant-onboard__custom-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  background-color: transparent;
  border: none;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
}

.merchant-onboard__agree {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.merchant-onboard__actions {
  margin-top: var(--space-xl);
}

.merchant-onboard__reject {
  margin-top: var(--space-md);
  color: var(--color-warning);
}

.merchant-onboard__section-title {
  display: block;
  margin-top: var(--space-xl);
  margin-bottom: var(--space-sm);
}

.merchant-onboard__loc-btn {
  margin-top: var(--space-sm);
}

.merchant-onboard__loc-hint {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.merchant-onboard__photo-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--color-border);
  background-color: var(--color-bg-muted);
  overflow: hidden;
}

.merchant-onboard__photo-slot--add {
  border-style: dashed;
}

.merchant-onboard__photo {
  width: 100%;
  height: 100%;
}

.merchant-onboard__photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.merchant-onboard__photo-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.merchant-onboard__photo-del {
  position: absolute;
  top: 4rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: var(--radius-full);
  background-color: rgba(0, 0, 0, 0.45);
  color: var(--color-text-inverse);
  font-size: 28rpx;
}
