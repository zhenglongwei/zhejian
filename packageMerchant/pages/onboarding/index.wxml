<view class="merchant-onboard bg-album" wx:if="{{status === 'pending'}}">
  <view class="page-content merchant-onboard__top">
    <view class="merchant-onboard__folio surface-album-folio">
      <view class="merchant-onboard__folio-inner">
        <text class="merchant-onboard__title text-h2">入驻审核中</text>
        <text class="merchant-onboard__sub text-caption text-secondary">我们将在 1–3 个工作日内完成审核，通过后将引导你了解套餐并开通工作台。</text>
      </view>
    </view>
    <view class="merchant-onboard__panel surface-album-panel">
      <ui-compliance-notice type="history" text="审核期间可返回本页刷新状态；通过后须刷新登录态以使用商家功能。" />
      <view class="merchant-onboard__actions">
        <ui-button type="primary" loading="{{submitting}}" bind:btntap="onRefreshAudit">刷新审核状态</ui-button>
      </view>
    </view>
  </view>
</view>

<view class="merchant-onboard bg-album" wx:elif="{{status === 'normal' || status === 'rejected' || status === 'need_modify'}}">
  <view class="page-content merchant-onboard__top">
    <view class="merchant-onboard__folio surface-album-folio">
      <view class="merchant-onboard__folio-inner">
        <text class="merchant-onboard__title text-h2">{{heroCopy.title}}</text>
        <text class="merchant-onboard__sub text-caption text-secondary">{{heroCopy.subtitle}}</text>
      </view>
    </view>

    <view class="merchant-onboard__panel surface-album-panel">
      <ui-compliance-notice type="history" text="入驻资料仅用于资质审核与门店展示，请确保信息真实有效。审核通过后将引导你了解套餐与工具权益。" />
    </view>

    <view wx:if="{{status === 'rejected'}}" class="merchant-onboard__reject surface-album-panel">
      <text class="text-caption">上次审核未通过{{profile.rejectReason ? '：' + profile.rejectReason : ''}}，请修改后重新提交。</text>
    </view>
    <view wx:if="{{status === 'need_modify'}}" class="merchant-onboard__reject surface-album-panel">
      <text class="text-caption">请按审核意见修改{{profile.rejectReason ? '：' + profile.rejectReason : ''}}，修改后重新提交。</text>
    </view>
  </view>

  <view class="page-content merchant-form-page merchant-onboard__form">
    <view class="merchant-form__section merchant-onboard__license-first">
      <text class="merchant-form__label">营业执照照片 *</text>
      <text class="text-caption merchant-onboard__optional-hint">请先上传营业执照，系统将自动识别主体名称与统一社会信用代码，识别结果可手动修改。</text>
      <view class="merchant-onboard__photo-slot merchant-onboard__photo-slot--license" bindtap="onPickLicense">
        <image wx:if="{{form.licensePhotoUrl}}" class="merchant-onboard__photo" src="{{form.licensePhotoUrl}}" mode="aspectFill" />
        <view wx:else class="merchant-onboard__photo-placeholder">
          <text class="merchant-onboard__photo-placeholder-title text-body">上传营业执照</text>
          <text class="text-caption text-secondary">拍照或从相册选择</text>
        </view>
      </view>
      <text wx:if="{{licenseOcrHint}}" class="text-caption merchant-onboard__ocr-hint">{{licenseOcrHint}}</text>
    </view>

    <text class="merchant-onboard__section-title text-h3">商家主体</text>
    <view class="merchant-form__section">
      <text class="merchant-form__label">主体名称（与执照一致） *</text>
      <input class="merchant-form__input" placeholder="上传执照后自动识别，也可手动填写" value="{{form.legalName}}" data-field="legalName" bindinput="onInput" />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">统一社会信用代码 *</text>
      <input class="merchant-form__input" placeholder="18 位信用代码" value="{{form.creditCode}}" data-field="creditCode" bindinput="onInput" maxlength="18" />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">联系邮箱</text>
      <input class="merchant-form__input" placeholder="选填" value="{{form.contactEmail}}" data-field="contactEmail" bindinput="onInput" />
    </view>

    <text class="merchant-onboard__section-title text-h3">门店信息</text>
    <view class="merchant-form__section">
      <text class="merchant-form__label">门店名称 *</text>
      <input class="merchant-form__input" placeholder="用户端展示名称" value="{{form.storeName}}" data-field="storeName" bindinput="onInput" />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">负责人 *</text>
      <input class="merchant-form__input" placeholder="负责人姓名" value="{{form.contactName}}" data-field="contactName" bindinput="onInput" />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">负责人手机 *</text>
      <input class="merchant-form__input" type="number" placeholder="审核与通知联系" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">联系电话</text>
      <input class="merchant-form__input" type="number" value="{{form.storePhone}}" data-field="storePhone" bindinput="onInput" />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">门店地址 *</text>
      <text class="text-caption merchant-onboard__optional-hint">须在地图上选点，不可手填；审核通过后可在工作台修改</text>
      <view
        class="merchant-form__input merchant-onboard__address-picker {{form.address ? '' : 'merchant-onboard__address-picker--empty'}}"
        hover-class="merchant-onboard__address-picker--active"
        catchtap="onChooseLocation"
      >
        <text class="merchant-onboard__address-text">{{form.address || '点击选择门店地址'}}</text>
      </view>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">门店简介</text>
      <textarea class="merchant-form__textarea" placeholder="选填，用户端门店详情展示" value="{{form.intro}}" data-field="intro" bindinput="onInput" maxlength="500" />
    </view>

    <text class="merchant-onboard__section-title text-h3">门店照片</text>
    <text class="text-caption merchant-onboard__optional-hint">以下照片可审核通过后在工作台完善</text>
    <view class="merchant-form__section">
      <text class="merchant-form__label">门头照片</text>
      <view class="merchant-onboard__photo-slot" bindtap="onPickFacade">
        <image wx:if="{{form.facadePhotoUrl}}" class="merchant-onboard__photo" src="{{form.facadePhotoUrl}}" mode="aspectFill" />
        <text wx:else class="text-caption">点击上传</text>
      </view>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">工位照片</text>
      <view class="merchant-onboard__photo-grid">
        <view wx:for="{{form.workshopPhotoUrls}}" wx:key="*this" class="merchant-onboard__photo-wrap">
          <image class="merchant-onboard__photo" src="{{item}}" mode="aspectFill" />
          <text class="merchant-onboard__photo-del" data-index="{{index}}" catchtap="onRemoveWorkshop">×</text>
        </view>
        <view class="merchant-onboard__photo-slot merchant-onboard__photo-slot--add" bindtap="onPickWorkshop">
          <text class="text-caption">+</text>
        </view>
      </view>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">接待区照片</text>
      <view class="merchant-onboard__photo-slot" bindtap="onPickReception">
        <image wx:if="{{form.receptionPhotoUrl}}" class="merchant-onboard__photo" src="{{form.receptionPhotoUrl}}" mode="aspectFill" />
        <text wx:else class="text-caption">选填</text>
      </view>
    </view>

    <text class="merchant-onboard__section-title text-h3">维修资质</text>
    <view class="merchant-form__section">
      <text class="merchant-form__label">基础资质类型 *</text>
      <picker mode="selector" range="{{qualificationOptions}}" range-key="label" value="{{qualificationIndex}}" bindchange="onQualificationChange">
        <view class="merchant-form__picker">{{qualificationOptions[qualificationIndex].label}}</view>
      </picker>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">基础资质照片 *</text>
      <view class="merchant-onboard__photo-slot" bindtap="onPickQualification">
        <image wx:if="{{form.qualificationPhotoUrl}}" class="merchant-onboard__photo" src="{{form.qualificationPhotoUrl}}" mode="aspectFill" />
        <text wx:else class="text-caption">点击上传</text>
      </view>
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">资质编号</text>
      <input class="merchant-form__input" placeholder="选填" value="{{form.qualificationNo}}" data-field="qualificationNo" bindinput="onInput" />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">有效期至</text>
      <picker mode="date" value="{{form.qualificationValidUntil || today}}" bindchange="onValidUntilChange">
        <view class="merchant-form__picker {{form.qualificationValidUntil ? '' : 'merchant-form__picker--placeholder'}}">
          {{form.qualificationValidUntil || '请选择'}}
        </view>
      </picker>
    </view>
    <view class="merchant-form__switch-row">
      <text class="text-body">同时具备新能源专项资质</text>
      <switch checked="{{form.newEnergyEnabled}}" bindchange="onNewEnergyToggle" color="{{switchColor}}" />
    </view>
    <block wx:if="{{form.newEnergyEnabled}}">
      <view class="merchant-form__section">
        <text class="merchant-form__label">新能源资质照片 *</text>
        <view class="merchant-onboard__photo-slot" bindtap="onPickNewEnergy">
          <image wx:if="{{form.newEnergyPhotoUrl}}" class="merchant-onboard__photo" src="{{form.newEnergyPhotoUrl}}" mode="aspectFill" />
          <text wx:else class="text-caption">点击上传</text>
        </view>
      </view>
      <view class="merchant-form__section">
        <text class="merchant-form__label">新能源资质编号</text>
        <input class="merchant-form__input" placeholder="选填" value="{{form.newEnergyNo}}" data-field="newEnergyNo" bindinput="onInput" />
      </view>
      <view class="merchant-form__section">
        <text class="merchant-form__label">新能源有效期至</text>
        <picker mode="date" value="{{form.newEnergyValidUntil || today}}" bindchange="onNewEnergyValidUntilChange">
          <view class="merchant-form__picker {{form.newEnergyValidUntil ? '' : 'merchant-form__picker--placeholder'}}">
            {{form.newEnergyValidUntil || '请选择'}}
          </view>
        </picker>
      </view>
    </block>
    <view class="merchant-form__section">
      <text class="merchant-form__label">品牌授权证明</text>
      <view class="merchant-onboard__photo-slot" bindtap="onPickBrandAuth">
        <image wx:if="{{form.brandAuthPhotoUrl}}" class="merchant-onboard__photo" src="{{form.brandAuthPhotoUrl}}" mode="aspectFill" />
        <text wx:else class="text-caption">选填</text>
      </view>
    </view>

    <view class="merchant-onboard__agree">
      <ui-checkbox-row checked="{{agreed}}" bind:toggle="onToggleAgreement">
        <text>{{consentTextBefore}}<text class="merchant-onboard__agree-link" catchtap="onOpenMerchantAgreement">{{agreementLink}}</text>{{consentTextAfter}}</text>
      </ui-checkbox-row>
    </view>
  </view>

  <view class="merchant-form__spacer" />
  <ui-fixed-bottom-bar>
    <ui-button type="secondary" size="sm" slot="left" loading="{{submitting}}" bind:btntap="onSaveDraft">保存草稿</ui-button>
    <ui-button type="primary" slot="right" loading="{{submitting}}" bind:btntap="onSubmit">提交入驻</ui-button>
  </ui-fixed-bottom-bar>

  <privacy-authorize-popup id="privacyAuthorizePopup" />
</view>
