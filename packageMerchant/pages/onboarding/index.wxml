<view class="page merchant-onboard page-content merchant-form-page" wx:if="{{status === 'normal'}}">
  <view class="merchant-onboard__hero">
    <text class="text-h1">成为辙见服务商</text>
    <text class="text-body merchant-onboard__sub">把每一单维修变成可信案例，让专业被用户看见</text>
  </view>
  <ui-compliance-notice type="history" text="入驻资料仅用于平台审核与门店展示，MVP 阶段审核结果可先 mock 通过。" />
  <view class="merchant-onboard__form">
    <view class="merchant-form__section">
      <text class="merchant-form__label">门店名称 *</text>
      <input
        class="merchant-form__input"
        placeholder="请输入门店名称"
        value="{{form.storeName}}"
        data-field="storeName"
        bindinput="onInput"
      />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">联系人 *</text>
      <input
        class="merchant-form__input"
        placeholder="负责人姓名"
        value="{{form.contactName}}"
        data-field="contactName"
        bindinput="onInput"
      />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">手机号 *</text>
      <input
        class="merchant-form__input"
        type="number"
        placeholder="用于接单联系"
        value="{{form.phone}}"
        data-field="phone"
        bindinput="onInput"
      />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">门店地址 *</text>
      <input
        class="merchant-form__input"
        placeholder="详细地址"
        value="{{form.address}}"
        data-field="address"
        bindinput="onInput"
      />
    </view>
    <view class="merchant-form__section">
      <text class="merchant-form__label">擅长服务 *</text>
      <view class="merchant-onboard__chips">
        <view
          wx:for="{{serviceTags}}"
          wx:key="name"
          class="merchant-onboard__chip {{item.selected ? 'merchant-onboard__chip--on' : ''}}"
          data-name="{{item.name}}"
          bindtap="onToggleService"
        >{{item.name}}</view>
      </view>
      <view class="merchant-onboard__custom-line">
        <text class="merchant-onboard__custom-label text-body">自定义</text>
        <input
          class="merchant-onboard__custom-input"
          placeholder=""
          value="{{customServiceInput}}"
          maxlength="{{16}}"
          confirm-type="done"
          bindinput="onCustomServiceInput"
          bindblur="onCustomServiceCommit"
          bindconfirm="onCustomServiceCommit"
        />
      </view>
    </view>
    <label class="merchant-onboard__agree">
      <checkbox-group bindchange="onAgreeChange">
        <checkbox value="1" checked="{{agreed}}" />
      </checkbox-group>
      <text class="text-caption">我已阅读入驻要求</text>
    </label>
  </view>
  <view class="merchant-form__spacer" />
  <ui-fixed-bottom-bar>
    <ui-button type="secondary" size="sm" slot="left" loading="{{submitting}}" bind:tap="onSaveDraft">保存草稿</ui-button>
    <ui-button type="primary" slot="right" loading="{{submitting}}" bind:tap="onSubmit">提交入驻</ui-button>
  </ui-fixed-bottom-bar>
</view>
