<view class="page merchant-svc-list">
  <view class="page-content merchant-svc-list__tabs">
    <ui-tabs tabs="{{statusTabs}}" activeKey="{{tab}}" bind:change="onTabChange" />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content">
      <ui-skeleton wx:for="{{[1,2]}}" wx:key="*this" rows="{{3}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="暂无服务方案"
        description="创建服务方案并上架后，用户可在服务 Tab 浏览"
        actionText="新建服务"
        bind:action="onCreate"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-svc-list__items merchant-list__scroll-pad">
      <ui-service-card
        wx:for="{{list}}"
        wx:key="id"
        serviceId="{{item.id}}"
        name="{{item.name}}"
        categoryName="{{item.categoryName}}"
        summary="{{item.summary}}"
        priceMode="{{item.priceMode}}"
        amount="{{item.amount}}"
        minAmount="{{item.minAmount}}"
        maxAmount="{{item.maxAmount}}"
        statusLabel="{{item.statusLabel}}"
        statusVariant="{{item.statusVariant}}"
        showStoreName="{{false}}"
        bind:tap="onServiceTap"
      />
    </view>
  </block>

  <view class="merchant-list-fab page-content">
    <ui-button type="primary" bind:tap="onCreate">新建服务方案</ui-button>
  </view>
</view>
