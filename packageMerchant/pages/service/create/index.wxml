<view class="page service-create page-content merchant-form-page">
  <block wx:if="{{!itemsReady}}">
    <view class="merchant-form__section">
      <text class="text-caption">正在加载…</text>
    </view>
  </block>

  <block wx:else>
  <view class="merchant-form__section">
    <text class="merchant-form__label">服务名称 *</text>
    <input
      class="merchant-form__input"
      placeholder="如：小保养、贴膜、精洗"
      value="{{form.name}}"
      maxlength="32"
      bindfocus="onNameFocus"
      bindblur="onNameBlur"
      bindinput="onNameInput"
    />
    <view wx:if="{{showNameSuggestions}}" class="merchant-form__suggest">
      <text class="merchant-form__hint-inline text-caption">
        {{nameQuery ? '匹配到的服务，点选快速填充' : '常见服务，点选快速填充'}}
      </text>
      <view wx:if="{{matchedTags.length}}" class="merchant-form__chips">
        <view
          wx:for="{{matchedTags}}"
          wx:key="name"
          class="merchant-form__chip {{item.selected ? 'merchant-form__chip--on' : ''}}"
          data-name="{{item.name}}"
          catchtap="onSelectQuickTag"
        >{{item.name}}</view>
      </view>
      <text
        wx:elif="{{nameQuery}}"
        class="merchant-form__suggest-empty text-caption"
      >未找到匹配项，可直接使用「{{nameQuery}}」作为服务名称</text>
    </view>
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">价格模式</text>
    <picker
      mode="selector"
      range="{{priceModes}}"
      range-key="label"
      value="{{priceModeIndex}}"
      bindchange="onPriceModeChange"
    >
      <view class="merchant-form__picker">{{priceModes[priceModeIndex].label}}</view>
    </picker>
    <view wx:if="{{pricePreview.mode === 'accident'}}" class="merchant-form__notice">
      <ui-compliance-notice type="accident" />
    </view>
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">服务封面</text>
    <text class="merchant-form__hint text-caption">选填，用于服务卡与 H5 详情展示</text>
    <view class="svc-create__cover-wrap">
      <view wx:if="{{form.coverUrl}}" class="svc-create__cover-slot">
        <image class="svc-create__cover-img" src="{{form.coverUrl}}" mode="aspectFill" />
        <text class="svc-create__cover-del" catchtap="onRemoveCover">×</text>
      </view>
      <view wx:else class="svc-create__cover-slot svc-create__cover-slot--add" bindtap="onPickCover">
        <text class="text-caption">点击上传</text>
      </view>
    </view>
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">服务简介</text>
    <textarea
      class="merchant-form__textarea"
      placeholder="简要说明适用场景与服务内容"
      value="{{form.summary}}"
      data-field="summary"
      bindinput="onInput"
    />
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">服务详情</text>
    <textarea
      class="merchant-form__textarea"
      placeholder="用户端详情页展示的详细说明"
      value="{{form.detail}}"
      data-field="detail"
      bindinput="onInput"
    />
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">服务包含</text>
    <text class="merchant-form__hint text-caption">选填，每行一项；留空时用户端展示平台默认说明</text>
    <textarea
      class="merchant-form__textarea"
      placeholder="如：指定机油、机滤&#10;标准工时&#10;基础检测"
      value="{{form.includedItemsText}}"
      data-field="includedItemsText"
      bindinput="onInput"
    />
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">服务不包含</text>
    <text class="merchant-form__hint text-caption">选填，每行一项</text>
    <textarea
      class="merchant-form__textarea"
      placeholder="如：额外维修项目&#10;非套餐配件&#10;特殊车型差价"
      value="{{form.excludedItemsText}}"
      data-field="excludedItemsText"
      bindinput="onInput"
    />
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">适用车型</text>
    <text class="merchant-form__hint text-caption">选填，每行一项；如品牌、车系或年款限制</text>
    <textarea
      class="merchant-form__textarea"
      placeholder="如：大众、奥迪部分车型&#10;不含进口行政加长版"
      value="{{form.applicableVehiclesText}}"
      data-field="applicableVehiclesText"
      bindinput="onInput"
    />
  </view>

  <view wx:if="{{showPriceFields && priceModes[priceModeIndex].value === 'range'}}" class="merchant-form__section">
    <text class="merchant-form__label">价格影响因素</text>
    <textarea
      class="merchant-form__textarea"
      placeholder="每行一项，如：车型与年款"
      value="{{form.priceFactorsText}}"
      data-field="priceFactorsText"
      bindinput="onInput"
    />
  </view>

  <view class="merchant-form__section">
    <text class="merchant-form__label">咨询与预约</text>
    <view class="merchant-form__switch-row">
      <text class="text-body">接受线上咨询/预约</text>
      <switch checked="{{form.acceptConsult}}" bindchange="onAcceptConsultChange" color="{{switchColor}}" />
    </view>
    <block wx:if="{{form.acceptConsult}}">
      <text class="merchant-form__hint-inline text-caption">用户提交后由门店电话联系，非平台订单</text>
      <text class="merchant-form__label merchant-form__label--sub">可预约时段</text>
      <textarea
        class="merchant-form__textarea"
        placeholder="如：周一至周六 9:00–18:00；周日休息"
        value="{{form.slotNote}}"
        data-field="slotNote"
        bindinput="onInput"
        maxlength="200"
      />
      <view class="merchant-form__switch-row">
        <text class="text-body">需提前预约</text>
        <switch checked="{{form.advanceRequired}}" bindchange="onAdvanceRequiredChange" color="{{switchColor}}" />
      </view>
      <textarea
        wx:if="{{form.advanceRequired}}"
        class="merchant-form__textarea"
        placeholder="如：请至少提前 1 天预约"
        value="{{form.advanceNote}}"
        data-field="advanceNote"
        bindinput="onInput"
        maxlength="120"
      />
      <text class="merchant-form__label merchant-form__label--sub">节假日说明</text>
      <textarea
        class="merchant-form__textarea"
        placeholder="如：法定节假日营业时间以门店通知为准"
        value="{{form.holidayNote}}"
        data-field="holidayNote"
        bindinput="onInput"
        maxlength="120"
      />
      <text class="merchant-form__label merchant-form__label--sub">咨询说明</text>
      <textarea
        class="merchant-form__textarea"
        placeholder="提交咨询时希望用户了解的事项，如：请备注车型与故障现象"
        value="{{form.consultGuide}}"
        data-field="consultGuide"
        bindinput="onInput"
        maxlength="300"
      />
    </block>
  </view>

  <view wx:if="{{showPriceFields}}" class="merchant-form__section">
    <text class="merchant-form__label">
      {{priceModes[priceModeIndex].value === 'fixed' ? '一口价（元）' : '参考价格区间（元）'}}
    </text>
    <block wx:if="{{priceModes[priceModeIndex].value === 'fixed'}}">
      <input
        class="merchant-form__input"
        type="number"
        placeholder="售价（元）"
        value="{{form.amount}}"
        data-field="amount"
        bindinput="onInput"
      />
    </block>
    <block wx:else>
      <view class="merchant-form__row">
        <input
          class="merchant-form__input merchant-form__input--half"
          type="number"
          placeholder="下限（元）"
          value="{{form.minAmount}}"
          data-field="minAmount"
          bindinput="onInput"
        />
        <text>—</text>
        <input
          class="merchant-form__input merchant-form__input--half"
          type="number"
          placeholder="上限（元）"
          value="{{form.maxAmount}}"
          data-field="maxAmount"
          bindinput="onInput"
        />
      </view>
    </block>
    <view class="merchant-form__price-preview">
      <ui-price-display
        mode="{{pricePreview.mode}}"
        amount="{{pricePreview.amount}}"
        minAmount="{{pricePreview.minAmount}}"
        maxAmount="{{pricePreview.maxAmount}}"
        showDisclaimer="{{true}}"
        showSuffix="{{pricePreview.mode !== 'fixed'}}"
      />
    </view>
    <ui-compliance-notice wx:if="{{pricePreview.mode === 'range'}}" type="price" />
  </view>

  <view class="merchant-form__spacer" />
  </block>

  <ui-fixed-bottom-bar>
    <ui-button
      type="secondary"
      size="sm"
      slot="left"
      loading="{{submitting}}"
      disabled="{{!itemsReady}}"
      bind:tap="onSaveDraft"
    >存草稿</ui-button>
    <ui-button
      type="primary"
      slot="right"
      loading="{{submitting}}"
      disabled="{{!itemsReady}}"
      bind:tap="onSubmit"
    >保存并上架</ui-button>
  </ui-fixed-bottom-bar>
</view>
