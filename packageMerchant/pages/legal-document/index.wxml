<view class="page legal-doc page-content">
  <text class="legal-doc__updated text-caption">版本 {{version}} · 更新日期：{{updatedAt}}</text>
  <view wx:for="{{sections}}" wx:key="heading" class="legal-doc__section">
    <text class="legal-doc__heading text-h3">{{item.heading}}</text>
    <text class="legal-doc__body text-body">{{item.body}}</text>
  </view>
</view>
