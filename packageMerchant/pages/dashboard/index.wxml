<ui-tool-page-shell
  wx:if="{{status !== 'loading'}}"
  show-band="{{false}}"
  compliance-text="{{complianceText}}"
  show-compliance="{{status === 'normal' || status === 'empty'}}"
>
  <view class="merchant-dash__cockpit">
    <view class="merchant-dash__topbar bg-band">
      <view class="merchant-dash__topbar-row">
        <view class="merchant-dash__topbar-main">
          <text class="merchant-dash__topbar-title text-body">数据概览</text>
          <text wx:if="{{storeName}}" class="merchant-dash__topbar-sub text-body">· {{storeName}}</text>
        </view>
      </view>
      <text wx:if="{{lagHint}}" class="merchant-dash__topbar-hint text-caption">{{lagHint}}</text>
    </view>

    <block wx:if="{{status === 'error'}}">
      <view class="merchant-dash__gate">
        <ui-empty
          theme="album"
          title="数据加载失败"
          description="{{errorMessage}}"
          actionText="重试"
          bind:action="onRetry"
        />
      </view>
    </block>

    <block wx:elif="{{status === 'empty'}}">
      <view class="merchant-dash__body">
        <view class="merchant-dash__main surface-album-panel">
          <view class="merchant-dash__filter-sticky">
            <ui-tabs
              tabs="{{periodTabs}}"
              activeKey="{{period}}"
              scrollable="{{true}}"
              bind:change="onPeriodChange"
            />
          </view>

          <view class="merchant-dash__gate merchant-dash__gate--inline">
            <ui-empty
              theme="album"
              title="暂无统计数据"
              description="站外案例页产生浏览或电话点击后，次日可在此查看；也可先处理下方待办"
              actionText="刷新"
              bind:action="onRetry"
            />
          </view>

          <view class="surface-album-inset-divider" />

          <text class="text-h3 merchant-dash__section-title">当前待办</text>
          <view class="merchant-dash__queue">
            <view class="merchant-dash__action-row merchant-dash__action-row--tap" bindtap="onGoLeads">
              <view class="merchant-dash__action-copy">
                <text class="text-body">{{display.pendingLeads}} 条咨询待处理</text>
              </view>
              <text class="text-caption text-link">去处理</text>
            </view>
            <view class="merchant-dash__action-row merchant-dash__action-row--tap" bindtap="onGoAlbumAuth">
              <view class="merchant-dash__action-copy">
                <text class="text-body">{{display.pendingAuth}} 本待公开授权</text>
              </view>
              <text class="text-caption text-link">去授权</text>
            </view>
          </view>

          <block wx:if="{{suggestions.length}}">
            <view class="surface-album-inset-divider" />
            <text class="text-h3 merchant-dash__section-title">优化建议</text>
            <view wx:for="{{suggestions}}" wx:key="*this" class="merchant-dash__tip">
              <text class="text-body">{{item}}</text>
            </view>
          </block>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="merchant-dash__body">
        <view class="merchant-dash__main surface-album-panel">
          <view class="merchant-dash__filter-sticky">
            <ui-tabs
              tabs="{{periodTabs}}"
              activeKey="{{period}}"
              scrollable="{{true}}"
              bind:change="onPeriodChange"
            />
            <text wx:if="{{rangeLabel}}" class="merchant-dash__range text-caption">{{rangeLabel}}</text>
          </view>

          <view class="surface-album-metric-grid merchant-dash__metrics">
            <view wx:for="{{heroKpis}}" wx:key="key" class="surface-album-metric-cell">
              <text class="surface-album-metric-num text-h2 text-numeric">{{item.value}}</text>
              <text class="text-caption surface-album-metric-label">{{item.label}}</text>
            </view>
          </view>

          <view class="surface-album-inset-divider" />

          <text class="text-h3 merchant-dash__section-title">站外曝光 · 真实用户</text>
          <text class="text-caption merchant-dash__hint">{{metricNotes.userExposure}}</text>
          <view class="merchant-dash__chip-row">
            <view wx:for="{{exposureChips}}" wx:key="key" class="merchant-dash__chip">
              <text class="merchant-dash__chip-num text-body text-numeric">{{item.value}}</text>
              <text class="text-caption merchant-dash__chip-label">{{item.label}}</text>
            </view>
          </view>

          <view class="surface-album-inset-divider" />

          <text class="text-h3 merchant-dash__section-title">爬虫访问 · 代理指标</text>
          <view class="merchant-dash__crawler-card">
            <text class="merchant-dash__crawler-num text-h2 text-numeric">{{crawlerMetric.value}}</text>
            <text class="text-body merchant-dash__crawler-label">{{crawlerMetric.label}}</text>
            <text class="text-caption merchant-dash__crawler-tag">{{crawlerMetric.hint}}</text>
            <text class="text-caption merchant-dash__hint">{{metricNotes.crawlerProxy}}</text>
            <text class="text-caption merchant-dash__hint merchant-dash__hint--probe">{{metricNotes.probeInternal}}</text>
          </view>

          <view class="surface-album-inset-divider" />

          <view class="merchant-dash__section-head">
            <text class="text-h3">咨询线索</text>
            <text class="text-caption merchant-dash__rates">线索率 {{display.leadRate}} · 联系率 {{display.contactRate}}</text>
          </view>
          <view class="merchant-dash__queue">
            <view
              wx:for="{{leadRows}}"
              wx:key="key"
              class="merchant-dash__action-row merchant-dash__action-row--{{item.key}} {{item.active ? 'merchant-dash__action-row--active' : ''}} {{item.handler ? 'merchant-dash__action-row--tap' : ''}}"
              data-handler="{{item.handler}}"
              bindtap="onLeadRowTap"
            >
              <view class="merchant-dash__action-dot {{item.active ? 'merchant-dash__action-dot--active' : ''}}" />
              <view class="merchant-dash__action-copy">
                <text class="text-body">{{item.value}} {{item.label}}</text>
              </view>
              <text wx:if="{{item.action}}" class="text-caption text-link">{{item.action}}</text>
            </view>
          </view>
          <text class="text-caption merchant-dash__rates merchant-dash__rates--foot">案例咨询率 {{display.caseConsultRate}}</text>

          <view class="surface-album-inset-divider" />

          <text class="text-h3 merchant-dash__section-title">服务相册</text>
          <view class="merchant-dash__queue">
            <view
              wx:for="{{albumRows}}"
              wx:key="key"
              class="merchant-dash__action-row merchant-dash__action-row--{{item.key}} {{item.active ? 'merchant-dash__action-row--active' : ''}} {{item.handler ? 'merchant-dash__action-row--tap' : ''}}"
              data-handler="{{item.handler}}"
              bindtap="onLeadRowTap"
            >
              <view class="merchant-dash__action-dot {{item.active ? 'merchant-dash__action-dot--active' : ''}}" />
              <view class="merchant-dash__action-copy">
                <text class="text-body">{{item.value}} {{item.label}}</text>
              </view>
              <text wx:if="{{item.action}}" class="text-caption text-link">{{item.action}}</text>
            </view>
          </view>

          <block wx:if="{{topCases.length || topServices.length}}">
            <view class="surface-album-inset-divider" />
            <text class="text-h3 merchant-dash__section-title">案例 / 服务排行</text>
            <text class="text-caption merchant-dash__hint">按站外浏览与区间留资统计，转化率为留资÷浏览</text>
            <block wx:if="{{topCases.length}}">
              <text class="text-body merchant-dash__rank-sub">案例榜</text>
              <view class="merchant-dash__timeline">
                <view wx:for="{{topCases}}" wx:key="rank" class="merchant-dash__timeline-item">
                  <view class="merchant-dash__timeline-rail">
                    <text class="merchant-dash__rank-badge text-caption">{{item.rank}}</text>
                    <view wx:if="{{index < topCases.length - 1}}" class="merchant-dash__timeline-line" />
                  </view>
                  <view class="merchant-dash__timeline-body">
                    <text class="text-body merchant-dash__rank-title">{{item.title}}</text>
                    <text class="text-caption merchant-dash__rank-meta">浏览 {{item.viewCountText}}{{item.viewDetailText ? '（' + item.viewDetailText + '）' : ''}} · 留资 {{item.leadCountText}} · 转化 {{item.leadRateText}}</text>
                  </view>
                </view>
              </view>
            </block>
            <block wx:if="{{topServices.length}}">
              <text class="text-body merchant-dash__rank-sub">服务榜</text>
              <view class="merchant-dash__timeline">
                <view wx:for="{{topServices}}" wx:key="rank" class="merchant-dash__timeline-item">
                  <view class="merchant-dash__timeline-rail">
                    <text class="merchant-dash__rank-badge text-caption">{{item.rank}}</text>
                    <view wx:if="{{index < topServices.length - 1}}" class="merchant-dash__timeline-line" />
                  </view>
                  <view class="merchant-dash__timeline-body">
                    <text class="text-body merchant-dash__rank-title">{{item.title}}</text>
                    <text class="text-caption merchant-dash__rank-meta">浏览 {{item.viewCountText}}{{item.viewDetailText ? '（' + item.viewDetailText + '）' : ''}} · 留资 {{item.leadCountText}} · 转化 {{item.leadRateText}}</text>
                  </view>
                </view>
              </view>
            </block>
          </block>

          <block wx:if="{{suggestions.length}}">
            <view class="surface-album-inset-divider" />
            <text class="text-h3 merchant-dash__section-title">优化建议</text>
            <view wx:for="{{suggestions}}" wx:key="*this" class="merchant-dash__tip">
              <text class="text-body">{{item}}</text>
            </view>
          </block>

          <view class="surface-album-inset-divider" />

          <view class="merchant-dash__score-head">
            <view>
              <text class="text-h3">门店透明度</text>
              <text class="text-caption merchant-dash__hint">资料完整度与响应表现综合得分</text>
            </view>
            <text class="merchant-dash__score text-h1 text-numeric">{{display.transparencyScore}}</text>
          </view>
          <view
            wx:for="{{transparencyBreakdown}}"
            wx:key="key"
            class="merchant-dash__breakdown-row"
          >
            <text class="text-body">{{item.label}}</text>
            <text class="text-body merchant-dash__breakdown-val text-numeric">{{item.score}} 分</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</ui-tool-page-shell>

<view wx:else class="page merchant-dash merchant-dash--loading bg-album">
  <view class="merchant-dash__topbar bg-band">
    <text class="merchant-dash__topbar-title text-body">数据概览</text>
  </view>
  <view class="page-content merchant-dash__loading-body">
    <ui-skeleton rows="{{6}}" title="{{true}}" />
  </view>
</view>
