.merchant-dash__cockpit {
  min-height: 100vh;
  background-color: var(--color-bg-album);
}

.merchant-dash__topbar {
  padding: var(--space-sm) var(--page-padding-x) var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.merchant-dash__topbar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.merchant-dash__topbar-main {
  display: flex;
  align-items: center;
  min-width: 0;
  overflow: hidden;
}

.merchant-dash__topbar-title {
  flex-shrink: 0;
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.merchant-dash__topbar-sub {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.merchant-dash__topbar-hint {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-dash__body {
  padding: var(--space-md) var(--page-padding-x) var(--space-xl);
  box-sizing: border-box;
}

.merchant-dash__main {
  display: flex;
  flex-direction: column;
}

.merchant-dash__filter-sticky {
  position: sticky;
  top: 0;
  z-index: var(--z-fixed);
  margin: calc(-1 * var(--space-md)) calc(-1 * var(--space-md)) var(--space-md);
  padding: var(--space-md);
  background-color: var(--color-album-frame-inner);
  border-bottom: 1rpx solid var(--color-album-frame-line);
  box-sizing: border-box;
}

.merchant-dash__range {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-dash__metrics {
  margin-bottom: 0;
}

.merchant-dash__section-title {
  display: block;
  margin-bottom: var(--space-sm);
}

.merchant-dash__section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.merchant-dash__chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.merchant-dash__chip {
  width: calc(50% - var(--space-sm) / 2);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  box-sizing: border-box;
}

.merchant-dash__chip-num {
  display: block;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.merchant-dash__chip-label {
  display: block;
  margin-top: 2rpx;
  color: var(--color-text-secondary);
}

.merchant-dash__hint {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-tertiary);
}

.merchant-dash__hint--probe {
  margin-top: var(--space-xs);
}

.merchant-dash__crawler-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  box-sizing: border-box;
}

.merchant-dash__crawler-num {
  color: var(--color-text-primary);
}

.merchant-dash__crawler-label {
  color: var(--color-text-secondary);
}

.merchant-dash__crawler-tag {
  color: var(--color-text-tertiary);
}

.merchant-dash__rates {
  color: var(--color-text-tertiary);
  text-align: right;
}

.merchant-dash__rates--foot {
  display: block;
  margin-top: var(--space-sm);
  text-align: left;
}

.merchant-dash__queue {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-dash__action-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  box-sizing: border-box;
}

.merchant-dash__action-row--active.merchant-dash__action-row--pending {
  border-left: 6rpx solid var(--color-warning);
  padding-left: calc(var(--space-md) - 6rpx);
}

.merchant-dash__action-row--active.merchant-dash__action-row--auth {
  border-left: 6rpx solid var(--color-success);
  padding-left: calc(var(--space-md) - 6rpx);
}

.merchant-dash__action-row--tap:active {
  opacity: 0.72;
}

.merchant-dash__action-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-frame-line);
  flex-shrink: 0;
}

.merchant-dash__action-dot--active {
  background-color: var(--color-album-frame-corner);
}

.merchant-dash__action-row--pending.merchant-dash__action-row--active .merchant-dash__action-dot--active {
  background-color: var(--color-warning);
}

.merchant-dash__action-row--auth.merchant-dash__action-row--active .merchant-dash__action-dot--active {
  background-color: var(--color-success);
}

.merchant-dash__action-copy {
  flex: 1;
  min-width: 0;
}

.merchant-dash__rank-sub {
  display: block;
  margin: var(--space-sm) 0 var(--space-xs);
  font-weight: var(--font-weight-medium);
}

.merchant-dash__timeline {
  display: flex;
  flex-direction: column;
}

.merchant-dash__timeline-item {
  display: flex;
  gap: var(--space-md);
}

.merchant-dash__timeline-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.merchant-dash__rank-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  color: var(--color-album-frame-corner);
  font-weight: var(--font-weight-medium);
}

.merchant-dash__timeline-line {
  flex: 1;
  width: 2rpx;
  min-height: 40rpx;
  margin-top: var(--space-xs);
  background-color: var(--color-album-frame-line);
}

.merchant-dash__timeline-body {
  flex: 1;
  min-width: 0;
  padding-bottom: var(--space-md);
}

.merchant-dash__rank-title {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.merchant-dash__rank-meta {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.merchant-dash__tip {
  padding: var(--space-sm) var(--space-md);
  margin-top: var(--space-xs);
  border-radius: var(--radius-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
}

.merchant-dash__tip:first-of-type {
  margin-top: 0;
}

.merchant-dash__score-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.merchant-dash__score {
  flex-shrink: 0;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}

.merchant-dash__breakdown-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-album-frame-line);
}

.merchant-dash__breakdown-row:last-child {
  border-bottom: none;
}

.merchant-dash__breakdown-val {
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.merchant-dash__gate,
.merchant-dash__loading-body {
  padding: var(--space-xl) var(--page-padding-x);
  box-sizing: border-box;
}

.merchant-dash__gate--inline {
  padding: var(--space-md) 0 0;
}

.merchant-dash__loading-body {
  padding-top: var(--space-md);
}
