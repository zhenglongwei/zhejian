<view class="page merchant-wb">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content merchant-wb__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'pending'}}">
    <view class="page-content merchant-wb__hero">
      <text class="text-h1">入驻审核中</text>
      <text class="text-body merchant-wb__sub">审核通过后即可使用商家工作台</text>
      <ui-button type="primary" bind:tap="onRefreshAudit">查看审核进度</ui-button>
    </view>
  </block>

  <block wx:elif="{{status === 'rejected'}}">
    <view class="page-content merchant-wb__hero">
      <text class="text-h1">入驻未通过</text>
      <text wx:if="{{profile.rejectReason}}" class="text-body merchant-wb__sub">{{profile.rejectReason}}</text>
      <text wx:else class="text-body merchant-wb__sub">请修改资料后重新提交</text>
      <ui-button type="primary" bind:tap="onGoOnboarding">修改入驻资料</ui-button>
    </view>
  </block>

  <block wx:elif="{{status === 'need_modify'}}">
    <view class="page-content merchant-wb__hero">
      <text class="text-h1">资料需修改</text>
      <text wx:if="{{profile.rejectReason}}" class="text-body merchant-wb__sub">{{profile.rejectReason}}</text>
      <text wx:else class="text-body merchant-wb__sub">请按审核意见修改后重新提交</text>
      <ui-button type="primary" bind:tap="onGoOnboarding">修改入驻资料</ui-button>
    </view>
  </block>

  <block wx:elif="{{status === 'none'}}">
    <view class="page-content merchant-wb__hero">
      <text class="text-h1">商家工作台</text>
      <text class="text-body merchant-wb__sub">入驻后可创建服务相册、处理咨询线索与管理服务方案</text>
      <ui-button type="primary" bind:tap="onGoOnboarding">立即入驻</ui-button>
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-wb__head">
      <text class="text-h2">{{profile.storeName}}</text>
      <ui-tag variant="success" text="已认证" />
      <text class="text-caption merchant-wb__addr">{{profile.address}}</text>
    </view>
    <view class="page-content merchant-wb__stats">
      <ui-card shadow="{{true}}">
        <view class="merchant-wb__stat-row">
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="active"
            bindtap="onAlbumList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.activeAlbums}}</text>
            <text class="text-caption">进行中服务相册</text>
          </view>
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="all"
            bindtap="onAlbumList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.pendingUpload}}</text>
            <text class="text-caption">待补节点</text>
          </view>
        </view>
        <view class="merchant-wb__stat-row">
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="pending_auth"
            bindtap="onAlbumList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.pendingAuth}}</text>
            <text class="text-caption">待公开授权</text>
          </view>
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="pending"
            bindtap="onLeadList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.pendingLeads}}</text>
            <text class="text-caption">待处理线索</text>
          </view>
        </view>
      </ui-card>
    </view>
    <view class="page-content merchant-wb__actions">
      <text class="text-h3 merchant-wb__section">快捷操作</text>
      <ui-button type="primary" bind:tap="onCreateAlbum">新建服务相册</ui-button>
      <ui-button type="secondary" bind:tap="onLeadList">咨询线索</ui-button>
      <ui-button type="secondary" bind:tap="onAlbumList">服务相册管理</ui-button>
      <ui-button type="secondary" bind:tap="onServiceList">服务方案</ui-button>
    </view>
  </block>
</view>
