<view class="page merchant-wb">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content merchant-wb__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'none'}}">
    <view class="page-content merchant-wb__hero">
      <text class="text-h1">商家工作台</text>
      <text class="text-body merchant-wb__sub">入驻后可创建维修案例、管理相册</text>
      <ui-button type="primary" bind:tap="onGoOnboarding">立即入驻</ui-button>
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-wb__head">
      <text class="text-h2">{{profile.storeName}}</text>
      <ui-tag variant="success" text="已认证" />
      <text class="text-caption merchant-wb__addr">{{profile.address}}</text>
    </view>
    <view class="page-content merchant-wb__stats">
      <ui-card shadow="{{true}}">
        <view class="merchant-wb__stat-row">
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="today"
            bindtap="onOrderList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.today}}</text>
            <text class="text-caption">今日预约</text>
          </view>
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="waitAccept"
            bindtap="onOrderList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.waitAccept}}</text>
            <text class="text-caption">待接单</text>
          </view>
        </view>
        <view class="merchant-wb__stat-row">
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="inService"
            bindtap="onOrderList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.inService}}</text>
            <text class="text-caption">维修中</text>
          </view>
          <view
            class="merchant-wb__stat merchant-wb__stat--tap"
            data-tab="inService"
            bindtap="onOrderList"
          >
            <text class="merchant-wb__stat-num text-h2">{{todos.waitComplete}}</text>
            <text class="text-caption">待提交完工</text>
          </view>
        </view>
      </ui-card>
    </view>
    <view class="page-content merchant-wb__actions">
      <text class="text-h3 merchant-wb__section">快捷操作</text>
      <ui-button type="primary" bind:tap="onOrderList">订单管理</ui-button>
      <ui-button type="primary" bind:tap="onCreateAlbum">新建历史案例</ui-button>
      <ui-button type="secondary" bind:tap="onAlbumList">案例管理</ui-button>
      <ui-button type="secondary" bind:tap="onServiceList">服务方案</ui-button>
    </view>
  </block>
</view>
