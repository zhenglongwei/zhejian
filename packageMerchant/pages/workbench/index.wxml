<ui-tool-page-shell showBand="{{false}}" showCompliance="{{false}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="merchant-hub__pad">
      <ui-skeleton rows="{{2}}" title="{{true}}" avatar="{{false}}" />
      <view class="merchant-hub__sk-gap">
        <ui-skeleton rows="{{4}}" title="{{false}}" />
      </view>
    </view>
  </block>

  <block wx:elif="{{status === 'pending'}}">
    <view class="merchant-hub__gate">
      <ui-empty
        title="{{gatePending.title}}"
        description="{{gatePending.description}}"
        actionText="查看审核进度"
        bind:action="onRefreshAudit"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'rejected'}}">
    <view class="merchant-hub__gate">
      <ui-empty
        title="入驻未通过"
        description="{{profile.rejectReason || '请修改资料后重新提交'}}"
        actionText="修改入驻资料"
        bind:action="onGoOnboarding"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'need_modify'}}">
    <view class="merchant-hub__gate">
      <ui-empty
        title="资料需修改"
        description="{{profile.rejectReason || '请按审核意见修改后重新提交'}}"
        actionText="修改入驻资料"
        bind:action="onGoOnboarding"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'none'}}">
    <view class="merchant-hub__gate">
      <ui-empty
        title="{{gateNone.title}}"
        description="{{gateNone.description}}"
        actionText="申请入驻"
        bind:action="onGoOnboarding"
      />
    </view>
  </block>

  <block wx:else>
    <view class="merchant-hub">
      <view class="merchant-hub__folio bg-album">
        <ui-merchant-store-header
          storeName="{{profile.storeName}}"
          address="{{profile.address}}"
          overviewLine="{{overviewLine}}"
          canSwitchStore="{{canSwitchStore}}"
          switchingStore="{{switchingStore}}"
          storeOptions="{{storeOptions}}"
          storePickerIndex="{{storePickerIndex}}"
          unreadBadgeText="{{unreadBadgeText}}"
          bind:storechange="onStoreHeaderChange"
          bind:messagetap="onMessageList"
        />
      </view>

      <view class="merchant-hub__section merchant-hub__section--panel">
        <view class="merchant-hub__section-head">
          <text class="merchant-hub__section-title text-h3">{{albumSectionTitle}}</text>
          <view class="merchant-hub__section-links">
            <view class="merchant-hub__section-link" bindtap="onAlbumList">
              <text class="merchant-hub__section-link-text text-caption text-link">全部</text>
              <text wx:if="{{albumSectionBadge}}" class="merchant-hub__link-badge text-caption">{{albumSectionBadge}}</text>
            </view>
          </view>
        </view>

        <block wx:if="{{albumHeroCards.length}}">
          <view class="merchant-hub__album-stack">
            <ui-album-card
              wx:for="{{albumHeroCards}}"
              wx:key="albumId"
              item="{{item}}"
              audience="merchant"
              showProgress="{{true}}"
              showHeaderActions="{{true}}"
              data-id="{{item.albumId}}"
              bind:tap="onAlbumCardTap"
            />
          </view>
        </block>

        <block wx:else>
          <ui-empty
            title="暂无服务相册"
            description="{{albumEmptyHint}}"
            actionText="新建服务相册"
            bind:action="onCreateAlbum"
          />
        </block>
      </view>

      <view wx:if="{{todoSummary}}" class="merchant-hub__section merchant-hub__section--panel merchant-hub__todo">
        <text class="merchant-hub__todo-headline text-body">{{todoSummary.headline}}</text>
        <view class="merchant-hub__todo-list">
          <view
            wx:for="{{todoSummary.items}}"
            wx:key="key"
            class="merchant-hub__todo-item"
            data-action="{{item.action}}"
            bindtap="onTodoItemTap"
          >
            <text class="merchant-hub__todo-dot" />
            <text class="text-caption">{{item.label}}</text>
            <text class="merchant-hub__todo-arrow text-caption">›</text>
          </view>
        </view>
      </view>

      <view wx:if="{{casePublishRecent.length}}" class="merchant-hub__section merchant-hub__section--panel">
        <view class="merchant-hub__section-head">
          <text class="merchant-hub__section-title text-h3">{{caseSectionTitle}}</text>
          <view class="merchant-hub__section-link" bindtap="onAlbumList">
            <text class="merchant-hub__section-link-text text-caption text-link">全部相册</text>
          </view>
        </view>
        <view class="merchant-hub__case-list">
          <view
            wx:for="{{casePublishRecent}}"
            wx:key="caseId"
            class="merchant-hub__case-item"
            data-index="{{index}}"
            data-album-id="{{item.albumId}}"
            data-case-id="{{item.caseId}}"
            bindtap="onCasePublishItemTap"
          >
            <view class="merchant-hub__case-main">
              <text class="text-body merchant-hub__case-title">{{item.title}}</text>
              <text class="text-caption text-tertiary">{{item.serviceName}}</text>
            </view>
            <ui-tag
              variant="{{item.publishStatus === 'published_wechat' ? 'success' : 'info'}}"
              text="{{item.publishLabel}}"
            />
          </view>
        </view>
      </view>

      <view
        wx:if="{{geoOpportunity}}"
        class="merchant-hub__geo"
        bindtap="onAlbumList"
      >
        <text class="text-caption text-secondary">{{geoOpportunity.hint}}</text>
      </view>

      <view class="merchant-hub__dock">
        <view
          wx:for="{{hubDock}}"
          wx:key="key"
          class="merchant-hub__dock-item"
          data-key="{{item.key}}"
          bindtap="onDockTap"
        >
          <view class="merchant-hub__dock-well merchant-hub__dock-well--{{item.iconBg}}">
            <image class="merchant-hub__dock-icon" src="{{item.icon}}" mode="aspectFit" />
            <text wx:if="{{item.badge}}" class="merchant-hub__dock-badge">{{item.badge}}</text>
          </view>
          <text class="merchant-hub__dock-label text-caption">{{item.label}}</text>
        </view>
      </view>

      <view wx:if="{{canManageStaff}}" class="merchant-hub__section merchant-hub__section--panel">
        <text class="merchant-hub__section-title text-h3 merchant-hub__manage-title">{{manageSectionTitle}}</text>
        <view class="merchant-hub__manage-grid">
          <view
            wx:for="{{manageGrid}}"
            wx:key="key"
            class="merchant-hub__manage-item"
            data-key="{{item.key}}"
            bindtap="onManageTap"
          >
            <view class="merchant-hub__manage-well merchant-hub__manage-well--{{item.iconBg}}">
              <image class="merchant-hub__manage-icon" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <text class="merchant-hub__manage-label text-caption">{{item.label}}</text>
            <text class="merchant-hub__manage-hint text-caption text-tertiary">{{item.hint}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</ui-tool-page-shell>
