<ui-tool-page-shell
  wx:if="{{status !== 'loading'}}"
  show-band="{{false}}"
  show-compliance="{{false}}"
>
  <block wx:if="{{status === 'pending'}}">
    <view class="merchant-wb__topbar bg-band">
      <text class="merchant-wb__topbar-title text-body">商家工作台</text>
    </view>
    <view class="merchant-wb__gate">
      <ui-empty
        title="{{gatePending.title}}"
        description="{{gatePending.description}}"
        actionText="查看审核进度"
        bind:action="onRefreshAudit"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'rejected'}}">
    <view class="merchant-wb__topbar bg-band">
      <text class="merchant-wb__topbar-title text-body">商家工作台</text>
    </view>
    <view class="merchant-wb__gate">
      <ui-empty
        title="入驻未通过"
        description="{{profile.rejectReason || '请修改资料后重新提交'}}"
        actionText="修改入驻资料"
        bind:action="onGoOnboarding"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'need_modify'}}">
    <view class="merchant-wb__topbar bg-band">
      <text class="merchant-wb__topbar-title text-body">商家工作台</text>
    </view>
    <view class="merchant-wb__gate">
      <ui-empty
        title="资料需修改"
        description="{{profile.rejectReason || '请按审核意见修改后重新提交'}}"
        actionText="修改入驻资料"
        bind:action="onGoOnboarding"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'none'}}">
    <view class="merchant-wb__topbar bg-band">
      <text class="merchant-wb__topbar-title text-body">商家工作台</text>
    </view>
    <view class="merchant-wb__gate">
      <ui-empty
        title="{{gateNone.title}}"
        description="{{gateNone.description}}"
        actionText="申请入驻"
        bind:action="onGoOnboarding"
      />
    </view>
  </block>

  <block wx:else>
    <view class="merchant-wb__cockpit">
      <view class="merchant-wb__topbar bg-band">
        <view class="merchant-wb__topbar-row">
          <view class="merchant-wb__topbar-main">
            <picker
              wx:if="{{canSwitchStore}}"
              class="merchant-wb__store-picker"
              mode="selector"
              range="{{storeOptions}}"
              range-key="name"
              value="{{storePickerIndex}}"
              disabled="{{switchingStore}}"
              bindchange="onStoreChange"
            >
              <view class="merchant-wb__topbar-title-wrap">
                <text class="merchant-wb__topbar-title text-body">商家工作台</text>
                <text class="merchant-wb__topbar-sub text-body">· {{profile.storeName}} ▾</text>
              </view>
            </picker>
            <view wx:else class="merchant-wb__topbar-title-wrap">
              <text class="merchant-wb__topbar-title text-body">商家工作台</text>
              <text class="merchant-wb__topbar-sub text-body">· {{profile.storeName}}</text>
            </view>
          </view>
          <view class="merchant-wb__band-actions">
            <view class="merchant-wb__icon-btn" bindtap="onWechatNotifyTap">
              <image class="merchant-wb__icon-img" src="/assets/nav/authorize.png" mode="aspectFit" />
              <view wx:if="{{needsSubscribePrompt}}" class="merchant-wb__icon-dot" />
            </view>
            <view class="merchant-wb__icon-btn" bindtap="onMessageList">
              <image class="merchant-wb__icon-img" src="/assets/nav/message.png" mode="aspectFit" />
              <view wx:if="{{unreadBadgeText}}" class="merchant-wb__icon-badge">{{unreadBadgeText}}</view>
            </view>
          </view>
        </view>
        <text wx:if="{{profile.address}}" class="merchant-wb__topbar-addr text-caption">{{profile.address}}</text>
      </view>

      <view class="merchant-wb__action-cabin">
        <view class="merchant-wb__cabin-head">
          <text class="text-h3">今日待办</text>
          <text wx:if="{{todoTotal > 0}}" class="merchant-wb__cabin-count text-caption">{{todoTotal}} 项</text>
          <text wx:else class="text-caption text-tertiary">暂无待办</text>
        </view>

        <view class="merchant-wb__todo-queue">
          <view
            wx:for="{{todoQueue}}"
            wx:key="key"
            class="merchant-wb__todo-item merchant-wb__todo-item--{{item.key}} {{item.active ? 'merchant-wb__todo-item--active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onTodoRowTap"
          >
            <view class="merchant-wb__todo-dot {{item.active ? 'merchant-wb__todo-dot--active' : ''}}" />
            <view class="merchant-wb__todo-copy">
              <text class="text-body">{{item.count}} {{item.label}}</text>
            </view>
            <text class="text-caption text-link">{{item.actionLabel}}</text>
          </view>
        </view>

        <ui-button type="primary" block bind:btntap="onCreateAlbum">新建服务相册</ui-button>
      </view>

      <view class="merchant-wb__scroll-body">
        <view wx:if="{{geoOpportunity}}" class="merchant-wb__panel merchant-wb__geo-opp">
          <view class="merchant-wb__panel-head">
            <text class="text-h3">GEO 供给参考</text>
          </view>
          <text class="text-body">{{geoOpportunity.hint}}</text>
          <text class="text-caption text-tertiary merchant-wb__geo-meta">
            同城公开案例中位数 {{geoOpportunity.cityMedianPublicCases || 0}} 条 · 本店 {{geoOpportunity.storePublicCaseCount || 0}} 条
          </text>
          <text class="text-caption text-tertiary">{{geoOpportunity.disclaimer}}</text>
        </view>

        <view class="merchant-wb__quick-panel">
          <text class="text-h3 merchant-wb__quick-title">快捷操作</text>
          <scroll-view class="merchant-wb__quick-strip" scroll-x enable-flex show-scrollbar="{{false}}">
            <view class="merchant-wb__quick-inner">
              <view
                wx:for="{{quickActions}}"
                wx:key="key"
                class="merchant-wb__quick-item"
                data-key="{{item.key}}"
                bindtap="onQuickActionTap"
              >
                <view class="merchant-wb__quick-well merchant-wb__quick-well--{{item.iconBg}}">
                  <image class="merchant-wb__quick-icon" src="{{item.icon}}" mode="aspectFit" />
                </view>
                <text class="text-caption merchant-wb__quick-label">{{item.label}}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <view class="merchant-wb__panel">
          <view class="merchant-wb__panel-head">
            <text class="text-h3">案例动态</text>
            <text class="text-caption text-link" bindtap="onAlbumList">全部相册</text>
          </view>
          <block wx:if="{{casePublishRecent.length}}">
            <view class="merchant-wb__timeline">
              <view
                wx:for="{{casePublishRecent}}"
                wx:key="caseId"
                class="merchant-wb__timeline-item"
                data-index="{{index}}"
                data-album-id="{{item.albumId}}"
                data-case-id="{{item.caseId}}"
                bindtap="onCasePublishItemTap"
              >
                <view class="merchant-wb__timeline-rail">
                  <view class="merchant-wb__timeline-dot" />
                  <view wx:if="{{index < casePublishRecent.length - 1}}" class="merchant-wb__timeline-line" />
                </view>
                <view class="merchant-wb__timeline-body">
                  <view class="merchant-wb__timeline-top">
                    <text class="text-body merchant-wb__timeline-title">{{item.title}}</text>
                    <ui-tag
                      variant="{{item.publishStatus === 'published_wechat' ? 'success' : 'info'}}"
                      text="{{item.publishLabel}}"
                    />
                  </view>
                  <text class="text-caption merchant-wb__timeline-meta">{{item.serviceName}} · 近7天 H5 {{item.h5ViewCount7d || 0}} · 小程序 {{item.mpViewCount7d || 0}}</text>
                </view>
              </view>
            </view>
          </block>
          <view wx:else class="merchant-wb__timeline-empty">
            <text class="text-caption text-secondary">完工相册提交审核后将在此展示动态</text>
          </view>
        </view>

        <view class="merchant-wb__kpi-line merchant-wb__kpi-line--tap" bindtap="onDashboard">
          <text class="text-caption text-secondary">近7天</text>
          <text class="text-body">咨询 {{overview.leadSubmit}}</text>
          <text class="text-caption text-tertiary">·</text>
          <text class="text-body">透明度 {{overview.transparency}}</text>
          <text class="text-caption text-link merchant-wb__kpi-more">详情 ›</text>
        </view>

        <view wx:if="{{canManageStaff}}" class="merchant-wb__store-links">
          <text class="text-caption text-link" data-key="editStore" bindtap="onMoreMenuTap">编辑门店资料</text>
          <text class="text-caption text-tertiary">·</text>
          <text class="text-caption text-link" data-key="staff" bindtap="onMoreMenuTap">员工管理</text>
        </view>
      </view>
    </view>
  </block>
</ui-tool-page-shell>

<view wx:else class="page merchant-wb merchant-wb--loading">
  <view class="page-content merchant-wb__loading-body">
    <ui-skeleton rows="{{2}}" title="{{true}}" />
    <view class="merchant-wb__sk-gap">
      <ui-skeleton rows="{{3}}" title="{{false}}" />
    </view>
  </view>
</view>

<ui-bottom-sheet
  visible="{{subscribeSheetVisible}}"
  title="开启微信通知"
  hint="{{subscribeBannerDescription}}"
  confirmText="开启微信通知"
  cancelText="稍后再说"
  bind:close="onSubscribeSheetClose"
  bind:cancel="onSubscribeSheetClose"
  bind:confirm="onSubscribeSheetConfirm"
/>
