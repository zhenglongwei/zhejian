.merchant-hub__pad {
  padding-top: var(--space-md);
}

.merchant-hub__sk-gap {
  margin-top: var(--space-md);
}

.merchant-hub__gate {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: var(--space-xl);
  padding-bottom: var(--space-xl);
  box-sizing: border-box;
}

.merchant-hub {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-sm);
  padding-bottom: var(--space-md);
  background-color: var(--color-bg-album);
}

.merchant-hub__folio {
  margin: 0 calc(-1 * var(--page-padding-x));
  padding: var(--space-lg) var(--page-padding-x);
  background: linear-gradient(
    180deg,
    var(--color-primary-light) 0%,
    var(--color-album-frame-inner) 180rpx,
    var(--color-album-frame-inner) 100%
  );
  border-bottom: 1rpx solid var(--color-album-frame-line);
  box-sizing: border-box;
}

.merchant-hub__section--panel {
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.merchant-hub__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.merchant-hub__section-title {
  color: var(--color-text-primary);
}

.merchant-hub__manage-title {
  display: block;
  margin-bottom: var(--space-sm);
}

.merchant-hub__manage-grid {
  display: flex;
  flex-wrap: wrap;
}

.merchant-hub__manage-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  width: 50%;
  padding: var(--space-md) var(--space-sm);
  box-sizing: border-box;
}

.merchant-hub__manage-item:nth-child(odd) {
  border-right: 1rpx solid var(--color-border);
}

.merchant-hub__manage-item:nth-child(-n + 2) {
  border-bottom: 1rpx solid var(--color-border);
}

.merchant-hub__manage-item:active {
  opacity: 0.72;
}

.merchant-hub__manage-well {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-nav-icon-well);
}

.merchant-hub__manage-well--primary-light {
  background-color: var(--color-primary-light);
}

.merchant-hub__manage-well--info-light {
  background-color: var(--color-info-light);
}

.merchant-hub__manage-well--warning-light {
  background-color: var(--color-warning-light);
}

.merchant-hub__manage-well--success-light {
  background-color: var(--color-success-light);
}

.merchant-hub__manage-icon {
  width: 40rpx;
  height: 40rpx;
}

.merchant-hub__manage-label {
  color: var(--color-text-primary);
  text-align: center;
}

.merchant-hub__manage-hint {
  text-align: center;
  line-height: 1.2;
}

.merchant-hub__section-links {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: var(--space-xs);
}

.merchant-hub__section-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  min-height: var(--font-caption-lh);
}

.merchant-hub__section-link-text {
  line-height: var(--font-caption-lh);
}

.merchant-hub__link-badge {
  color: var(--color-danger);
  line-height: var(--font-caption-lh);
}

.merchant-hub__album-stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-hub__todo-headline {
  display: block;
  margin-bottom: var(--space-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.merchant-hub__todo-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-hub__todo-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-xs) 0;
}

.merchant-hub__todo-item:active {
  opacity: 0.72;
}

.merchant-hub__todo-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-primary);
}

.merchant-hub__todo-arrow {
  margin-left: auto;
  color: var(--color-text-tertiary);
}

.merchant-hub__case-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.merchant-hub__case-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.merchant-hub__case-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.merchant-hub__case-item:active {
  opacity: 0.72;
}

.merchant-hub__case-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-hub__case-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.merchant-hub__geo {
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-album-frame-line);
  box-sizing: border-box;
}

.merchant-hub__geo:active {
  opacity: 0.72;
}

.merchant-hub__dock {
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  gap: var(--space-xs);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.merchant-hub__dock-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-xs);
  box-sizing: border-box;
}

.merchant-hub__dock-item:active {
  opacity: 0.72;
}

.merchant-hub__dock-well {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-nav-icon-well);
}

.merchant-hub__dock-well--primary-light {
  background-color: var(--color-primary-light);
}

.merchant-hub__dock-well--info-light {
  background-color: var(--color-info-light);
}

.merchant-hub__dock-well--warning-light {
  background-color: var(--color-warning-light);
}

.merchant-hub__dock-icon {
  width: 44rpx;
  height: 44rpx;
}

.merchant-hub__dock-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 28rpx;
  padding: 0 6rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
  color: var(--color-text-inverse);
  background-color: var(--color-danger);
  border-radius: var(--radius-full);
  box-sizing: border-box;
}

.merchant-hub__dock-label {
  color: var(--color-text-secondary);
  text-align: center;
}
