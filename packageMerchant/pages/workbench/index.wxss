.merchant-wb__pad {
  padding-top: var(--space-lg);
}

.merchant-wb__hero {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: var(--space-md);
  padding-top: var(--space-xl);
  padding-bottom: var(--space-xl);
}

.merchant-wb__sub {
  color: var(--color-text-secondary);
  max-width: 560rpx;
}

.merchant-wb__head {
  padding-top: var(--space-lg);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-sm);
}

.merchant-wb__addr {
  width: 100%;
  color: var(--color-text-tertiary);
}

.merchant-wb__stats {
  margin-top: var(--space-md);
}

.merchant-wb__overview-card {
  margin-bottom: var(--space-md);
}

.merchant-wb__overview-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.merchant-wb__overview-hint {
  color: var(--color-text-tertiary);
}

.merchant-wb__stat-row {
  display: flex;
}

.merchant-wb__stat {
  flex: 1;
  text-align: center;
  padding: var(--space-sm);
}

.merchant-wb__stat-num {
  display: block;
}

.merchant-wb__stat--tap:active {
  opacity: 0.72;
}

.merchant-wb__actions {
  margin-top: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.merchant-wb__section {
  display: block;
  margin-bottom: var(--space-sm);
}
