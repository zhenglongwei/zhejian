<view class="page merchant-staff">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content merchant-staff__pad">
      <ui-skeleton rows="{{3}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content merchant-staff__hero">
      <text class="text-body">{{errorMessage}}</text>
      <ui-button type="primary" bind:btntap="onRetry">重试</ui-button>
    </view>
  </block>

  <block wx:else>
    <view class="page-content merchant-staff__intro">
      <text class="text-caption merchant-staff__hint">
        员工账号权限相同，可用于服务相册、咨询线索与服务方案等日常维护。添加时仅需登记手机号；对方日后用该号登录并绑定手机后即可进入工作台。
      </text>
    </view>

    <view class="page-content merchant-staff__list">
      <view
        class="merchant-staff__card"
        wx:for="{{list}}"
        wx:key="id"
      >
        <view class="merchant-staff__card-main">
          <view class="merchant-staff__card-head">
            <text class="text-h3">{{item.nickname}}</text>
            <ui-tag variant="{{item.role === 'owner' ? 'success' : 'default'}}" text="{{item.roleLabel}}" />
            <ui-tag wx:if="{{item.pending}}" variant="warning" text="待登录" />
            <text wx:if="{{item.isSelf}}" class="text-caption merchant-staff__self">我</text>
          </view>
          <text class="text-caption merchant-staff__phone">{{item.phoneDisplay}}</text>
        </view>
        <view
          wx:if="{{item.canRemove}}"
          class="merchant-staff__remove text-caption"
          data-id="{{item.id}}"
          data-name="{{item.nickname}}"
          bindtap="onRemoveStaff"
        >移除</view>
      </view>
    </view>

    <view class="page-content merchant-staff__invite">
      <text class="text-caption">已添加 {{memberCount}} / {{maxStaff}} 名员工</text>
      <block wx:if="{{showInvite}}">
        <view class="merchant-staff__form">
          <input
            class="merchant-staff__input"
            type="number"
            maxlength="11"
            placeholder="员工微信绑定的手机号"
            value="{{invitePhone}}"
            bindinput="onInviteInput"
          />
          <ui-button type="primary" loading="{{inviting}}" bind:btntap="onSubmitInvite">确认添加</ui-button>
          <ui-button type="ghost" bind:btntap="onCloseInvite">取消</ui-button>
        </view>
      </block>
      <block wx:else>
        <ui-button
          type="secondary"
          disabled="{{memberCount >= maxStaff}}"
          bind:tap="onOpenInvite"
        >添加员工</ui-button>
      </block>
    </view>
  </block>
</view>
