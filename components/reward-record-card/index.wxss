.reward-record-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-md);
}

.reward-record-card__main {
  flex: 1;
  min-width: 0;
}

.reward-record-card__source {
  display: block;
}

.reward-record-card__time {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.reward-record-card__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.reward-record-card__amount {
  color: var(--color-text-primary);
}
