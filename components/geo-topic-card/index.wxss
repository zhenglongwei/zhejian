.geo-topic-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.geo-topic-card__cover {
  width: 100%;
  height: var(--size-geo-card-cover);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--space-xs);
}

.geo-topic-card__cover-img {
  width: 100%;
  height: 100%;
}

.geo-topic-card__title {
  color: var(--color-text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.geo-topic-card__summary {
  color: var(--color-text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.geo-topic-card__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.geo-topic-card__updated {
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}
