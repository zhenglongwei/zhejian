.album-compare-slider {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  width: 100%;
}

.album-compare-slider__stage {
  position: relative;
  width: 100%;
  height: 960rpx;
  overflow: hidden;
  border-radius: var(--radius-md);
  background: var(--color-album-frame-inner);
}

.album-compare-slider__image {
  display: block;
  width: 100%;
  height: 100%;
}

.album-compare-slider__image--before {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}

.album-compare-slider__after-wrap {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  overflow: hidden;
}

.album-compare-slider__image--after {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  max-width: none;
}

.album-compare-slider__handle {
  position: absolute;
  top: 0;
  bottom: 0;
  z-index: 2;
  width: 0;
  transform: translateX(-50%);
  pointer-events: none;
}

.album-compare-slider__handle-line {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 4rpx;
  margin-left: -2rpx;
  background: #fff;
  box-shadow: 0 0 8rpx rgba(0, 0, 0, 0.35);
}

.album-compare-slider__handle-knob {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 56rpx;
  height: 56rpx;
  margin-top: -28rpx;
  margin-left: -28rpx;
  border: 4rpx solid #fff;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  box-shadow: var(--shadow-card);
}

.album-compare-slider__labels {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 3;
  display: flex;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-md);
  background: linear-gradient(transparent, rgba(22, 20, 18, 0.72));
  pointer-events: none;
}

.album-compare-slider__label {
  color: #fff;
  font-weight: var(--font-weight-medium);
}

.album-compare-slider__hint {
  color: var(--color-text-tertiary);
  text-align: center;
}
