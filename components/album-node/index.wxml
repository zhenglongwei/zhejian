<view
  class="album-node {{mode === 'edit' ? 'album-node--edit' : ''}} {{compact ? 'album-node--compact' : ''}}"
>
  <view class="album-node__head {{mode === 'edit' ? 'album-node__head--edit' : ''}}">
    <view wx:if="{{mode === 'view'}}" class="album-node__dot" />
    <text class="album-node__title text-h3">{{title}}</text>
    <ui-tag
      wx:if="{{mode === 'edit' && requiredLevelLabel}}"
      variant="{{requiredLevelVariant || 'default'}}"
      text="{{requiredLevelLabel}}"
    />
  </view>

  <view class="album-node__content {{mode === 'edit' ? 'album-node__content--edit' : ''}}">
    <block wx:if="{{mode === 'edit'}}">
      <text
        wx:if="{{!compact && description}}"
        class="album-node__desc text-caption"
      >{{description}}</text>
      <text
        wx:if="{{!compact && photoTips}}"
        class="album-node__tips text-caption"
      >{{photoTips}}</text>
      <view
        wx:if="{{!compact && compareGuidance}}"
        class="album-node__compare-guide album-node__compare-guide--compact"
      >
        <text class="album-node__compare-guide-text text-caption">{{compareGuidance}}</text>
      </view>
      <textarea
        wx:if="{{!compact}}"
        class="album-node__note-input input"
        placeholder="{{notePlaceholder}}"
        value="{{note}}"
        bindinput="onNoteInput"
      />
      <text
        wx:if="{{uploadHint}}"
        class="album-node__upload-hint text-caption"
      >{{uploadHint}}</text>
      <ui-image-uploader
        images="{{images}}"
        maxCount="{{maxCount}}"
        variant="album"
        bind:change="onImagesChange"
      />
    </block>

    <block wx:else>
      <text wx:if="{{note}}" class="album-node__note text-caption">{{note}}</text>
      <view wx:if="{{displayImages.length}}" class="album-node__grid">
        <view
          wx:for="{{displayImages}}"
          wx:key="*this"
          class="album-node__cell image-placeholder"
          data-index="{{index}}"
          bindtap="onPreview"
        >
          <image class="album-node__img" src="{{item}}" mode="aspectFill" />
        </view>
      </view>
      <view wx:elif="{{!note}}" class="album-node__empty">
        <text class="album-node__empty-text text-caption">{{emptyText}}</text>
      </view>
      <text wx:if="{{time}}" class="album-node__time text-caption">{{time}}</text>
      <text
        wx:if="{{showFeedback && mode === 'view'}}"
        class="album-node__feedback text-caption text-link"
        bindtap="onFeedbackTap"
      >对此节点有疑问</text>
    </block>
  </view>
</view>
