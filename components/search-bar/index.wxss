.search-bar {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.search-bar__field {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  min-height: var(--button-height-sm);
  padding: 0 var(--space-md);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-full);
}

.search-bar__field--readonly {
  min-height: var(--button-height-sm);
}

.search-bar__icon {
  color: var(--color-text-tertiary);
  font-size: var(--font-body);
  line-height: 1;
}

.search-bar__input {
  flex: 1;
  min-width: 0;
  height: var(--button-height-sm);
  color: var(--color-text-primary);
}

.search-bar__placeholder {
  flex: 1;
  color: var(--color-text-tertiary);
}

.search-bar__clear {
  padding: 0 var(--space-xs);
  color: var(--color-text-tertiary);
}

.search-bar__cancel,
.search-bar__submit {
  flex-shrink: 0;
  color: var(--color-primary);
}

.search-bar__submit {
  font-weight: 500;
}
