.album-flip-book {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-flip-book__empty {
  padding: var(--space-xl) var(--space-md);
  text-align: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-album-frame-line);
}

.album-flip-book__empty-text {
  color: var(--color-text-tertiary);
}

.album-flip-book__book {
  position: relative;
  padding-left: var(--space-sm);
}

.album-flip-book__spine {
  position: absolute;
  left: 0;
  top: 12%;
  bottom: 12%;
  width: 12rpx;
  border-radius: var(--radius-sm);
  background: linear-gradient(
    90deg,
    var(--color-album-frame-line) 0%,
    var(--color-album-frame) 100%
  );
  box-shadow: var(--shadow-card-soft);
}

.album-flip-book__frame {
  position: relative;
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-album-frame);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.album-flip-book__frame-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-md);
  border-bottom: 1rpx solid var(--color-album-frame-line);
  background: var(--color-bg-album);
}

.album-flip-book__label {
  font-size: var(--font-album-display);
  line-height: var(--font-album-display-lh);
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--color-text-secondary);
}

.album-flip-book__counter {
  color: var(--color-text-tertiary);
}

.album-flip-book__swiper {
  height: 920rpx;
}

.album-flip-book__page {
  display: flex;
  flex-direction: column;
  height: 100%;
  margin: var(--space-sm) var(--space-xs);
  background: var(--color-bg-album);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-album-frame-line);
  box-shadow: var(--shadow-card-soft);
  overflow: hidden;
  transform: scale(0.96);
  opacity: 0.88;
  transition:
    transform 320ms ease,
    opacity 320ms ease;
}

.album-flip-book__page--active {
  transform: scale(1);
  opacity: 1;
  box-shadow: var(--shadow-card);
}

.album-flip-book__photo {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm);
  background: var(--color-bg-muted);
}

.album-flip-book__img {
  width: 100%;
  height: 100%;
  max-height: 620rpx;
}

.album-flip-book__caption {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-md);
  border-top: 1rpx solid var(--color-album-frame-line);
  background: var(--color-bg-card);
  min-height: 200rpx;
  box-sizing: border-box;
}

.album-flip-book__node {
  color: var(--color-text-primary);
}

.album-flip-book__sub,
.album-flip-book__time {
  color: var(--color-text-tertiary);
}

.album-flip-book__note {
  color: var(--color-text-secondary);
}

.album-flip-book__feedback {
  margin-top: var(--space-xs);
}

.album-flip-book__nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-card);
  opacity: 0.96;
  border: 1rpx solid var(--color-border);
  z-index: 2;
}

.album-flip-book__nav--prev {
  left: var(--space-xs);
  border-radius: var(--radius-md) 0 0 var(--radius-md);
}

.album-flip-book__nav--next {
  right: var(--space-xs);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
}

.album-flip-book__nav--disabled {
  opacity: 0.35;
  pointer-events: none;
}

.album-flip-book__nav-icon {
  font-size: 40rpx;
  line-height: 1;
  color: var(--color-text-secondary);
}

.album-flip-book__chapters {
  width: 100%;
  white-space: nowrap;
}

.album-flip-book__chapters-inner {
  display: flex;
  flex-direction: row;
  gap: var(--space-xs);
  padding: var(--space-xs) 0;
}

.album-flip-book__chapter {
  flex-shrink: 0;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-card);
}

.album-flip-book__chapter--active {
  border-color: var(--color-album-active);
  background: var(--color-album-active-light);
}

.album-flip-book__chapter-text {
  color: var(--color-text-secondary);
}

.album-flip-book__chapter--active .album-flip-book__chapter-text {
  color: var(--color-album-active);
}

.album-flip-book__hint {
  display: block;
  text-align: center;
  color: var(--color-text-tertiary);
  padding-bottom: var(--space-xs);
}
