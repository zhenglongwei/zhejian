<view wx:if="{{visible}}" class="album-info-sheet">
  <view class="album-info-sheet__mask" bindtap="onMaskTap" />
  <view class="album-info-sheet__panel safe-bottom" catchtap="noop">
    <view class="album-info-sheet__head">
      <text class="album-info-sheet__title text-h3">说明与档案</text>
      <view
        class="album-info-sheet__close"
        hover-class="album-info-sheet__close--hover"
        bindtap="onCloseTap"
        aria-role="button"
        aria-label="关闭"
      >
        <text class="album-info-sheet__close-icon">×</text>
      </view>
    </view>

    <scroll-view class="album-info-sheet__body" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{pageProgress}}" class="album-info-sheet__progress-row">
        <text class="text-caption">阅读进度 {{pageProgress}}</text>
      </view>

      <ui-privacy-banner scene="{{scene}}" />

      <block wx:if="{{aiSummary}}">
        <view class="album-info-sheet__section-title text-caption">维修摘要</view>
        <ui-ai-summary-block content="{{aiSummary}}" />
      </block>

      <block wx:if="{{hasSummaryRows}}">
        <view class="album-info-sheet__section-title text-caption">档案摘要</view>
        <ui-key-info-table rows="{{summaryRows}}" />
      </block>

      <block wx:if="{{showStoreLink && storeId}}">
        <view class="album-info-sheet__section-title text-caption">关联门店</view>
        <ui-store-card
          storeId="{{storeId}}"
          name="{{storeName}}"
          subtitle="{{storeSubtitle}}"
          showLink="{{true}}"
          bind:cardtap="onStoreTap"
        />
        <text class="album-info-sheet__store-hint text-caption">可查看本店公开案例与服务方案</text>
      </block>

      <block wx:if="{{hasParts}}">
        <view class="album-info-sheet__section-title text-caption">配件清单</view>
        <album-part-row
          wx:for="{{parts}}"
          wx:key="partId"
          variant="card"
          index="{{index}}"
          thumb-url="{{item.thumbUrl}}"
          name="{{item.name}}"
          part-type="{{item.partType}}"
          type-variant="{{item.typeVariant || 'default'}}"
          qty="{{item.qty}}"
          bind:tap="onPartTap"
        />
        <view wx:if="{{showPartVerifyEntry}}" class="album-info-sheet__verify">
          <ui-button type="secondary" size="sm" block bind:btntap="onPartVerifyTap">
            配件验真
          </ui-button>
          <text wx:if="{{partVerifySummary}}" class="text-caption album-info-sheet__verify-hint">
            {{partVerifySummary}}
          </text>
        </view>
      </block>

      <block wx:if="{{hasNotes}}">
        <view class="album-info-sheet__section-title text-caption">门店说明</view>

        <view wx:if="{{storeNote}}" class="album-info-sheet__store-note">
          <text class="album-info-sheet__store-note-label text-caption">门店总说明</text>
          <text class="album-info-sheet__note-text text-body">{{storeNote}}</text>
        </view>

        <view
          wx:for="{{nodeNotes}}"
          wx:key="nodeId"
          class="album-info-sheet__note-item"
        >
          <image
            wx:if="{{item.thumbUrl}}"
            class="album-info-sheet__thumb"
            src="{{item.thumbUrl}}"
            mode="aspectFill"
          />
          <view wx:else class="album-info-sheet__thumb album-info-sheet__thumb--placeholder" />
          <view class="album-info-sheet__note-content">
            <text class="album-info-sheet__node-title text-body">{{item.nodeTitle}}</text>
            <text class="album-info-sheet__note-text text-caption">{{item.note}}</text>
          </view>
        </view>
      </block>

      <view wx:if="{{showContact && hasStorePhone}}" class="album-info-sheet__contact">
        <ui-button type="secondary" block bind:btntap="onContactTap">联系门店</ui-button>
      </view>

      <ui-compliance-notice wx:if="{{showCompliance}}" type="homePlatform" />
    </scroll-view>
  </view>
</view>
