.review-card {
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.review-card--compact {
  padding: var(--space-sm) var(--space-md);
}

.review-card--plain {
  padding: 0;
  background-color: transparent;
  border: none;
  border-radius: 0;
}

.review-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
}

.review-card__user {
  flex: 1;
  min-width: 0;
}

.review-card__name {
  display: block;
}

.review-card__time {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.review-card__score-row {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.review-card__stars {
  display: flex;
  gap: var(--space-star-gap);
}

.review-card__star {
  font-size: var(--size-rating-star);
  line-height: 1;
  color: var(--color-border-strong);
}

.review-card__star.is-active {
  color: var(--color-warning);
}

.review-card__score {
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.review-card__service {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-tertiary);
}

.review-card__content {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-primary);
}

.review-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.review-card__status {
  margin-top: var(--space-sm);
}

.review-card__images {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.review-card__image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  background-color: var(--color-bg-muted);
}

.review-card__image-notice {
  width: 100%;
  margin-top: var(--space-xs);
}
