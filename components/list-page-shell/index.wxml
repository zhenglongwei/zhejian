<view class="list-page-shell">
  <slot name="intro" />

  <view
    wx:if="{{tabs.length}}"
    class="list-page-shell__tabs page-content {{tabsCard ? 'list-page-shell__tabs--card' : ''}}"
  >
    <ui-tabs
      tabs="{{tabs}}"
      activeKey="{{activeKey}}"
      scrollable="{{scrollableTabs}}"
      bind:change="onTabChange"
    />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content list-page-shell__body">
      <ui-skeleton wx:for="{{skeletonItems}}" wx:key="*this" rows="{{skeletonRows}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="page-content">
      <ui-empty
        title="{{unauthTitle}}"
        description="{{unauthDescription}}"
        actionText="{{unauthActionText}}"
        bind:action="onUnauthAction"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="{{errorActionText}}"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content list-page-shell__empty">
      <slot name="empty">
        <ui-empty
          title="{{emptyTitle}}"
          description="{{emptyDescription}}"
          actionText="{{emptyActionText}}"
          bind:action="onEmptyAction"
        />
      </slot>
    </view>
  </block>

  <block wx:else>
    <view class="page-content list-page-shell__body {{bodyClearance ? 'list-page-shell__body--clearance' : ''}}">
      <slot />
    </view>
  </block>

  <slot name="footer" />
</view>
