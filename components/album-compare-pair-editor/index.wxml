<view class="album-compare-pair-editor">
  <view class="album-compare-pair-editor__head">
    <text class="album-compare-pair-editor__title text-h3">{{title}}</text>
    <ui-tag
      wx:if="{{requiredLevelLabel}}"
      variant="{{requiredLevelVariant || 'default'}}"
      text="{{requiredLevelLabel}}"
    />
  </view>

  <text wx:if="{{description}}" class="album-compare-pair-editor__desc text-caption">{{description}}</text>

  <view class="album-compare-pair-editor__table">
    <view class="album-compare-pair-editor__table-head album-compare-pair-editor__table-head--labels">
      <view class="album-compare-pair-editor__col-head">
        <text class="album-compare-pair-editor__col-label text-caption">{{afterColumnLabel}}</text>
        <text class="album-compare-pair-editor__col-sub text-caption">同角拍摄</text>
      </view>
      <view class="album-compare-pair-editor__col-head">
        <text class="album-compare-pair-editor__col-label text-caption">{{beforeColumnLabel}}</text>
        <text class="album-compare-pair-editor__col-sub text-caption">可后补</text>
      </view>
    </view>

    <view
      wx:for="{{pairRows}}"
      wx:key="index"
      class="album-compare-pair-editor__table-row"
    >
      <view class="album-compare-pair-editor__cell">
        <ui-image-uploader
          images="{{item.after ? [item.after] : []}}"
          maxCount="{{1}}"
          variant="album"
          disabled="{{disabled}}"
          data-index="{{index}}"
          data-field="after"
          bind:change="onRowImageChange"
        />
      </view>
      <view class="album-compare-pair-editor__cell">
        <ui-image-uploader
          images="{{item.before ? [item.before] : []}}"
          maxCount="{{1}}"
          variant="album"
          disabled="{{disabled}}"
          data-index="{{index}}"
          data-field="before"
          bind:change="onRowImageChange"
        />
      </view>
      <text
        wx:if="{{!disabled && pairRows.length > 1}}"
        class="album-compare-pair-editor__remove text-caption text-link"
        data-index="{{index}}"
        catchtap="onRemoveRow"
      >删除</text>
    </view>
  </view>

  <view wx:if="{{!disabled && pairRows.length < maxCount}}" class="album-compare-pair-editor__add-row">
    <ui-button type="secondary" size="sm" bind:btntap="onAddRow">添加一组</ui-button>
  </view>

  <view wx:if="{{pairPreview.length}}" class="album-compare-pair-editor__preview">
    <text class="album-compare-pair-editor__preview-title text-caption">配对预览</text>
    <view
      wx:for="{{pairPreview}}"
      wx:key="index"
      class="album-compare-pair-editor__preview-row"
    >
      <text class="album-compare-pair-editor__preview-label text-caption">{{item.label}}</text>
      <view class="album-compare-pair-editor__preview-body">
        <view class="album-compare-pair-editor__preview-thumb {{item.beforeUrl ? '' : 'album-compare-pair-editor__preview-thumb--empty'}}">
          <image
            wx:if="{{item.beforeUrl}}"
            class="album-compare-pair-editor__preview-img"
            src="{{item.beforeUrl}}"
            mode="aspectFill"
          />
          <text wx:else class="album-compare-pair-editor__preview-ph text-caption">前</text>
        </view>
        <view class="album-compare-pair-editor__preview-bridge" aria-hidden="true">
          <view class="album-compare-pair-editor__preview-line" />
          <view class="album-compare-pair-editor__preview-dot album-compare-pair-editor__preview-dot--left" />
          <view class="album-compare-pair-editor__preview-dot album-compare-pair-editor__preview-dot--right" />
        </view>
        <view class="album-compare-pair-editor__preview-thumb {{item.afterUrl ? '' : 'album-compare-pair-editor__preview-thumb--empty'}}">
          <image
            wx:if="{{item.afterUrl}}"
            class="album-compare-pair-editor__preview-img"
            src="{{item.afterUrl}}"
            mode="aspectFill"
          />
          <text wx:else class="album-compare-pair-editor__preview-ph text-caption">后</text>
        </view>
        <text
          wx:if="{{item.complete}}"
          class="album-compare-pair-editor__preview-status text-caption"
        >可对比</text>
        <text
          wx:else
          class="album-compare-pair-editor__preview-status text-caption"
        >仅完工</text>
      </view>
    </view>
  </view>

  <view class="album-compare-pair-editor__actions">
    <ui-button
      wx:if="{{!disabled && showSyncAssessment}}"
      type="secondary"
      size="sm"
      bind:btntap="onSyncFromAssessment"
    >从检测记录填入维修前</ui-button>
  </view>

  <textarea
    class="album-compare-pair-editor__note input"
    placeholder="{{notePlaceholder}}"
    value="{{note}}"
    disabled="{{disabled}}"
    bindinput="onNoteInput"
  />
  <text wx:if="{{uploadHint}}" class="album-compare-pair-editor__upload-hint text-caption">{{uploadHint}}</text>
</view>
