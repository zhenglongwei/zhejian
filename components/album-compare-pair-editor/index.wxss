.album-compare-pair-editor {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-compare-pair-editor__head {
  display: flex;
  gap: var(--space-xs);
  align-items: center;
  justify-content: space-between;
}

.album-compare-pair-editor__title {
  flex: 1;
  min-width: 0;
}

.album-compare-pair-editor__desc {
  color: var(--color-text-secondary);
}

.album-compare-pair-editor__tips {
  color: var(--color-text-tertiary);
}

.album-compare-pair-editor__compare-hint {
  display: block;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  color: var(--color-text-secondary);
  background: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
}

.album-compare-pair-editor__table {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.album-compare-pair-editor__table-head,
.album-compare-pair-editor__table-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: var(--space-sm);
  align-items: start;
}

.album-compare-pair-editor__table-head {
  padding-bottom: var(--space-xs);
  border-bottom: 1rpx solid var(--color-border);
}

.album-compare-pair-editor__col-label {
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.album-compare-pair-editor__table-row {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx dashed var(--color-border);
}

.album-compare-pair-editor__table-row:last-child {
  border-bottom: none;
}

.album-compare-pair-editor__cell {
  min-width: 0;
}

.album-compare-pair-editor__remove {
  align-self: center;
  padding: var(--space-xs);
  white-space: nowrap;
}

.album-compare-pair-editor__add-row {
  margin-top: var(--space-xs);
}

.album-compare-pair-editor__sections {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: var(--space-xs);
}

.album-compare-pair-editor__section {
  width: 100%;
}

.album-compare-pair-editor__section-title {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}

.album-compare-pair-editor__section-hint {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
}

.album-compare-pair-editor__section-divider {
  display: flex;
  gap: var(--space-sm);
  align-items: center;
  margin: var(--space-md) 0;
}

.album-compare-pair-editor__section-divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.album-compare-pair-editor__section-divider-label {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
}

.album-compare-pair-editor__warn {
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  color: var(--color-warning);
  background: var(--color-warning-light);
}

.album-compare-pair-editor__preview {
  padding: var(--space-sm);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  background: var(--color-album-frame-inner);
}

.album-compare-pair-editor__preview-title {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.album-compare-pair-editor__preview-row {
  margin-bottom: var(--space-sm);
}

.album-compare-pair-editor__preview-row:last-child {
  margin-bottom: 0;
}

.album-compare-pair-editor__preview-label {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-tertiary);
}

.album-compare-pair-editor__preview-body {
  display: flex;
  gap: var(--space-xs);
  align-items: center;
}

.album-compare-pair-editor__preview-thumb {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  overflow: hidden;
  border-radius: var(--radius-album-list-thumb);
  border: 1rpx solid var(--color-album-frame-line);
  background: var(--color-album-frame-inner);
  box-shadow: var(--shadow-album-list-thumb);
}

.album-compare-pair-editor__preview-thumb--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--color-album-frame-line);
}

.album-compare-pair-editor__preview-img {
  display: block;
  width: 100%;
  height: 100%;
}

.album-compare-pair-editor__preview-ph {
  color: var(--color-text-tertiary);
}

.album-compare-pair-editor__preview-bridge {
  position: relative;
  flex-shrink: 0;
  width: 72rpx;
  height: 32rpx;
}

.album-compare-pair-editor__preview-line {
  position: absolute;
  top: 50%;
  right: 8rpx;
  left: 8rpx;
  height: 4rpx;
  margin-top: -2rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  opacity: 0.45;
}

.album-compare-pair-editor__preview-dot {
  position: absolute;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  margin-top: -7rpx;
  border: 3rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  background: var(--color-bg-card);
  box-sizing: border-box;
}

.album-compare-pair-editor__preview-dot--left {
  left: 0;
}

.album-compare-pair-editor__preview-dot--right {
  right: 0;
  background: var(--color-primary);
}

.album-compare-pair-editor__preview-status {
  flex: 1;
  min-width: 0;
  color: var(--color-warning);
}

.album-compare-pair-editor__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.album-compare-pair-editor__note {
  width: 100%;
  min-height: 120rpx;
  margin-top: var(--space-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-album-frame-line);
  background-color: var(--color-album-frame-inner);
  font-size: var(--font-body);
  box-sizing: border-box;
}

.album-compare-pair-editor__upload-hint {
  color: var(--color-text-tertiary);
}
