<view class="mine-user-header">
  <view class="mine-user-header__avatar-shell">
    <button
      wx:if="{{isLoggedIn}}"
      class="mine-user-header__avatar-btn"
      open-type="chooseAvatar"
      bind:chooseavatar="onChooseAvatar"
      aria-label="选择头像"
    >
      <image
        wx:if="{{displayAvatarUrl}}"
        class="mine-user-header__avatar"
        src="{{displayAvatarUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="mine-user-header__avatar mine-user-header__avatar--placeholder image-placeholder">
        <text class="mine-user-header__avatar-icon">👤</text>
      </view>
    </button>
    <view
      wx:else
      class="mine-user-header__avatar mine-user-header__avatar--placeholder image-placeholder"
    >
      <text class="mine-user-header__avatar-icon">👤</text>
    </view>
    <text wx:if="{{isLoggedIn}}" class="mine-user-header__avatar-hint">换头像</text>
  </view>

  <view class="mine-user-header__meta">
    <block wx:if="{{isLoggedIn}}">
      <input
        class="mine-user-header__nickname-input"
        type="nickname"
        placeholder="昵称（选填）"
        placeholder-class="mine-user-header__nickname-placeholder"
        value="{{nicknameInput}}"
        maxlength="32"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
      <text wx:if="{{user.isPhoneBound}}" class="mine-user-header__phone text-caption">{{user.phoneDisplay}}</text>
      <view wx:else class="mine-user-header__bind-hint">
        <ui-tag variant="info" text="未绑定手机号" />
        <text class="mine-user-header__bind-desc text-caption">绑定后可接收相册更新与配件确认通知</text>
        <ui-button type="secondary" size="sm" catch:tap="onBindPhoneTap">绑定手机号</ui-button>
      </view>
    </block>
    <block wx:else>
      <view class="mine-user-header__guest">
        <ui-button type="primary" block bind:btntap="onLoginTap">{{guestLoginButton}}</ui-button>
      </view>
    </block>
  </view>
</view>
