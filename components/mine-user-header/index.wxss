.mine-user-header {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.mine-user-header__avatar-shell {
  position: relative;
  flex-shrink: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
}

.mine-user-header__avatar-btn {
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  max-width: 120rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  line-height: 1;
  display: block;
  box-sizing: border-box;
  border-radius: var(--radius-full);
}

.mine-user-header__avatar-btn::after {
  display: none;
  border: none;
}

.mine-user-header__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  display: block;
}

.mine-user-header__avatar--placeholder {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
}

.mine-user-header--hub:active {
  opacity: 0.72;
}

.mine-user-header__nickname {
  display: block;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.mine-user-header__vehicle {
  display: block;
}

.mine-user-header__chevron {
  flex-shrink: 0;
  margin-left: var(--space-xs);
  color: var(--color-text-tertiary);
  font-size: 40rpx;
  line-height: 1;
}

.mine-user-header__avatar-icon {
  font-size: 48rpx;
  opacity: 0.5;
}

.mine-user-header__avatar-hint {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  padding: 6rpx 0;
  text-align: center;
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--color-text-inverse);
  background-color: var(--color-mask);
  pointer-events: none;
}

.mine-user-header__meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: var(--space-xs);
}

.mine-user-header__nickname {
  display: block;
}

.mine-user-header__nickname-input {
  display: block;
  width: 100%;
  min-width: 0;
  height: var(--font-h2-lh);
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  box-sizing: border-box;
  font-size: var(--font-h2);
  line-height: var(--font-h2-lh);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.mine-user-header__nickname-placeholder {
  font-size: var(--font-h2);
  line-height: var(--font-h2-lh);
  font-weight: var(--font-weight-regular);
  color: var(--color-text-tertiary);
}

.mine-user-header__phone {
  display: block;
  color: var(--color-text-secondary);
}

.mine-user-header__guest {
  width: 100%;
}

.mine-user-header__bind-desc {
  display: block;
  color: var(--color-text-tertiary);
}

.mine-user-header__bind-hint {
  margin-top: var(--space-sm);
}

.mine-user-header__bind-hint {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-xs);
  width: 100%;
}
