.mine-user-header {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
}

.mine-user-header__avatar-wrap {
  flex-shrink: 0;
}

.mine-user-header__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
}

.mine-user-header__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.mine-user-header__avatar-icon {
  font-size: 48rpx;
  opacity: 0.5;
}

.mine-user-header__meta {
  flex: 1;
  min-width: 0;
}

.mine-user-header__nickname {
  display: block;
}

.mine-user-header__phone {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.mine-user-header__guest-desc,
.mine-user-header__bind-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.mine-user-header__login-btn,
.mine-user-header__bind-hint {
  margin-top: var(--space-sm);
}

.mine-user-header__bind-hint {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-xs);
}
