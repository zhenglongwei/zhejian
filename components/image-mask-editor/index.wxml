<view class="mask-editor">
  <view class="mask-editor__hint text-caption">
    在图片上拖拽框选车牌、人脸等敏感区域；可框选多处后应用打码。
  </view>
  <view class="mask-editor__canvas-wrap" style="height: {{canvasH}}px;">
    <canvas
      id="maskCanvas"
      type="2d"
      class="mask-editor__canvas"
      disable-scroll="{{true}}"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
      bindtouchcancel="onTouchEnd"
    />
    <view wx:if="{{!ready}}" class="mask-editor__loading">
      <text class="text-caption">加载图片…</text>
    </view>
  </view>
  <view class="mask-editor__toolbar">
    <view class="mask-editor__modes">
      <view
        class="mask-editor__mode {{activeMode === 'mosaic' ? 'mask-editor__mode--active' : ''}}"
        data-mode="mosaic"
        bindtap="onSetMode"
      >马赛克</view>
      <view
        class="mask-editor__mode {{activeMode === 'blur' ? 'mask-editor__mode--active' : ''}}"
        data-mode="blur"
        bindtap="onSetMode"
      >模糊</view>
    </view>
    <view class="mask-editor__actions">
      <ui-button type="ghost" size="sm" bind:tap="onUndo" disabled="{{!regions.length}}">撤销</ui-button>
      <ui-button type="ghost" size="sm" bind:tap="onClear" disabled="{{!regions.length}}">清除</ui-button>
    </view>
  </view>
  <view class="mask-editor__footer">
    <ui-button type="primary" block loading="{{submitting}}" disabled="{{!ready || submitting}}" bind:tap="onSubmit">
      应用打码（{{regions.length}} 处）
    </ui-button>
  </view>
</view>
