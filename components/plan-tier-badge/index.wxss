/**
 * 方案档位 · 相册扉页 chip（暖灰线框，不用 info/warning 促销色）
 */
.plan-tier-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  box-sizing: border-box;
  color: var(--color-text-secondary);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-album-list-thumb);
}

.plan-tier-badge__mark {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plan-tier-badge__text {
  white-space: nowrap;
  font-weight: var(--font-weight-medium);
}

.plan-tier-badge--flagship {
  color: var(--color-text-primary);
}

.plan-tier-badge--flagship .plan-tier-badge__text {
  font-weight: var(--font-weight-semibold);
}

/* md · 扉页 */
.plan-tier-badge--size-md {
  height: 44rpx;
  padding: 0 var(--space-sm);
}

.plan-tier-badge--size-md .plan-tier-badge__mark {
  width: 24rpx;
  height: 24rpx;
}

.plan-tier-badge--size-md .plan-tier-badge__text {
  font-size: var(--font-caption);
  line-height: var(--font-caption-lh);
}

/* lg · 套餐页当前方案 */
.plan-tier-badge--size-lg {
  height: 52rpx;
  padding: 0 var(--space-md);
  gap: var(--space-sm);
}

.plan-tier-badge--size-lg .plan-tier-badge__mark {
  width: 28rpx;
  height: 28rpx;
}

.plan-tier-badge--size-lg .plan-tier-badge__text {
  font-size: var(--font-body);
  line-height: var(--font-body-lh);
}

/* 档位标记 · 统一 album-frame-corner 色 */
.plan-tier-badge--size-md.plan-tier-badge--basic .plan-tier-badge__glyph {
  width: 14rpx;
  height: 10rpx;
  border: 2rpx solid var(--color-album-frame-corner);
  border-radius: 2rpx;
  box-sizing: border-box;
}

.plan-tier-badge--size-lg.plan-tier-badge--basic .plan-tier-badge__glyph {
  width: 16rpx;
  height: 11rpx;
  border: 2rpx solid var(--color-album-frame-corner);
  border-radius: 2rpx;
  box-sizing: border-box;
}

.plan-tier-badge--size-md.plan-tier-badge--standard .plan-tier-badge__glyph {
  position: relative;
  width: 16rpx;
  height: 13rpx;
}

.plan-tier-badge--size-md.plan-tier-badge--standard .plan-tier-badge__glyph::before,
.plan-tier-badge--size-md.plan-tier-badge--standard .plan-tier-badge__glyph::after {
  content: '';
  position: absolute;
  left: 0;
  width: 13rpx;
  height: 9rpx;
  border: 2rpx solid var(--color-album-frame-corner);
  border-radius: 2rpx;
  box-sizing: border-box;
  background-color: var(--color-album-frame-inner);
}

.plan-tier-badge--size-md.plan-tier-badge--standard .plan-tier-badge__glyph::before {
  top: 0;
  opacity: 0.45;
}

.plan-tier-badge--size-md.plan-tier-badge--standard .plan-tier-badge__glyph::after {
  top: 4rpx;
  left: 3rpx;
}

.plan-tier-badge--size-lg.plan-tier-badge--standard .plan-tier-badge__glyph {
  position: relative;
  width: 18rpx;
  height: 15rpx;
}

.plan-tier-badge--size-lg.plan-tier-badge--standard .plan-tier-badge__glyph::before,
.plan-tier-badge--size-lg.plan-tier-badge--standard .plan-tier-badge__glyph::after {
  content: '';
  position: absolute;
  left: 0;
  width: 15rpx;
  height: 10rpx;
  border: 2rpx solid var(--color-album-frame-corner);
  border-radius: 2rpx;
  box-sizing: border-box;
  background-color: var(--color-album-frame-inner);
}

.plan-tier-badge--size-lg.plan-tier-badge--standard .plan-tier-badge__glyph::before {
  top: 0;
  opacity: 0.45;
}

.plan-tier-badge--size-lg.plan-tier-badge--standard .plan-tier-badge__glyph::after {
  top: 5rpx;
  left: 3rpx;
}

.plan-tier-badge--size-md.plan-tier-badge--flagship .plan-tier-badge__glyph {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid var(--color-album-frame-corner);
  border-right: 3rpx solid var(--color-album-frame-corner);
  box-sizing: border-box;
}

.plan-tier-badge--size-lg.plan-tier-badge--flagship .plan-tier-badge__glyph {
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid var(--color-album-frame-corner);
  border-right: 3rpx solid var(--color-album-frame-corner);
  box-sizing: border-box;
}
