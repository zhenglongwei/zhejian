<view wx:if="{{displayText}}" class="plan-tier-badge plan-tier-badge--{{tierClass}} plan-tier-badge--size-{{sizeClass}}">
  <view class="plan-tier-badge__mark" aria-hidden="true">
    <view class="plan-tier-badge__glyph" />
  </view>
  <text class="plan-tier-badge__text">{{displayText}}</text>
</view>
