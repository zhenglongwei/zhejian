.album-authorize-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-authorize-section__title {
  display: block;
  color: var(--color-text-primary);
}

.album-authorize-section__reject-link {
  margin-top: var(--space-3);
}

.album-authorize-section__actions {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.album-authorize-section__action {
  flex: 1;
  min-width: 0;
}

.album-authorize-section__tiers {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.album-authorize-section__tier {
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
}

.album-authorize-section__tier--active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.album-authorize-section__tier-label {
  display: block;
  color: var(--color-text-primary);
}

.album-authorize-section__tier-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}
