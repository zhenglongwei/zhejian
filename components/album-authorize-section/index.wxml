<ui-card shadow="{{true}}" padding="{{true}}">
  <view class="album-authorize-section">
    <text class="album-authorize-section__title text-h3">{{title}}</text>

    <view wx:if="{{pitch}}" class="album-authorize-section__pitch">
      <text class="text-body">{{pitch}}</text>
    </view>

    <view wx:if="{{benefitLine}}" class="album-authorize-section__benefit">
      <text class="text-body album-authorize-section__benefit-text">{{benefitLine}}</text>
      <text wx:if="{{disclaimer}}" class="text-caption album-authorize-section__disclaimer">{{disclaimer}}</text>
    </view>

    <view class="album-authorize-section__control">
      <text class="text-caption">{{controlLine}}</text>
    </view>

    <ui-compliance-notice type="authorize" />

    <ui-checkbox-row
      checked="{{checked}}"
      disabled="{{submitting}}"
      bind:toggle="onToggle"
    >
      <text>{{consentText}}</text>
      <text
        wx:if="{{showPolicyLink}}"
        class="text-link"
        catchtap="onPolicyTap"
      >{{policyLinkText}}</text>
    </ui-checkbox-row>
    <view wx:if="{{!showActions && showRejectLink}}" class="album-authorize-section__reject-link">
      <text class="text-caption text-link" bindtap="onReject">{{rejectText}}</text>
    </view>
    <view wx:if="{{showActions}}" class="album-authorize-section__actions">
      <view class="album-authorize-section__action">
        <ui-button
          type="ghost"
          size="sm"
          block="{{true}}"
          disabled="{{submitting}}"
          bind:btntap="onReject"
        >{{rejectText}}</ui-button>
      </view>
      <view class="album-authorize-section__action">
        <ui-button
          type="primary"
          size="sm"
          block="{{true}}"
          disabled="{{submitting}}"
          bind:btntap="onSubmit"
        >{{confirmText}}</ui-button>
      </view>
    </view>
  </view>
</ui-card>
