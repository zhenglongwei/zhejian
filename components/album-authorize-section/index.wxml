<ui-card shadow="{{true}}" padding="{{true}}">
  <view class="album-authorize-section">
    <text class="album-authorize-section__title text-h3">{{title}}</text>
    <ui-compliance-notice type="authorize" />
    <view class="album-authorize-section__notice">
      <text class="text-caption">授权公示将在 H5/GEO 展示脱敏后的公开素材，并展示服务门店名称。</text>
    </view>
    <ui-checkbox-row
      checked="{{checked}}"
      disabled="{{submitting}}"
      bind:toggle="onToggle"
    >
      <text>我已核对公开内容，同意授权公示本次服务相册（含门店名称）。</text>
      <text
        wx:if="{{showPolicyLink}}"
        class="text-link"
        catchtap="onPolicyTap"
      >{{policyLinkText}}</text>
    </ui-checkbox-row>
    <view wx:if="{{!showActions && showRejectLink}}" class="album-authorize-section__reject-link">
      <text class="text-caption text-link" bindtap="onReject">{{rejectText}}</text>
    </view>
    <view wx:if="{{showActions}}" class="album-authorize-section__actions">
      <view class="album-authorize-section__action">
        <ui-button
          type="ghost"
          size="sm"
          block="{{true}}"
          disabled="{{submitting}}"
          bind:btntap="onReject"
        >{{rejectText}}</ui-button>
      </view>
      <view class="album-authorize-section__action">
        <ui-button
          type="primary"
          size="sm"
          block="{{true}}"
          disabled="{{submitting}}"
          bind:btntap="onSubmit"
        >{{confirmText}}</ui-button>
      </view>
    </view>
  </view>
</ui-card>
