<ui-card shadow="{{true}}" padding="{{true}}">
  <view class="album-authorize-section">
    <text class="album-authorize-section__title text-h3">{{title}}</text>
    <ui-compliance-notice type="authorize" />
    <view class="album-authorize-section__tiers">
      <view
        class="album-authorize-section__tier {{authTier === 'named' ? 'album-authorize-section__tier--active' : ''}}"
        data-tier="named"
        bindtap="onTierTap"
      >
        <text class="album-authorize-section__tier-label text-body">实名授权</text>
        <text class="album-authorize-section__tier-desc text-caption">可展示门店与车型信息</text>
      </view>
      <view
        class="album-authorize-section__tier {{authTier === 'anonymous' ? 'album-authorize-section__tier--active' : ''}}"
        data-tier="anonymous"
        bindtap="onTierTap"
      >
        <text class="album-authorize-section__tier-label text-body">匿名授权</text>
        <text class="album-authorize-section__tier-desc text-caption">不展示门店名称</text>
      </view>
    </view>
    <ui-checkbox-row
      checked="{{checked}}"
      disabled="{{submitting}}"
      bind:toggle="onToggle"
    >
      <text>我已核对公开内容，同意将本次服务相册公开为案例。</text>
      <text
        wx:if="{{showPolicyLink}}"
        class="text-link"
        catchtap="onPolicyTap"
      >{{policyLinkText}}</text>
    </ui-checkbox-row>
    <view class="album-authorize-section__actions">
      <view class="album-authorize-section__action">
        <ui-button
          type="ghost"
          size="sm"
          block="{{true}}"
          disabled="{{submitting}}"
          bind:tap="onReject"
        >{{rejectText}}</ui-button>
      </view>
      <view class="album-authorize-section__action">
        <ui-button
          type="primary"
          size="sm"
          block="{{true}}"
          disabled="{{submitting}}"
          bind:tap="onSubmit"
        >{{confirmText}}</ui-button>
      </view>
    </view>
  </view>
</ui-card>
