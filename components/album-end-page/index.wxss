.album-end-page {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  min-height: 0;
}

.album-end-page__sheet {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  min-height: 0;
  padding: var(--space-xl) var(--space-md);
}

.album-end-page__finisher {
  display: flex;
  gap: var(--space-sm);
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: var(--space-md);
}

.album-end-page__finisher-line {
  flex: 1;
  max-width: 120rpx;
  height: 1rpx;
  background: var(--color-album-end-finish);
  opacity: 0.55;
}

.album-end-page__finisher-label {
  flex-shrink: 0;
  color: var(--color-album-end-finish);
  letter-spacing: 0.12em;
}

.album-end-page__album-title {
  display: block;
  max-width: 100%;
  margin-bottom: var(--space-lg);
  overflow: hidden;
  text-align: center;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--color-text-tertiary);
}

.album-end-page__actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  width: 100%;
  max-width: 420rpx;
}

.album-end-page__hint {
  display: block;
  margin-top: calc(-1 * var(--space-xs));
  margin-bottom: var(--space-xs);
  text-align: center;
  color: var(--color-text-tertiary);
}
