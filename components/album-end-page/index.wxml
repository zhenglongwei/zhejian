<view class="album-end-page">
  <view class="album-end-page__sheet">
    <view class="album-end-page__finisher" aria-hidden="true">
      <view class="album-end-page__finisher-line" />
      <text class="album-end-page__finisher-label text-caption">本册已阅</text>
      <view class="album-end-page__finisher-line" />
    </view>

    <text wx:if="{{albumTitle}}" class="album-end-page__album-title">{{albumTitle}}</text>

    <view wx:if="{{invitePitch}}" class="album-end-page__invite surface-album-panel">
      <text wx:if="{{inviteEyebrow}}" class="album-end-page__eyebrow">{{inviteEyebrow}}</text>
      <text class="album-end-page__pitch">{{invitePitch}}</text>
      <view wx:if="{{controlLine}}" class="album-end-page__trust">
        <text class="album-end-page__trust-label">你的控制权</text>
        <text class="album-end-page__control">{{controlLine}}</text>
      </view>
    </view>

    <text wx:if="{{statusHint}}" class="album-end-page__status">{{statusHint}}</text>

    <view class="album-end-page__actions">
      <ui-button
        wx:for="{{gateActions}}"
        wx:key="key"
        type="secondary"
        block
        data-key="{{item.key}}"
        bind:btntap="onGateActionTap"
      >{{item.label}}</ui-button>

      <view wx:if="{{showPreview}}" class="album-end-page__preview-wrap">
        <ui-button
          type="primary"
          disabled="{{previewDisabled}}"
          bind:btntap="onPreviewTap"
        >{{previewLabel}}</ui-button>
      </view>
      <text
        wx:if="{{showPreview && previewDisabled && previewHint}}"
        class="album-end-page__status album-end-page__status--tight"
      >{{previewHint}}</text>

      <ui-button
        wx:if="{{showWithdraw}}"
        type="secondary"
        block
        bind:btntap="onWithdrawTap"
      >{{withdrawLabel}}</ui-button>

      <ui-button
        wx:if="{{showStoreBrowse}}"
        type="secondary"
        block
        bind:btntap="onStoreBrowseTap"
      >{{storeBrowseLabel}}</ui-button>

      <ui-button
        wx:if="{{showContact}}"
        type="secondary"
        block
        bind:btntap="onContactTap"
      >{{contactLabel}}</ui-button>

      <view
        wx:if="{{showFeedback}}"
        class="album-end-page__feedback"
        bindtap="onFeedbackTap"
        hover-class="album-end-page__feedback--hover"
        hover-stay-time="80"
      >
        <text class="album-end-page__feedback-text">{{feedbackLabel}}</text>
      </view>
    </view>
  </view>
</view>
