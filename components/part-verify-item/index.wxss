.part-verify-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md);
  box-sizing: border-box;
}

.part-verify-item__status-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.part-verify-item__detail-toggle {
  padding: var(--space-xs) 0;
}

.part-verify-item__textarea {
  width: 100%;
  min-height: 120rpx;
  box-sizing: border-box;
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
}

.part-verify-item__upload-hint {
  display: block;
  line-height: var(--line-height-relaxed);
}
