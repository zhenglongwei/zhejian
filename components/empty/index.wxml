<view class="empty {{theme === 'album' ? 'empty--album' : ''}}">
  <image wx:if="{{image}}" class="empty__image" src="{{image}}" mode="aspectFit" />
  <view wx:else class="empty__placeholder image-placeholder {{theme === 'album' ? 'empty__placeholder--album' : ''}}" />
  <text class="empty__title text-h3">{{title}}</text>
  <text wx:if="{{description}}" class="empty__desc text-caption">{{description}}</text>
  <view wx:if="{{actionText}}" class="empty__action">
    <ui-button type="primary" size="sm" bind:btntap="onAction">{{actionText}}</ui-button>
  </view>
</view>
