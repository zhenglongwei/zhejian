.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-lg);
  text-align: center;
}

.empty--album {
  padding-top: var(--space-lg);
}

.empty__image,
.empty__placeholder {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: var(--space-md);
}

.empty__placeholder--album {
  border: 2rpx dashed var(--color-album-frame-line);
  border-radius: var(--radius-md);
  background: var(--color-album-frame-inner);
  box-shadow: var(--shadow-album-list-thumb);
}

.empty__title {
  color: var(--color-text-primary);
}

.empty__desc {
  margin-top: var(--space-xs);
  max-width: 520rpx;
}

.empty__action {
  margin-top: var(--space-lg);
}
