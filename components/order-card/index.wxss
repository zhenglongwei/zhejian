.order-card__inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.order-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
}

.order-card__time {
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.order-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.order-card__service {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.order-card__meta {
  color: var(--color-text-secondary);
}

.order-card__price {
  margin-top: var(--space-xs);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.order-card__paid {
  color: var(--color-text-primary);
}

.order-card__price-hint {
  color: var(--color-text-tertiary);
}

.order-card__album-hint {
  color: var(--color-primary);
}

.order-card__actions {
  display: flex;
  justify-content: flex-end;
  margin-top: var(--space-sm);
}
