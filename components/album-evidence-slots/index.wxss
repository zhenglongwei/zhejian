.album-evidence-slots {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.album-evidence-slots__intro {
  margin-bottom: var(--space-xs);
}

.album-evidence-slots__slot {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-album-frame-line);
}

.album-evidence-slots__slot:last-child {
  border-bottom: none;
}

.album-evidence-slots__slot-head {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  align-items: center;
  margin-bottom: var(--space-xs);
}

.album-evidence-slots__slot-label {
  font-weight: var(--font-weight-medium);
}

.album-evidence-slots__slot-hint {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.album-evidence-slots__uploader {
  display: block;
}

.album-evidence-slots__upload-hint {
  display: block;
  color: var(--color-text-tertiary);
  line-height: 1.4;
}
