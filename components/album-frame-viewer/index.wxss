.album-frame-viewer--immersive {
  background: #000;
}

.album-frame-viewer__immersive {
  position: relative;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__swiper--immersive {
  width: 100%;
}

.album-frame-viewer__slide--immersive {
  width: 100%;
  height: 100%;
  background: #000;
}

.album-frame-viewer__photo-tap {
  width: 100%;
  height: 100%;
}

.album-frame-viewer__immersive-photo {
  display: block;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__immersive-end {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  padding: var(--space-lg) var(--space-md);
  background: var(--color-bg-album);
}

.album-frame-viewer__end-book {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  min-height: 360rpx;
  padding: var(--space-lg) var(--space-sm);
}

.album-frame-viewer__immersive-caption {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 2;
  box-sizing: border-box;
  padding: var(--space-xl) var(--space-md) calc(env(safe-area-inset-bottom) + 112rpx);
  pointer-events: none;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.62) 0%, transparent 100%);
}

.album-frame-viewer__immersive-caption-text {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: rgba(255, 255, 255, 0.92);
}

.album-frame-viewer__immersive-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  min-height: 480rpx;
  padding: var(--space-md);
  background: #000;
}

.album-frame-viewer {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  min-height: 0;
}

.album-frame-viewer__frame {
  display: flex;
  flex: 1;
  flex-direction: column;
  box-sizing: border-box;
  min-height: 0;
  height: 100%;
}

.album-frame-viewer__topbar {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  height: var(--size-album-frame-topbar);
  padding: 0 var(--space-md);
  border-bottom: 1rpx solid var(--color-album-frame-line);
  background: var(--color-album-frame-inner);
}

.album-frame-viewer__info {
  padding: var(--space-xs) 0;
}

.album-frame-viewer__swiper {
  flex-shrink: 0;
  width: 100%;
}

.album-frame-viewer__slide {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__photo-wrap {
  flex: 1;
  min-height: 0;
  background: var(--color-bg-muted);
}

.album-frame-viewer__photo {
  display: block;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__caption {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  box-sizing: border-box;
  height: var(--size-album-caption-bar);
  padding: 0 var(--space-md);
  background: var(--color-album-caption-bar);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.album-frame-viewer__caption-text {
  overflow: hidden;
  width: 100%;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--color-text-secondary);
}

.album-frame-viewer__end-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  min-height: 100%;
  padding: var(--space-lg) var(--space-md);
  background: var(--color-album-frame-inner);
}

.album-frame-viewer__loading {
  box-sizing: border-box;
  flex: 1;
  min-height: 480rpx;
  padding: var(--space-md);
}

.album-frame-viewer__empty {
  box-sizing: border-box;
  padding: var(--space-xl) var(--space-md);
  text-align: center;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-lg);
}

.album-frame-viewer__empty-text {
  color: var(--color-text-tertiary);
}
