.album-frame-viewer--immersive {
  background: var(--color-bg-immersive);
}

.album-frame-viewer__immersive {
  position: relative;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__swiper--immersive {
  width: 100%;
}

.album-frame-viewer__slide--immersive {
  width: 100%;
  height: 100%;
  background: var(--color-bg-immersive);
}

.album-frame-viewer__photo-tap {
  width: 100%;
  height: 100%;
}

.album-frame-viewer__immersive-photo {
  display: block;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__slide--immersive.album-frame-viewer__slide--end {
  background: var(--color-bg-album);
}

.album-frame-viewer__immersive-end {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  padding: calc(env(safe-area-inset-top) + var(--space-lg)) var(--space-lg)
    calc(env(safe-area-inset-bottom) + var(--space-lg));
  background: var(--color-bg-album);
}

.album-frame-viewer__end-book {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  min-height: 0;
  max-height: 100%;
}

.album-frame-viewer__immersive-end .album-photo-frame--detail {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 0;
  max-height: 100%;
}

.album-frame-viewer__immersive-caption {
  position: absolute;
  right: 0;
  bottom: calc(env(safe-area-inset-bottom) + var(--space-md));
  left: 0;
  z-index: 2;
  box-sizing: border-box;
  padding: 0 var(--space-md);
  pointer-events: none;
}

.album-frame-viewer__immersive-caption--with-toolbar {
  bottom: calc(env(safe-area-inset-bottom) + 128rpx);
}

.album-frame-viewer__immersive-caption-bar {
  box-sizing: border-box;
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--color-album-immersive-border);
  border-radius: var(--radius-md);
  background: var(--color-album-immersive-caption-bg);
  box-shadow: var(--shadow-album-immersive-panel);
}

.album-frame-viewer__immersive-caption-text {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  font-weight: var(--font-weight-medium);
  line-height: var(--font-body-lh);
  color: #fff;
  text-shadow: var(--shadow-album-caption-text);
  word-break: break-word;
}

.album-frame-viewer__immersive-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  min-height: 480rpx;
  padding: var(--space-md);
  background: var(--color-bg-immersive);
}

.album-frame-viewer {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  min-height: 0;
}

.album-frame-viewer__frame {
  display: flex;
  flex: 1;
  flex-direction: column;
  box-sizing: border-box;
  min-height: 0;
  height: 100%;
}

.album-frame-viewer__topbar {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  height: var(--size-album-frame-topbar);
  padding: 0 var(--space-md);
  border-bottom: 1rpx solid var(--color-album-frame-line);
  background: var(--color-album-frame-inner);
}

.album-frame-viewer__info {
  padding: var(--space-xs) 0;
}

.album-frame-viewer__swiper {
  flex-shrink: 0;
  width: 100%;
}

.album-frame-viewer__slide {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__photo-wrap {
  flex: 1;
  min-height: 0;
  background: var(--color-bg-muted);
}

.album-frame-viewer__photo {
  display: block;
  width: 100%;
  height: 100%;
}

.album-frame-viewer__caption {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  box-sizing: border-box;
  height: var(--size-album-caption-bar);
  padding: 0 var(--space-md);
  background: var(--color-album-caption-bar);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.album-frame-viewer__caption-text {
  overflow: hidden;
  width: 100%;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--color-text-secondary);
}

.album-frame-viewer__end-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  min-height: 100%;
  padding: var(--space-md);
  background: var(--color-bg-album);
}

.album-frame-viewer__loading {
  box-sizing: border-box;
  flex: 1;
  min-height: 480rpx;
  padding: var(--space-md);
}

.album-frame-viewer__empty {
  box-sizing: border-box;
  padding: var(--space-xl) var(--space-md);
  text-align: center;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-lg);
}

.album-frame-viewer__empty-text {
  color: var(--color-text-tertiary);
}
