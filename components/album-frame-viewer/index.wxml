<view class="album-frame-viewer {{immersive ? 'album-frame-viewer--immersive' : ''}}" style="height: {{hostHeight}}px;">
  <block wx:if="{{loading}}">
    <block wx:if="{{immersive}}">
      <view class="album-frame-viewer__immersive-loading">
        <ui-skeleton rows="{{4}}" />
      </view>
    </block>
    <block wx:else>
      <album-photo-frame variant="detail">
        <view class="album-frame-viewer__loading">
          <ui-skeleton rows="{{4}}" />
        </view>
      </album-photo-frame>
    </block>
  </block>

  <block wx:elif="{{!photoCount}}">
    <view class="album-frame-viewer__empty">
      <text class="album-frame-viewer__empty-text text-caption">{{emptyText}}</text>
    </view>
  </block>

  <block wx:elif="{{immersive}}">
    <view class="album-frame-viewer__immersive">
      <swiper
        class="album-frame-viewer__swiper album-frame-viewer__swiper--immersive"
        style="height: {{swiperHeightPx}}px"
        current="{{innerCurrent}}"
        duration="{{280}}"
        easing-function="easeOutCubic"
        bindchange="onSwiperChange"
      >
        <swiper-item wx:for="{{displayPages}}" wx:key="id">
          <view class="album-frame-viewer__slide album-frame-viewer__slide--immersive {{item.type === 'end' ? 'album-frame-viewer__slide--end' : ''}}">
            <block wx:if="{{item.type === 'photo'}}">
              <view class="album-frame-viewer__photo-tap" bindtap="onStageTap">
                <image
                  class="album-frame-viewer__immersive-photo"
                  style="{{item.imageStyle}}"
                  src="{{item.imageUrl}}"
                  mode="aspectFill"
                  show-menu-by-longpress="{{false}}"
                />
                <view wx:if="{{item.imageLabel}}" class="album-frame-viewer__image-label">
                  <text class="album-frame-viewer__image-label-text text-caption">{{item.imageLabel}}</text>
                </view>
              </view>
            </block>
            <block wx:else>
              <view class="album-frame-viewer__immersive-end">
                <album-photo-frame variant="detail">
                  <view class="album-frame-viewer__end-book">
                    <slot name="endPage" />
                  </view>
                </album-photo-frame>
              </view>
            </block>
          </view>
        </swiper-item>
      </swiper>

      <view
        wx:if="{{showImmersiveCaption && currentPageType === 'photo' && currentCaptionLine}}"
        class="album-frame-viewer__immersive-caption {{chromeVisible ? 'album-frame-viewer__immersive-caption--with-toolbar' : ''}}"
      >
        <view class="album-frame-viewer__immersive-caption-bar">
          <text class="album-frame-viewer__immersive-caption-text text-body">{{currentCaptionLine}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <album-photo-frame variant="detail">
      <view class="album-frame-viewer__frame">
        <view class="album-frame-viewer__topbar">
          <text class="album-frame-viewer__page text-album-frame-page">
            {{innerCurrent + 1}} / {{totalCount}}
          </text>
          <text
            class="album-frame-viewer__info text-caption text-link"
            bindtap="onInfoTap"
          >信息</text>
        </view>

        <swiper
          class="album-frame-viewer__swiper"
          style="height: {{swiperHeightPx}}px"
          current="{{innerCurrent}}"
          duration="{{280}}"
          easing-function="easeOutCubic"
          bindchange="onSwiperChange"
        >
          <swiper-item wx:for="{{displayPages}}" wx:key="id">
            <view class="album-frame-viewer__slide">
              <block wx:if="{{item.type === 'photo'}}">
                <view class="album-frame-viewer__photo-wrap">
                  <image
                    class="album-frame-viewer__photo"
                    src="{{item.imageUrl}}"
                    mode="aspectFill"
                    show-menu-by-longpress="{{false}}"
                  />
                  <view wx:if="{{item.imageLabel}}" class="album-frame-viewer__image-label">
                    <text class="album-frame-viewer__image-label-text text-caption">{{item.imageLabel}}</text>
                  </view>
                </view>
              </block>
              <block wx:else>
                <view class="album-frame-viewer__end-body">
                  <slot name="endPage" />
                </view>
              </block>
            </view>
          </swiper-item>
        </swiper>

        <view
          wx:if="{{currentPageType === 'photo'}}"
          class="album-frame-viewer__caption"
        >
          <text class="album-frame-viewer__caption-text text-caption">{{currentCaptionLine}}</text>
        </view>
      </view>
    </album-photo-frame>
  </block>
</view>
