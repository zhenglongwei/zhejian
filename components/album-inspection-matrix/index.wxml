<view wx:if="{{rows.length || methodRows.length || documentBundle}}" class="album-inspection-matrix {{compact ? 'album-inspection-matrix--compact' : ''}}">
  <view wx:if="{{title}}" class="album-inspection-matrix__head">
    <text class="text-body album-inspection-matrix__title">{{title}}</text>
    <text wx:if="{{subtitle}}" class="text-caption album-inspection-matrix__subtitle">{{subtitle}}</text>
  </view>

  <view wx:if="{{layout === 'inventory' && rows.length}}" class="surface-album-inset album-inspection-matrix__table-wrap">
    <view class="album-inspection-matrix__table">
      <view class="album-inspection-matrix__row album-inspection-matrix__row--head">
        <text class="album-inspection-matrix__label album-inspection-matrix__label--head text-caption">项目</text>
        <text class="album-inspection-matrix__importance-head text-caption">{{importanceColumnLabel}}</text>
        <text class="album-inspection-matrix__status-head text-caption">状态</text>
        <text class="album-inspection-matrix__thumb-head text-caption">图</text>
      </view>

      <view
        wx:for="{{rows}}"
        wx:key="id"
        wx:for-item="row"
        class="album-inspection-matrix__row album-inspection-matrix__row--inventory"
      >
        <text class="text-caption album-inspection-matrix__name album-inspection-matrix__label">{{row.label}}</text>
        <text class="text-caption album-inspection-matrix__importance">{{row.importanceLabel}}</text>
        <text class="album-inspection-matrix__status text-caption album-inspection-matrix__status--{{row.statusLevel}}">{{row.statusSymbol}}</text>
        <view class="album-inspection-matrix__thumb">
          <scroll-view
            wx:if="{{row.images.length}}"
            class="album-inspection-matrix__thumb-scroll"
            scroll-x
            enable-flex
            show-scrollbar="{{false}}"
          >
            <view class="album-inspection-matrix__thumb-row">
              <image
                wx:for="{{row.images}}"
                wx:key="*this"
                wx:for-item="imgUrl"
                class="album-inspection-matrix__thumb-img"
                src="{{imgUrl}}"
                mode="aspectFill"
                data-url="{{imgUrl}}"
                data-urls="{{row.images}}"
                catchtap="onPreviewRow"
              />
            </view>
          </scroll-view>
          <text wx:else class="text-caption album-inspection-matrix__thumb-empty">无</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{layout === 'method' && methodRows.length}}" class="surface-album-inset album-inspection-matrix__table-wrap">
    <view class="album-inspection-matrix__table album-inspection-matrix__table--method">
      <view
        wx:for="{{methodRows}}"
        wx:key="id"
        wx:for-item="row"
        class="album-inspection-matrix__method-card album-inspection-matrix__method-card--{{row.rowLevel}}"
      >
        <text class="text-caption album-inspection-matrix__method-card-label">{{row.label}}</text>

        <block wx:if="{{row.isMissing}}">
          <view class="album-inspection-matrix__method-card-field">
            <text class="text-caption album-inspection-matrix__method-card-key">还缺</text>
            <text class="text-caption album-inspection-matrix__method-card-value album-inspection-matrix__method-card-value--missing">{{row.missingSummary}}</text>
          </view>
          <view class="album-inspection-matrix__method-card-field">
            <text class="text-caption album-inspection-matrix__method-card-key">会怎样</text>
            <text class="text-caption album-inspection-matrix__method-card-value">{{row.riskHint}}</text>
          </view>
          <view class="album-inspection-matrix__method-card-field">
            <text class="text-caption album-inspection-matrix__method-card-key">怎么办</text>
            <text class="text-caption album-inspection-matrix__method-card-value album-inspection-matrix__method-card-value--primary">{{row.actionHint}}</text>
          </view>
        </block>

        <block wx:else>
          <view class="album-inspection-matrix__method-card-field">
            <text class="text-caption album-inspection-matrix__method-card-key">这样看</text>
            <text class="text-caption album-inspection-matrix__method-card-value">{{row.howToCheck}}</text>
          </view>

          <view class="album-inspection-matrix__method-card-pair">
            <view class="album-inspection-matrix__method-card-pair-row">
              <text class="text-caption album-inspection-matrix__method-card-key">对上了</text>
              <text class="text-caption album-inspection-matrix__method-card-value">{{row.ifMatch}}</text>
            </view>
            <view class="album-inspection-matrix__method-card-pair-row">
              <text class="text-caption album-inspection-matrix__method-card-key">对不上</text>
              <text class="text-caption album-inspection-matrix__method-card-value">{{row.ifMismatch}}</text>
            </view>
          </view>

          <view class="album-inspection-matrix__method-card-field">
            <text class="text-caption album-inspection-matrix__method-card-key">怎么办</text>
            <text class="text-caption album-inspection-matrix__method-card-value album-inspection-matrix__method-card-value--primary">{{row.advice}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view wx:if="{{layout === 'document-bundle' && documentBundle}}" class="surface-album-inset album-inspection-matrix__table-wrap">
    <text wx:if="{{documentBundle.intro}}" class="text-caption album-inspection-matrix__bundle-intro">{{documentBundle.intro}}</text>

    <view wx:if="{{documentBundle.missingBlock}}" class="album-inspection-matrix__bundle-section album-inspection-matrix__bundle-section--first">
      <view class="album-inspection-matrix__method-card-field">
        <text class="text-caption album-inspection-matrix__method-card-key">会怎样</text>
        <text class="text-caption album-inspection-matrix__method-card-value">{{documentBundle.missingBlock.riskHint}}</text>
      </view>
      <view class="album-inspection-matrix__method-card-field">
        <text class="text-caption album-inspection-matrix__method-card-key">怎么办</text>
        <text class="text-caption album-inspection-matrix__method-card-value album-inspection-matrix__method-card-value--primary">{{documentBundle.missingBlock.actionHint}}</text>
      </view>
    </view>

    <view wx:if="{{documentBundle.checkGuide}}" class="album-inspection-matrix__bundle-section">
      <view class="album-inspection-matrix__method-card-field">
        <text class="text-caption album-inspection-matrix__method-card-key">这样看</text>
        <text class="text-caption album-inspection-matrix__method-card-value">{{documentBundle.checkGuide.howToCheck}}</text>
      </view>
      <view class="album-inspection-matrix__method-card-pair">
        <view class="album-inspection-matrix__method-card-pair-row">
          <text class="text-caption album-inspection-matrix__method-card-key">对上了</text>
          <text class="text-caption album-inspection-matrix__method-card-value">{{documentBundle.checkGuide.ifMatch}}</text>
        </view>
        <view class="album-inspection-matrix__method-card-pair-row">
          <text class="text-caption album-inspection-matrix__method-card-key">对不上</text>
          <text class="text-caption album-inspection-matrix__method-card-value">{{documentBundle.checkGuide.ifMismatch}}</text>
        </view>
      </view>
      <view class="album-inspection-matrix__method-card-field">
        <text class="text-caption album-inspection-matrix__method-card-key">怎么办</text>
        <text class="text-caption album-inspection-matrix__method-card-value album-inspection-matrix__method-card-value--primary">{{documentBundle.checkGuide.advice}}</text>
      </view>
    </view>
  </view>
</view>
