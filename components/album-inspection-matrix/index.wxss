.album-inspection-matrix {
  margin-bottom: var(--space-md);
}

.album-inspection-matrix__head {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: var(--space-sm);
}

.album-inspection-matrix__title {
  font-weight: var(--font-weight-medium);
}

.album-inspection-matrix__subtitle {
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.album-inspection-matrix__table-wrap {
  padding: var(--space-xs) 0;
  overflow: hidden;
}

.album-inspection-matrix__table {
  width: 100%;
}

.album-inspection-matrix__row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-xs);
  box-sizing: border-box;
  width: 100%;
  min-height: 72rpx;
  padding: var(--space-sm);
  border-bottom: 1rpx solid var(--color-album-frame-line);
}

.album-inspection-matrix__row:last-child {
  border-bottom: none;
}

.album-inspection-matrix__row--head {
  min-height: 56rpx;
  align-items: center;
  background: var(--color-album-frame-inner);
}

.album-inspection-matrix__label {
  flex: 1.6;
  min-width: 0;
  line-height: 1.35;
}

.album-inspection-matrix__label--head {
  flex: 1.6;
}

.album-inspection-matrix__name {
  color: var(--color-text-primary);
}

.album-inspection-matrix__importance-head,
.album-inspection-matrix__importance {
  flex: 1;
  min-width: 72rpx;
  text-align: center;
  color: var(--color-text-secondary);
  line-height: 1.35;
}

.album-inspection-matrix__status-head,
.album-inspection-matrix__status {
  flex: 0 0 64rpx;
  text-align: center;
  font-weight: var(--font-weight-medium);
  line-height: 1.35;
}

.album-inspection-matrix__status--ok {
  color: var(--color-success);
}

.album-inspection-matrix__status--missing {
  color: var(--color-warning);
}

.album-inspection-matrix__thumb-head,
.album-inspection-matrix__thumb {
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
}

.album-inspection-matrix__thumb-head {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
}

.album-inspection-matrix__thumb-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-album-list-thumb);
  border: 1rpx solid var(--color-album-frame-line);
  background: var(--color-album-frame-inner);
}

.album-inspection-matrix__thumb-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: var(--color-text-tertiary);
}

.album-inspection-matrix__table--method {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  font-size: var(--font-caption-size);
}

.album-inspection-matrix__method-card {
  box-sizing: border-box;
  padding: var(--space-sm) var(--space-md);
  border-bottom: 1rpx solid var(--color-album-frame-line);
}

.album-inspection-matrix__method-card:last-child {
  border-bottom: none;
}

.album-inspection-matrix__method-card--missing .album-inspection-matrix__method-card-label {
  color: var(--color-warning);
}

.album-inspection-matrix__method-card-label {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  line-height: 1.4;
}

.album-inspection-matrix__method-card-field {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
  margin-top: var(--space-xs);
}

.album-inspection-matrix__method-card-key {
  flex: 0 0 112rpx;
  color: var(--color-text-tertiary);
  line-height: 1.45;
}

.album-inspection-matrix__method-card-value {
  flex: 1;
  min-width: 0;
  color: var(--color-text-secondary);
  line-height: 1.45;
  word-break: break-word;
}

.album-inspection-matrix__method-card-value--primary {
  color: var(--color-text-primary);
}

.album-inspection-matrix__method-card-value--missing {
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.album-inspection-matrix__method-card-pair {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-top: var(--space-xs);
}

.album-inspection-matrix__method-card-pair-row {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
}

.album-inspection-matrix--compact .album-inspection-matrix__row {
  min-height: 64rpx;
}

.album-inspection-matrix--compact .album-inspection-matrix__thumb,
.album-inspection-matrix--compact .album-inspection-matrix__thumb-head {
  width: 64rpx;
  height: 64rpx;
}
