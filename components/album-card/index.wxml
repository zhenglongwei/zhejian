<ui-card shadow="{{true}}" padding="{{true}}">
  <view class="record-card__inner" data-id="{{item.albumId}}" bindtap="onTap">
    <view class="record-card__head">
      <view class="record-card__tags">
        <ui-tag
          wx:if="{{item.statusLabel}}"
          variant="{{item.statusVariant}}"
          text="{{item.statusLabel}}"
        />
        <ui-tag
          wx:if="{{audience === 'user' && item.visibilityLabel}}"
          variant="{{item.visibilityVariant}}"
          text="{{item.visibilityLabel}}"
        />
      </view>
      <view class="record-card__head-right">
        <button
          wx:if="{{audience === 'merchant' && item.canShareToOwner}}"
          class="record-card__share-btn"
          open-type="share"
          catchtap="onShareTap"
          data-album-id="{{item.albumId}}"
          data-store-name="{{item.storeName}}"
          data-user-phone="{{item.userPhone}}"
        >分享</button>
        <text wx:if="{{item.updatedAtText}}" class="record-card__time text-caption">{{item.updatedAtText}}</text>
      </view>
    </view>

    <text class="record-card__service text-body">{{item.serviceName}}</text>

    <block wx:if="{{audience === 'user'}}">
      <text wx:if="{{item.storeName}}" class="record-card__meta text-caption">{{item.storeName}}</text>
    </block>
    <block wx:else>
      <text wx:if="{{item.userPhoneDisplay}}" class="record-card__meta text-caption">车主 {{item.userPhoneDisplay}}</text>
    </block>

    <text wx:if="{{item.vehicleDisplay}}" class="record-card__meta text-caption">{{item.vehicleDisplay}}</text>
    <text wx:if="{{item.imageCount}}" class="record-card__meta text-caption">{{item.imageCount}} 张过程图</text>
  </view>
</ui-card>
