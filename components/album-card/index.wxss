:host {
  display: block;
  width: 100%;
}

.album-card__shell--raised {
  overflow: hidden;
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-album-card-raised);
}

.album-card__shell--embedded {
  overflow: hidden;
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-album-list-thumb);
}

.album-card__inner {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  align-items: stretch;
  box-sizing: border-box;
  min-height: var(--size-album-list-card-min-height);
  padding: var(--space-md);
  width: 100%;
}

.album-card__thumb-col {
  flex-shrink: 0;
  width: var(--size-album-list-thumb);
  height: var(--size-album-list-thumb);
}

.album-card__thumb-col .album-photo-frame {
  width: var(--size-album-list-thumb);
  height: var(--size-album-list-thumb);
}

.album-card__thumb-wrap {
  width: var(--size-album-list-thumb);
  height: var(--size-album-list-thumb);
  overflow: hidden;
  border-radius: var(--radius-album-list-thumb);
}

.album-card__thumb-wrap--plain {
  border: 1rpx solid var(--color-album-frame-line);
  background: var(--color-album-frame-inner);
  box-shadow: var(--shadow-album-list-thumb);
}

.album-card__thumb {
  display: block;
  width: var(--size-album-list-thumb);
  height: var(--size-album-list-thumb);
}

.album-card__thumb--placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  padding: var(--space-sm);
  background: linear-gradient(
    180deg,
    var(--color-album-frame-inner) 0%,
    var(--color-album-active-light) 100%
  );
  box-sizing: border-box;
}

.album-card__thumb-initial {
  color: var(--color-album-frame-corner);
  font-size: var(--font-h2);
  line-height: var(--font-h2-lh);
}

.album-card__thumb-progress {
  width: 100%;
  padding: 0 var(--space-xs);
  box-sizing: border-box;
}

.album-card__thumb-ph {
  color: var(--color-text-tertiary);
}

.album-card__body {
  display: flex;
  flex: 1;
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
}

.album-card__body--stacked {
  flex: 1;
  flex-direction: column;
  gap: var(--space-xs);
  justify-content: center;
  min-width: 0;
  min-height: var(--size-album-list-thumb);
}

.album-card__body--split {
  flex: 1 1 0%;
  flex-direction: row;
  align-items: flex-start;
  gap: var(--space-sm);
  width: 0;
  min-height: var(--size-album-list-thumb);
}

.album-card__head {
  position: relative;
  display: block;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.album-card__head--with-share {
  padding-right: 80rpx;
}

.album-card__service--head {
  display: block;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.album-card__head-share {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 1;
  width: 80rpx;
  height: var(--font-body-lh);
}

.album-card__share-btn--head {
  position: absolute;
  top: 0;
  right: 0;
  width: 80rpx !important;
  min-width: 0 !important;
  max-width: 80rpx;
  height: var(--font-body-lh);
  padding: 0;
  margin: 0;
  font-size: var(--font-caption);
  line-height: var(--font-body-lh);
  text-align: right;
  box-sizing: border-box;
  color: var(--color-primary);
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.album-card__main {
  display: flex;
  flex: 1 1 0%;
  flex-direction: column;
  gap: var(--space-xs);
  justify-content: flex-start;
  width: 0;
  min-width: 0;
  min-height: var(--size-album-list-thumb);
  overflow: hidden;
}

.album-card__service {
  display: block;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.album-card__service.text-body {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.album-card__shell--raised .album-card__service.text-album-display {
  font-size: var(--font-h3);
  line-height: var(--font-h3-lh);
  letter-spacing: 3rpx;
  color: var(--color-text-primary);
}

.album-card__actions {
  display: flex;
  flex-shrink: 0;
  flex-wrap: wrap;
  gap: var(--space-xs);
  align-items: center;
}

.album-card__actions--column {
  flex-direction: column;
  flex-wrap: nowrap;
  align-items: flex-end;
  align-self: flex-start;
  gap: 6rpx;
}

.album-card__actions--column .album-card__action {
  padding: 2rpx 0;
}

.album-card__shell--raised .album-card__actions--column .album-card__action {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-active-light);
}

.album-card__shell--raised .album-card__action {
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-active-light);
}

.album-card__shell--raised .album-card__action--muted {
  background-color: var(--color-bg-muted);
}

.album-card__action {
  padding: 2rpx var(--space-xs);
}

.album-card__action--muted .album-card__action-text {
  color: var(--color-text-tertiary);
}

.album-card__action-text {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.album-card__share-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0;
  width: auto !important;
  min-width: 0 !important;
  font-size: var(--font-caption);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: transparent;
  line-height: 1.4;
}

.album-card__share-btn::after {
  border: none;
}

.album-card__meta {
  display: block;
  width: 100%;
  overflow: hidden;
  color: var(--color-text-secondary);
  white-space: nowrap;
  text-overflow: ellipsis;
}

.album-card__meta--store {
  color: var(--color-text-tertiary);
}

.album-card__summary {
  display: block;
  width: 100%;
  overflow: hidden;
  color: var(--color-text-secondary);
  white-space: nowrap;
  text-overflow: ellipsis;
}

.album-card__date {
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.album-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-xs);
}

.album-card__hint {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-warning);
}

.album-card__progress-wrap {
  width: 100%;
  margin-top: var(--space-xs);
}

.album-card__footer {
  display: flex;
  align-items: center;
  margin-top: auto;
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.album-card__time {
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.album-card__time--fresh {
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}
