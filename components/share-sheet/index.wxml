<ui-bottom-sheet
  visible="{{visible}}"
  showActions="{{false}}"
  scrollable="{{true}}"
  bind:close="onCloseFromSheet"
>
  <view class="share-sheet__body">
    <view class="share-sheet__head">
      <text class="share-sheet__title text-h3">分享</text>
      <text class="share-sheet__close text-caption text-link" bind:tap="onCloseTap">关闭</text>
    </view>

    <!-- 门店/案例等：简洁三渠道 -->
    <block wx:if="{{variant !== 'owner'}}">
      <view class="share-sheet__channels">
        <view
          class="share-sheet__channel {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
          bindtap="onTimelineTap"
        >
          <view class="share-sheet__icon-wrap">
            <image class="share-sheet__icon" src="/assets/share/icon-moments.svg" mode="aspectFit" />
          </view>
          <text class="share-sheet__channel-label text-caption">分享到朋友圈</text>
        </view>

        <button
          class="share-sheet__channel share-sheet__channel-btn {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
          open-type="share"
          data-share-intent="{{shareIntent}}"
          disabled="{{actionsDisabled}}"
        >
          <view class="share-sheet__icon-wrap">
            <image class="share-sheet__icon" src="/assets/share/icon-friend.svg" mode="aspectFit" />
          </view>
          <text class="share-sheet__channel-label text-caption">转发给朋友</text>
        </button>

        <view
          class="share-sheet__channel {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
          bindtap="onSocialTap"
        >
          <view class="share-sheet__icon-wrap">
            <image class="share-sheet__icon" src="/assets/share/icon-social.svg" mode="aspectFit" />
          </view>
          <text class="share-sheet__channel-label text-caption">复制链接</text>
        </view>
      </view>
      <view wx:if="{{showOwnerShare}}" class="share-sheet__footer">
        <text class="share-sheet__privacy-text text-caption">私人分享仅使用脱敏后的图片，完整留档请在小程序内查看。</text>
      </view>
    </block>

    <!-- 车主服务相册：三列意图（USER-PUB） -->
    <block wx:else>
      <text wx:if="{{honorHint}}" class="share-sheet__honor text-caption">{{honorHint}}</text>

      <view class="share-sheet__section">
        <text class="share-sheet__section-title text-body">① 发给微信</text>
        <text class="share-sheet__section-hint text-caption">完工即可；不会自动出现在公开网站</text>
        <view class="share-sheet__channels">
          <view
            class="share-sheet__channel {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
            bindtap="onTimelineTap"
          >
            <view class="share-sheet__icon-wrap">
              <image class="share-sheet__icon" src="/assets/share/icon-moments.svg" mode="aspectFit" />
            </view>
            <text class="share-sheet__channel-label text-caption">朋友圈</text>
          </view>
          <button
            class="share-sheet__channel share-sheet__channel-btn {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
            open-type="share"
            data-share-intent="owner"
            disabled="{{actionsDisabled}}"
          >
            <view class="share-sheet__icon-wrap">
              <image class="share-sheet__icon" src="/assets/share/icon-friend.svg" mode="aspectFit" />
            </view>
            <text class="share-sheet__channel-label text-caption">转发给朋友</text>
          </button>
          <view
            class="share-sheet__channel {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
            bindtap="onCopyOwnerTap"
          >
            <view class="share-sheet__icon-wrap">
              <image class="share-sheet__icon" src="/assets/share/icon-social.svg" mode="aspectFit" />
            </view>
            <text class="share-sheet__channel-label text-caption">复制分享链接</text>
          </view>
        </view>
      </view>

      <view class="share-sheet__section">
        <text class="share-sheet__section-title text-body">② 复制去社交媒体</text>
        <text class="share-sheet__section-hint text-caption">生成长文供你自行粘贴；平台不代发</text>
        <view class="share-sheet__tabs">
          <view
            wx:for="{{socialPlatforms}}"
            wx:key="id"
            class="share-sheet__tab {{socialPlatform === item.id ? 'is-active' : ''}}"
            data-id="{{item.id}}"
            bindtap="onSocialPlatformTap"
          >
            <text class="text-caption">{{item.label}}</text>
          </view>
        </view>
        <view class="share-sheet__draft">
          <text class="share-sheet__draft-text text-caption" selectable>{{socialDraftLoading ? '正在准备文案…' : (socialDraftWaitHint || socialDraftText || '暂无文案')}}</text>
        </view>
        <ui-button
          type="ghost"
          size="sm"
          block
          disabled="{{socialDraftLoading || socialDraftWaitHint || !socialDraftText}}"
          bind:btntap="onCopySocialTap"
        >一键复制</ui-button>
      </view>

      <view class="share-sheet__section">
        <text class="share-sheet__section-title text-body">③ 分享脱敏案例给同城车友</text>
        <text class="share-sheet__section-hint text-caption">须预览确认；人工审核通过后才会展示</text>
        <text wx:if="{{publishHint}}" class="share-sheet__publish-hint text-caption">{{publishHint}}</text>

        <block wx:if="{{publishState === 'approved'}}">
          <text class="share-sheet__status text-body">已在公开网站</text>
          <ui-button
            wx:if="{{showPublicWebLink}}"
            type="primary"
            size="sm"
            block
            bind:btntap="onCopyPublicTap"
          >复制公开网页链接</ui-button>
        </block>
        <block wx:elif="{{publishState === 'pending'}}">
          <text class="share-sheet__status text-body">审核中</text>
        </block>
        <block wx:elif="{{publishState === 'need_modify'}}">
          <text class="share-sheet__status text-body">需按审核意见修改后重新发布</text>
          <ui-button
            type="primary"
            size="sm"
            block
            disabled="{{publishDisabled}}"
            bind:btntap="onPublishTap"
          >重新预览并发布</ui-button>
        </block>
        <block wx:else>
          <ui-button
            type="primary"
            size="sm"
            block
            disabled="{{publishDisabled}}"
            bind:btntap="onPublishTap"
          >预览并发布</ui-button>
        </block>
      </view>

      <view class="share-sheet__footer">
        <text class="share-sheet__privacy-text text-caption">发给微信或复制文案不会自动上网；仅「分享脱敏案例」并过审后才会出现在案例站。</text>
      </view>
    </block>
  </view>
</ui-bottom-sheet>
