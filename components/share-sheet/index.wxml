<ui-bottom-sheet
  visible="{{visible}}"
  showActions="{{false}}"
  scrollable="{{true}}"
  bind:close="onCloseFromSheet"
>
  <view class="share-sheet__body">
    <view class="share-sheet__head">
      <text class="share-sheet__title text-h3">分享</text>
      <text class="share-sheet__close text-caption text-link" bind:tap="onCloseTap">关闭</text>
    </view>

    <view class="share-sheet__channels">
      <view
        class="share-sheet__channel {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
        bindtap="onTimelineTap"
      >
        <view class="share-sheet__icon-wrap">
          <image class="share-sheet__icon" src="/assets/share/icon-moments.svg" mode="aspectFit" />
        </view>
        <text class="share-sheet__channel-label text-caption">分享到朋友圈</text>
      </view>

      <button
        class="share-sheet__channel share-sheet__channel-btn {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
        open-type="share"
        data-share-intent="{{shareIntent}}"
        disabled="{{actionsDisabled}}"
      >
        <view class="share-sheet__icon-wrap">
          <image class="share-sheet__icon" src="/assets/share/icon-friend.svg" mode="aspectFit" />
        </view>
        <text class="share-sheet__channel-label text-caption">转发给朋友</text>
      </button>

      <view
        class="share-sheet__channel {{actionsDisabled ? 'share-sheet__channel--disabled' : ''}}"
        bindtap="onSocialTap"
      >
        <view class="share-sheet__icon-wrap">
          <image class="share-sheet__icon" src="/assets/share/icon-social.svg" mode="aspectFit" />
        </view>
        <text class="share-sheet__channel-label text-caption">转发到社交媒体</text>
      </view>
    </view>

    <view wx:if="{{showOwnerShare}}" class="share-sheet__footer">
      <text class="share-sheet__privacy-text text-caption">私人分享仅使用脱敏后的图片，完整留档请在小程序内查看。</text>
    </view>
  </view>
</ui-bottom-sheet>
