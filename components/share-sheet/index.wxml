<view wx:if="{{visible}}" class="share-sheet">
  <view class="share-sheet__mask" bindtap="onMaskTap" />
  <view class="share-sheet__panel safe-bottom" catchtap="noop">
    <view class="share-sheet__head">
      <text class="share-sheet__title text-h3">分享</text>
      <text class="share-sheet__close text-caption text-link" bindtap="onCloseTap">关闭</text>
    </view>

    <block wx:if="{{showOwnerShare}}">
      <ui-privacy-banner scene="{{ownerPrivacyScene}}" />
      <ui-checkbox-row
        checked="{{shareUseOriginal}}"
        disabled="{{ownerSharePreparing}}"
        bind:toggle="onToggleOriginal"
      >
        <text>使用原图分享</text>
      </ui-checkbox-row>
      <view class="share-sheet__group">
        <text class="share-sheet__group-title text-caption">分享我的服务相册</text>
        <view class="share-sheet__actions">
          <slot name="ownerWechatShare" />
          <ui-button
            type="ghost"
            size="sm"
            block="{{true}}"
            disabled="{{!ownerShareReady || ownerSharePreparing}}"
            bind:tap="onCopyOwnerLink"
          >复制分享链接</ui-button>
        </view>
      </view>
    </block>

    <block wx:if="{{showPublicCaseShare}}">
      <view class="share-sheet__group">
        <ui-privacy-banner scene="publicCaseShare" />
        <text class="share-sheet__group-title text-caption">平台公示案例</text>
        <view class="share-sheet__actions">
          <slot name="publicWechatShare" />
          <ui-button
            type="ghost"
            size="sm"
            block="{{true}}"
            bind:tap="onCopyPublicWebLink"
          >复制公示网页链接</ui-button>
        </view>
      </view>
    </block>

    <text class="share-sheet__footnote note-block text-caption">
      右上角 ··· 可分享至朋友圈。上方「复制分享/公示链接」为浏览器可打开的网页；右上角「复制链接」为微信内小程序链。
    </text>
  </view>
</view>
