<view class="fixed-bottom-bar fixed-bottom {{safeArea ? 'safe-bottom' : ''}}">
  <view class="fixed-bottom-bar__inner">
    <view class="fixed-bottom-bar__left">
      <view wx:if="{{leftActions.length}}" class="fixed-bottom-bar__left-actions tag-row">
        <ui-button
          wx:for="{{leftActions}}"
          wx:key="key"
          type="{{item.type || 'secondary'}}"
          size="sm"
          disabled="{{item.disabled}}"
          data-key="{{item.key}}"
          bind:tap="onLeftAction"
        >{{item.text}}</ui-button>
      </view>
      <slot wx:else name="left" />
    </view>
    <view class="fixed-bottom-bar__right">
      <view wx:if="{{rightActions.length}}" class="fixed-bottom-bar__right-actions">
        <ui-button
          wx:for="{{rightActions}}"
          wx:key="key"
          type="{{item.type || 'primary'}}"
          size="{{item.size || 'default'}}"
          block="{{item.block}}"
          disabled="{{item.disabled}}"
          loading="{{item.loading}}"
          data-key="{{item.key}}"
          bind:tap="onRightAction"
        >{{item.text}}</ui-button>
      </view>
      <block wx:else>
        <slot name="right" />
        <slot />
      </block>
    </view>
  </view>
</view>
