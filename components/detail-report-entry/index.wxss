.detail-report-entry {
  margin-top: var(--space-xl);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--color-border);
  text-align: center;
}

.detail-report-entry--attached {
  margin-top: 0;
  text-align: left;
}

.detail-report-entry__text {
  color: var(--color-text-tertiary);
}

.detail-report-entry--attached .detail-report-entry__text {
  color: var(--color-text-tertiary);
}
