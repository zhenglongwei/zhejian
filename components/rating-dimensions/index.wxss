.rating-dimensions__row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.rating-dimensions__row:last-child {
  border-bottom: none;
}

.rating-dimensions__copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.rating-dimensions__label {
  padding-right: 0;
}

.rating-dimensions__hint {
  color: var(--color-text-tertiary);
  line-height: var(--line-height-relaxed);
}

.rating-dimensions__stars {
  display: flex;
  gap: var(--space-xs);
}

.rating-dimensions__star {
  font-size: var(--size-rating-star);
  line-height: 1;
  color: var(--color-border-strong);
}

.rating-dimensions__star.is-active {
  color: var(--color-warning);
}

.rating-dimensions__toggle {
  padding-top: var(--space-sm);
  text-align: center;
}
