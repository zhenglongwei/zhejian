.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline__item {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
  padding-bottom: var(--space-lg);
}

.timeline__item:last-child {
  padding-bottom: 0;
}

.timeline--compact .timeline__item {
  padding-bottom: var(--space-md);
}

.timeline__rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 24rpx;
  flex-shrink: 0;
}

.timeline__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  background-color: transparent;
  box-sizing: border-box;
  flex-shrink: 0;
}

.timeline__line {
  flex: 1;
  width: 2rpx;
  min-height: 32rpx;
  margin-top: var(--space-xs);
  background-color: var(--color-border);
}

.timeline__item--done .timeline__dot {
  border-color: var(--color-primary);
  background-color: var(--color-primary);
}

.timeline__item--done .timeline__line {
  background-color: var(--color-primary-light);
}

.timeline__item--active .timeline__dot {
  border-color: var(--color-primary);
  background-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx var(--color-primary-light);
}

.timeline__item--active .timeline__title {
  color: var(--color-primary-dark);
  font-weight: 600;
}

.timeline__item--pending .timeline__dot {
  border-color: var(--color-border);
  background-color: transparent;
}

.timeline__item--pending .timeline__title,
.timeline__item--pending .timeline__desc {
  color: var(--color-text-tertiary);
}

.timeline__body {
  flex: 1;
  min-width: 0;
  padding-top: 0;
}

.timeline__head {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-xs);
}

.timeline__time {
  color: var(--color-text-tertiary);
}

.timeline__desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.timeline__link {
  display: inline-block;
  margin-top: var(--space-xs);
  color: var(--color-primary);
}
