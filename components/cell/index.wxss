.cell-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: var(--cell-height);
  padding: var(--space-md);
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--color-border);
}

.cell-row--no-border,
.cell-row:last-child {
  border-bottom: none;
}

.cell-row--disabled {
  opacity: 0.4;
}

.cell-row--with-icon {
  gap: var(--space-md);
}

.cell-row__icon-well {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: var(--size-nav-icon-well);
  height: var(--size-nav-icon-well);
  border-radius: var(--radius-md);
}

.cell-row__icon-well--well {
  background-color: var(--color-nav-icon-well);
}

.cell-row__icon-well--primary-light {
  background-color: var(--color-primary-light);
}

.cell-row__icon-well--success-light {
  background-color: var(--color-success-light);
}

.cell-row__icon-well--info-light {
  background-color: var(--color-info-light);
}

.cell-row__icon-well--warning-light {
  background-color: var(--color-warning-light);
}

.cell-row__icon {
  width: var(--size-nav-icon);
  height: var(--size-nav-icon);
}

.cell-row__main {
  flex: 1;
  min-width: 0;
}

.cell-row__title {
  display: block;
}

.cell-row__desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.cell-row__extra {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.cell-row__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-danger);
}

.cell-row__badge {
  min-width: 32rpx;
  padding: 0 8rpx;
  font-size: var(--font-caption);
  line-height: 32rpx;
  text-align: center;
  color: var(--color-text-inverse);
  background-color: var(--color-danger);
  border-radius: var(--radius-full);
}

.cell-row__arrow {
  color: var(--color-text-tertiary);
}
