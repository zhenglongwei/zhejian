<view
  class="cell-row {{border ? '' : 'cell-row--no-border'}} {{disabled ? 'cell-row--disabled' : ''}} {{icon ? 'cell-row--with-icon' : ''}}"
  bindtap="onTap"
>
  <view
    wx:if="{{icon}}"
    class="cell-row__icon-well cell-row__icon-well--{{iconBg || 'well'}}"
  >
    <image class="cell-row__icon" src="{{icon}}" mode="aspectFit" aria-hidden="true" />
  </view>
  <view class="cell-row__main">
    <text class="cell-row__title text-body">{{title}}</text>
    <text wx:if="{{desc}}" class="cell-row__desc text-caption">{{desc}}</text>
  </view>
  <view class="cell-row__extra">
    <view wx:if="{{dot}}" class="cell-row__dot" aria-hidden="true"></view>
    <text wx:elif="{{badge}}" class="cell-row__badge">{{badge}}</text>
    <text wx:if="{{value}}" class="cell-row__value text-body">{{value}}</text>
    <text wx:if="{{arrow}}" class="cell-row__arrow text-caption">›</text>
    <slot name="extra" />
  </view>
</view>
