<view class="report-type-picker">
  <view
    wx:for="{{options}}"
    wx:key="value"
    class="report-type-picker__item {{value === item.value ? 'report-type-picker__item--active' : ''}}"
    data-value="{{item.value}}"
    bindtap="onSelect"
  >
    <text class="text-body">{{item.label}}</text>
  </view>
</view>
