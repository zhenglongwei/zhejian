<view class="surface-record-card">
  <view class="record-card__inner">
    <view class="record-card__head">
      <view class="record-card__tags">
        <ui-tag
          wx:for="{{item.displayTags}}"
          wx:key="text"
          variant="{{item.variant}}"
          text="{{item.text}}"
        />
      </view>
      <text wx:if="{{item.updatedAtText}}" class="record-card__time text-caption">{{item.updatedAtText}}</text>
    </view>

    <text class="record-card__service text-body">{{item.serviceName}}</text>
    <text class="record-card__meta text-caption">{{item.storeName}}</text>
    <text wx:if="{{item.vehicleDisplay}}" class="record-card__meta text-caption">{{item.vehicleDisplay}}</text>

    <view wx:if="{{item.cardAction.label}}" class="record-card__actions">
      <ui-button
        type="{{item.cardAction.buttonType}}"
        size="sm"
        disabled="{{item.cardAction.disabled}}"
        bind:btntap="onCardAction"
      >{{item.cardAction.label}}</ui-button>
    </view>
  </view>
</view>
