<view class="checkbox-row" bindtap="onToggle">
  <view class="checkbox-row__box {{checked ? 'checkbox-row__box--on' : ''}} {{disabled ? 'checkbox-row__box--disabled' : ''}}">
    <text wx:if="{{checked}}" class="checkbox-row__mark">✓</text>
  </view>
  <view class="checkbox-row__label text-caption">
    <slot />
  </view>
</view>
