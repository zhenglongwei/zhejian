.checkbox-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
}

.checkbox-row__check {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: var(--font-caption-lh);
}

.checkbox-row__box {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.checkbox-row__box--on {
  border-color: var(--color-primary);
  background-color: var(--color-primary);
}

.checkbox-row__box--disabled {
  opacity: var(--opacity-disabled);
}

.checkbox-row__mark {
  color: var(--color-text-inverse);
  font-size: var(--font-caption);
  line-height: 1;
}

.checkbox-row__label {
  flex: 1;
  min-width: 0;
}

.checkbox-row__label text {
  font-size: var(--font-caption);
  line-height: var(--font-caption-lh);
}
