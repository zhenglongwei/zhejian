<view class="store-card" bindtap="onTap">
  <text class="store-card__name text-body">{{name}}</text>
  <text wx:if="{{address}}" class="store-card__meta text-caption">{{address}}</text>
  <text wx:if="{{businessHours}}" class="store-card__meta text-caption">营业时间 {{businessHours}}</text>
  <view wx:if="{{score || caseCount}}" class="store-card__row">
    <text wx:if="{{score}}" class="store-card__meta text-caption">评分 {{score}}</text>
    <text wx:if="{{caseCount}}" class="store-card__meta text-caption">公开案例 {{caseCount}}</text>
  </view>
  <view wx:if="{{cardTags.length}}" class="store-card__tags">
    <ui-tag
      wx:for="{{cardTags}}"
      wx:key="text"
      variant="{{item.variant}}"
      text="{{item.text}}"
    />
  </view>
  <text wx:if="{{showLink}}" class="store-card__link text-caption text-link">{{linkText}}</text>
</view>
