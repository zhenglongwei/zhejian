<view class="service-card" bindtap="onTap">
  <view class="service-card__body">
    <view class="service-card__tags">
      <ui-tag
        wx:for="{{tagList}}"
        wx:key="text"
        variant="{{item.variant}}"
        text="{{item.text}}"
      />
    </view>
    <text class="service-card__title text-h3">{{name}}</text>
    <text wx:if="{{summary}}" class="service-card__summary text-body">{{summary}}</text>
    <view class="service-card__meta">
      <ui-price-display
        mode="{{priceMode}}"
        amount="{{amount}}"
        minAmount="{{minAmount}}"
        maxAmount="{{maxAmount}}"
        showDisclaimer="{{true}}"
        showSuffix="{{showPriceSuffix}}"
      />
    </view>
    <view wx:if="{{showStoreName && storeName}}" class="service-card__footer text-caption">
      <text>{{storeName}}</text>
    </view>
  </view>
</view>
