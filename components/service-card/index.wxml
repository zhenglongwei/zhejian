<view
  class="service-card {{readonly ? 'service-card--readonly' : ''}} {{embedded ? 'service-card--embedded' : ''}}"
  bindtap="onTap"
>
  <view class="service-card__body">
    <view wx:if="{{tagList.length}}" class="service-card__tags tag-row">
      <ui-tag
        wx:for="{{tagList}}"
        wx:key="text"
        variant="{{item.variant}}"
        text="{{item.text}}"
      />
    </view>
    <text class="service-card__title text-h3">{{name}}</text>
    <text wx:if="{{!showTags && categoryName}}" class="service-card__category text-caption">{{categoryName}}</text>
    <text wx:if="{{summary}}" class="service-card__summary text-body">{{summary}}</text>
    <view class="service-card__meta">
      <ui-price-display
        mode="{{priceMode}}"
        amount="{{amount}}"
        minAmount="{{minAmount}}"
        maxAmount="{{maxAmount}}"
        showDisclaimer="{{true}}"
        showSuffix="{{showSuffix !== null ? showSuffix : showPriceSuffix}}"
        disclaimerText="{{disclaimerText}}"
      />
    </view>
    <view wx:if="{{showStoreName && storeName}}" class="service-card__footer text-caption">
      <text>{{storeName}}</text>
    </view>
  </view>
</view>
