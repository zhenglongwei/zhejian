.album-bottom-toolbar--overlay {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: calc(var(--z-fixed) + 1);
  height: auto;
  padding: 0 var(--space-sm) calc(env(safe-area-inset-bottom) + var(--space-sm));
  background: transparent;
  border-top: none;
  pointer-events: none;
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__scroll {
  pointer-events: auto;
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__inner {
  padding: 0;
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__item {
  border-color: transparent;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.14);
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__item--active {
  border-color: var(--color-album-active);
  background: rgba(255, 255, 255, 0.96);
}

.album-bottom-toolbar {
  box-sizing: border-box;
  width: 100%;
  height: var(--size-album-toolbar-height);
  background: var(--color-album-toolbar-bg);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.album-bottom-toolbar--disabled {
  opacity: var(--opacity-muted);
  pointer-events: none;
}

.album-bottom-toolbar__scroll {
  width: 100%;
  height: 100%;
}

.album-bottom-toolbar__inner {
  display: inline-flex;
  flex-direction: row;
  gap: var(--space-xs);
  align-items: center;
  box-sizing: border-box;
  height: 100%;
  padding: 0 var(--space-md);
}

.album-bottom-toolbar__item {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  max-width: 240rpx;
  padding: var(--space-xs) var(--space-sm);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-full);
  background: var(--color-bg-card);
}

.album-bottom-toolbar__item--active {
  border-color: var(--color-album-active);
  background: var(--color-album-active-light);
}

.album-bottom-toolbar__label {
  overflow: hidden;
  max-width: 100%;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--color-text-secondary);
}

.album-bottom-toolbar__item--active .album-bottom-toolbar__label {
  color: var(--color-album-active);
}

.album-bottom-toolbar--progress.album-bottom-toolbar--overlay {
  padding: 0 var(--space-md) calc(env(safe-area-inset-bottom) + var(--space-md));
}

.album-bottom-toolbar__panel {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  box-sizing: border-box;
  width: 100%;
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: var(--radius-md);
  background: var(--color-album-immersive-caption-bg);
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.28);
  pointer-events: auto;
}

.album-bottom-toolbar__panel-copy {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  width: 100%;
}

.album-bottom-toolbar__panel-node {
  color: #fff;
  font-weight: var(--font-weight-semibold);
  line-height: var(--font-body-lh);
}

.album-bottom-toolbar__panel-note {
  display: block;
  color: rgba(255, 255, 255, 0.88);
  line-height: var(--font-caption-lh);
  word-break: break-word;
  white-space: pre-wrap;
}

.album-bottom-toolbar__segments {
  display: flex;
  gap: 6rpx;
  align-items: center;
  width: 100%;
  max-width: 520rpx;
}

.album-bottom-toolbar__segment {
  flex: 1;
  height: 6rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.28);
}

.album-bottom-toolbar__segment--filled {
  background: rgba(255, 255, 255, 0.55);
}

.album-bottom-toolbar__segment--active {
  height: 8rpx;
  background: var(--color-album-active);
  box-shadow: 0 0 12rpx rgba(22, 119, 255, 0.45);
}

