.album-bottom-toolbar--overlay {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: calc(var(--z-fixed) + 4);
  box-sizing: border-box;
  height: auto;
  padding: 0 var(--space-md) var(--toolbar-bottom-pad, calc(env(safe-area-inset-bottom) + var(--space-md)));
  background: transparent;
  border-top: none;
  pointer-events: none;
}

.album-bottom-toolbar--embedded {
  box-sizing: border-box;
  width: 100%;
  height: auto;
  background: transparent;
  pointer-events: auto;
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__scroll {
  pointer-events: auto;
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__inner {
  padding: 0;
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__item {
  border-color: transparent;
  background: var(--color-album-overlay-chip);
  box-shadow: var(--shadow-album-overlay-chip);
}

.album-bottom-toolbar--overlay .album-bottom-toolbar__item--active {
  border-color: var(--color-album-active);
  background: var(--color-album-overlay-chip-active);
}

.album-bottom-toolbar {
  box-sizing: border-box;
  width: 100%;
  height: var(--size-album-toolbar-height);
  background: var(--color-album-toolbar-bg);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.album-bottom-toolbar--overlay,
.album-bottom-toolbar--progress {
  height: auto;
  min-height: 0;
  background: transparent;
  border-top: none;
}

.album-bottom-toolbar--disabled {
  opacity: var(--opacity-muted);
  pointer-events: none;
}

.album-bottom-toolbar__scroll {
  width: 100%;
  height: 100%;
}

.album-bottom-toolbar__inner {
  display: inline-flex;
  flex-direction: row;
  gap: var(--space-xs);
  align-items: center;
  box-sizing: border-box;
  height: 100%;
  padding: 0 var(--space-md);
}

.album-bottom-toolbar__item {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  max-width: 240rpx;
  padding: var(--space-xs) var(--space-sm);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-full);
  background: var(--color-bg-card);
}

.album-bottom-toolbar__item--active {
  border-color: var(--color-album-active);
  background: var(--color-album-active-light);
}

.album-bottom-toolbar__label {
  overflow: hidden;
  max-width: 100%;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--color-text-secondary);
}

.album-bottom-toolbar__item--active .album-bottom-toolbar__label {
  color: var(--color-album-active);
}

.album-bottom-toolbar--progress.album-bottom-toolbar--overlay {
  padding-right: var(--space-md);
  padding-left: var(--space-md);
}

.album-bottom-toolbar__panel {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  box-sizing: border-box;
  width: 100%;
  max-height: 46vh;
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--color-album-immersive-border);
  border-radius: var(--radius-md);
  background: var(--color-album-immersive-caption-bg);
  box-shadow: var(--shadow-album-immersive-panel);
  pointer-events: auto;
}

.album-bottom-toolbar__panel-head {
  display: flex;
  flex-shrink: 0;
  gap: var(--space-sm);
  align-items: flex-start;
  width: 100%;
}

.album-bottom-toolbar__panel-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  gap: var(--space-xs);
}

.album-bottom-toolbar__archive {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  margin-top: 2rpx;
  padding: 4rpx var(--space-sm);
  border: 1rpx solid var(--color-album-immersive-border);
  border-radius: var(--radius-full);
  background: var(--color-album-nav-back);
}

.album-bottom-toolbar__archive--hover {
  background: var(--color-album-nav-back-pressed);
}

.album-bottom-toolbar__archive-text {
  font-weight: var(--font-weight-medium);
  color: #fff;
}

.album-bottom-toolbar__panel-node {
  flex-shrink: 0;
  color: #fff;
  font-size: var(--font-body);
  font-weight: var(--font-weight-semibold);
  line-height: var(--font-body-lh);
}

.album-bottom-toolbar__panel-note-box {
  display: block;
  box-sizing: border-box;
  width: 100%;
  max-height: 32vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.album-bottom-toolbar__panel-note {
  display: block;
  box-sizing: border-box;
  width: 100%;
  color: var(--color-album-immersive-note);
  font-size: var(--font-caption);
  line-height: var(--font-caption-lh);
  word-break: break-word;
  white-space: pre-wrap;
}

.album-bottom-toolbar__segments {
  display: flex;
  flex-shrink: 0;
  gap: 6rpx;
  align-items: center;
  width: 100%;
  max-width: 520rpx;
}

.album-bottom-toolbar__segment {
  flex: 1;
  height: 6rpx;
  border-radius: var(--radius-full);
  background: var(--color-album-segment-idle);
}

.album-bottom-toolbar__segment--filled {
  background: var(--color-album-segment-filled);
}

.album-bottom-toolbar__segment--active {
  height: 8rpx;
  background: var(--color-album-active);
  box-shadow: var(--shadow-album-segment-active);
}
