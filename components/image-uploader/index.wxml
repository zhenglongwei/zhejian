<view class="image-uploader {{variant === 'album' ? 'image-uploader--album' : ''}}">
  <view
    wx:for="{{images}}"
    wx:key="*this"
    class="image-uploader__item image-placeholder"
    data-index="{{index}}"
    bindtap="onPreview"
  >
    <image class="image-uploader__img" src="{{item}}" mode="aspectFill" />
    <view
      wx:if="{{!disabled}}"
      class="image-uploader__remove"
      data-index="{{index}}"
      catchtap="onRemove"
    >×</view>
  </view>
  <view
    wx:if="{{images.length < maxCount && !disabled}}"
    class="image-uploader__add image-placeholder"
    bindtap="onAdd"
  >
    <image
      class="image-uploader__add-icon"
      src="{{addIconSrc}}"
      mode="aspectFit"
    />
  </view>
</view>
