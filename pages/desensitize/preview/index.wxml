<view class="page desensitize-preview page-content">
  <block wx:if="{{status === 'loading'}}">
    <ui-skeleton rows="{{4}}" title="{{true}}" />
  </block>

  <block wx:elif="{{status === 'error'}}">
    <ui-empty
      title="无法加载预览"
      description="{{errorMessage}}"
      actionText="重试"
      bind:action="onRetryLoad"
    />
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <ui-empty
      title="暂无待核对图片"
      description="请返回服务相册重试"
      actionText="返回相册"
      bind:action="onBackAlbum"
    />
  </block>

  <block wx:else>
    <view class="desensitize-preview__banner">
      <ui-privacy-banner scene="desensitize" />
    </view>
    <view wx:if="{{fromPreMask}}" class="desensitize-preview__ready">
      <ui-tag variant="desensitized" text="已自动脱敏" />
      <text class="desensitize-preview__ready-hint text-caption">敏感信息已预处理，请逐张核对后再授权公示。</text>
    </view>
    <view wx:if="{{needPreviewHint}}" class="desensitize-preview__preview-hint text-caption">
      建议逐张查看右侧脱敏图，确认效果符合预期后再授权公示。
    </view>
    <ui-desensitize-workbench
      items="{{workbenchItems}}"
      processedCount="{{stats.processed}}"
      totalCount="{{stats.total}}"
      failedCount="{{stats.failed}}"
      liabilityText="{{liabilityText}}"
      liabilityAccepted="{{liabilityAccepted}}"
      bind:liabilitychange="onLiabilityChange"
      bind:preview="onPreview"
      bind:retry="onRetryAsset"
      bind:manualmask="onManualMaskItem"
    />
    <view class="desensitize-preview__spacer" />
    <ui-fixed-bottom-bar>
      <view slot="left" class="desensitize-preview__bar-left">
        <ui-button
          wx:if="{{!fromPreMask}}"
          type="primary"
          size="sm"
          loading="{{autoMaskLoading}}"
          bind:btntap="onAutoMask"
        >一键 AI 脱敏</ui-button>
        <ui-button
          type="ghost"
          size="sm"
          bind:btntap="onManualMask"
        >手工打码</ui-button>
      </view>
      <ui-button
        type="primary"
        slot="right"
        loading="{{confirmLoading}}"
        disabled="{{confirmLoading}}"
        bind:btntap="onConfirm"
      >{{confirmLabelShort}}</ui-button>
    </ui-fixed-bottom-bar>
  </block>
</view>
