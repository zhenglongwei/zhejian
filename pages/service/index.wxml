<view class="page service-page">
  <ui-list-page-shell
    tabs="{{categoryTabs}}"
    activeKey="{{filterCategory}}"
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    emptyTitle="暂无可预约服务"
    emptyDescription="商家上架服务方案后将展示在此"
    emptyActionText="刷新"
    skeletonRows="{{3}}"
    bind:tabchange="onTabChange"
    bind:retry="onRetry"
    bind:emptyaction="onRetry"
  >
    <view slot="intro">
      <view class="tab-page__search page-content">
        <ui-search-bar
          readonly="{{true}}"
          placeholder="{{searchPlaceholder}}"
          bind:navigate="onSearchNavigate"
        />
      </view>
      <view class="tab-page__intro page-content">
        <text class="tab-page__intro-title text-h2">可展示服务</text>
        <text class="tab-page__intro-desc text-caption">价格模式清晰标注，可提交咨询或预约到店</text>
        <view class="tab-page__intro-notice">
          <ui-compliance-notice type="price" />
        </view>
      </view>
    </view>

    <ui-service-card
      wx:for="{{list}}"
      wx:key="id"
      serviceId="{{item.id}}"
      name="{{item.name}}"
      categoryName="{{item.categoryName}}"
      summary="{{item.summary}}"
      priceMode="{{item.priceMode}}"
      amount="{{item.amount}}"
      minAmount="{{item.minAmount}}"
      maxAmount="{{item.maxAmount}}"
      storeName="{{item.storeName}}"
      bind:cardtap="onServiceTap"
    />
  </ui-list-page-shell>
</view>
