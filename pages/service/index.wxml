<view class="page service-page">
  <view class="service-page__intro page-content">
    <text class="text-h2">可预约服务</text>
    <text class="text-caption service-page__desc">价格模式清晰标注，实际费用以门店检测为准</text>
    <view class="service-page__compliance">
      <ui-compliance-notice type="price" />
    </view>
  </view>

  <view class="service-page__tabs page-content">
    <ui-tabs tabs="{{categoryTabs}}" activeKey="{{filterCategory}}" bind:change="onTabChange" />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content service-page__list">
      <ui-skeleton wx:for="{{[1,2,3]}}" wx:key="*this" rows="{{3}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="暂无可预约服务"
        description="商家上架服务方案后将展示在此"
        actionText="刷新"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content service-page__list">
      <ui-service-card
        wx:for="{{list}}"
        wx:key="id"
        serviceId="{{item.id}}"
        name="{{item.name}}"
        categoryName="{{item.categoryName}}"
        summary="{{item.summary}}"
        priceMode="{{item.priceMode}}"
        amount="{{item.amount}}"
        minAmount="{{item.minAmount}}"
        maxAmount="{{item.maxAmount}}"
        storeName="{{item.storeName}}"
        onlinePaymentEnabled="{{item.onlinePaymentEnabled}}"
        bind:tap="onServiceTap"
      />
    </view>
  </block>
</view>
