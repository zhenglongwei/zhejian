<view class="page service-detail">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content service-detail__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法加载服务"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="service-detail__body page-content">
      <view class="service-detail__head">
        <text class="service-detail__title text-h1">{{detail.name}}</text>
        <view class="service-detail__tags">
          <ui-tag
            wx:for="{{detail.headTags}}"
            wx:key="text"
            variant="{{item.variant}}"
            text="{{item.text}}"
          />
        </view>
      </view>

      <view class="service-detail__section">
        <ui-price-display
          mode="{{detail.priceMode}}"
          amount="{{detail.amount}}"
          minAmount="{{detail.minAmount}}"
          maxAmount="{{detail.maxAmount}}"
          showDisclaimer="{{true}}"
          showSuffix="{{detail.priceMode !== 'fixed'}}"
        />
        <view class="service-detail__notice">
          <ui-compliance-notice type="price" wx:if="{{detail.priceMode === 'range' || detail.priceMode === 'consult'}}" />
          <ui-compliance-notice type="accident" wx:if="{{isAccident}}" />
        </view>
      </view>

      <ui-ai-summary-block content="{{detail.summary}}" />

      <ui-key-info-table rows="{{detail.keyInfoRows}}" />

      <view class="service-detail__section">
        <text class="service-detail__section-title text-h2">服务说明</text>
        <text class="text-body">{{detail.detail}}</text>
      </view>

      <view wx:if="{{detail.includedItems.length}}" class="service-detail__section">
        <text class="service-detail__section-title text-h2">服务包含</text>
        <view class="service-detail__list">
          <text
            wx:for="{{detail.includedItems}}"
            wx:key="*this"
            class="service-detail__list-item text-body"
          >· {{item}}</text>
        </view>
      </view>

      <view wx:if="{{detail.excludedItems.length}}" class="service-detail__section">
        <text class="service-detail__section-title text-h2">服务不包含</text>
        <view class="service-detail__list">
          <text
            wx:for="{{detail.excludedItems}}"
            wx:key="*this"
            class="service-detail__list-item text-body"
          >· {{item}}</text>
        </view>
        <view class="service-detail__notice">
          <text class="text-caption">如到店检测发现车辆情况与所选服务不符，门店会与你确认新的维修方案和费用。</text>
        </view>
      </view>

      <view wx:if="{{detail.applicableScenes.length}}" class="service-detail__section">
        <text class="service-detail__section-title text-h2">适用情况</text>
        <view class="service-detail__list">
          <text
            wx:for="{{detail.applicableScenes}}"
            wx:key="*this"
            class="service-detail__list-item text-body"
          >· {{item}}</text>
        </view>
      </view>

      <view wx:if="{{detail.notApplicableScenes.length}}" class="service-detail__section">
        <text class="service-detail__section-title text-h2">不适用情况</text>
        <view class="service-detail__list">
          <text
            wx:for="{{detail.notApplicableScenes}}"
            wx:key="*this"
            class="service-detail__list-item text-body"
          >· {{item}}</text>
        </view>
      </view>

      <view wx:if="{{showPriceFactors && detail.priceFactors.length}}" class="service-detail__section">
        <text class="service-detail__section-title text-h2">影响价格的因素</text>
        <view class="bullet-list">
          <text
            wx:for="{{detail.priceFactors}}"
            wx:key="*this"
            class="bullet-list__item"
          >· {{item}}</text>
        </view>
      </view>

      <view id="cases-section" class="service-detail__section">
        <view class="service-detail__section-head">
          <text class="service-detail__section-title text-h2">类似案例</text>
          <text
            wx:if="{{detail.relatedCases.length}}"
            class="service-detail__more text-caption"
            bindtap="onViewAllCases"
          >查看更多</text>
        </view>
        <view class="service-detail__notice">
          <ui-compliance-notice type="casePrice" />
        </view>
        <block wx:if="{{!detail.relatedCases.length}}">
          <ui-empty
            title="暂无类似案例"
            description="你可以先查看门店或联系客服了解维修能力"
          />
        </block>
        <view wx:else class="service-detail__cases">
          <ui-case-card
            wx:for="{{detail.relatedCases}}"
            wx:key="id"
            caseId="{{item.id}}"
            authorizationTier="{{item.authorizationTier}}"
            coverImage="{{item.coverImage}}"
            title="{{item.title}}"
            serviceName="{{item.serviceName}}"
            summary="{{item.summary}}"
            priceMode="{{item.priceMode}}"
            amount="{{item.amount}}"
            minAmount="{{item.minAmount}}"
            maxAmount="{{item.maxAmount}}"
            storeName="{{item.storeName}}"
            viewCount="{{item.viewCount}}"
            showStoreName="{{true}}"
            bind:tap="onCaseTap"
          />
        </view>
      </view>

      <view class="service-detail__section">
        <text class="service-detail__section-title text-h2">可预约门店</text>
        <block wx:if="{{!detail.availableMerchants.length}}">
          <ui-empty
            title="当前暂无可预约门店"
            description="你可以查看类似案例或联系客服"
          />
        </block>
        <view wx:else class="service-detail__stores">
          <ui-store-card
            wx:for="{{detail.availableMerchants}}"
            wx:key="id"
            storeId="{{item.id}}"
            name="{{item.name}}"
            address="{{item.address}}"
            businessHours="{{item.businessHours}}"
            cardTags="{{item.cardTags}}"
            showLink="{{true}}"
            bind:tap="onStoreTap"
          />
        </view>
      </view>

      <view wx:if="{{detail.serviceFlow.length}}" class="service-detail__section">
        <text class="service-detail__section-title text-h2">服务流程</text>
        <view class="service-detail__flow">
          <view
            wx:for="{{detail.serviceFlow}}"
            wx:key="*this"
            class="service-detail__flow-step"
          >
            <text class="service-detail__flow-index text-caption">{{index + 1}}</text>
            <text class="text-body">{{item}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{detail.faq.length}}" class="service-detail__section">
        <text class="service-detail__section-title text-h2">常见问题</text>
        <ui-faq-list items="{{detail.faq}}" showQPrefix="{{true}}" variant="card" />
      </view>
    </view>

    <ui-fixed-bottom-bar leftActions="{{bottomLeftActions}}" bind:leftaction="onBottomLeftAction">
      <ui-button
        type="primary"
        slot="right"
        disabled="{{!bookable}}"
        bind:tap="onMessage"
      >留言</ui-button>
    </ui-fixed-bottom-bar>

    <ui-login-sheet
      visible="{{loginSheetVisible}}"
      mode="{{loginSheetMode}}"
      bindContext="{{loginSheetBindContext}}"
      bind:close="closeLoginSheet"
      bind:cancel="closeLoginSheet"
      bind:success="onLoginSheetSuccess"
    />
  </block>
</view>
