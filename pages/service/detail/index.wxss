@import '../../../styles/deep-link-detail.wxss';

.service-detail__body {
  padding-top: var(--space-md);
}

.service-detail__panel {
  margin-bottom: var(--space-lg);
}

.service-detail__head {
  margin-bottom: var(--space-md);
}

.service-detail__title {
  display: block;
  margin-bottom: var(--space-sm);
}

.service-detail__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.service-detail__key-well {
  margin-top: var(--space-md);
}

.service-detail__price-section {
  margin-top: 0;
}

.service-detail__contact-well {
  margin-top: var(--space-md);
}

.service-detail__phone-row {
  padding-left: 0;
  padding-right: 0;
}

.service-detail__evidence {
  margin-top: 0;
}

.service-detail__consult-guide {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
}

.service-detail__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.service-detail__list-item {
  color: var(--color-text-primary);
}

.service-detail__flow {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.service-detail__flow-step {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
}

.service-detail__flow-index {
  flex-shrink: 0;
  width: var(--size-flow-step);
  height: var(--size-flow-step);
  line-height: var(--size-flow-step);
  text-align: center;
  background-color: var(--color-primary-light);
  color: var(--color-primary);
  border-radius: var(--radius-full);
}
