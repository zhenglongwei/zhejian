<view class="page consult-submit">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content consult-submit__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法加载"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{confirm}}">
    <view class="page-content consult-submit__body">
      <ui-card wx:if="{{!isMessageMode && confirm.service}}" shadow="{{true}}" padding="{{true}}">
        <text class="consult-submit__section-title text-h3">服务信息</text>
        <ui-service-card
          readonly="{{true}}"
          embedded="{{true}}"
          showTags="{{false}}"
          showStoreName="{{false}}"
          showSuffix="{{false}}"
          disclaimerText="{{priceDisclaimerText}}"
          name="{{confirm.service.name}}"
          categoryName="{{confirm.service.categoryName}}"
          priceMode="{{confirm.service.priceMode}}"
          amount="{{confirm.service.amount}}"
          minAmount="{{confirm.service.minAmount}}"
          maxAmount="{{confirm.service.maxAmount}}"
        />
        <view wx:if="{{showPriceCompliance}}" class="consult-submit__notice">
          <ui-compliance-notice type="price" />
        </view>
        <view wx:if="{{isAccident}}" class="consult-submit__notice">
          <ui-compliance-notice type="accident" />
        </view>
        <view wx:if="{{confirm.consultGuide}}" class="consult-submit__notice">
          <text class="text-caption">门店说明：{{confirm.consultGuide}}</text>
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="consult-submit__section-title text-h3">门店信息</text>
        <ui-key-info-table rows="{{confirm.storeInfoRows}}" />
      </ui-card>

      <ui-card wx:if="{{confirm.caseContext && confirm.caseContext.caseId}}" shadow="{{true}}" padding="{{true}}">
        <text class="consult-submit__section-title text-h3">留言说明</text>
        <text class="text-caption consult-submit__case-hint">你正在就浏览的公开案例向门店留言，门店将结合案例上下文与你联系。</text>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="consult-submit__section-title text-h3">车辆信息</text>
        <view class="consult-submit__field">
          <text class="merchant-form__label">品牌</text>
          <input
            class="merchant-form__input input"
            placeholder="如宝马（选填）"
            value="{{form.brand}}"
            data-field="brand"
            bindinput="onInput"
          />
        </view>
        <view class="consult-submit__field">
          <text class="merchant-form__label">车型</text>
          <input
            class="merchant-form__input input"
            placeholder="如 3 系（选填）"
            value="{{form.series}}"
            data-field="series"
            bindinput="onInput"
          />
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="consult-submit__section-title text-h3">问题描述</text>
        <view class="consult-submit__field">
          <textarea
            class="merchant-form__textarea text-body"
            placeholder="{{descriptionPlaceholder}}"
            value="{{form.description}}"
            data-field="description"
            maxlength="500"
            bindinput="onInput"
          />
        </view>
        <view class="consult-submit__field">
          <text class="merchant-form__label">上传图片（选填）</text>
          <ui-image-uploader
            images="{{form.images}}"
            maxCount="{{9}}"
            bind:change="onImagesChange"
          />
          <view class="consult-submit__notice">
            <ui-compliance-notice type="reviewUpload" />
          </view>
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="consult-submit__section-title text-h3">期望到店时间（选填）</text>
        <view class="consult-submit__field">
          <text class="merchant-form__label">预约日期</text>
          <picker mode="selector" range="{{dateOptions}}" value="{{dateIndex}}" bindchange="onDateChange">
            <view class="merchant-form__picker">{{form.appointmentDateLabel || '请选择日期'}}</view>
          </picker>
        </view>
        <view class="consult-submit__field">
          <text class="merchant-form__label">时间段</text>
          <picker mode="selector" range="{{slotOptions}}" value="{{slotIndex}}" bindchange="onSlotChange">
            <view class="merchant-form__picker">{{form.appointmentSlot || '请选择时间段'}}</view>
          </picker>
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="consult-submit__section-title text-h3">联系人</text>
        <view class="consult-submit__field">
          <text class="merchant-form__label">称呼 *</text>
          <input
            class="merchant-form__input input"
            placeholder="请填写你的称呼"
            value="{{form.contactName}}"
            data-field="contactName"
            bindinput="onInput"
          />
        </view>
        <view class="consult-submit__field">
          <text class="merchant-form__label">手机号 *</text>
          <input
            class="merchant-form__input input"
            type="number"
            maxlength="11"
            placeholder="授权手机号，可修改"
            value="{{form.contactPhone}}"
            data-field="contactPhone"
            bindinput="onInput"
          />
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="consult-submit__consent">
          <ui-checkbox-row checked="{{form.platformConsent}}" bind:toggle="togglePlatformConsent">
            我已知晓实际维修服务由门店线下提供，此处仅提供信息展示和咨询转接。
          </ui-checkbox-row>
        </view>
        <view wx:if="{{isAccident}}" class="consult-submit__consent">
          <ui-checkbox-row checked="{{form.accidentConsent}}" bind:toggle="toggleAccidentConsent">
            我已知晓事故车需到店检测后由门店报价。
          </ui-checkbox-row>
        </view>
      </ui-card>

      <view class="consult-submit__footer-note">
        <ui-compliance-notice type="consultPrivacy" />
      </view>
    </view>

    <ui-fixed-bottom-bar>
      <ui-button
        type="primary"
        slot="right"
        block
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bind:btntap="onSubmit"
      >{{submitLabel}}</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="consult"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
