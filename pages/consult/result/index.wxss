.consult-result__pad {
  padding-top: var(--space-md);
}

.consult-result__body {
  padding-top: var(--space-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
}

.consult-result__actions {
  width: 100%;
  margin-top: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}
