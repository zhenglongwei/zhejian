<view class="page consult-result">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content consult-result__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
    </view>
  </block>

  <block wx:else>
    <view class="page-content consult-result__body">
      <block wx:if="{{success}}">
        <ui-result-hero type="success" title="{{title}}" description="{{description}}">
          <ui-card wx:if="{{summaryRows.length}}" shadow="{{true}}" padding="{{true}}">
            <ui-key-info-table rows="{{summaryRows}}" />
          </ui-card>
        </ui-result-hero>

        <view class="consult-result__actions">
          <ui-button type="primary" block bind:tap="onViewConsult">查看咨询详情</ui-button>
          <ui-button type="secondary" block bind:tap="onViewList">我的咨询</ui-button>
          <ui-button type="ghost" block bind:tap="onBackHome">返回首页</ui-button>
        </view>
      </block>

      <block wx:else>
        <ui-empty
          title="{{title}}"
          description="{{description}}"
          actionText="返回重试"
          bind:action="onRetry"
        />
      </block>
    </view>
  </block>
</view>
