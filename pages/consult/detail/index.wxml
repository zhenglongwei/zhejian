<view class="page record-detail-page">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content record-detail__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content">
      <ui-lead-detail-body
        title="{{lead.serviceName || '门店留言'}}"
        status="{{lead.status}}"
        statusLabel="{{lead.statusLabel}}"
        detailRows="{{detailRows}}"
        description="{{lead.description}}"
        images="{{lead.images}}"
        imageComplianceType="consultImage"
        footerComplianceType="consultRecord"
      />
    </view>

    <ui-fixed-bottom-bar
      leftActions="{{leftActions}}"
      bind:leftaction="onLeftAction"
    >
      <ui-button
        wx:if="{{canCancel}}"
        type="secondary"
        disabled="{{cancelling}}"
        bind:tap="onCancelConsult"
      >取消咨询</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="consult"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
