<view class="page reward-records">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content reward-records__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
      <ui-skeleton rows="{{3}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法加载奖励记录"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="暂无奖励记录"
        description="提交真实服务评价并通过审核后，奖励将在此展示。"
        actionText="查看奖励规则"
        bind:action="onOpenRules"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content reward-records__body">
      <view class="reward-records__notice">
        <ui-compliance-notice type="reward" />
      </view>
      <text class="reward-records__hint text-caption">共 {{total}} 条记录 · MVP 阶段为 mock 发放</text>
      <view class="reward-records__list">
        <ui-card
          wx:for="{{records}}"
          wx:key="rewardId"
          shadow="{{true}}"
          padding="{{true}}"
        >
          <ui-reward-record-card
            rewardId="{{item.rewardId}}"
            orderId="{{item.orderId}}"
            sourceLabel="{{item.sourceLabel}}"
            createdAtText="{{item.createdAtText}}"
            amount="{{item.amount}}"
            statusLabel="{{item.statusLabel}}"
            statusVariant="{{item.statusVariant}}"
            bind:tap="onRecordTap"
          />
        </ui-card>
      </view>
      <view class="reward-records__footer">
        <ui-button type="ghost" size="sm" bind:tap="onOpenRules">评价奖励规则</ui-button>
      </view>
    </view>
  </block>
</view>
