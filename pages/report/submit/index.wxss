.report-submit__pad {
  padding-top: var(--space-md);
}

.report-submit__body {
  padding-top: var(--space-md);
  padding-bottom: var(--page-fixed-clearance);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.report-submit__section-title {
  display: block;
  margin-bottom: var(--space-md);
}

.report-submit__textarea {
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
}

.report-submit__counter {
  display: block;
  margin-top: var(--space-xs);
  text-align: right;
  color: var(--color-text-tertiary);
}

.report-submit__input {
  width: 100%;
  box-sizing: border-box;
}

.report-submit__consent {
  margin-top: var(--space-xs);
}

.report-submit__notice {
  margin-top: var(--space-sm);
}
