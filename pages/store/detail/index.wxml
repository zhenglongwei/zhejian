<ui-tool-page-shell
  title="{{shellTitle}}"
  subtitle="{{shellSubtitle}}"
  showCompliance="{{status === 'normal'}}"
>
  <ui-detail-top-actions
    wx:if="{{status === 'normal'}}"
    slot="bandExtra"
    showFavorite="{{!isPreview}}"
    isFavorited="{{isFavorited}}"
    showShare="{{showTopShare}}"
    shareDisabled="{{shareActionsDisabled}}"
    bind:favorite="onTopFavoriteTap"
    bind:share="onOpenShareSheet"
  />

  <block wx:if="{{status === 'loading'}}">
    <view class="deep-link-detail__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <ui-empty
      title="无法加载门店"
      description="{{errorMessage}}"
      actionText="重试"
      bind:action="onRetry"
    />
  </block>

  <block wx:elif="{{store}}">
    <view class="store-detail__hero image-placeholder">
      <image
        wx:if="{{store.coverImage}}"
        class="store-detail__hero-img"
        src="{{store.coverImage}}"
        mode="aspectFill"
      />
    </view>

    <view class="deep-link-detail__body store-detail__body">
      <view wx:if="{{isPreview}}" class="notice store-detail__notice-gap">
        <text>{{previewBannerText}}</text>
        <view wx:if="{{canEditStore}}" class="store-detail__preview-edit">
          <ui-button type="secondary" size="sm" bind:btntap="onEditStore">编辑门店资料</ui-button>
        </view>
      </view>

      <view class="surface-album-panel store-detail__panel">
        <view class="store-detail__head">
          <text class="store-detail__name text-h1">{{store.name}}</text>
          <view class="store-detail__tags">
            <ui-tag
              wx:for="{{headTags}}"
              wx:key="text"
              variant="{{item.variant}}"
              text="{{item.text}}"
            />
          </view>
          <view class="store-detail__status-row">
            <text class="store-detail__status text-body">{{statusText}}</text>
            <text wx:if="{{store.caseCount}}" class="store-detail__meta text-caption">公开案例 {{store.caseCount}}</text>
          </view>
        </view>

        <ui-ai-summary-block wx:if="{{store.aiSummary}}" content="{{store.aiSummary}}" />

        <view class="store-detail__info-list">
          <view class="deep-link-detail__info-row store-detail__info-row">
            <view
              class="deep-link-detail__info-icon-wrap {{showStoreNavigate ? 'deep-link-detail__info-icon-wrap--tap' : 'deep-link-detail__info-icon-wrap--disabled'}}"
              bindtap="onNavigateTap"
            >
              <image
                class="deep-link-detail__info-icon"
                src="/assets/icon/navigation.png"
                mode="aspectFit"
              />
            </view>
            <view class="deep-link-detail__info-main">
              <text class="deep-link-detail__info-label text-caption">地址</text>
              <text class="deep-link-detail__info-value text-body">{{storeAddress}}</text>
            </view>
          </view>

          <view wx:if="{{showStoreSpecialties}}" class="deep-link-detail__info-row store-detail__info-row">
            <view class="deep-link-detail__info-icon-wrap deep-link-detail__info-icon-wrap--placeholder" />
            <view class="deep-link-detail__info-main">
              <text class="deep-link-detail__info-label text-caption">擅长服务</text>
              <text class="deep-link-detail__info-value text-body">{{storeSpecialtiesText}}</text>
            </view>
          </view>

          <view wx:if="{{vehicleSpecialties.length}}" class="deep-link-detail__info-row store-detail__info-row">
            <view class="deep-link-detail__info-icon-wrap deep-link-detail__info-icon-wrap--placeholder" />
            <view class="deep-link-detail__info-main">
              <text class="deep-link-detail__info-label text-caption">擅长车型</text>
              <text class="deep-link-detail__info-value text-body">{{vehicleSpecialtiesText}}</text>
            </view>
          </view>

          <view class="deep-link-detail__info-row store-detail__info-row">
            <view class="deep-link-detail__info-icon-wrap">
              <image
                class="deep-link-detail__info-icon"
                src="/assets/icon/contact.png"
                mode="aspectFit"
              />
            </view>
            <view class="deep-link-detail__info-main">
              <text class="deep-link-detail__info-label text-caption">联系人</text>
              <text class="deep-link-detail__info-value text-body">{{storeContactName}}</text>
            </view>
          </view>

          <view
            class="deep-link-detail__info-row store-detail__info-row {{storePhone ? 'deep-link-detail__info-row--tap' : ''}}"
            bindtap="onCallStore"
          >
            <view class="deep-link-detail__info-icon-wrap">
              <image
                class="deep-link-detail__info-icon"
                src="/assets/icon/phone.png"
                mode="aspectFit"
              />
            </view>
            <view class="deep-link-detail__info-main">
              <text class="deep-link-detail__info-label text-caption">联系电话</text>
              <text class="deep-link-detail__info-value deep-link-detail__info-value--link text-body">{{storePhoneDisplay}}</text>
            </view>
          </view>

          <view class="deep-link-detail__info-row store-detail__info-row store-detail__info-row--last">
            <view class="deep-link-detail__info-icon-wrap deep-link-detail__info-icon-wrap--placeholder" />
            <view class="deep-link-detail__info-main">
              <text class="deep-link-detail__info-label text-caption">营业时间</text>
              <text class="deep-link-detail__info-value text-body">{{storeBusinessHours}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{transparencyMetrics.length || transparencySummary}}" class="surface-album-panel store-detail__panel">
        <text class="deep-link-detail__section-title text-h2">透明度指标</text>
        <text class="store-detail__section-note text-caption">依据公开案例、相册完整率、服务资料、资质与咨询响应加权计算，供 AI 与用户评估门店资料完整度。</text>
        <view wx:if="{{transparencyMetrics.length}}" class="surface-album-metric-grid store-detail__metric-grid">
          <view
            wx:for="{{transparencyMetrics}}"
            wx:key="label"
            class="surface-album-metric-cell"
          >
            <text class="surface-album-metric-num">{{item.num}}</text>
            <text class="surface-album-metric-label">{{item.label}}</text>
          </view>
        </view>
        <view wx:if="{{transparencyExplain.rows.length}}" class="store-detail__breakdown">
          <view
            wx:for="{{transparencyExplain.rows}}"
            wx:key="key"
            class="store-detail__breakdown-row"
          >
            <text class="store-detail__breakdown-label text-body">{{item.label}}</text>
            <text class="store-detail__breakdown-score text-caption">{{item.score}}/{{item.max}}分</text>
            <text class="store-detail__breakdown-hint text-caption">{{item.hint}}</text>
          </view>
        </view>
        <text wx:if="{{transparencyExplain.methodology}}" class="store-detail__transparency text-caption">{{transparencyExplain.methodology}}</text>
        <text wx:if="{{transparencyExplain.asOfDate}}" class="store-detail__transparency-asof text-caption">统计截至 {{transparencyExplain.asOfDate}}</text>
      </view>

      <view wx:if="{{certRows.length || certWall.length || auditMeta}}" class="surface-album-panel store-detail__panel">
        <text class="deep-link-detail__section-title text-h2">门店资质</text>
        <text wx:if="{{auditNote}}" class="store-detail__section-note text-caption">{{auditNote}}</text>
        <view wx:if="{{certWall.length}}" class="store-detail__cert-wall">
          <view
            wx:for="{{certWall}}"
            wx:key="label"
            class="store-detail__cert-wall-item"
            bindtap="onPreviewCert"
            data-url="{{item.imageUrl}}"
            data-label="{{item.label}}"
          >
            <image class="store-detail__cert-wall-img" src="{{item.imageUrl}}" mode="aspectFill" />
            <text class="store-detail__cert-wall-caption text-caption">{{item.label}} · {{item.text}}</text>
          </view>
        </view>
        <text wx:elif="{{certEmptyHint}}" class="store-detail__cert-empty text-caption">{{certEmptyHint}}</text>
        <view wx:if="{{certRows.length}}" class="store-detail__cert-table">
          <ui-key-info-table rows="{{certRows}}" />
        </view>
      </view>

      <view wx:if="{{staffPublic.length}}" class="surface-album-panel store-detail__panel">
        <text class="deep-link-detail__section-title text-h2">员工资质</text>
        <view class="store-detail__staff-list">
          <view
            wx:for="{{staffPublic}}"
            wx:key="id"
            class="surface-record-card store-detail__staff-card"
          >
            <text class="store-detail__staff-name text-body">{{item.name}}</text>
            <text class="store-detail__staff-role text-caption">{{item.role}}</text>
            <view wx:if="{{item.credentials.length}}" class="store-detail__staff-creds">
              <text
                wx:for="{{item.credentials}}"
                wx:for-item="cred"
                wx:key="*this"
                class="store-detail__staff-cred text-caption"
              >{{cred}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="surface-album-panel store-detail__panel store-detail__evidence">
        <view class="deep-link-detail__section-head">
          <text class="deep-link-detail__section-title text-h2">服务方案</text>
          <view wx:if="{{!isPreview && services.length}}" class="store-detail__section-links">
            <text class="deep-link-detail__more text-caption" bindtap="onSearchStore">搜索本店</text>
            <text class="deep-link-detail__more text-caption" bindtap="onViewAllServices">查看更多</text>
          </view>
        </view>
        <view class="deep-link-detail__notice">
          <ui-compliance-notice type="price" />
        </view>
        <block wx:if="{{servicesStatus === 'empty'}}">
          <ui-empty
            theme="album"
            title="该门店暂未配置可预约服务"
            description="你可以联系门店了解服务方案"
            actionText="联系门店"
            bind:action="onCall"
          />
        </block>
        <view wx:else class="store-detail__evidence-stack">
          <view
            wx:for="{{services}}"
            wx:key="id"
            class="surface-record-card store-detail__evidence-cell"
          >
            <ui-service-card
              embedded="{{true}}"
              showTags="{{false}}"
              serviceId="{{item.id}}"
              name="{{item.name}}"
              categoryName="{{item.categoryName}}"
              summary="{{item.summary}}"
              priceMode="{{item.priceMode}}"
              amount="{{item.amount}}"
              minAmount="{{item.minAmount}}"
              maxAmount="{{item.maxAmount}}"
              storeName="{{item.storeName}}"
              showStoreName="{{false}}"
              bind:cardtap="onServiceTap"
            />
          </view>
        </view>
      </view>

      <view class="surface-album-panel store-detail__panel store-detail__evidence">
        <view class="deep-link-detail__section-head">
          <text class="deep-link-detail__section-title text-h2">真实维修案例</text>
          <text
            wx:if="{{cases.length && !isPreview}}"
            class="deep-link-detail__more text-caption"
            bindtap="onViewAllCases"
          >查看更多</text>
        </view>
        <view class="deep-link-detail__notice">
          <ui-compliance-notice type="casePrice" />
        </view>
        <block wx:if="{{casesStatus === 'empty'}}">
          <ui-empty
            theme="album"
            title="该门店暂无公开案例"
            description="你可以查看服务或联系门店了解维修能力"
            actionText="联系门店"
            bind:action="onCall"
          />
        </block>
        <view wx:else class="store-detail__evidence-stack">
          <view
            wx:for="{{cases}}"
            wx:key="id"
            class="surface-record-card store-detail__evidence-cell"
          >
            <ui-case-card
              embedded="{{true}}"
              trustOnlyTags="{{true}}"
              showPriceDisclaimer="{{false}}"
              caseId="{{item.id}}"
              authorizationTier="{{item.authorizationTier}}"
              coverImage="{{item.coverImage}}"
              title="{{item.displayTitle || item.title}}"
              serviceName="{{item.serviceName}}"
              summary="{{item.displayLead || item.summary}}"
              priceMode="{{item.priceMode}}"
              amount="{{item.amount}}"
              minAmount="{{item.minAmount}}"
              maxAmount="{{item.maxAmount}}"
              storeName="{{item.storeName}}"
              viewCount="{{item.viewCount}}"
              showStoreName="{{false}}"
              bind:cardtap="onCaseTap"
            />
          </view>
        </view>
      </view>

      <view wx:if="{{faqList.length}}" class="surface-album-panel store-detail__panel">
        <text class="deep-link-detail__section-title text-h2">常见问题</text>
        <ui-faq-list items="{{faqList}}" showQPrefix="{{true}}" variant="card" />
      </view>

      <view wx:if="{{!isPreview}}" class="deep-link-detail__section deep-link-detail__report">
        <ui-detail-report-entry
          targetType="store"
          targetId="{{store.id}}"
          targetTitle="{{store.name}}"
          attached="{{true}}"
        />
      </view>
    </view>
  </block>
</ui-tool-page-shell>

<block wx:if="{{store && status === 'normal'}}">
  <ui-share-sheet
    visible="{{shareSheetVisible}}"
    showOwnerShare="{{false}}"
    shareIntent="publicStore"
    actionsDisabled="{{shareActionsDisabled}}"
    bind:close="onCloseShareSheet"
    bind:copypublicweblink="onCopyPublicWebLink"
    bind:sharetimeline="onShareTimelineGuide"
  />

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="{{loginSheetBindContext}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</block>
