.store-detail__pad {
  padding-top: var(--space-md);
}

.store-detail__hero {
  width: 100%;
  height: 360rpx;
  background-color: var(--color-bg-muted);
}

.store-detail__hero-img {
  width: 100%;
  height: 100%;
}

.store-detail__body {
  padding-top: var(--space-md);
  padding-bottom: var(--page-fixed-clearance);
}

.store-detail__report {
  margin-top: var(--space-lg);
}

.store-detail__notice-gap {
  margin-bottom: var(--space-md);
}

.store-detail__compliance--top {
  margin-top: 0;
  margin-bottom: var(--space-md);
}

.store-detail__head {
  margin-bottom: var(--space-md);
}

.store-detail__name {
  display: block;
  margin-bottom: var(--space-sm);
}

.store-detail__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.store-detail__status-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-sm);
}

.store-detail__status {
  color: var(--color-success);
}

.store-detail__meta {
  color: var(--color-text-secondary);
}

.store-detail__card-wrap {
  margin-top: var(--space-md);
}

.store-detail__section {
  margin-top: var(--space-lg);
}

.store-detail__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.store-detail__section-title {
  display: block;
}

.store-detail__more {
  color: var(--color-primary);
}

.store-detail__privacy,
.store-detail__compliance {
  display: block;
  margin-bottom: var(--space-sm);
}

.store-detail__cases {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-top: var(--space-md);
}
