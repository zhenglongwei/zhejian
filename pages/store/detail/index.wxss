@import '../../../styles/deep-link-detail.wxss';

.store-detail__hero {
  width: 100%;
  height: 360rpx;
  margin-bottom: var(--space-lg);
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.store-detail__hero-img {
  width: 100%;
  height: 100%;
}

.store-detail__hero-swiper {
  width: 100%;
  height: 100%;
}

.store-detail__body {
  padding-top: var(--space-md);
}

.store-detail__panel--top {
  margin-top: 0;
}

.store-detail__head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.store-detail__head {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.store-detail__head-actions {
  flex-shrink: 0;
  padding-top: var(--space-xs);
}

.store-detail__panel {
  margin-bottom: var(--space-lg);
}

.store-detail__panel:last-child {
  margin-bottom: 0;
}

.store-detail__notice-gap {
  margin-bottom: var(--space-md);
}

.store-detail__preview-edit {
  margin-top: var(--space-sm);
}

.store-detail__name {
  display: block;
  margin-bottom: var(--space-sm);
}

.store-detail__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.store-detail__status-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-sm);
}

.store-detail__status {
  color: var(--color-success);
}

.store-detail__meta {
  color: var(--color-text-secondary);
}

.store-detail__section-note {
  display: block;
  margin-bottom: var(--space-md);
  color: var(--color-text-secondary);
  line-height: 1.55;
}

.store-detail__info-list {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-md);
  padding: var(--space-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.store-detail__info-row {
  padding-left: 0;
  padding-right: 0;
}

.store-detail__info-row--last {
  border-bottom: none;
}

.store-detail__metric-grid {
  margin-bottom: var(--space-md);
}

.store-detail__breakdown {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.store-detail__breakdown-row {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.store-detail__breakdown-row:last-child {
  border-bottom: none;
}

.store-detail__breakdown-label {
  display: block;
  font-weight: 600;
}

.store-detail__breakdown-score {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.store-detail__breakdown-hint {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.store-detail__transparency {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.55;
}

.store-detail__transparency-asof {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.store-detail__cert-table {
  margin-top: var(--space-md);
}

.store-detail__cert-empty {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-tertiary);
}

.store-detail__cert-wall {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-md);
  margin-top: var(--space-md);
}

.store-detail__cert-wall-item {
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-bg-muted);
  border: 1rpx solid var(--color-border);
}

.store-detail__cert-wall-img {
  width: 100%;
  height: 200rpx;
  display: block;
}

.store-detail__cert-wall-caption {
  display: block;
  padding: var(--space-sm) var(--space-md);
  color: var(--color-text-secondary);
}

.store-detail__staff-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.store-detail__staff-card {
  padding: var(--space-md);
}

.store-detail__staff-head {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.store-detail__staff-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-bg-muted);
  flex-shrink: 0;
}

.store-detail__staff-meta {
  flex: 1;
  min-width: 0;
}

.store-detail__staff-name {
  display: block;
  font-weight: 600;
}

.store-detail__staff-role {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.store-detail__staff-creds {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-sm);
}

.store-detail__staff-cred {
  padding: var(--space-xs) var(--space-sm);
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  color: var(--color-text-secondary);
}

.store-detail__staff-photos {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.store-detail__staff-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  background-color: var(--color-bg-muted);
}

.store-detail__section-links {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.store-detail__evidence {
  margin-top: 0;
}

.store-detail__evidence-stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-top: var(--space-md);
}

.store-detail__evidence-cell {
  padding: var(--space-md);
}
