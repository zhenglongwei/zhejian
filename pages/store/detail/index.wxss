@import '../../../styles/deep-link-detail.wxss';

.store-detail__hero {
  width: 100%;
  height: 360rpx;
  background-color: var(--color-bg-muted);
}

.store-detail__hero-img {
  width: 100%;
  height: 100%;
}

.store-detail__notice-gap {
  margin-bottom: var(--space-md);
}

.store-detail__preview-edit {
  margin-top: var(--space-sm);
}

.store-detail__head {
  margin-bottom: var(--space-md);
}

.store-detail__name {
  display: block;
  margin-bottom: var(--space-sm);
}

.store-detail__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.store-detail__status-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-sm);
}

.store-detail__status {
  color: var(--color-success);
}

.store-detail__meta {
  color: var(--color-text-secondary);
}

.store-detail__section-links {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}
