<view class="page order-confirm">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content order-confirm__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法加载"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{confirm}}">
    <view class="page-content order-confirm__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="order-confirm__section-title text-h3">服务信息</text>
        <text class="order-confirm__service-name text-body">{{confirm.service.name}}</text>
        <text class="order-confirm__service-meta text-caption">{{confirm.service.categoryName}}</text>
        <view class="order-confirm__price">
          <ui-price-display
            mode="{{confirm.service.priceMode}}"
            amount="{{confirm.service.amount}}"
            minAmount="{{confirm.service.minAmount}}"
            maxAmount="{{confirm.service.maxAmount}}"
            showDisclaimer="{{true}}"
            showSuffix="{{false}}"
          />
        </view>
        <view wx:if="{{showPriceCompliance}}" class="order-confirm__notice">
          <ui-compliance-notice type="price" />
        </view>
        <view wx:if="{{isAccident}}" class="order-confirm__notice">
          <ui-compliance-notice type="accident" />
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="order-confirm__section-title text-h3">门店信息</text>
        <ui-key-info-table rows="{{confirm.storeInfoRows}}" />
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="order-confirm__section-title text-h3">车辆信息</text>
        <view class="order-confirm__field">
          <text class="merchant-form__label">品牌 *</text>
          <input
            class="merchant-form__input input"
            placeholder="如宝马"
            value="{{form.brand}}"
            data-field="brand"
            bindinput="onInput"
          />
        </view>
        <view class="order-confirm__field">
          <text class="merchant-form__label">车型 *</text>
          <input
            class="merchant-form__input input"
            placeholder="如 3 系"
            value="{{form.series}}"
            data-field="series"
            bindinput="onInput"
          />
        </view>
        <view class="order-confirm__field">
          <text class="merchant-form__label">车牌号（可选）</text>
          <input
            class="merchant-form__input input"
            placeholder="提交后按规则脱敏展示"
            value="{{form.plate}}"
            data-field="plate"
            bindinput="onInput"
          />
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="order-confirm__section-title text-h3">预约时间</text>
        <view class="order-confirm__field">
          <text class="merchant-form__label">预约日期 *</text>
          <picker mode="selector" range="{{dateOptions}}" value="{{dateIndex}}" bindchange="onDateChange">
            <view class="merchant-form__picker">{{form.appointmentDateLabel || '请选择日期'}}</view>
          </picker>
        </view>
        <view class="order-confirm__field">
          <text class="merchant-form__label">时间段 *</text>
          <picker mode="selector" range="{{slotOptions}}" value="{{slotIndex}}" bindchange="onSlotChange">
            <view class="merchant-form__picker">{{form.appointmentSlot || '请选择时间段'}}</view>
          </picker>
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="order-confirm__section-title text-h3">联系人</text>
        <view class="order-confirm__field">
          <text class="merchant-form__label">称呼 *</text>
          <input
            class="merchant-form__input input"
            placeholder="姓名或称呼"
            value="{{form.contactName}}"
            data-field="contactName"
            bindinput="onInput"
          />
        </view>
        <view class="order-confirm__field">
          <text class="merchant-form__label">手机号</text>
          <text class="order-confirm__readonly text-body">{{confirm.defaultContact.phoneDisplay || '请先绑定手机号'}}</text>
        </view>
      </ui-card>

      <ui-card wx:if="{{confirm.priceSummary}}" shadow="{{true}}" padding="{{true}}">
        <text class="order-confirm__section-title text-h3">价格明细</text>
        <ui-key-info-table rows="{{confirm.priceInfoRows}}" />
        <ui-compliance-notice
          wx:if="{{isStandardOrder}}"
          text="标准套餐以页面标注价格为准；超出套餐范围的项目，门店会与你确认后再收费。"
        />
      </ui-card>

      <ui-card wx:if="{{isAccident}}" shadow="{{true}}" padding="{{true}}">
        <ui-checkbox-row checked="{{form.liabilityAccepted}}" bind:toggle="toggleLiability">
          我已知晓事故车维修需到店检测或拆检后确认维修方案和费用
        </ui-checkbox-row>
      </ui-card>

      <view class="order-confirm__footer-note">
        <ui-compliance-notice type="authorize" text="订单与车辆信息仅用于本次服务联系，不会公开展示完整车牌或手机号。" />
      </view>
    </view>

    <ui-fixed-bottom-bar>
      <ui-button
        type="primary"
        slot="right"
        block
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bind:tap="onSubmit"
      >{{submitLabel}}</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="order"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
