<view class="page message-list">
  <ui-list-page-shell
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    emptyTitle="暂无消息"
    emptyDescription="咨询进度、服务相册与授权审核结果会在这里通知你"
    unauthTitle="登录后查看消息"
    unauthDescription="登录后可接收咨询、相册与案例审核相关通知"
    bind:retry="onRetry"
    bind:unauthaction="onLoginTap"
  >
    <view slot="intro" wx:if="{{isLoggedIn}}">
      <ui-message-subscribe-banner bind:subscribe="onSubscribeWechat" />
    </view>
    <view wx:if="{{unreadCount > 0 && status === 'normal'}}" class="message-list__toolbar">
      <text class="text-caption">未读 {{unreadCount}} 条</text>
      <text class="text-link text-caption" bindtap="onMarkAllRead">全部已读</text>
    </view>
    <ui-message-card
      wx:for="{{list}}"
      wx:key="id"
      messageId="{{item.id}}"
      title="{{item.title}}"
      content="{{item.content}}"
      time="{{item.createdAt}}"
      read="{{item.read}}"
      jumpPath="{{item.jumpPath}}"
      bind:tap="onItemTap"
    />
  </ui-list-page-shell>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="consult"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
