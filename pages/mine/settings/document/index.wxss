.legal-doc {
  padding-top: var(--space-md);
  padding-bottom: var(--space-xl);
}

.legal-doc__updated {
  display: block;
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-lg);
}

.legal-doc__section {
  margin-bottom: var(--space-lg);
}

.legal-doc__heading {
  display: block;
  margin-bottom: var(--space-sm);
}

.legal-doc__body {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
