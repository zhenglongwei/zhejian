.about-page {
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
}

.about-page__main {
  display: flex;
  flex-direction: column;
}

.about-page__block {
  margin-bottom: 0;
}

.about-page__heading {
  display: block;
  margin-bottom: var(--space-sm);
}

.about-page__body {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.about-page__note {
  margin-top: var(--space-md);
}

.about-page__note-title {
  display: block;
  margin-bottom: var(--space-xs);
}

.about-page__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}
