<ui-tool-page-shell
  showBand="{{false}}"
  complianceText="{{platformNotice}}"
  showCompliance="{{true}}"
>
  <view class="settings-page">
    <view class="settings-page__main surface-album-panel">
      <ui-cell
        title="使用说明与帮助"
        border="{{true}}"
        arrow="{{true}}"
        data-key="help"
        bind:celltap="onCellTap"
      />
      <ui-cell
        title="用户协议"
        border="{{true}}"
        arrow="{{true}}"
        data-key="agreement"
        bind:celltap="onCellTap"
      />
      <ui-cell
        title="隐私政策"
        border="{{true}}"
        arrow="{{true}}"
        data-key="privacy"
        bind:celltap="onCellTap"
      />
      <ui-cell
        title="关于辙见"
        border="{{false}}"
        arrow="{{true}}"
        data-key="about"
        bind:celltap="onCellTap"
      />

      <block wx:if="{{isLoggedIn}}">
        <view class="surface-album-inset-divider" />
        <ui-cell
          title="账号注销"
          desc="不可恢复，请谨慎操作"
          border="{{false}}"
          arrow="{{true}}"
          data-key="deactivate"
          bind:celltap="onCellTap"
        />
      </block>
    </view>

    <view wx:if="{{isLoggedIn}}" class="settings-page__logout">
      <ui-button type="danger" block bind:btntap="onLogout">退出登录</ui-button>
    </view>
  </view>
</ui-tool-page-shell>
