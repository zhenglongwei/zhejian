.profile-form__pad {
  padding-top: var(--space-md);
}

.profile-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-sm);
  padding-bottom: var(--space-md);
}

.profile-form__main {
  padding: 0;
}

.profile-form__row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: var(--space-md);
  min-height: var(--cell-height);
  padding: var(--space-md);
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--color-album-frame-line);
}

.profile-form__row--bordered {
  border-bottom: 1rpx solid var(--color-album-frame-line);
}

.profile-form__row--last {
  border-bottom: none;
}

.profile-form__row--avatar {
  min-height: 128rpx;
}

.profile-form__row--input {
  min-height: var(--cell-height);
}

.profile-form__row:active:not(.profile-form__row--input) {
  opacity: 0.72;
}

.profile-form__label {
  flex-shrink: 0;
  color: var(--color-text-primary);
}

.profile-form__value-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-xs);
  flex: 1;
  min-width: 0;
}

.profile-form__trail {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.profile-form__value {
  flex: 1;
  min-width: 0;
  text-align: right;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-form__value--muted {
  color: var(--color-text-tertiary);
}

.profile-form__arrow {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
  font-size: 36rpx;
  line-height: 1;
}

.profile-form__avatar-btn {
  width: 96rpx;
  min-width: 96rpx;
  max-width: 96rpx;
  height: 96rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  line-height: 1;
  display: block;
  box-sizing: border-box;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.profile-form__avatar-btn::after {
  display: none;
  border: none;
}

.profile-form__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  display: block;
}

.profile-form__avatar--placeholder {
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
}

.profile-form__input {
  flex: 1;
  min-width: 0;
  height: var(--font-body-lh);
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  text-align: right;
  color: var(--color-text-secondary);
  box-sizing: border-box;
}

.profile-form__placeholder {
  color: var(--color-text-tertiary);
}
