<ui-tool-page-shell>
  <view class="help-center">
    <view class="help-center__main surface-album-panel">
      <view wx:for="{{sections}}" wx:key="heading" class="help-center__section">
        <text class="help-center__heading text-h3">{{item.heading}}</text>
        <text class="help-center__body text-body">{{item.body}}</text>
      </view>

      <view class="surface-album-inset-divider" />

      <view class="help-center__actions">
        <ui-button type="ghost" size="sm" bind:btntap="onOpenAbout">关于辙见</ui-button>
        <ui-button type="ghost" size="sm" bind:btntap="onOpenH5Site">浏览 H5 内容站</ui-button>
        <ui-button type="secondary" size="sm" bind:btntap="onContactSupport">联系客服</ui-button>
      </view>
    </view>
  </view>
</ui-tool-page-shell>
