<view class="page vehicle-list bg-album">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content vehicle-list__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="page-content">
      <ui-empty
        theme="album"
        title="{{needPhone ? '绑定手机号后管理车辆' : '登录后管理车辆'}}"
        description="{{needPhone ? '绑定后可保存常用车辆信息' : '登录后可保存常用车辆信息'}}"
        actionText="{{needPhone ? '绑定手机号' : '微信一键登录'}}"
        bind:action="onLoginTap"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        theme="album"
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content vehicle-list__empty-wrap">
      <ui-empty
        theme="album"
        title="暂无车辆"
        description="添加常用车辆信息"
        actionText="添加车辆"
        bind:action="onAddVehicle"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content vehicle-list__body">
      <view class="vehicle-list__main surface-album-panel">
        <view
          wx:for="{{list}}"
          wx:key="id"
          class="vehicle-list__row"
          data-id="{{item.id}}"
          bind:tap="onOpenDetail"
        >
          <view class="vehicle-list__row-main">
            <view class="vehicle-list__title-row">
              <text class="vehicle-list__title text-body">{{item.displayTitle}}</text>
              <ui-tag wx:if="{{item.isDefault}}" variant="success" text="默认" />
            </view>
            <text wx:if="{{item.plateDisplay}}" class="vehicle-list__meta text-caption">车牌 {{item.plateDisplay}}</text>
            <text class="vehicle-list__meta text-caption">服务相册 {{item.albumCount || 0}} 本</text>
          </view>
          <view class="vehicle-list__actions" catchtap="">
            <text
              class="vehicle-list__action text-link"
              data-id="{{item.id}}"
              catchtap="onEditVehicle"
            >编辑</text>
            <text
              wx:if="{{!item.isDefault}}"
              class="vehicle-list__action text-link"
              data-id="{{item.id}}"
              catchtap="onSetDefault"
            >设默认</text>
            <text
              class="vehicle-list__action text-link"
              data-id="{{item.id}}"
              catchtap="onDeleteVehicle"
            >删除</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <ui-fixed-bottom-bar wx:if="{{status === 'normal' || status === 'empty'}}">
    <ui-button type="primary" block="{{true}}" disabled="{{!canAdd && status === 'normal'}}" bind:btntap="onAddVehicle">
      新增车辆
    </ui-button>
  </ui-fixed-bottom-bar>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="{{loginSheetBindContext}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
