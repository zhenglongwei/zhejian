.vehicle-detail__state {
  padding-top: var(--space-lg);
  padding-bottom: var(--space-xl);
}

.vehicle-detail__head {
  padding-top: var(--space-sm);
}

.vehicle-detail__head-inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.vehicle-detail__title-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  align-items: center;
}

.vehicle-detail__title {
  color: var(--color-text-primary);
}

.vehicle-detail__meta {
  color: var(--color-text-secondary);
}

.vehicle-detail__head-actions {
  margin-top: var(--space-xs);
}

.vehicle-detail__section-title {
  padding-top: var(--space-md);
  padding-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
}

.vehicle-detail__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-bottom: var(--space-xl);
}
