<view class="page vehicle-edit">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content vehicle-edit__pad">
      <ui-skeleton rows="{{5}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content vehicle-edit__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="vehicle-edit__field">
          <text class="merchant-form__label">品牌</text>
          <input
            class="merchant-form__input input"
            placeholder="如宝马"
            value="{{form.brand}}"
            data-field="brand"
            bindinput="onInput"
          />
        </view>
        <view class="vehicle-edit__field">
          <text class="merchant-form__label">车型</text>
          <input
            class="merchant-form__input input"
            placeholder="如 3 系"
            value="{{form.series}}"
            data-field="series"
            bindinput="onInput"
          />
        </view>
        <view class="vehicle-edit__field">
          <text class="merchant-form__label">年款（选填）</text>
          <input
            class="merchant-form__input input"
            placeholder="如 2020"
            value="{{form.modelYear}}"
            data-field="modelYear"
            bindinput="onInput"
          />
        </view>
        <view class="vehicle-edit__field">
          <text class="merchant-form__label">车牌（选填）</text>
          <input
            class="merchant-form__input input"
            placeholder="保存后将脱敏展示"
            value="{{form.plate}}"
            data-field="plate"
            bindinput="onInput"
          />
        </view>
        <view class="vehicle-edit__switch">
          <text class="text-body">设为默认车辆</text>
          <switch checked="{{form.isDefault}}" color="var(--color-primary)" bindchange="onDefaultChange" />
        </view>
        <text class="text-caption vehicle-edit__hint">不采集 VIN 与行驶证信息；最多保存 {{maxVehicles}} 辆车。</text>
      </ui-card>
    </view>

    <ui-fixed-bottom-bar>
      <ui-button type="primary" block="{{true}}" loading="{{submitting}}" bind:tap="onSubmit">保存</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="{{loginSheetBindContext}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
