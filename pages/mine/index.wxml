<view class="page mine">
  <block wx:if="{{status === 'loading' && isLoggedIn}}">
    <view class="page-content mine__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" avatar="{{true}}" />
      <view class="mine__sk-block">
        <ui-skeleton rows="{{2}}" title="{{false}}" />
      </view>
      <ui-skeleton rows="{{5}}" title="{{false}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content mine__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <ui-mine-user-header
          isLoggedIn="{{isLoggedIn}}"
          user="{{user}}"
          bind:usertap="onUserAreaTap"
          bind:logintap="onLoginTap"
          bind:bindphonetap="onBindPhoneTap"
        />
      </ui-card>

      <view wx:if="{{showAlbumPreview}}" class="mine__album-section">
        <view class="mine__section-head">
          <view class="mine__section-title-wrap">
            <text class="mine__section-title text-h3">我的服务记录</text>
            <text wx:if="{{albumPendingAuthBadge}}" class="mine__section-badge">{{albumPendingAuthBadge}}</text>
          </view>
          <text class="mine__more text-caption" bindtap="onViewAllAlbums">查看全部</text>
        </view>
        <view class="mine__album-stack">
          <ui-album-card
            wx:for="{{albumPreview}}"
            wx:key="albumId"
            item="{{item}}"
            bind:tap="onAlbumCardTap"
          />
        </view>
      </view>

      <ui-card wx:elif="{{isLoggedIn && showAlbumEmpty}}" shadow="{{true}}" padding="{{true}}">
        <text class="mine__section-title text-h3">我的服务记录</text>
        <text class="mine__empty-hint text-caption">暂无服务相册，请返回首页扫描门店二维码或输入相册码</text>
      </ui-card>

      <ui-card
        wx:for="{{menuSections}}"
        wx:key="key"
        shadow="{{true}}"
        padding="{{false}}"
      >
        <ui-cell
          wx:for="{{item.items}}"
          wx:for-item="cell"
          wx:for-index="cellIndex"
          wx:key="key"
          title="{{cell.label}}"
          desc="{{cell.desc}}"
          badge="{{cell.badge}}"
          border="{{cellIndex < item.items.length - 1}}"
          data-key="{{cell.key}}"
          bind:celltap="onMenuCellTap"
        />
      </ui-card>

      <ui-compliance-notice text="{{platformNotice}}" />
    </view>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="{{loginSheetBindContext}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
