<view class="page mine">
  <block wx:if="{{status === 'loading' && isLoggedIn}}">
    <view class="page-content mine__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" avatar="{{true}}" />
      <ui-skeleton rows="{{5}}" title="{{false}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content mine__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <ui-mine-user-header
          isLoggedIn="{{isLoggedIn}}"
          user="{{user}}"
          avatarPreview="{{avatarPreview}}"
          bind:logintap="onLoginTap"
          bind:bindphonetap="onBindPhoneTap"
          bind:avatarchoose="onAvatarChoose"
          bind:nicknamechange="onNicknameChange"
        />
      </ui-card>

      <ui-card
        wx:for="{{menuSections}}"
        wx:key="key"
        shadow="{{true}}"
        padding="{{false}}"
      >
        <ui-cell
          wx:for="{{item.items}}"
          wx:for-item="cell"
          wx:for-index="cellIndex"
          wx:key="key"
          title="{{cell.label}}"
          desc="{{cell.desc}}"
          badge="{{cell.badge}}"
          dot="{{cell.dot}}"
          border="{{cellIndex < item.items.length - 1}}"
          data-key="{{cell.key}}"
          bind:celltap="onMenuCellTap"
        />
      </ui-card>

      <ui-compliance-notice text="{{platformNotice}}" />
    </view>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="{{loginSheetBindContext}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
