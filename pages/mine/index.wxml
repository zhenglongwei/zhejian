<view class="page mine">
  <block wx:if="{{status === 'loading' && isLoggedIn}}">
    <view class="page-content mine__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" avatar="{{true}}" />
      <view class="mine__sk-block">
        <ui-skeleton rows="{{2}}" title="{{false}}" />
      </view>
      <ui-skeleton rows="{{5}}" title="{{false}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content mine__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="mine__user" bindtap="onUserAreaTap">
          <view class="mine__avatar-wrap">
            <image
              wx:if="{{isLoggedIn && user.avatarUrl}}"
              class="mine__avatar"
              src="{{user.avatarUrl}}"
              mode="aspectFill"
            />
            <view wx:else class="mine__avatar mine__avatar--placeholder image-placeholder">
              <text class="mine__avatar-icon">👤</text>
            </view>
          </view>
          <view class="mine__user-meta">
            <block wx:if="{{isLoggedIn}}">
              <text class="mine__nickname text-h2">{{user.nickname || '微信用户'}}</text>
              <text wx:if="{{user.isPhoneBound}}" class="mine__phone text-caption">{{user.phoneDisplay}}</text>
              <view wx:else class="mine__bind-hint">
                <ui-tag variant="info" text="未绑定手机号" />
                <text class="mine__bind-desc text-caption">绑定手机号后可下单、预约和接收服务通知</text>
                <ui-button type="secondary" size="sm" catch:tap="onBindPhoneTap">绑定手机号</ui-button>
              </view>
            </block>
            <block wx:else>
              <text class="mine__nickname text-h2">点击登录</text>
              <text class="mine__guest-desc text-caption">登录后查看订单、车辆和奖励</text>
              <view class="mine__login-btn">
                <ui-button type="primary" size="sm" catch:tap="onLoginTap">微信一键登录</ui-button>
              </view>
            </block>
          </view>
        </view>
      </ui-card>

      <!-- 订单快捷入口 PRD §10 -->
      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="mine__section-head">
          <text class="mine__section-title text-h3">我的订单</text>
        </view>
        <view class="mine__orders">
          <view
            wx:for="{{orderShortcuts}}"
            wx:key="key"
            class="mine__order-item"
            data-key="{{item.key}}"
            bindtap="onOrderShortcutTap"
          >
            <text class="mine__order-label text-caption">{{item.label}}</text>
            <text wx:if="{{item.count}}" class="mine__order-badge">{{item.count}}</text>
          </view>
        </view>
      </ui-card>

      <!-- 资产摘要（已登录） -->
      <ui-card wx:if="{{isLoggedIn && assets}}" shadow="{{true}}" padding="{{true}}">
        <view class="mine__assets">
          <view class="mine__asset-item">
            <text class="mine__asset-value text-h3">¥{{assets.availableReward}}</text>
            <text class="mine__asset-label text-caption">可用奖励</text>
          </view>
          <view class="mine__asset-item">
            <text class="mine__asset-value text-h3">¥{{assets.pendingIncome}}</text>
            <text class="mine__asset-label text-caption">待结算</text>
          </view>
          <view class="mine__asset-item">
            <text class="mine__asset-value text-h3">{{assets.couponCount}}</text>
            <text class="mine__asset-label text-caption">优惠券</text>
          </view>
        </view>
        <ui-compliance-notice type="reward" />
      </ui-card>

      <!-- 功能菜单 -->
      <ui-card shadow="{{true}}" padding="{{false}}">
        <view
          wx:for="{{protectedMenus}}"
          wx:key="key"
          class="cell mine__cell"
          data-key="{{item.key}}"
          bindtap="onProtectedMenuTap"
        >
          <view class="mine__cell-main">
            <text class="text-body">{{item.label}}</text>
            <text wx:if="{{item.desc}}" class="mine__cell-desc text-caption">{{item.desc}}</text>
          </view>
          <view class="mine__cell-extra">
            <text wx:if="{{item.key === 'vehicles' && vehicleCount}}" class="mine__cell-count text-caption">{{vehicleCount}} 辆</text>
            <text wx:if="{{item.key === 'archive' && repairArchiveCount}}" class="mine__cell-count text-caption">{{repairArchiveCount}} 份</text>
            <text class="mine__arrow text-caption">›</text>
          </view>
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{false}}">
        <view
          wx:for="{{publicMenus}}"
          wx:key="key"
          class="cell mine__cell"
          data-key="{{item.key}}"
          bindtap="onPublicMenuTap"
        >
          <text class="text-body">{{item.label}}</text>
          <text class="mine__arrow text-caption">›</text>
        </view>
        <view class="cell mine__cell" bindtap="onOpenMerchant">
          <text class="text-body">商家工作台</text>
          <text class="mine__arrow text-caption">›</text>
        </view>
      </ui-card>
    </view>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="{{loginSheetBindContext}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
