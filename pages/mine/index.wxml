<ui-tool-page-shell showBand="{{false}}" showCompliance="{{false}}">
  <block wx:if="{{status === 'loading' && isLoggedIn}}">
    <view class="mine__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" avatar="{{true}}" />
      <ui-skeleton rows="{{5}}" title="{{false}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <ui-empty
      theme="album"
      title="加载失败"
      description="{{errorMessage}}"
      actionText="重试"
      bind:action="onRetry"
    />
  </block>

  <block wx:else>
    <view class="mine__hub">
      <view wx:if="{{!isLoggedIn}}" class="mine__tool-hint surface-album-panel">
        <text class="text-caption text-secondary">{{guestToolHint}}</text>
      </view>

      <view class="mine__folio surface-album-folio">
        <ui-mine-user-header
          variant="hub"
          isLoggedIn="{{isLoggedIn}}"
          user="{{user}}"
          vehicleSummary="{{vehicleSummary}}"
          bind:logintap="onLoginTap"
          bind:profiletap="onProfileTap"
        />
      </view>

      <view class="mine__main surface-album-panel">
        <view class="mine__section-head">
          <text class="mine__section-title text-h3">{{albumSectionTitle}}</text>
          <view wx:if="{{isLoggedIn}}" class="mine__section-links">
            <view class="mine__section-link" bindtap="onAlbumListTap">
              <text class="mine__section-link-text text-caption text-link">全部</text>
            </view>
            <text class="mine__section-divider text-caption text-secondary">·</text>
            <view class="mine__section-link" bindtap="onAlbumPublishableTap">
              <text class="mine__section-link-text text-caption text-link">可公示</text>
              <text wx:if="{{pendingAuthBadge}}" class="mine__link-badge text-caption">{{pendingAuthBadge}}</text>
            </view>
            <text class="mine__section-divider text-caption text-secondary">·</text>
            <view class="mine__section-link" bindtap="onAlbumPublishedTap">
              <text class="mine__section-link-text text-caption text-link">已公示</text>
            </view>
          </view>
        </view>

        <block wx:if="{{isLoggedIn && albumHeroCards.length}}">
          <view class="mine__album-stack">
            <ui-album-card
              wx:for="{{albumHeroCards}}"
              wx:key="albumId"
              item="{{item}}"
              audience="user"
              showProgress="{{true}}"
              showHeaderActions="{{true}}"
              embedded="{{true}}"
              data-id="{{item.albumId}}"
              bind:tap="onAlbumCardTap"
              bind:authorize="onAlbumCardAuthorize"
              bind:share="onAlbumCardShare"
              bind:withdraw="onAlbumCardWithdraw"
            />
          </view>
        </block>

        <block wx:elif="{{isLoggedIn}}">
          <ui-empty
            theme="album"
            title="暂无服务相册"
            description="{{albumEmptyHint}}"
            actionText="使用说明"
            bind:action="onHelpFromSettings"
          />
        </block>

        <block wx:else>
          <view class="mine__guest-album" bindtap="onLoginTap">
            <text class="text-body">登录查看服务相册</text>
            <text class="text-caption text-secondary">{{guestAlbumHint}}</text>
          </view>
        </block>

        <block wx:if="{{todoSummary}}">
          <view class="surface-album-inset-divider" />
          <view class="mine__todo">
            <text class="mine__todo-headline text-body">{{todoSummary.headline}}</text>
            <view class="mine__todo-list">
              <view
                wx:for="{{todoSummary.items}}"
                wx:key="key"
                class="mine__todo-item"
                data-action="{{item.action}}"
                bindtap="onTodoItemTap"
              >
                <text class="mine__todo-dot" />
                <text class="text-caption">{{item.label}}</text>
                <text class="mine__todo-arrow text-caption">›</text>
              </view>
            </view>
          </view>
        </block>

        <block wx:if="{{isLoggedIn && showShareIncentive}}">
          <view class="surface-album-inset-divider" />
          <view class="mine__incentive" bindtap="onShareIncentiveTap">
            <view class="mine__incentive-head">
              <text class="text-body">{{shareIncentiveTitle}}</text>
              <ui-tag variant="default" text="{{shareIncentivePreview.statusLabel}}" />
            </view>
            <text class="text-caption text-secondary">{{shareIncentivePreview.summaryHint}}</text>
          </view>
        </block>

        <view class="surface-album-inset-divider" />
        <view class="mine__dock">
          <view
            wx:for="{{hubDock}}"
            wx:key="key"
            class="mine__dock-item"
            data-key="{{item.key}}"
            bindtap="onDockTap"
          >
            <view class="mine__dock-well surface-album-well">
              <image class="mine__dock-icon nav-icon-tone-album" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <text class="mine__dock-label text-caption">{{item.label}}</text>
          </view>
        </view>
      </view>

      <view
        wx:if="{{showH5Link}}"
        class="mine__h5-outlet"
        bindtap="onH5OutletTap"
      >
        <text class="text-caption text-link">{{h5OutletText}}</text>
      </view>
    </view>
  </block>
</ui-tool-page-shell>

<ui-login-sheet
  visible="{{loginSheetVisible}}"
  mode="{{loginSheetMode}}"
  bindContext="{{loginSheetBindContext}}"
  bind:close="closeLoginSheet"
  bind:cancel="closeLoginSheet"
  bind:success="onLoginSheetSuccess"
/>

<ui-bottom-sheet
  visible="{{authSheetVisible}}"
  title="授权公示"
  showActions="{{false}}"
  scrollable="{{true}}"
  bind:close="onCloseAuthSheet"
>
  <ui-album-authorize-section
    checked="{{authChecked}}"
    authTier="{{authTier}}"
    submitting="{{authSubmitting}}"
    showActions="{{false}}"
    showRejectLink="{{true}}"
    bind:toggle="onAuthCheckToggle"
    bind:tierchange="onAuthTierChange"
    bind:reject="onRejectAuth"
    bind:policy="onOpenBenefitPolicy"
  />
  <view class="mine__auth-submit">
    <ui-button
      type="primary"
      block
      disabled="{{authSubmitting}}"
      loading="{{authSubmitting}}"
      bind:btntap="onSubmitAuth"
    >确认并进入脱敏预览</ui-button>
  </view>
</ui-bottom-sheet>

<ui-bottom-sheet
  visible="{{withdrawSheetVisible}}"
  title="撤回授权"
  hint="撤回后公开案例将下架，已产生的传播数据保留后台记录。私密服务相册仍保留。"
  confirmText="确认撤回"
  cancelText="取消"
  loading="{{withdrawSheetLoading}}"
  bind:close="onWithdrawSheetClose"
  bind:cancel="onWithdrawSheetClose"
  bind:confirm="onWithdrawSheetConfirm"
/>

<ui-share-sheet
  visible="{{shareSheetVisible}}"
  showOwnerShare="{{showShareEntry}}"
  shareIntent="{{shareSheetIntent}}"
  shareUseOriginal="{{shareUseOriginal}}"
  ownerSharePreparing="{{sharePreparing}}"
  actionsDisabled="{{shareActionsDisabled}}"
  bind:close="onCloseShareSheet"
  bind:toggleoriginal="onShareOriginalToggle"
  bind:copyownerlink="onCopyOwnerShareLink"
  bind:copypublicweblink="onCopyPublicWebLink"
  bind:sharetimeline="onShareTimelineGuide"
/>
