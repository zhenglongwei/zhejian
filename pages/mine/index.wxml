<ui-tool-page-shell
  complianceText="{{platformNotice}}"
  showCompliance="{{status !== 'loading' && status !== 'error'}}"
>
  <block wx:if="{{status === 'loading' && isLoggedIn}}">
    <view class="mine__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" avatar="{{true}}" />
      <ui-skeleton rows="{{5}}" title="{{false}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <ui-empty
      title="加载失败"
      description="{{errorMessage}}"
      actionText="重试"
      bind:action="onRetry"
    />
  </block>

  <block wx:else>
    <view class="mine__hub">
      <view class="mine__folio bg-album">
        <ui-mine-user-header
          id="mineUserHeader"
          isLoggedIn="{{isLoggedIn}}"
          user="{{user}}"
          avatarPreview="{{avatarPreview}}"
          bind:logintap="onLoginTap"
          bind:bindphonetap="onBindPhoneTap"
          bind:avatarchoose="onAvatarChoose"
          bind:nicknamechange="onNicknameChange"
        />
        <view wx:if="{{isLoggedIn && statusPills.length}}" class="mine__status-pills">
          <view
            wx:for="{{statusPills}}"
            wx:key="key"
            class="mine__pill mine__pill--{{item.tone || (item.emphasis ? 'primary' : 'calm')}}"
          >
            <text class="text-caption">{{item.label}}</text>
          </view>
        </view>
        <view wx:elif="{{!isLoggedIn}}" class="mine__guest-hint">
          <text class="text-caption text-secondary">登录后可查看门店为你创建的维修档案</text>
        </view>
      </view>

      <view class="mine__section mine__section--panel">
        <view class="mine__section-head">
          <text class="mine__section-title text-h3">我的服务相册</text>
          <text
            wx:if="{{isLoggedIn}}"
            class="text-caption text-link"
            bindtap="onAlbumListTap"
          >全部</text>
        </view>
        <scroll-view class="mine__album-rail" scroll-x enable-flex show-scrollbar="{{false}}">
          <view class="mine__album-rail-inner">
            <block wx:if="{{isLoggedIn && albumRail.length}}">
              <view
                wx:for="{{albumRail}}"
                wx:key="id"
                class="mine__album-tile {{item.variant}}"
                data-id="{{item.albumId}}"
                data-action="{{item.action}}"
                bindtap="onAlbumRailTap"
              >
                <album-photo-frame wx:if="{{item.showFrame}}" variant="thumb" show-corners="{{false}}">
                  <image
                    wx:if="{{item.coverUrl}}"
                    class="mine__album-cover"
                    src="{{item.coverUrl}}"
                    mode="aspectFill"
                  />
                  <view wx:else class="mine__album-cover mine__album-cover--placeholder image-placeholder" />
                </album-photo-frame>
                <view wx:else class="mine__album-more">
                  <text class="mine__album-more-icon">+</text>
                </view>
                <text class="mine__album-title text-caption">{{item.title}}</text>
                <text wx:if="{{item.meta}}" class="mine__album-meta text-caption">{{item.meta}}</text>
                <view wx:if="{{item.dot}}" class="mine__album-dot" />
              </view>
            </block>
            <view wx:else class="mine__album-tile mine__album-tile--guest" bindtap="onLoginTap">
              <view class="mine__album-guest-card">
                <text class="text-body">登录查看服务相册</text>
                <text class="text-caption text-secondary">门店维修留档，随时翻阅</text>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view
        class="mine__earnings-panel"
        bindtap="onEarningsTap"
      >
        <view class="mine__earnings-main">
          <view class="mine__earnings-head">
            <text class="text-h3">分享收益</text>
            <view class="mine__earnings-tag">
              <text class="text-caption">{{earningsPreview.statusLabel}}</text>
            </view>
          </view>
          <text class="text-caption mine__earnings-desc">{{earningsPreview.summaryHint}}</text>
        </view>
        <view class="mine__earnings-stat">
          <text class="mine__earnings-amount text-h2 text-numeric">{{earningsPreview.totalText}}</text>
          <text class="text-caption mine__earnings-unit">累计收益（元）</text>
        </view>
        <text class="text-caption text-link mine__earnings-link">查看明细 ›</text>
      </view>

      <view class="mine__section mine__section--panel">
        <text class="mine__section-title text-h3">常用工具</text>
        <view class="mine__grid">
          <view
            wx:for="{{secondaryMenus}}"
            wx:key="key"
            class="mine__grid-tile mine__grid-tile--{{item.tone}}"
            data-key="{{item.key}}"
            bindtap="onSecondaryMenuTap"
          >
            <view class="mine__grid-well mine__grid-well--{{item.iconBg}}">
              <image class="mine__grid-icon" src="{{item.icon}}" mode="aspectFit" />
            </view>
            <view class="mine__grid-copy">
              <text class="mine__grid-label text-body">{{item.label}}</text>
              <text wx:if="{{item.desc}}" class="mine__grid-desc text-caption">{{item.desc}}</text>
            </view>
            <text class="mine__grid-arrow text-caption">›</text>
            <view wx:if="{{item.dot}}" class="mine__grid-dot" />
            <text wx:elif="{{item.badge}}" class="mine__grid-badge">{{item.badge}}</text>
          </view>
        </view>
      </view>

      <view class="mine__footer-bar">
        <view
          wx:for="{{footerMenus}}"
          wx:key="key"
          class="mine__footer-item"
          data-key="{{item.key}}"
          bindtap="onFooterMenuTap"
        >
          <view class="mine__footer-well mine__footer-well--{{item.key}}">
            <image class="mine__footer-icon" src="{{item.icon}}" mode="aspectFit" />
          </view>
          <text class="text-caption mine__footer-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </block>
</ui-tool-page-shell>

<ui-login-sheet
  visible="{{loginSheetVisible}}"
  mode="{{loginSheetMode}}"
  bindContext="{{loginSheetBindContext}}"
  bind:close="closeLoginSheet"
  bind:cancel="closeLoginSheet"
  bind:success="onLoginSheetSuccess"
/>
