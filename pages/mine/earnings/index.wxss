.mine-earnings__body {
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
}

.mine-earnings__gate {
  padding: var(--space-xl) 0;
}

.mine-earnings__main {
  display: flex;
  flex-direction: column;
}

.mine-earnings__status-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.mine-earnings__metrics {
  margin-bottom: 0;
}

.mine-earnings__section-title {
  display: block;
  margin-bottom: var(--space-md);
}

.mine-earnings__steps {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--space-md);
}

.mine-earnings__step {
  display: flex;
  gap: var(--space-md);
}

.mine-earnings__step-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.mine-earnings__step-no {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  color: var(--color-album-frame-corner);
  font-weight: var(--font-weight-medium);
}

.mine-earnings__step-line {
  flex: 1;
  width: 2rpx;
  min-height: 40rpx;
  margin-top: var(--space-xs);
  background-color: var(--color-album-frame-line);
}

.mine-earnings__step-body {
  flex: 1;
  min-width: 0;
  padding-bottom: var(--space-md);
}

.mine-earnings__step-title {
  display: block;
  font-weight: var(--font-weight-medium);
}

.mine-earnings__step-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}
