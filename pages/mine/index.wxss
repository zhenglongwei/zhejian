.mine__pad {
  padding-top: var(--space-md);
}

.mine__hub {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-sm);
  padding-bottom: var(--space-md);
  background-color: var(--color-bg-album);
}

.mine__tool-hint {
  padding-top: var(--space-sm);
  padding-bottom: var(--space-sm);
}

.mine__folio {
  margin: 0 calc(-1 * var(--page-padding-x));
  padding: var(--space-lg) var(--page-padding-x);
}

.mine__main {
  display: flex;
  flex-direction: column;
}

.mine__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.mine__section-title {
  color: var(--color-text-primary);
}

.mine__section-links {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: var(--space-xs);
}

.mine__section-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  min-height: var(--font-caption-lh);
}

.mine__section-link-text {
  line-height: var(--font-caption-lh);
}

.mine__section-divider {
  line-height: var(--font-caption-lh);
  opacity: 0.5;
}

.mine__link-badge {
  color: var(--color-danger);
  line-height: var(--font-caption-lh);
}

.mine__album-stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.mine__guest-album {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-lg);
  border-radius: var(--radius-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  box-shadow: var(--shadow-album-list-thumb);
  box-sizing: border-box;
}

.mine__guest-album:active {
  opacity: 0.72;
}

.mine__consult-entry {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
  padding: var(--space-sm) 0;
}

.mine__consult-entry:active {
  opacity: 0.72;
}

.mine__consult-main {
  flex: 1;
  min-width: 0;
}

.mine__todo-headline {
  display: block;
  margin-bottom: var(--space-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.mine__todo-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.mine__todo-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-xs) 0;
}

.mine__todo-item:active {
  opacity: 0.72;
}

.mine__todo-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-album-frame-corner);
}

.mine__todo-arrow {
  margin-left: auto;
  color: var(--color-text-tertiary);
}

.mine__incentive:active {
  opacity: 0.72;
}

.mine__incentive-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-xs) var(--space-sm);
  margin-bottom: var(--space-xs);
}

.mine__dock {
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  gap: var(--space-sm);
}

.mine__dock-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-xs);
  box-sizing: border-box;
}

.mine__dock-item:active {
  opacity: 0.72;
}

.mine__dock-well {
  width: var(--size-nav-icon-well);
  height: var(--size-nav-icon-well);
  border-radius: var(--radius-md);
}

.mine__dock-icon {
  width: var(--size-nav-icon);
  height: var(--size-nav-icon);
}

.mine__dock-label {
  color: var(--color-text-secondary);
  text-align: center;
}

.mine__h5-outlet {
  padding: var(--space-sm) var(--space-md);
  text-align: center;
  box-sizing: border-box;
}

.mine__h5-outlet:active {
  opacity: 0.72;
}

.mine__auth-submit {
  padding: var(--space-md) var(--page-padding-x) var(--space-lg);
}
