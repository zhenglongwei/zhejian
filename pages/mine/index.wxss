.mine__pad {
  padding-top: var(--space-md);
}

.mine__hub {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-sm);
  padding-bottom: var(--space-md);
  background-color: var(--color-bg-album);
}

.mine__folio {
  margin: 0 calc(-1 * var(--page-padding-x));
  padding: var(--space-lg) var(--page-padding-x);
  background: linear-gradient(
    180deg,
    var(--color-primary-light) 0%,
    var(--color-album-frame-inner) 180rpx,
    var(--color-album-frame-inner) 100%
  );
  border-bottom: 1rpx solid var(--color-album-frame-line);
  box-sizing: border-box;
}

.mine__status-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.mine__pill {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-full);
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.mine__pill--primary {
  background-color: var(--color-primary-light);
  border-color: transparent;
  color: var(--color-primary-dark);
}

.mine__pill--success {
  background-color: var(--color-success-light);
  border-color: transparent;
  color: var(--color-success);
}

.mine__pill--info {
  background-color: var(--color-info-light);
  border-color: transparent;
  color: var(--color-info);
}

.mine__pill--calm {
  background-color: var(--color-bg-card);
  border-color: var(--color-album-frame-line);
  color: var(--color-text-secondary);
}

.mine__guest-hint {
  margin-top: var(--space-md);
}

.mine__section--panel {
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.mine__earnings-panel {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: var(--space-sm) var(--space-md);
  padding: var(--space-md);
  background: linear-gradient(
    135deg,
    var(--color-warning-light) 0%,
    var(--color-bg-card) 72%
  );
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-album-frame-line);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.mine__earnings-main {
  flex: 1;
  min-width: 0;
}

.mine__earnings-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-xs) var(--space-sm);
}

.mine__earnings-tag {
  padding: 2rpx var(--space-xs);
  border-radius: var(--radius-full);
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  color: var(--color-text-secondary);
}

.mine__earnings-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.mine__earnings-stat {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.mine__earnings-amount {
  color: var(--color-warning);
  font-weight: var(--font-weight-semibold);
}

.mine__earnings-unit {
  margin-top: 2rpx;
  color: var(--color-text-secondary);
}

.mine__earnings-link {
  width: 100%;
  text-align: right;
}

.mine__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.mine__section-title {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-primary);
}

.mine__section-head .mine__section-title {
  margin-bottom: 0;
}

.mine__album-rail {
  width: 100%;
  white-space: nowrap;
}

.mine__album-rail-inner {
  display: inline-flex;
  gap: var(--space-sm);
  padding-bottom: var(--space-xs);
}

.mine__album-tile {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  flex-shrink: 0;
  width: 200rpx;
  vertical-align: top;
}

.mine__album-tile--hero {
  width: 280rpx;
}

.mine__album-tile--more {
  width: 160rpx;
  align-items: center;
  justify-content: center;
}

.mine__album-tile--guest {
  width: 100%;
  min-width: 520rpx;
}

.mine__album-tile:active {
  opacity: 0.72;
}

.mine__album-cover {
  width: 100%;
  height: 160rpx;
  display: block;
}

.mine__album-tile--hero .mine__album-cover {
  height: 220rpx;
}

.mine__album-cover--placeholder {
  width: 100%;
  height: 160rpx;
  background-color: var(--color-primary-light);
}

.mine__album-tile--hero .mine__album-cover--placeholder {
  height: 220rpx;
}

.mine__album-more {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 160rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-primary-light);
  border: 1rpx dashed var(--color-primary);
  box-sizing: border-box;
}

.mine__album-more-icon {
  font-size: 48rpx;
  line-height: 1;
  color: var(--color-primary);
}

.mine__album-title {
  display: block;
  margin-top: var(--space-xs);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.mine__album-meta {
  display: block;
  margin-top: 2rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mine__album-dot {
  position: absolute;
  top: var(--space-xs);
  right: var(--space-xs);
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-danger);
  border: 2rpx solid var(--color-bg-card);
  box-sizing: border-box;
}

.mine__album-guest-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  width: 100%;
  padding: var(--space-lg);
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-bg-card) 100%);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.mine__grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.mine__grid-tile {
  position: relative;
  display: flex;
  align-items: center;
  gap: var(--space-md);
  min-height: 136rpx;
  padding: var(--space-md);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.mine__grid-tile--authorize {
  background-color: var(--color-success-light);
}

.mine__grid-tile--message {
  background-color: var(--color-info-light);
}

.mine__grid-tile--vehicle {
  background-color: var(--color-primary-light);
}

.mine__grid-tile--settings {
  background-color: var(--color-warning-light);
}

.mine__grid-tile:active {
  opacity: 0.72;
}

.mine__grid-well {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-card);
  box-shadow: var(--shadow-card);
}

.mine__grid-well--well {
  background-color: var(--color-bg-card);
}

.mine__grid-well--primary-light,
.mine__grid-well--success-light,
.mine__grid-well--info-light,
.mine__grid-well--warning-light {
  background-color: var(--color-bg-card);
}

.mine__grid-icon {
  width: 48rpx;
  height: 48rpx;
}

.mine__grid-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.mine__grid-label {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.mine__grid-desc {
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mine__grid-arrow {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
  font-size: 36rpx;
  line-height: 1;
}

.mine__grid-dot {
  position: absolute;
  top: var(--space-md);
  right: var(--space-md);
  width: 14rpx;
  height: 14rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-danger);
}

.mine__grid-badge {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  min-width: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
  color: var(--color-text-inverse);
  background-color: var(--color-danger);
  border-radius: var(--radius-full);
  box-sizing: border-box;
}

.mine__footer-bar {
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  gap: var(--space-sm);
  padding: var(--space-md);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.mine__footer-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-xs);
  box-sizing: border-box;
}

.mine__footer-item:active {
  opacity: 0.72;
}

.mine__footer-well {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
}

.mine__footer-well--help {
  background-color: var(--color-info-light);
}

.mine__footer-well--support {
  background-color: var(--color-success-light);
}

.mine__footer-well--merchant {
  background-color: var(--color-warning-light);
}

.mine__footer-icon {
  width: 40rpx;
  height: 40rpx;
}

.mine__footer-label {
  color: var(--color-text-secondary);
  text-align: center;
}
