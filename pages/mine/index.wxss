.mine__pad {
  padding-top: var(--space-md);
}

.mine__sk-block {
  margin: var(--space-md) 0;
}

.mine__body {
  padding-top: var(--space-md);
  padding-bottom: var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.mine__user {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
}

.mine__avatar-wrap {
  flex-shrink: 0;
}

.mine__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
}

.mine__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.mine__avatar-icon {
  font-size: 48rpx;
  opacity: 0.5;
}

.mine__user-meta {
  flex: 1;
  min-width: 0;
}

.mine__nickname {
  display: block;
}

.mine__phone {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.mine__guest-desc,
.mine__bind-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.mine__login-btn,
.mine__bind-hint {
  margin-top: var(--space-sm);
}

.mine__bind-hint {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-xs);
}

.mine__section-head {
  margin-bottom: var(--space-md);
}

.mine__section-title {
  display: block;
}

.mine__orders {
  display: flex;
  flex-wrap: wrap;
}

.mine__order-item {
  position: relative;
  width: 33.33%;
  padding: var(--space-sm) 0;
  text-align: center;
}

.mine__order-label {
  display: block;
  color: var(--color-text-secondary);
}

.mine__order-badge {
  position: absolute;
  top: 0;
  right: 24rpx;
  min-width: 32rpx;
  padding: 0 8rpx;
  font-size: var(--font-caption);
  line-height: 32rpx;
  text-align: center;
  color: var(--color-text-inverse);
  background-color: var(--color-danger);
  border-radius: var(--radius-full);
}

.mine__assets {
  display: flex;
  margin-bottom: var(--space-md);
}

.mine__asset-item {
  flex: 1;
  text-align: center;
}

.mine__asset-value {
  display: block;
  color: var(--color-text-primary);
}

.mine__asset-label {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.mine__cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
}

.mine__cell:last-child {
  border-bottom: none;
}

.mine__cell-main {
  flex: 1;
  min-width: 0;
}

.mine__cell-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.mine__cell-extra {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  flex-shrink: 0;
}

.mine__cell-count {
  color: var(--color-text-tertiary);
}

.mine__arrow {
  color: var(--color-text-tertiary);
}
