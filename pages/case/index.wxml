<view class="page public-list-h5">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content public-list-h5__pad">
      <ui-skeleton rows="{{3}}" title="{{true}}" />
      <text class="public-list-h5__hint text-caption">{{loadingText}}</text>
      <text class="public-list-h5__hint text-caption">{{hint}}</text>
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content public-list-h5__pad">
      <ui-empty
        title="{{offlineTitle}}"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
      <view class="public-list-h5__actions">
        <ui-button type="secondary" bind:btntap="onBackHome">返回工具首页</ui-button>
      </view>
    </view>
  </block>
</view>
