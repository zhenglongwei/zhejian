<view class="page case-page">
  <ui-list-page-shell
    tabs="{{filterTabs}}"
    activeKey="{{filterSource}}"
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    emptyTitle="暂无公开案例"
    emptyDescription="服务相册授权公开后将展示在此"
    emptyActionText="刷新"
    skeletonRows="{{3}}"
    bind:tabchange="onTabChange"
    bind:retry="onRetry"
    bind:emptyaction="onRetry"
  >
    <view slot="intro">
      <view class="tab-page__search page-content">
        <ui-search-bar
          readonly="{{true}}"
          placeholder="{{searchPlaceholder}}"
          bind:navigate="onSearchNavigate"
        />
      </view>
      <view class="tab-page__intro page-content">
        <text class="tab-page__intro-title text-h2">公开维修案例</text>
        <text class="tab-page__intro-desc text-caption">{{introDesc}}</text>
        <view class="tab-page__intro-notice">
          <ui-privacy-banner
            text="以下为已脱敏、已审核的公开案例，不含车牌、手机号等个人信息。"
          />
        </view>
        <view class="tab-page__intro-notice">
          <ui-compliance-notice type="{{complianceType}}" />
        </view>
      </view>
    </view>

    <ui-case-card
      wx:for="{{list}}"
      wx:key="id"
      caseId="{{item.id}}"
      authorizationTier="{{item.authorizationTier}}"
      coverImage="{{item.coverImage}}"
      coverImageDesensitized="{{item.coverImageDesensitized}}"
      title="{{item.title}}"
      serviceName="{{item.serviceName}}"
      summary="{{item.summary}}"
      priceMode="{{item.priceMode}}"
      amount="{{item.amount}}"
      minAmount="{{item.minAmount}}"
      maxAmount="{{item.maxAmount}}"
      storeName="{{item.storeName}}"
      viewCount="{{item.viewCount}}"
      bind:tap="onCaseTap"
    />
  </ui-list-page-shell>
</view>
