@import '../../../styles/deep-link-detail.wxss';

.case-detail__body {
  padding-top: var(--space-md);
}

.case-detail__merchant-banner {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
  padding: var(--space-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.case-detail__merchant-banner-text {
  display: block;
  color: var(--color-text-secondary);
  line-height: 1.55;
}

.case-detail__panel {
  margin-bottom: var(--space-lg);
}

.case-detail__panel--top {
  margin-top: 0;
}

.case-detail__head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.case-detail__head {
  flex: 1;
  min-width: 0;
}

.case-detail__head-actions {
  flex-shrink: 0;
  padding-top: var(--space-xs);
}

.case-detail__tags {
  margin-bottom: var(--space-sm);
}

.case-detail__head .case-detail__title {
  margin-bottom: 0;
}

.case-detail__title {
  display: block;
  margin-bottom: var(--space-md);
}

.case-detail__process-note {
  display: block;
  margin-bottom: var(--space-md);
  color: var(--color-text-tertiary);
  line-height: 1.55;
}

.case-detail__evidence {
  margin-top: 0;
}

.case-detail__store-panel .deep-link-detail__section-title {
  margin-bottom: var(--space-md);
}

.case-detail__store-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.case-detail__phone-row {
  padding: var(--space-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.case-detail__phone-row .deep-link-detail__info-row {
  padding-left: 0;
  padding-right: 0;
}

.case-detail__review-scores {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
  color: var(--color-text-secondary);
}

.case-detail__review-hint {
  display: block;
  margin-bottom: var(--space-sm);
}

.case-detail__review-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.case-detail__merchant-reply {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
