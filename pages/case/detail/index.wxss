@import '../../../styles/deep-link-detail.wxss';

.case-detail__body {
  padding-top: var(--space-md);
}

.case-detail__panel {
  margin-bottom: var(--space-lg);
}

.case-detail__tags {
  margin-bottom: var(--space-sm);
}

.case-detail__title {
  display: block;
  margin-bottom: var(--space-md);
}

.case-detail__process-note {
  display: block;
  margin-bottom: var(--space-md);
  color: var(--color-text-tertiary);
  line-height: 1.55;
}

.case-detail__evidence {
  margin-top: 0;
}

.case-detail__store-panel .deep-link-detail__section-title {
  margin-bottom: var(--space-md);
}

.case-detail__store-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.case-detail__phone-row {
  padding: var(--space-md);
  background-color: var(--color-album-frame-inner);
  border: 1rpx solid var(--color-album-frame-line);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.case-detail__phone-row .deep-link-detail__info-row {
  padding-left: 0;
  padding-right: 0;
}
