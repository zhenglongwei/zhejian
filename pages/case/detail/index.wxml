<view class="page case-detail">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content case-detail__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法加载案例"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="case-detail__body page-content">
      <view class="case-detail__tags">
        <ui-tag-row authorizationTier="{{detail.authorizationTier}}" />
      </view>
      <view class="case-detail__privacy">
        <ui-compliance-notice type="displayDisclaimer" />
      </view>
      <text class="case-detail__title text-h1">{{detail.title}}</text>
      <ui-ai-summary-block content="{{detail.aiSummary}}" />
      <ui-key-info-table rows="{{detail.keyInfo}}" />
      <view class="case-detail__section">
        <text class="case-detail__section-title text-h3">{{detail.priceMode === 'fixed' ? '方案报价' : '价格说明'}}</text>
        <ui-price-display
          mode="{{detail.priceMode}}"
          amount="{{detail.amount}}"
          minAmount="{{detail.minAmount}}"
          maxAmount="{{detail.maxAmount}}"
          showSuffix="{{detail.priceMode !== 'fixed'}}"
          showDisclaimer="{{detail.priceMode !== 'fixed'}}"
        />
        <view wx:if="{{detail.priceMode !== 'fixed'}}" class="case-detail__notice">
          <ui-compliance-notice type="casePrice" />
        </view>
        <view wx:else class="case-detail__notice">
          <ui-compliance-notice type="authorizedCaseFixed" />
        </view>
      </view>
      <view wx:if="{{detail.faultDesc}}" class="case-detail__section">
        <text class="case-detail__section-title text-h3">故障表现</text>
        <text class="text-body">{{detail.faultDesc}}</text>
      </view>
      <view wx:if="{{detail.inspectResult}}" class="case-detail__section">
        <text class="case-detail__section-title text-h3">检查结果</text>
        <text class="text-body">{{detail.inspectResult}}</text>
      </view>
      <view wx:if="{{detail.repairPlan}}" class="case-detail__section">
        <text class="case-detail__section-title text-h3">维修方案</text>
        <text class="text-body">{{detail.repairPlan}}</text>
      </view>
      <view wx:if="{{detail.priceFactors.length}}" class="case-detail__section">
        <text class="case-detail__section-title text-h3">影响价格的因素</text>
        <view class="bullet-list">
          <text
            wx:for="{{detail.priceFactors}}"
            wx:key="*this"
            class="bullet-list__item"
          >· {{item}}</text>
        </view>
      </view>
      <view class="case-detail__section">
        <text class="case-detail__section-title text-h3">维修过程</text>
        <ui-album-node
          wx:for="{{detail.nodes}}"
          wx:key="id"
          title="{{item.title}}"
          images="{{item.images}}"
          note="{{item.note}}"
        />
      </view>
      <view class="case-detail__section">
        <text class="case-detail__section-title text-h3">{{showStorePublicly ? '关联门店' : '联系门店'}}</text>
        <ui-store-card
          wx:if="{{showStorePublicly}}"
          storeId="{{detail.storeId}}"
          name="{{detail.storeName}}"
          subtitle="{{detail.city}}"
          showLink="{{true}}"
          bind:tap="onStoreTap"
        />
        <ui-store-card
          wx:else
          mode="anonymous"
          subtitle="{{detail.city}}"
        />
      </view>
      <view wx:if="{{faqList.length}}" class="case-detail__section">
        <text class="case-detail__section-title text-h3">常见问题</text>
        <ui-faq-list items="{{faqList}}" />
      </view>
      <view class="case-detail__section case-detail__report">
        <ui-detail-report-entry
          targetType="case"
          targetId="{{detail.id}}"
          targetTitle="{{detail.title}}"
          attached="{{true}}"
        />
      </view>
      <view wx:if="{{relatedCases.length}}" class="case-detail__section">
        <text class="case-detail__section-title text-h3">相关案例</text>
        <view class="case-detail__related">
          <ui-case-card
            wx:for="{{relatedCases}}"
            wx:key="id"
            caseId="{{item.id}}"
            authorizationTier="{{item.authorizationTier}}"
            coverImage="{{item.coverImage}}"
            title="{{item.title}}"
            serviceName="{{item.serviceName}}"
            summary="{{item.summary}}"
            priceMode="{{item.priceMode}}"
            amount="{{item.amount}}"
            minAmount="{{item.minAmount}}"
            maxAmount="{{item.maxAmount}}"
            storeName="{{item.storeName}}"
            viewCount="{{item.viewCount}}"
            bind:tap="onRelatedCaseTap"
          />
        </view>
      </view>
    </view>
    <ui-fixed-bottom-bar leftActions="{{bottomLeftActions}}" bind:leftaction="onBottomLeftAction">
      <ui-button type="primary" slot="right" bind:tap="onMessage">留言</ui-button>
    </ui-fixed-bottom-bar>

    <ui-share-sheet
      visible="{{shareSheetVisible}}"
      showOwnerShare="{{false}}"
      shareIntent="publicCase"
      actionsDisabled="{{shareActionsDisabled}}"
      bind:close="onCloseShareSheet"
      bind:copypublicweblink="onCopyPublicWebLink"
      bind:sharetimeline="onShareTimelineGuide"
    />

    <ui-login-sheet
      visible="{{loginSheetVisible}}"
      mode="{{loginSheetMode}}"
      bindContext="{{loginSheetBindContext}}"
      bind:close="closeLoginSheet"
      bind:cancel="closeLoginSheet"
      bind:success="onLoginSheetSuccess"
    />
  </block>
</view>
