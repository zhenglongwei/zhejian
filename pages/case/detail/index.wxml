<ui-tool-page-shell
  showBand="{{false}}"
  showCompliance="{{status === 'normal'}}"
>
  <block wx:if="{{status === 'loading'}}">
    <view class="deep-link-detail__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <ui-empty
      title="无法加载案例"
      description="{{errorMessage}}"
      actionText="重试"
      bind:action="onRetry"
    />
  </block>

  <block wx:elif="{{detail}}">
    <view class="deep-link-detail__body case-detail__body">
      <view wx:if="{{showMerchantH5Copy}}" class="case-detail__merchant-banner surface-album-panel">
        <text class="case-detail__merchant-banner-text text-caption">
          这是您的公开案例预览。如需分享给客户，可复制下方链接，在微信或浏览器中粘贴打开。
        </text>
        <ui-button type="secondary" size="sm" block bind:btntap="onCopyMerchantH5Link">
          复制 H5 链接
        </ui-button>
      </view>
      <view class="surface-album-panel case-detail__panel case-detail__panel--top">
        <view class="case-detail__head-row">
          <view class="case-detail__head">
            <view class="case-detail__tags">
              <ui-tag-row authorizationTier="{{detail.authorizationTier}}" />
            </view>
            <text class="case-detail__title text-h1">{{detail.title}}</text>
          </view>
          <ui-detail-top-actions
            wx:if="{{status === 'normal'}}"
            class="case-detail__head-actions"
            showFavorite="{{true}}"
            isFavorited="{{isFavorited}}"
            showShare="{{true}}"
            shareDisabled="{{shareActionsDisabled}}"
            bind:favorite="onTopFavoriteTap"
            bind:share="onTopShareTap"
          />
        </view>
        <ui-ai-summary-block wx:if="{{detail.displayAiSummary}}" content="{{detail.displayAiSummary}}" />

        <ui-key-info-table
          wx:if="{{detail.keyInfo.length}}"
          variant="inset"
          rows="{{detail.keyInfo}}"
        />
      </view>

      <view wx:if="{{detail.displayNodes.length}}" class="surface-album-folio case-detail__panel case-detail__evidence">
        <text class="deep-link-detail__section-title text-h2">维修过程</text>
        <text class="case-detail__process-note text-caption">无图片且无说明的节点不展示；说明缺失时系统可依据图片生成草稿供门店确认。</text>
        <ui-album-node
          wx:for="{{detail.displayNodes}}"
          wx:key="id"
          title="{{item.title}}"
          images="{{item.images}}"
          note="{{item.note}}"
        />
      </view>

      <view wx:if="{{detail.priceFactors.length}}" class="surface-album-panel case-detail__panel">
        <text class="deep-link-detail__section-title text-h3">影响价格的因素</text>
        <view class="bullet-list">
          <text
            wx:for="{{detail.priceFactors}}"
            wx:key="*this"
            class="bullet-list__item"
          >· {{item}}</text>
        </view>
      </view>

      <view class="surface-album-panel case-detail__panel">
        <text class="deep-link-detail__section-title text-h3">{{detail.priceView.sectionTitle}}</text>
        <ui-price-display
          mode="{{detail.priceView.priceMode}}"
          amount="{{detail.priceView.amount}}"
          minAmount="{{detail.priceView.minAmount}}"
          maxAmount="{{detail.priceView.maxAmount}}"
          showSuffix="{{detail.priceView.showSuffix}}"
          showDisclaimer="{{detail.priceView.showDisclaimer}}"
        />
        <view class="deep-link-detail__notice">
          <ui-compliance-notice type="{{detail.priceView.disclaimerType}}" />
        </view>
      </view>

      <view class="surface-album-panel case-detail__panel case-detail__store-panel">
        <text class="deep-link-detail__section-title text-h3">{{showStorePublicly ? '关联门店' : '联系门店'}}</text>
        <view class="case-detail__store-block">
          <ui-store-card
            wx:if="{{showStorePublicly}}"
            storeId="{{detail.storeId}}"
            name="{{detail.storeName}}"
            subtitle="{{detail.city}}"
            showLink="{{true}}"
            bind:cardtap="onStoreTap"
          />
          <view
            wx:if="{{showStorePublicly && detail.storePhone}}"
            class="case-detail__phone-row deep-link-detail__info-row deep-link-detail__info-row--tap deep-link-detail__info-row--last"
            bindtap="onCall"
          >
            <view class="deep-link-detail__info-icon-wrap">
              <image
                class="deep-link-detail__info-icon"
                src="/assets/icon/phone.png"
                mode="aspectFit"
              />
            </view>
            <view class="deep-link-detail__info-main">
              <text class="deep-link-detail__info-label text-caption">联系电话</text>
              <text class="deep-link-detail__info-value deep-link-detail__info-value--link text-body">{{detail.storePhone}}</text>
            </view>
          </view>
          <ui-store-card
            wx:elif="{{!showStorePublicly}}"
            mode="anonymous"
            subtitle="{{detail.city}}"
          />
        </view>
      </view>

      <view wx:if="{{relatedCases.length}}" class="surface-album-panel case-detail__panel">
        <text class="deep-link-detail__section-title text-h3">{{storeIsolated ? '本店更多案例' : '相关案例'}}</text>
        <view class="deep-link-detail__stack">
          <ui-case-card
            wx:for="{{relatedCases}}"
            wx:key="id"
            caseId="{{item.id}}"
            authorizationTier="{{item.authorizationTier}}"
            coverImage="{{item.coverImage}}"
            title="{{item.title}}"
            serviceName="{{item.serviceName}}"
            summary="{{item.summary}}"
            priceMode="{{item.priceMode}}"
            amount="{{item.amount}}"
            minAmount="{{item.minAmount}}"
            maxAmount="{{item.maxAmount}}"
            storeName="{{item.storeName}}"
            viewCount="{{item.viewCount}}"
            showStoreName="{{!storeIsolated}}"
            bind:cardtap="onRelatedCaseTap"
          />
        </view>
      </view>

      <view wx:if="{{faqList.length}}" class="surface-album-panel case-detail__panel">
        <text class="deep-link-detail__section-title text-h3">延伸阅读</text>
        <ui-faq-list items="{{faqList}}" />
      </view>

      <view class="deep-link-detail__section deep-link-detail__report">
        <ui-detail-report-entry
          targetType="case"
          targetId="{{detail.id}}"
          targetTitle="{{detail.title}}"
          attached="{{true}}"
        />
      </view>
    </view>
  </block>
</ui-tool-page-shell>

<block wx:if="{{detail && status === 'normal'}}">
  <ui-share-sheet
    visible="{{shareSheetVisible}}"
    showOwnerShare="{{false}}"
    shareIntent="publicCase"
    actionsDisabled="{{shareActionsDisabled}}"
    bind:close="onCloseShareSheet"
    bind:copypublicweblink="onCopyPublicWebLink"
    bind:sharetimeline="onShareTimelineGuide"
  />

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="{{loginSheetBindContext}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</block>
