<view class="page review-result">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content review-result__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法查看结果"
        description="{{errorMessage}}"
        actionText="查看订单"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content review-result__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="review-result__title text-h2">评价已提交</text>
        <text class="review-result__desc text-body">
          你的评价已通过平台审核（mock）。感谢分享真实服务体验。
        </text>
        <view class="review-result__reward-wrap">
          <ui-reward-summary-block
            variant="result"
            amount="{{rewardAmount}}"
            metaText="{{rewardAmount > 0 ? '已发放至奖励记录（mock）' : ''}}"
            bind:rules="onOpenRules"
          />
        </view>
      </ui-card>

      <view class="review-result__actions">
        <view class="review-result__action">
          <ui-button type="secondary" block="{{true}}" bind:tap="onGoOrders">查看全部订单</ui-button>
        </view>
        <view class="review-result__action">
          <ui-button type="primary" block="{{true}}" bind:tap="onBackOrder">返回订单详情</ui-button>
        </view>
      </view>
    </view>
  </block>
</view>
