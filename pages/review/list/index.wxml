<view class="page review-list">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content review-list__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
      <ui-skeleton rows="{{3}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法加载评价"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="暂无评价记录"
        description="完成订单后可提交真实服务评价，帮助其他用户了解门店。"
        actionText="查看奖励规则"
        bind:action="onOpenRules"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content review-list__body">
      <text class="review-list__hint text-caption">共 {{total}} 条评价，仅本人可见完整记录。</text>
      <view class="review-list__items">
        <ui-review-card
          wx:for="{{reviews}}"
          wx:key="reviewId"
          reviewId="{{item.reviewId}}"
          orderId="{{item.orderId}}"
          displayName="{{item.displayName}}"
          overallScore="{{item.overallScore}}"
          content="{{item.content}}"
          tags="{{item.tags}}"
          serviceName="{{item.serviceName}}"
          createdAtText="{{item.createdAtText}}"
          showStatus="{{item.showStatus}}"
          statusLabel="{{item.statusLabel}}"
          statusVariant="{{item.statusVariant}}"
          bind:tap="onReviewTap"
        />
      </view>
      <view class="review-list__footer">
        <ui-button type="ghost" size="sm" bind:tap="onOpenRules">评价奖励规则</ui-button>
      </view>
    </view>
  </block>
</view>
