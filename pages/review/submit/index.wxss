.review-submit__pad {
  padding-top: var(--space-md);
}

.review-submit__body {
  padding-top: var(--space-md);
  padding-bottom: var(--page-fixed-clearance);
}

.review-submit__section-title {
  display: block;
  margin-bottom: var(--space-sm);
}

.review-submit__hint {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-tertiary);
}

.review-submit__reward-card {
  margin-bottom: var(--space-md);
}

.review-submit__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.review-submit__textarea {
  width: 100%;
  min-height: calc(var(--space-xl) * 4);
  padding: var(--space-sm);
  box-sizing: border-box;
  background-color: var(--color-bg-muted);
  border-radius: var(--radius-md);
}

.review-submit__counter {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
}

.review-submit__textarea-meta {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-md);
  margin-top: var(--space-xs);
}

.review-submit__content-guide {
  flex: 1;
  color: var(--color-text-secondary);
}

.review-submit__check-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
}

.review-submit__check-label {
  flex: 1;
}

.review-submit__notice-inline {
  margin-bottom: var(--space-sm);
}
