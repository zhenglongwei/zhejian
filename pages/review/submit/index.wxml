<view class="page review-submit">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content review-submit__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法评价"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{info}}">
    <view class="page-content review-submit__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="review-submit__section-title text-h3">订单摘要</text>
        <ui-key-info-table rows="{{summaryRows}}" />
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}" class="review-submit__reward-card">
        <text class="review-submit__section-title text-h3">评价奖励</text>
        <ui-reward-summary-block
          amount="{{info.rewardAmount}}"
          leadText="{{info.rewardLeadText}}"
          bind:rules="onOpenRules"
        />
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="review-submit__section-title text-h3">六维评分</text>
        <text class="review-submit__hint text-caption">请根据本次真实服务体验评分，1–5 星。</text>
        <ui-rating-dimensions values="{{scores}}" bind:change="onScoresChange" />
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="review-submit__section-title text-h3">评价标签</text>
        <text class="review-submit__hint text-caption">可选，可多选。点击标签将填入下方文字评价，便于快速表达。</text>
        <view class="review-submit__tags">
          <ui-review-tag-chip
            wx:for="{{tagItems}}"
            wx:key="text"
            text="{{item.text}}"
            selected="{{item.selected}}"
            bind:tap="onTagChipTap"
          />
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="review-submit__section-title text-h3">文字评价</text>
        <text class="review-submit__hint text-caption">选填，不强制字数。</text>
        <textarea
          class="review-submit__textarea input"
          placeholder="请分享本次真实维修体验，例如服务态度、维修过程、价格透明度、交付效果等。"
          maxlength="{{info.maxContentLength}}"
          value="{{content}}"
          bindinput="onContentInput"
        />
        <view class="review-submit__textarea-meta">
          <text class="review-submit__content-guide text-caption">{{contentGuide}}</text>
          <text class="review-submit__counter text-caption">{{contentCount}}/{{info.maxContentLength}}</text>
        </view>
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="review-submit__section-title text-h3">图片上传</text>
        <view class="review-submit__notice-inline">
          <ui-compliance-notice type="reviewUpload" />
        </view>
        <ui-image-uploader
          images="{{images}}"
          maxCount="{{info.maxImages}}"
          bind:change="onImagesChange"
        />
      </ui-card>

      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="review-submit__check-row" bindtap="onAnonymousToggle">
          <ui-checkbox-row checked="{{anonymous}}" />
          <text class="review-submit__check-label text-body">匿名评价</text>
        </view>
        <view class="review-submit__check-row" bindtap="onLiabilityToggle">
          <ui-checkbox-row checked="{{liabilityAccepted}}" />
          <text class="review-submit__check-label text-body">我确认本评价基于本人真实服务体验。</text>
        </view>
      </ui-card>
    </view>

    <ui-fixed-bottom-bar>
      <ui-button
        type="primary"
        slot="right"
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bind:tap="onSubmit"
      >提交评价</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
