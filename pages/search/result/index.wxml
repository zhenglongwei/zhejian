<view class="page search-result">
  <view class="search-result__bar page-content">
    <ui-search-bar
      value="{{keyword}}"
      placeholder="{{placeholder}}"
      showCancel="{{true}}"
      showSearch="{{true}}"
      bind:input="onInput"
      bind:confirm="onConfirm"
      bind:search="onConfirm"
      bind:clear="onClear"
      bind:cancel="onCancel"
    />
  </view>

  <view wx:if="{{activeTab !== 'all'}}" class="search-result__toolbar page-content">
    <text class="search-result__sort text-caption" bindtap="onSortTap">{{sortLabel}} ▾</text>
    <text class="search-result__filter text-caption {{hasActiveFilters ? 'search-result__filter--active' : ''}}" bindtap="onOpenFilter">筛选</text>
  </view>

  <ui-list-page-shell
    tabs="{{tabs}}"
    activeKey="{{activeTab}}"
    status="{{status}}"
    errorMessage="{{errorMessage}}"
    emptyTitle="{{emptyTitle}}"
    emptyDescription="{{emptyDescription}}"
    emptyActionText="{{emptyActionText}}"
    bind:tabchange="onTabChange"
    bind:retry="onRetry"
    bind:emptyaction="onEmptyAction"
  >
    <view
      wx:if="{{status === 'empty' && hotwords.length}}"
      slot="footer"
      class="search-result__hotwords page-content"
    >
      <text class="search-result__section-title text-h3">热门搜索</text>
      <view class="search-result__chips">
        <view
          wx:for="{{hotwords}}"
          wx:key="*this"
          class="search-result__chip-wrap"
          data-keyword="{{item}}"
          bindtap="onHotwordTap"
        >
          <ui-tag variant="default" text="{{item}}" />
        </view>
      </view>
    </view>

    <block wx:if="{{status === 'normal'}}">
    <view wx:if="{{geoPages.length}}" class="search-result__geo">
      <text class="search-result__section-title text-h3">本地专题</text>
      <ui-geo-topic-card
        wx:for="{{geoPages}}"
        wx:key="id"
        topicId="{{item.id}}"
        title="{{item.title}}"
        summary="{{item.summary}}"
        tagText="{{geoTopicTag}}"
        updatedAt="{{item.updatedAt}}"
        showMeta="{{true}}"
        bind:cardtap="onGeoTap"
      />
    </view>

    <view wx:if="{{activeTab === 'service' && !showTabEmpty && showServicePriceNotice}}" class="search-result__notice">
      <ui-compliance-notice type="price" />
    </view>
    <view wx:if="{{activeTab === 'service' && !showTabEmpty && showServiceAccidentNotice}}" class="search-result__notice">
      <ui-compliance-notice type="accident" />
    </view>
    <view wx:if="{{activeTab === 'case' && !showTabEmpty}}" class="search-result__notice">
      <ui-compliance-notice type="casePrice" />
    </view>

    <view wx:if="{{showTabEmpty}}" class="search-result__tab-empty">
      <ui-empty
        title="该分类暂无结果"
        description="{{tabEmptyHint || '可切换上方标签查看其他分类'}}"
      />
    </view>

    <block wx:elif="{{activeTab === 'all'}}">
      <view wx:if="{{services.length}}" class="search-result__group">
        <text class="search-result__section-title text-h3">服务</text>
        <view wx:if="{{showServicePriceNotice}}" class="search-result__notice">
          <ui-compliance-notice type="price" />
        </view>
        <view wx:if="{{showServiceAccidentNotice}}" class="search-result__notice">
          <ui-compliance-notice type="accident" />
        </view>
        <ui-service-card
          wx:for="{{services}}"
          wx:key="id"
          serviceId="{{item.id}}"
          name="{{item.name}}"
          categoryName="{{item.categoryName}}"
          summary="{{item.summary}}"
          priceMode="{{item.priceMode}}"
          amount="{{item.amount}}"
          minAmount="{{item.minAmount}}"
          maxAmount="{{item.maxAmount}}"
          storeName="{{item.storeName}}"
          bind:cardtap="onServiceTap"
        />
      </view>

      <view wx:if="{{merchants.length}}" class="search-result__group">
        <text class="search-result__section-title text-h3">门店</text>
        <ui-store-card
          wx:for="{{merchants}}"
          wx:key="id"
          storeId="{{item.id}}"
          name="{{item.name}}"
          address="{{item.address}}"
          distanceText="{{item.distanceText}}"
          businessHours="{{item.businessHours}}"
          caseCount="{{item.caseCount}}"
          cardTags="{{item.cardTags}}"
          showLink="{{true}}"
          bind:cardtap="onStoreTap"
        />
      </view>

      <view wx:if="{{cases.length}}" class="search-result__group">
        <text class="search-result__section-title text-h3">案例</text>
        <view class="search-result__notice">
          <ui-compliance-notice type="casePrice" />
        </view>
        <ui-case-card
          wx:for="{{cases}}"
          wx:key="id"
          caseId="{{item.id}}"
          authorizationTier="{{item.authorizationTier}}"
          coverImage="{{item.coverImage}}"
          coverImageDesensitized="{{item.coverImageDesensitized}}"
          title="{{item.title}}"
          serviceName="{{item.serviceName}}"
          summary="{{item.summary}}"
          priceMode="{{item.priceMode}}"
          amount="{{item.amount}}"
          minAmount="{{item.minAmount}}"
          maxAmount="{{item.maxAmount}}"
          storeName="{{item.storeName}}"
          viewCount="{{item.viewCount}}"
          bind:cardtap="onCaseTap"
        />
      </view>
    </block>

    <block wx:elif="{{activeTab === 'service'}}">
      <ui-service-card
        wx:for="{{services}}"
        wx:key="id"
        serviceId="{{item.id}}"
        name="{{item.name}}"
        categoryName="{{item.categoryName}}"
        summary="{{item.summary}}"
        priceMode="{{item.priceMode}}"
        amount="{{item.amount}}"
        minAmount="{{item.minAmount}}"
        maxAmount="{{item.maxAmount}}"
        storeName="{{item.storeName}}"
        bind:cardtap="onServiceTap"
      />
    </block>

    <block wx:elif="{{activeTab === 'merchant'}}">
      <ui-store-card
        wx:for="{{merchants}}"
        wx:key="id"
        storeId="{{item.id}}"
        name="{{item.name}}"
        address="{{item.address}}"
        distanceText="{{item.distanceText}}"
        businessHours="{{item.businessHours}}"
        caseCount="{{item.caseCount}}"
        cardTags="{{item.cardTags}}"
        showLink="{{true}}"
        bind:cardtap="onStoreTap"
      />
    </block>

    <block wx:elif="{{activeTab === 'case'}}">
      <ui-case-card
        wx:for="{{cases}}"
        wx:key="id"
        caseId="{{item.id}}"
        authorizationTier="{{item.authorizationTier}}"
        coverImage="{{item.coverImage}}"
        coverImageDesensitized="{{item.coverImageDesensitized}}"
        title="{{item.title}}"
        serviceName="{{item.serviceName}}"
        summary="{{item.summary}}"
        priceMode="{{item.priceMode}}"
        amount="{{item.amount}}"
        minAmount="{{item.minAmount}}"
        maxAmount="{{item.maxAmount}}"
        storeName="{{item.storeName}}"
        viewCount="{{item.viewCount}}"
        bind:cardtap="onCaseTap"
      />
    </block>
    </block>
  </ui-list-page-shell>

  <ui-bottom-sheet
    visible="{{filterSheetVisible}}"
    title="筛选"
    hint="不含评分、销量与在线支付项"
    confirmText="应用筛选"
    cancelText="取消"
    bind:close="onCloseFilter"
    bind:cancel="onCloseFilter"
    bind:confirm="onApplyFilter"
  >
    <view class="search-result__filter-list">
      <view
        wx:for="{{filterSections}}"
        wx:key="key"
        class="search-result__filter-block"
      >
        <text class="search-result__filter-label text-caption">{{item.label}}</text>
        <view
          wx:if="{{item.type === 'toggle'}}"
          class="search-result__filter-item"
          data-key="{{item.key}}"
          bindtap="onToggleFilter"
        >
          <text class="text-body">{{item.label}}</text>
          <ui-tag
            variant="{{filters[item.key] ? 'success' : 'default'}}"
            text="{{filters[item.key] ? '已选' : '可选'}}"
          />
        </view>
        <view wx:elif="{{item.type === 'select'}}" class="search-result__select-chips">
          <view
            wx:for="{{item.options}}"
            wx:for-item="opt"
            wx:key="value"
            class="search-result__chip-wrap"
            data-key="{{item.key}}"
            data-value="{{opt.value}}"
            bindtap="onSelectFilter"
          >
            <ui-tag
              variant="{{filters[item.key] === opt.value ? 'success' : 'default'}}"
              text="{{opt.label}}"
            />
          </view>
        </view>
      </view>
    </view>
  </ui-bottom-sheet>
</view>
