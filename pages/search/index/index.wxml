<view class="page search-index">
  <view class="search-index__bar page-content">
    <ui-search-bar
      value="{{keyword}}"
      placeholder="{{placeholder}}"
      focus="{{focus}}"
      showCancel="{{true}}"
      showSearch="{{true}}"
      bind:input="onInput"
      bind:confirm="onConfirm"
      bind:search="onConfirm"
      bind:clear="onClear"
      bind:cancel="onCancel"
    />
  </view>

  <block wx:if="{{showSuggests && suggests.length}}">
    <view class="search-index__panel page-content">
      <view
        wx:for="{{suggests}}"
        wx:key="index"
        data-keyword="{{item.keyword}}"
        bindtap="onSuggestTap"
      >
        <ui-cell
          title="{{item.keyword}}"
          badge="{{item.typeLabel}}"
          arrow="{{false}}"
        />
      </view>
      <view class="search-index__more">
        <text class="search-index__more-btn text-body" bindtap="onSearchAll">查看「{{keyword}}」的全部搜索结果</text>
      </view>
    </view>
  </block>

  <block wx:elif="{{keyword && showSearchAll}}">
    <view class="search-index__more page-content">
      <ui-button type="primary" bind:tap="onSearchAll">搜索「{{keyword}}」</ui-button>
    </view>
  </block>

  <block wx:else>
    <block wx:if="{{configStatus === 'loading'}}">
      <view class="page-content search-index__pad">
        <ui-skeleton rows="{{3}}" />
      </view>
    </block>

    <block wx:elif="{{configStatus === 'error'}}">
      <view class="page-content">
        <ui-empty
          title="加载失败"
          description="{{errorMessage}}"
          actionText="重试"
          bind:action="onRetryConfig"
        />
      </view>
    </block>

    <block wx:else>
      <view class="page-content search-index__body">
        <view wx:if="{{history.length}}" class="search-index__section">
          <view class="search-index__head">
            <text class="search-index__title text-h3">搜索历史</text>
            <text class="search-index__action text-caption" bindtap="onClearHistory">清空</text>
          </view>
          <view class="search-index__chips">
            <view
              wx:for="{{history}}"
              wx:key="*this"
              class="search-index__chip-wrap"
              data-keyword="{{item}}"
              bindtap="onHistoryTap"
            >
              <ui-tag variant="default" text="{{item}}" />
            </view>
          </view>
        </view>

        <view class="search-index__section">
          <text class="search-index__title text-h3">热门搜索</text>
          <view class="search-index__chips">
            <view
              wx:for="{{hotwords}}"
              wx:key="*this"
              class="search-index__chip-wrap"
              data-keyword="{{item}}"
              bindtap="onHotwordTap"
            >
              <ui-tag variant="default" text="{{item}}" />
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>
