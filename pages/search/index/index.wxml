<view class="page search-tool">
  <view class="page-content search-tool__body">
    <text class="search-tool__hint text-caption">{{migratedHint}}</text>

    <view
      class="search-tool__scan {{scanning ? 'search-tool__scan--loading' : ''}}"
      bindtap="onScanTap"
    >
      <text class="search-tool__scan-title text-h3">扫描门店二维码</text>
      <text class="search-tool__scan-desc text-caption">扫码打开门店服务相册</text>
    </view>

    <ui-card shadow="{{true}}" padding="{{true}}" class="search-tool__block">
      <text class="search-tool__block-title text-h3">输入相册码</text>
      <text class="search-tool__block-desc text-caption">门店提供的 alb_ 开头相册码</text>
      <input
        class="search-tool__input text-body"
        value="{{albumCode}}"
        placeholder="{{albumPlaceholder}}"
        maxlength="64"
        bindinput="onAlbumInput"
        confirm-type="done"
        bindconfirm="onAlbumSubmit"
      />
      <ui-button type="primary" bind:btntap="onAlbumSubmit">打开相册</ui-button>
    </ui-card>

    <ui-card wx:if="{{storeMode}}" shadow="{{true}}" padding="{{true}}" class="search-tool__block">
      <text class="search-tool__block-title text-h3">搜索本店</text>
      <text class="search-tool__block-desc text-caption">仅搜索当前门店的服务方案与公开案例</text>
      <input
        class="search-tool__input text-body"
        value="{{storeKeyword}}"
        placeholder="{{storePlaceholder}}"
        maxlength="30"
        bindinput="onStoreInput"
        confirm-type="search"
        bindconfirm="onStoreSearch"
      />
      <ui-button type="secondary" bind:btntap="onStoreSearch">搜索本店</ui-button>
    </ui-card>

    <ui-card wx:if="{{!storeMode}}" shadow="{{true}}" padding="{{false}}" class="search-tool__block">
      <ui-cell
        title="想找公开案例或门店？前往内容站"
        arrow="{{true}}"
        border="{{false}}"
        bind:celltap="onOpenH5"
      />
    </ui-card>

    <view class="search-tool__footer">
      <text class="text-link text-caption" bindtap="onBackHome">返回工具首页</text>
    </view>
  </view>
</view>
