<view class="album-detail page {{detail ? 'album-detail--immersive' : 'bg-album'}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="album-detail__stage" style="height: {{viewerHeightPx}}px;">
      <album-frame-viewer
        class="album-detail__viewer"
        immersive="{{true}}"
        host-height="{{viewerHeightPx}}"
        loading="{{true}}"
        pages="{{[]}}"
      />
    </view>
    <tool-immersive-nav
      overlay="{{true}}"
      transparent="{{true}}"
      tone="light"
      title=""
      statusBarPlaceholder="{{false}}"
    />
  </block>

  <block wx:elif="{{status === 'error'}}">
    <tool-immersive-nav title="服务相册" />
    <view class="album-detail__empty-wrap">
      <ui-empty
        theme="album"
        title="无法加载服务相册"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <tool-immersive-nav title="服务相册" />
    <view class="album-detail__empty-wrap">
      <ui-empty
        theme="album"
        title="门店暂未上传服务相册"
        description="如你对维修进度有疑问，可联系门店。"
        actionText="联系门店"
        bind:action="onContactStore"
      />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="album-detail__stage" style="height: {{viewerHeightPx}}px;">
      <album-frame-viewer
        class="album-detail__viewer"
        immersive="{{true}}"
        host-height="{{viewerHeightPx}}"
        chrome-visible="{{chromeVisible}}"
        show-immersive-caption="{{false}}"
        pages="{{flipPages}}"
        current="{{pageIndex}}"
        bind:pagechange="onPageChange"
        bind:togglechrome="onToggleChrome"
      >
        <album-end-page
          slot="endPage"
          album-id="{{albumId}}"
          album-title="{{detail.serviceName || ''}}"
          show-auth="{{false}}"
          show-share="{{false}}"
          show-feedback="{{true}}"
          show-part-verify="{{showPartsEntry}}"
          show-contact="{{false}}"
          show-store-browse="{{false}}"
          bind:feedback="onEndPageFeedback"
          bind:partverify="onEndPagePartVerify"
        />
      </album-frame-viewer>

      <image
        wx:if="{{heroVisible && heroCoverUrl}}"
        class="album-detail__hero {{heroVisible ? '' : 'album-detail__hero--hide'}}"
        src="{{heroCoverUrl}}"
        mode="aspectFill"
      />
    </view>

    <album-bottom-toolbar
      wx:if="{{chromeVisible && stageProgress.length && !isEndPage}}"
      overlay="{{true}}"
      mode="progress"
      stages="{{stageProgress}}"
      active-title="{{activeStageTitle}}"
      caption-line="{{activeStageNote}}"
      node-note-map="{{nodeNoteMap}}"
      toolbar-bottom-pad-px="{{toolbarBottomPadPx}}"
      chapters="{{flipChapters}}"
      active-node-id="{{activeNodeId}}"
      show-archive="{{true}}"
      show-compare="{{showCompareEntry}}"
      show-parts="{{showPartsEntry}}"
      bind:chaptertap="onChapterTap"
      bind:archivetap="onOpenInfoSheet"
      bind:comparetap="onOpenCompareOverlay"
      bind:partstap="onOpenPartVerify"
    />

    <view class="album-detail__chrome {{chromeVisible ? 'album-detail__chrome--visible' : ''}}">
      <view
        wx:if="{{!isEndPage && progressPercent > 0}}"
        class="album-detail__progress-track"
        style="padding-top: {{navSafeTopPx}}px;"
      >
        <view class="album-detail__progress-fill" style="width: {{progressPercent}}%;" />
      </view>

      <tool-immersive-nav
        overlay="{{true}}"
        transparent="{{true}}"
        tone="{{navTone}}"
        title=""
        statusBarPlaceholder="{{false}}"
      />
    </view>
  </block>

  <ui-bottom-sheet
    visible="{{authSheetVisible}}"
    title="授权公示"
    showActions="{{false}}"
    scrollable="{{true}}"
    bind:close="onCloseAuthSheet"
  >
    <ui-album-authorize-section
      checked="{{authChecked}}"
      authTier="{{authTier}}"
      submitting="{{authSubmitting}}"
      showActions="{{false}}"
      showRejectLink="{{true}}"
      bind:toggle="onAuthCheckToggle"
      bind:tierchange="onAuthTierChange"
      bind:reject="onRejectAuth"
      bind:policy="onOpenBenefitPolicy"
    />
    <view class="album-detail__auth-submit">
      <ui-button
        type="primary"
        block
        disabled="{{authSubmitting}}"
        loading="{{authSubmitting}}"
        bind:btntap="onSubmitAuth"
      >确认并进入脱敏预览</ui-button>
    </view>
  </ui-bottom-sheet>

  <ui-share-sheet
    visible="{{shareSheetVisible}}"
    showOwnerShare="{{showShareEntry}}"
    shareIntent="{{shareSheetIntent}}"
    shareUseOriginal="{{shareUseOriginal}}"
    ownerSharePreparing="{{sharePreparing}}"
    actionsDisabled="{{shareActionsDisabled}}"
    bind:close="onCloseShareSheet"
    bind:toggleoriginal="onShareOriginalToggle"
    bind:copyownerlink="onCopyOwnerShareLink"
    bind:copypublicweblink="onCopyPublicWebLink"
    bind:sharetimeline="onShareTimelineGuide"
  />

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="album"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />

  <album-info-sheet
    visible="{{infoSheetVisible}}"
    scene="album"
    summary-rows="{{infoSheetSummaryRows}}"
    ai-summary="{{infoSheetAiSummary}}"
    parts="{{infoSheetParts}}"
    store-note="{{detail.storeNote || ''}}"
    node-notes="{{infoSheetNodeNotes}}"
    page-progress="{{infoSheetPageProgress}}"
    store-id="{{linkedStoreId}}"
    store-name="{{linkedStoreName}}"
    store-subtitle="{{linkedStoreSubtitle}}"
    show-store-link="{{showStoreBrowse}}"
    show-part-verify-entry="{{showPartsEntry}}"
    part-verify-summary="{{partVerifySummary}}"
    bind:close="onCloseInfoSheet"
    bind:parttap="onInfoSheetPartTap"
    bind:verifytap="onOpenPartVerify"
    bind:storetap="onOpenLinkedStore"
  />

  <view
    wx:if="{{compareOverlayVisible && comparePairs.length}}"
    class="album-detail__compare-overlay"
  >
    <tool-immersive-nav
      overlay="{{true}}"
      transparent="{{false}}"
      tone="dark"
      title="前后对比"
      auto-back="{{false}}"
      bind:back="onCloseCompareOverlay"
    />
    <view class="album-detail__compare-body">
      <swiper
        class="album-detail__compare-swiper"
        style="height: {{compareSwiperHeightPx}}px;"
        current="{{comparePairIndex}}"
        bindchange="onComparePairChange"
        bindanimationfinish="onComparePairChange"
      >
        <swiper-item
          wx:for="{{comparePairs}}"
          wx:key="id"
          class="album-detail__compare-item"
        >
          <view
            class="album-detail__compare-slider-wrap"
            style="height: {{compareStageHeightPx}}px;"
          >
            <album-compare-slider
              immersive="{{true}}"
              stage-height="{{compareStageHeightPx}}"
              pair-key="{{item.id}}"
              before-url="{{item.beforeUrl}}"
              after-url="{{item.afterUrl}}"
              before-label="{{item.beforeLabel}}"
              after-label="{{item.afterLabel}}"
            />
          </view>
        </swiper-item>
      </swiper>
      <text
        wx:if="{{comparePairs.length > 1}}"
        class="album-detail__compare-pager text-caption"
      >{{comparePairIndex + 1}} / {{comparePairs.length}}</text>
      <text wx:if="{{compareHint}}" class="album-detail__compare-hint text-caption">{{compareHint}}</text>
    </view>
  </view>
</view>
