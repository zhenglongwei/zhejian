<view class="page service-album {{showBottomBar ? 'service-album--with-bar' : ''}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content service-album__pad">
      <ui-skeleton rows="{{3}}" title="{{true}}" />
      <ui-skeleton rows="{{4}}" />
      <ui-skeleton rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content service-album__body">
      <view class="service-album__privacy">
        <ui-privacy-banner scene="album" />
      </view>
      <ui-empty
        title="无法加载服务相册"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content service-album__body">
      <view class="service-album__privacy">
        <ui-privacy-banner scene="album" />
      </view>
      <ui-empty
        title="门店暂未上传服务相册"
        description="如你对维修进度有疑问，可联系门店或平台客服。"
        actionText="联系门店"
        bind:action="onCallStore"
      />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="page-content service-album__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="service-album__summary-head">
          <ui-tag variant="{{detail.statusVariant}}" text="{{albumStatusLabel}}" />
        </view>
        <ui-key-info-table rows="{{detail.summaryRows}}" />
      </ui-card>

      <view class="service-album__privacy">
        <ui-privacy-banner scene="album" />
      </view>

      <view class="service-album__section">
        <text class="service-album__section-title text-h3">过程记录</text>
        <ui-album-node
          wx:for="{{detail.nodes}}"
          wx:key="id"
          title="{{item.title}}"
          images="{{item.images}}"
          time="{{item.updatedAtText}}"
          note="{{item.note}}"
          emptyText="该节点暂无图片"
        />
        <text
          wx:if="{{detail.storeNote}}"
          class="note-block text-caption"
        >{{detail.storeNote}}</text>
      </view>

      <ui-album-authorize-section
        wx:if="{{showAuthSection}}"
        checked="{{authChecked}}"
        authTier="{{authTier}}"
        submitting="{{authSubmitting}}"
        bind:toggle="onAuthCheckToggle"
        bind:tierchange="onAuthTierChange"
        bind:submit="onSubmitAuth"
        bind:reject="onRejectAuth"
        bind:policy="onOpenBenefitPolicy"
      />

      <view wx:if="{{showOwnerShareSection}}" class="service-album__section service-album__share">
        <text class="service-album__section-title text-h3">分享</text>
        <ui-privacy-banner scene="{{shareUseOriginal ? 'ownerShareOriginal' : 'ownerShare'}}" />
        <ui-checkbox-row
          checked="{{shareUseOriginal}}"
          disabled="{{sharePreparing}}"
          bind:toggle="onShareOriginalToggle"
        >
          <text>使用原图分享</text>
        </ui-checkbox-row>
        <view class="service-album__share-actions">
          <ui-button
            type="ghost"
            size="sm"
            openType="share"
            disabled="{{!shareReady}}"
          >分享给好友</ui-button>
          <ui-button
            type="ghost"
            size="sm"
            bind:tap="onCopyOwnerShareLink"
            disabled="{{!shareReady}}"
          >复制分享说明</ui-button>
        </view>
      </view>

      <view wx:if="{{showPublicCaseLinks}}" class="service-album__section">
        <text class="service-album__section-title text-h3">平台公示</text>
        <text class="note-block text-caption">{{publicCaseHint}}</text>
        <view class="service-album__share-actions">
          <ui-button type="secondary" size="sm" bind:tap="onViewPublicCase">查看公示页</ui-button>
          <ui-button type="ghost" size="sm" bind:tap="onCopyCaseWebLink">复制公开网页链接</ui-button>
        </view>
      </view>

      <view wx:elif="{{publicCaseHint}}" class="service-album__section">
        <text class="service-album__public-hint note-block text-caption">{{publicCaseHint}}</text>
      </view>

      <view class="service-album__feedback">
        <text class="service-album__feedback-link text-caption text-link" bind:tap="onFeedback">对此相册有疑问？</text>
      </view>
    </view>

    <ui-fixed-bottom-bar>
      <ui-button type="secondary" size="sm" slot="left" bind:tap="onCallStore">联系门店</ui-button>
      <ui-button type="secondary" size="sm" slot="right" bind:tap="onSupport">联系客服</ui-button>
    </ui-fixed-bottom-bar>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="album"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
