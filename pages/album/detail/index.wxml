<view class="album-detail page {{detail ? 'album-detail--immersive' : 'bg-album'}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="album-detail__shell">
      <view class="album-detail__viewport" style="height: {{viewerHeightPx}}px;">
        <album-frame-viewer
          class="album-detail__viewer"
          immersive="{{true}}"
          host-height="{{viewerHeightPx}}"
          loading="{{true}}"
          pages="{{[]}}"
        />
      </view>
      <view class="album-detail__top-chrome">
        <tool-immersive-nav
          overlay="{{true}}"
          transparent="{{true}}"
          tone="light"
          title=""
          statusBarPlaceholder="{{false}}"
        />
      </view>
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <tool-immersive-nav title="服务相册" />
    <view class="album-detail__empty-wrap">
      <ui-empty
        theme="album"
        title="无法加载服务相册"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <tool-immersive-nav title="服务相册" />
    <view class="album-detail__empty-wrap">
      <ui-empty
        theme="album"
        title="门店暂未上传服务相册"
        description="如你对维修进度有疑问，可联系门店。"
        actionText="联系门店"
        bind:action="onContactStore"
      />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="album-detail__shell">
      <view class="album-detail__viewport" style="height: {{viewerHeightPx}}px;">
        <album-frame-viewer
          id="albumViewer"
          class="album-detail__viewer"
          immersive="{{true}}"
          host-height="{{viewerHeightPx}}"
          show-immersive-caption="{{false}}"
          pages="{{flipPages}}"
          current="{{pageIndex}}"
          bind:pagechange="onPageChange"
          bind:togglechrome="onToggleChrome"
        >
          <album-end-page
            slot="endPage"
            album-id="{{albumId}}"
            album-title="{{detail.serviceName || ''}}"
            show-auth="{{endPageShowAuth}}"
            auth-label="{{endPageAuthLabel}}"
            auth-disabled="{{endPageAuthDisabled}}"
            auth-hint="{{endPageAuthHint}}"
            show-withdraw="{{endPageShowWithdraw}}"
            withdraw-label="{{endPageWithdrawLabel}}"
            status-hint="{{endPageStatusHint}}"
            show-share="{{showShareButton}}"
            show-feedback="{{true}}"
            show-contact="{{false}}"
            show-store-browse="{{false}}"
            bind:auth="onEndPageAuth"
            bind:share="onOpenShareSheet"
            bind:withdraw="onEndPageWithdraw"
            bind:feedback="onEndPageFeedback"
          />
        </album-frame-viewer>
      </view>

      <view
        wx:if="{{stageProgress.length && !isEndPage}}"
        class="album-detail__dock"
        style="padding-bottom: {{toolbarBottomPadPx}}px;"
      >
        <view class="album-detail__dock-panel">
          <view class="album-detail__dock-head">
            <view class="album-detail__dock-copy">
              <text wx:if="{{activeStageTitle}}" class="album-detail__dock-title">{{activeStageTitle}}</text>
              <view wx:if="{{activeStageNote}}" class="album-detail__dock-note-box">
                <text class="album-detail__dock-note" selectable>{{activeStageNote}}</text>
              </view>
            </view>
            <view class="album-detail__dock-actions">
              <view
                wx:if="{{showInspectEntry}}"
                class="album-detail__dock-action"
                hover-class="album-detail__dock-action--hover"
                catchtap="onOpenInspect"
                aria-role="button"
                aria-label="相册检查"
              >
                <text class="album-detail__dock-action-text text-caption">检查</text>
              </view>
              <view
                class="album-detail__dock-action"
                hover-class="album-detail__dock-action--hover"
                catchtap="onOpenInfoSheet"
                aria-role="button"
                aria-label="档案"
              >
                <text class="album-detail__dock-action-text text-caption">档案</text>
              </view>
              <view
                wx:if="{{showPartsEntry}}"
                class="album-detail__dock-action"
                hover-class="album-detail__dock-action--hover"
                catchtap="onOpenPartVerify"
                aria-role="button"
                aria-label="配件验真"
              >
                <text class="album-detail__dock-action-text text-caption">配件验真</text>
              </view>
            </view>
          </view>
          <view class="album-detail__dock-segments">
            <view
              wx:for="{{stageProgress}}"
              wx:key="id"
              class="album-detail__dock-seg {{item.filled ? 'is-filled' : ''}} {{item.active ? 'is-active' : ''}}"
              data-node-id="{{item.id}}"
              data-start-index="{{item.startIndex}}"
              bindtap="onProgressSegmentTap"
            />
          </view>
        </view>
      </view>

      <view wx:if="{{chromeVisible && !isEndPage}}" class="album-detail__top-chrome">
        <tool-immersive-nav
          overlay="{{true}}"
          transparent="{{true}}"
          tone="{{navTone}}"
          title=""
          statusBarPlaceholder="{{false}}"
        />
        <view
          wx:if="{{progressPercent > 0}}"
          class="album-detail__read-progress"
          style="top: {{navSafeTopPx}}px;"
        >
          <view class="album-detail__read-progress-fill" style="width: {{progressPercent}}%;" />
        </view>
      </view>
    </view>
  </block>

  <ui-bottom-sheet
    visible="{{authSheetVisible}}"
    title="授权公示"
    showActions="{{false}}"
    scrollable="{{true}}"
    bind:close="onCloseAuthSheet"
  >
    <ui-album-authorize-section
      checked="{{authChecked}}"
      authTier="{{authTier}}"
      submitting="{{authSubmitting}}"
      showActions="{{false}}"
      showRejectLink="{{true}}"
      bind:toggle="onAuthCheckToggle"
      bind:tierchange="onAuthTierChange"
      bind:reject="onRejectAuth"
      bind:policy="onOpenBenefitPolicy"
    />
    <view class="album-detail__auth-submit">
      <ui-button
        type="primary"
        block
        disabled="{{authSubmitting}}"
        loading="{{authSubmitting}}"
        bind:btntap="onSubmitAuth"
      >确认并进入脱敏预览</ui-button>
    </view>
  </ui-bottom-sheet>

  <ui-share-sheet
    visible="{{shareSheetVisible}}"
    showOwnerShare="{{showShareEntry}}"
    shareIntent="{{shareSheetIntent}}"
    shareUseOriginal="{{shareUseOriginal}}"
    ownerSharePreparing="{{sharePreparing}}"
    actionsDisabled="{{shareActionsDisabled}}"
    bind:close="onCloseShareSheet"
    bind:toggleoriginal="onShareOriginalToggle"
    bind:copyownerlink="onCopyOwnerShareLink"
    bind:copypublicweblink="onCopyPublicWebLink"
    bind:sharetimeline="onShareTimelineGuide"
  />

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="album"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />

  <ui-bottom-sheet
    visible="{{withdrawSheetVisible}}"
    title="撤回授权"
    hint="撤回后公开案例将下架，已产生的传播数据保留后台记录。私密服务相册仍保留。"
    confirmText="确认撤回"
    cancelText="取消"
    loading="{{withdrawSheetLoading}}"
    bind:close="onWithdrawSheetClose"
    bind:cancel="onWithdrawSheetClose"
    bind:confirm="onWithdrawSheetConfirm"
  />

  <album-info-sheet
    visible="{{infoSheetVisible}}"
    scene="album"
    summary-rows="{{infoSheetSummaryRows}}"
    ai-summary="{{infoSheetAiSummary}}"
    parts="{{infoSheetParts}}"
    store-note="{{detail.storeNote || ''}}"
    node-notes="{{infoSheetNodeNotes}}"
    page-progress="{{infoSheetPageProgress}}"
    store-id="{{linkedStoreId}}"
    store-name="{{linkedStoreName}}"
    store-subtitle="{{linkedStoreSubtitle}}"
    show-store-link="{{showStoreBrowse}}"
    show-part-verify-entry="{{showPartsEntry}}"
    part-verify-summary="{{partVerifySummary}}"
    bind:close="onCloseInfoSheet"
    bind:parttap="onInfoSheetPartTap"
    bind:verifytap="onOpenPartVerify"
    bind:storetap="onOpenLinkedStore"
  />
</view>
