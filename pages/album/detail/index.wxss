.album-detail {
  position: relative;
  box-sizing: border-box;
  min-height: 100vh;
}

.album-detail--immersive {
  height: 100vh;
  background: var(--color-bg-immersive);
}

.album-detail__stage {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.album-detail__viewer {
  display: block;
  width: 100%;
  height: 100%;
}

.album-detail__hero {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: calc(var(--z-fixed) + 3);
  width: 100%;
  height: 100%;
  opacity: 1;
  transition: opacity 0.32s ease;
  pointer-events: none;
}

.album-detail__hero--hide {
  opacity: 0;
}

.album-detail__chrome {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: calc(var(--z-fixed) + 2);
  opacity: 0;
  transition: opacity 0.22s ease;
  pointer-events: none;
}

.album-detail__chrome--visible {
  opacity: 1;
  pointer-events: auto;
}

.album-detail__progress-track {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 3;
  box-sizing: border-box;
  height: 6rpx;
  padding-right: 200rpx;
  background: var(--color-album-progress-track);
}

.album-detail__progress-fill {
  height: 100%;
  border-radius: 0 3rpx 3rpx 0;
  background: var(--color-text-inverse);
  box-shadow: var(--shadow-album-progress-fill);
  transition: width 0.28s ease;
}

.album-detail__empty-wrap {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
  min-height: 60vh;
  padding: var(--space-xl) var(--page-padding-x);
}

.album-detail__auth-submit {
  margin-top: var(--space-md);
}

.album-detail__compare-overlay {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: var(--z-popup);
  display: flex;
  flex-direction: column;
  background: var(--color-bg-immersive);
}

.album-detail__compare-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  min-height: 0;
  padding: var(--space-md) var(--page-padding-x)
    calc(env(safe-area-inset-bottom) + var(--space-lg));
  box-sizing: border-box;
}

.album-detail__compare-swiper {
  width: 100%;
  flex-shrink: 0;
}

.album-detail__compare-item {
  box-sizing: border-box;
  height: 100%;
}

.album-detail__compare-slider-wrap {
  width: 100%;
  height: 100%;
}

.album-detail__compare-pager {
  flex-shrink: 0;
  margin-top: var(--space-sm);
  color: var(--color-text-inverse);
  opacity: 0.72;
  text-align: center;
}

.album-detail__compare-hint {
  flex-shrink: 0;
  margin-top: var(--space-sm);
  color: var(--color-text-inverse);
  opacity: 0.72;
  line-height: var(--font-caption-lh);
  text-align: center;
}
