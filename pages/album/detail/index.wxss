.album-detail {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

.album-detail__main {
  display: flex;
  flex: 1;
  flex-direction: column;
  box-sizing: border-box;
  min-height: 0;
  padding: var(--space-xs) var(--space-sm) 0;
}

.album-detail__viewer {
  flex: 1;
  min-height: 0;
  height: 0;
}

.album-detail__empty-wrap {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
  padding: var(--space-xl) var(--page-padding-x);
}

.album-detail__auth-submit {
  margin-top: var(--space-md);
}
