.service-album {
  padding-bottom: var(--space-xl);
}

.service-album--with-bar .service-album__body {
  padding-bottom: var(--page-fixed-clearance);
}

.service-album__pad {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.service-album__sticky {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: var(--z-fixed);
  padding: var(--space-md) var(--page-padding-x) var(--space-sm);
  background: var(--color-bg-page);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.service-album__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.service-album__privacy {
  display: block;
}

.service-album__section {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.service-album__section-title {
  display: block;
  color: var(--color-text-primary);
}

.service-album__feedback {
  padding: var(--space-sm) 0 var(--space-md);
}
