.album-detail {
  position: relative;
  box-sizing: border-box;
  min-height: 100vh;
}

.album-detail--immersive {
  height: 100vh;
  overflow: hidden;
  background: #000;
}

.album-detail__stage {
  position: relative;
  box-sizing: border-box;
  width: 100%;
}

.album-detail__viewer {
  display: block;
  width: 100%;
  height: 100%;
}

.album-detail__hero {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: calc(var(--z-fixed) + 3);
  width: 100%;
  height: 100%;
  opacity: 1;
  transition: opacity 0.32s ease;
  pointer-events: none;
}

.album-detail__hero--hide {
  opacity: 0;
}

.album-detail__chrome {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: calc(var(--z-fixed) + 2);
  opacity: 0;
  transition: opacity 0.22s ease;
  pointer-events: none;
}

.album-detail__chrome--visible {
  opacity: 1;
  pointer-events: auto;
}

.album-detail__progress-track {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 3;
  box-sizing: border-box;
  height: 6rpx;
  padding-right: 200rpx;
  background: rgba(255, 255, 255, 0.18);
}

.album-detail__progress-fill {
  height: 100%;
  border-radius: 0 3rpx 3rpx 0;
  background: #fff;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.35);
  transition: width 0.28s ease;
}

.album-detail__empty-wrap {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
  min-height: 60vh;
  padding: var(--space-xl) var(--page-padding-x);
}

.album-detail__auth-submit {
  margin-top: var(--space-md);
}
