.page.album-inspect-compare {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--color-bg-immersive);
}

.album-inspect-compare .tool-immersive-nav--fixed {
  background: var(--color-bg-immersive);
  border-bottom-color: transparent;
}

.album-inspect-compare .tool-immersive-nav--tone-dark .tool-immersive-nav__title,
.album-inspect-compare .tool-immersive-nav--tone-dark .tool-immersive-nav__back-icon {
  color: var(--color-text-inverse);
}

.album-inspect-compare .tool-immersive-nav--tone-dark .tool-immersive-nav__back {
  background: var(--color-album-nav-back);
}

.album-inspect-compare__pad {
  flex: 1;
  padding: var(--space-md) var(--page-padding-x);
}

.album-inspect-compare__body {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 0;
  padding: var(--space-md) var(--page-padding-x)
    calc(env(safe-area-inset-bottom) + var(--space-lg));
  box-sizing: border-box;
}

.album-inspect-compare__swiper {
  flex: 1;
  width: 100%;
  min-height: 0;
}

.album-inspect-compare__item {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 100%;
}

.album-inspect-compare__title {
  flex-shrink: 0;
  margin-bottom: var(--space-sm);
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-semibold);
  text-align: center;
}

.album-inspect-compare__slider-wrap {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 0;
}

.album-inspect-compare__slider-wrap .album-compare-slider--immersive,
.album-inspect-compare__slider-wrap .album-compare-slider--immersive .album-compare-slider__stage {
  height: 100%;
}

.album-inspect-compare__pager {
  flex-shrink: 0;
  margin-top: var(--space-sm);
  color: var(--color-text-inverse);
  opacity: 0.72;
  text-align: center;
}

.album-inspect-compare__hint {
  flex-shrink: 0;
  margin-top: var(--space-sm);
  color: var(--color-text-inverse);
  opacity: 0.72;
  line-height: var(--font-caption-lh);
  text-align: center;
}
