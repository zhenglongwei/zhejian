<view class="page album-engage">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-engage__pad">
      <ui-skeleton rows="{{6}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty title="无法打开" description="{{errorMessage}}" actionText="返回" bind:action="onBack" />
    </view>
  </block>

  <block wx:else>
    <view class="album-engage__header">
      <text class="album-engage__feedback-link text-link text-caption" bindtap="onOpenFeedback">问题反馈</text>
    </view>

    <view class="page-content album-engage__body {{eligible && !hasReview ? 'album-engage__body--with-bar' : ''}}">
      <view class="album-engage__hero">
        <text class="album-engage__album-title text-body">{{albumTitle}}</text>
        <text wx:if="{{hasReview}}" class="album-engage__done-hint text-caption text-secondary">评价已保存，你可继续授权公示或分享相册</text>
      </view>

      <block wx:if="{{hasReview}}">
        <view wx:if="{{existingRepairScore > 0 || existingAlbumScore > 0}}" class="album-engage__score-row">
          <text wx:if="{{existingRepairScore > 0}}" class="text-caption text-secondary">维修 {{existingRepairScore}}</text>
          <text wx:if="{{existingAlbumScore > 0}}" class="text-caption text-secondary">记录 {{existingAlbumScore}}</text>
        </view>

        <ui-card wx:if="{{hasReview && (showAuthAction || showShareButton || showStoreBrowse || hasParts || needsReviewImagePreview)}}" shadow="{{true}}" padding="{{true}}" class="album-engage__actions-card">
          <view class="album-engage__actions">
            <ui-button
              wx:if="{{needsReviewImagePreview}}"
              type="secondary"
              block
              bind:btntap="onOpenReviewImagePreview"
            >核对评价配图</ui-button>
            <block wx:if="{{showAuthAction}}">
              <ui-button
                type="secondary"
                block
                disabled="{{authDisabled}}"
                bind:btntap="onOpenAuthorize"
              >{{authLabel}}</ui-button>
              <text wx:if="{{authDisabled && authHint}}" class="album-engage__action-hint text-caption text-secondary">{{authHint}}</text>
            </block>
            <ui-button
              wx:if="{{showShareButton}}"
              type="secondary"
              block
              bind:btntap="onOpenShareSheet"
            >分享</ui-button>
            <ui-button
              wx:if="{{showStoreBrowse}}"
              type="secondary"
              block
              bind:btntap="onOpenLinkedStore"
            >查看门店主页</ui-button>
            <block wx:if="{{hasParts}}">
              <ui-button type="secondary" block bind:btntap="onOpenPartVerify">配件验真</ui-button>
              <text wx:if="{{partVerifySummary}}" class="album-engage__action-hint text-caption text-secondary">{{partVerifySummary}}</text>
            </block>
          </view>
        </ui-card>
      </block>

      <block wx:elif="{{!eligible}}">
        <ui-card shadow="{{true}}" padding="{{true}}">
          <view class="album-engage__option-head">
            <text class="text-h3">暂不可评价</text>
            <ui-tag variant="info" text="完工后可评" />
          </view>
        </ui-card>
      </block>

      <block wx:else>
        <view wx:if="{{repairScore > 0 || albumScore > 0}}" class="album-engage__score-row">
          <text wx:if="{{repairScore > 0}}" class="text-caption text-secondary">维修 {{repairScore}}</text>
          <text wx:if="{{albumScore > 0}}" class="text-caption text-secondary">记录 {{albumScore}}</text>
        </view>

        <block wx:for="{{reviewGroups}}" wx:key="key" wx:for-item="group">
          <ui-card shadow="{{true}}" padding="{{true}}">
            <text class="album-engage__section-title text-h3">{{group.title}}</text>
            <ui-rating-dimensions
              values="{{scores}}"
              dimensions="{{group.dimensions}}"
              collapse-from="{{99}}"
              bind:change="onScoresChange"
            />
          </ui-card>
        </block>

        <ui-card shadow="{{true}}" padding="{{true}}">
          <text class="album-engage__section-title text-h3">可选标签</text>
          <view class="album-engage__tags">
            <ui-review-tag-chip
              wx:for="{{tagItems}}"
              wx:key="text"
              text="{{item.text}}"
              selected="{{item.selected}}"
              bind:tap="onTagTap"
            />
          </view>
        </ui-card>

        <ui-card shadow="{{true}}" padding="{{true}}">
          <text class="album-engage__section-title text-h3">文字评价（选填）</text>
          <textarea
            class="album-engage__textarea text-body"
            placeholder="补充本次体验，最多 300 字"
            value="{{content}}"
            maxlength="300"
            bindinput="onContentInput"
          />
          <text class="album-engage__counter text-caption">{{contentLength}}/300</text>
        </ui-card>

        <ui-card shadow="{{true}}" padding="{{true}}">
          <text class="album-engage__section-title text-h3">配图（选填）</text>
          <ui-image-uploader images="{{form.images}}" maxCount="{{3}}" bind:change="onImagesChange" />
          <view class="album-engage__notice">
            <ui-compliance-notice type="reviewImageTip" />
          </view>
        </ui-card>
      </block>

      <ui-card
        wx:if="{{hasParts && !hasReview}}"
        shadow="{{true}}"
        padding="{{true}}"
        class="album-engage__actions-card"
      >
        <view class="album-engage__actions">
          <ui-button type="secondary" block bind:btntap="onOpenPartVerify">配件验真</ui-button>
          <text wx:if="{{partVerifySummary}}" class="album-engage__action-hint text-caption text-secondary">{{partVerifySummary}}</text>
        </view>
      </ui-card>

    </view>

    <ui-fixed-bottom-bar wx:if="{{eligible && !hasReview}}">
      <ui-button
        type="primary"
        slot="right"
        block
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bind:btntap="onSubmit"
      >提交评价</ui-button>
    </ui-fixed-bottom-bar>

    <ui-bottom-sheet
      visible="{{authSheetVisible}}"
      title="授权公示"
      showActions="{{false}}"
      scrollable="{{true}}"
      bind:close="onCloseAuthSheet"
    >
      <ui-album-authorize-section
        checked="{{authChecked}}"
        authTier="{{authTier}}"
        submitting="{{authSubmitting}}"
        showActions="{{false}}"
        showRejectLink="{{true}}"
        bind:toggle="onAuthCheckToggle"
        bind:tierchange="onAuthTierChange"
        bind:reject="onRejectAuth"
        bind:policy="onOpenBenefitPolicy"
      />
      <view class="album-engage__auth-submit">
        <ui-button
          type="primary"
          block
          disabled="{{authSubmitting}}"
          loading="{{authSubmitting}}"
          bind:btntap="onSubmitAuth"
        >确认并进入脱敏预览</ui-button>
      </view>
    </ui-bottom-sheet>

    <ui-share-sheet
      visible="{{shareSheetVisible}}"
      showOwnerShare="{{showShareEntry}}"
      shareIntent="{{shareSheetIntent}}"
      shareUseOriginal="{{shareUseOriginal}}"
      ownerSharePreparing="{{sharePreparing}}"
      actionsDisabled="{{shareActionsDisabled}}"
      bind:close="onCloseShareSheet"
      bind:toggleoriginal="onShareOriginalToggle"
      bind:copyownerlink="onCopyOwnerShareLink"
      bind:copypublicweblink="onCopyPublicWebLink"
      bind:sharetimeline="onShareTimelineGuide"
    />

    <ui-login-sheet
      visible="{{loginSheetVisible}}"
      mode="auto"
      bindContext="album"
      bind:close="closeLoginSheet"
      bind:cancel="closeLoginSheet"
      bind:success="onLoginSuccess"
    />
  </block>
</view>
