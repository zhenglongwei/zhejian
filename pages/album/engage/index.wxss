.album-engage__pad {
  padding: var(--space-md) var(--page-padding-x);
}

.album-engage__header {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: var(--space-xs) var(--page-padding-x) 0;
}

.album-engage__feedback-link {
  padding: var(--space-xs) 0;
}

.album-engage__body {
  padding: var(--space-sm) var(--page-padding-x) var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.album-engage__body--with-bar {
  padding-bottom: calc(var(--space-xl) + var(--fixed-bottom-bar-height));
}

.album-engage__hero {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-engage__album-title {
  display: block;
  color: var(--color-text-primary);
}

.album-engage__done-hint {
  display: block;
}

.album-engage__actions-card {
  display: block;
}

.album-engage__actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-engage__action-hint {
  display: block;
  text-align: center;
}

.album-engage__auth-submit {
  padding: var(--space-md) var(--page-padding-x) var(--space-lg);
}

.album-engage__score-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  padding: 0 var(--space-xs);
}

.album-engage__section-title {
  display: block;
  margin-bottom: var(--space-sm);
}

.album-engage__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.album-engage__textarea {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
}

.album-engage__counter {
  display: block;
  text-align: right;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
}

.album-engage__notice {
  margin-top: var(--space-sm);
}

.album-engage__option-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
}
