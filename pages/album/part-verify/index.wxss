.album-part-verify__pad,
.album-part-verify__body {
  padding: var(--space-md) var(--page-padding-x) calc(var(--space-xl) + var(--fixed-bottom-bar-height));
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-part-verify__hero {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md);
  box-sizing: border-box;
}

.album-part-verify__store {
  display: block;
  line-height: var(--line-height-relaxed);
}

.album-part-verify__guide {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding: var(--space-md);
  box-sizing: border-box;
  border-left: 4rpx solid var(--color-primary);
}

.album-part-verify__guide-title {
  display: block;
}

.album-part-verify__steps {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-part-verify__step {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
}

.album-part-verify__step-num {
  flex-shrink: 0;
  width: var(--size-rating-star);
  height: var(--size-rating-star);
  line-height: var(--size-rating-star);
  text-align: center;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.album-part-verify__step-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.album-part-verify__step-title {
  font-weight: var(--font-weight-medium);
  line-height: var(--line-height-relaxed);
}

.album-part-verify__store-method {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--color-border);
}

.album-part-verify__store-method-label {
  color: var(--color-text-tertiary);
  letter-spacing: 0.06em;
}

.album-part-verify__store-method-body {
  display: block;
  line-height: var(--line-height-relaxed);
  white-space: pre-wrap;
}

.album-part-verify__guide-feedback {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.album-part-verify__collapse-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.album-part-verify__progress {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-md);
  box-sizing: border-box;
}

.album-part-verify__summary,
.album-part-verify__degrade {
  display: block;
  line-height: var(--line-height-relaxed);
}

.album-part-verify__plan {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  box-sizing: border-box;
}

.album-part-verify__plan-text {
  display: block;
  line-height: var(--line-height-relaxed);
  white-space: pre-wrap;
}

.album-part-verify__quote-scroll {
  width: 100%;
  white-space: nowrap;
}

.album-part-verify__quote-row {
  display: inline-flex;
  gap: var(--space-sm);
}

.album-part-verify__quote-thumb {
  width: var(--size-geo-card-cover);
  height: var(--size-part-verify-quote-height);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--color-bg-subtle);
}

.album-part-verify__section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-sm);
  padding: var(--space-xs) var(--space-xs) 0;
}

.album-part-verify__section-head--sub {
  margin-top: var(--space-xs);
}

.album-part-verify__section-title {
  font-weight: var(--font-weight-medium);
}

.album-part-verify__status-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.album-part-verify__submit {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-md);
  box-sizing: border-box;
}

.album-part-verify__contact {
  margin-top: var(--space-xs);
}
