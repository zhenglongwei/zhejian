<view class="page album-part-verify bg-album">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-part-verify__pad">
      <ui-skeleton rows="{{5}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content album-part-verify__pad">
      <ui-empty theme="album" title="无法打开" description="{{errorMessage}}" actionText="重试" bind:action="onRetry" />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content album-part-verify__pad">
      <ui-empty
        theme="album"
        title="暂无登记配件"
        description="门店尚未在相册中登记更换配件。你可先查看维修方案说明，或联系门店补录后再验真。"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content album-part-verify__body">
      <view class="surface-album-folio album-part-verify__hero">
        <text class="text-h3">{{albumTitle}}</text>
        <text wx:if="{{storeName}}" class="text-caption text-secondary album-part-verify__store">{{storeName}}</text>
      </view>

      <view class="surface-album-panel album-part-verify__guide">
        <text class="text-h3 album-part-verify__guide-title">如何验真</text>
        <view class="album-part-verify__steps">
          <view wx:for="{{methodSteps}}" wx:key="step" class="album-part-verify__step">
            <text class="album-part-verify__step-num text-caption">{{item.step}}</text>
            <view class="album-part-verify__step-body">
              <text class="text-body album-part-verify__step-title">{{item.title}}</text>
              <text class="text-caption text-secondary">{{item.desc}}</text>
            </view>
          </view>
        </view>
        <view class="album-part-verify__store-method">
          <text class="text-caption album-part-verify__store-method-label">{{methodTitle}}</text>
          <text class="text-body album-part-verify__store-method-body">{{storeMethodText}}</text>
        </view>
        <view class="album-part-verify__guide-feedback">
          <view class="album-part-verify__collapse-head" bindtap="onToggleGuideFeedback">
            <text class="text-caption text-secondary">{{guideFeedbackTitle}}</text>
            <text class="text-caption text-link">{{guideFeedbackExpanded ? '收起' : '展开'}}</text>
          </view>
          <block wx:if="{{guideFeedbackExpanded}}">
            <view class="album-part-verify__status-row">
              <view
                wx:for="{{guideFeedbackOptions}}"
                wx:key="value"
                data-value="{{item.value}}"
                bindtap="onGuideFeedbackTap"
              >
                <ui-review-tag-chip text="{{item.label}}" selected="{{guideFeedback === item.value}}" />
              </view>
            </view>
          </block>
        </view>
      </view>

      <view wx:if="{{summaryLabel || showDegradeHint}}" class="surface-album-inset album-part-verify__progress">
        <text wx:if="{{summaryLabel}}" class="text-caption album-part-verify__summary">{{summaryLabel}}</text>
        <text wx:if="{{showDegradeHint}}" class="text-caption text-secondary album-part-verify__degrade">{{degradeHint}}</text>
      </view>

      <view wx:if="{{planSummary || planQuoteThumbs.length}}" class="surface-album-inset album-part-verify__plan">
        <view class="album-part-verify__collapse-head" bindtap="onTogglePlan">
          <text class="text-body">{{planSectionTitle}}</text>
          <text class="text-caption text-link">{{planExpanded ? '收起' : '展开'}}</text>
        </view>
        <block wx:if="{{planExpanded}}">
          <text wx:if="{{planSummary}}" class="text-body album-part-verify__plan-text">{{planSummary}}</text>
          <scroll-view
            wx:if="{{planQuoteThumbs.length}}"
            class="album-part-verify__quote-scroll"
            scroll-x
            enable-flex
            show-scrollbar="{{false}}"
          >
            <view class="album-part-verify__quote-row">
              <image
                wx:for="{{planQuoteThumbs}}"
                wx:key="*this"
                class="album-part-verify__quote-thumb"
                src="{{item}}"
                mode="aspectFill"
              />
            </view>
          </scroll-view>
        </block>
      </view>

      <view class="album-part-verify__section-head">
        <text class="text-body album-part-verify__section-title">{{albumSectionTitle}}</text>
        <text class="text-caption text-secondary">{{verifyItems.length}} 项</text>
      </view>

      <block wx:if="{{usePairsMode}}">
        <part-verify-item
          wx:for="{{pairs}}"
          wx:key="partKey"
          mode="pair"
          item="{{item}}"
          status-options="{{statusOptions}}"
          upload-hint="{{uploadHint}}"
          bind:statustap="onItemStatusTap"
          bind:detailtoggle="onItemDetailToggle"
          bind:noteinput="onItemNoteInput"
          bind:imageschange="onItemImagesChange"
        />

        <block wx:if="{{extras.length}}">
          <view class="album-part-verify__section-head album-part-verify__section-head--sub">
            <text class="text-body album-part-verify__section-title">{{extraSectionTitle}}</text>
            <text class="text-caption text-secondary">{{extras.length}} 项</text>
          </view>
          <part-verify-item
            wx:for="{{extras}}"
            wx:key="partKey"
            mode="pair"
            item="{{item}}"
            status-options="{{statusOptions}}"
            upload-hint="{{uploadHint}}"
            bind:statustap="onItemStatusTap"
            bind:detailtoggle="onItemDetailToggle"
            bind:noteinput="onItemNoteInput"
            bind:imageschange="onItemImagesChange"
          />
        </block>
      </block>

      <block wx:else>
        <part-verify-item
          wx:for="{{parts}}"
          wx:key="partKey"
          mode="row"
          item="{{item}}"
          status-options="{{statusOptions}}"
          upload-hint="{{uploadHint}}"
          bind:statustap="onItemStatusTap"
          bind:detailtoggle="onItemDetailToggle"
          bind:noteinput="onItemNoteInput"
          bind:imageschange="onItemImagesChange"
        />
      </block>

      <view class="surface-album-inset album-part-verify__submit">
        <ui-checkbox-row checked="{{consent}}" bind:toggle="toggleConsent">{{consentText}}</ui-checkbox-row>
        <view wx:if="{{storePhone}}" class="album-part-verify__contact">
          <ui-button type="ghost" size="sm" block bind:btntap="onContactStore">联系门店</ui-button>
        </view>
      </view>
    </view>

    <ui-fixed-bottom-bar>
      <ui-button
        type="primary"
        slot="right"
        block
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bind:btntap="onSubmit"
      >保存验真记录</ui-button>
    </ui-fixed-bottom-bar>

    <ui-login-sheet
      visible="{{loginSheetVisible}}"
      mode="auto"
      bindContext="album"
      bind:close="closeLoginSheet"
      bind:cancel="closeLoginSheet"
      bind:success="onLoginSuccess"
    />
  </block>
</view>
