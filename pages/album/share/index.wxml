<view class="page album-share">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-share__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
      <ui-skeleton rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法查看分享内容"
        description="{{errorMessage}}"
        actionText="返回首页"
        bind:action="onGoHome"
      />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="page-content album-share__body">
      <ui-privacy-banner text="{{detail.disclaimer}}" />
      <ui-service-album-summary-card
        title="{{detail.serviceName}}"
        rows="{{summaryRows}}"
      />
      <ui-service-album-process-section
        nodes="{{detail.nodes}}"
        storeNote="{{detail.storeNote}}"
        footerBannerText="私人分享内容，不代表授权公示案例。"
      />
    </view>
  </block>
</view>
