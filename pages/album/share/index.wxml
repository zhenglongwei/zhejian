<view class="page album-share">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-share__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
      <ui-skeleton rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法查看分享内容"
        description="{{errorMessage}}"
        actionText="返回首页"
        bind:action="onGoHome"
      />
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="page-content album-share__body">
      <ui-privacy-banner text="{{detail.disclaimer}}" />
      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="album-share__title text-h2">{{detail.serviceName}}</text>
        <ui-key-info-table rows="{{summaryRows}}" />
      </ui-card>
      <view class="album-share__section">
        <text class="album-share__section-title text-h3">过程记录</text>
        <ui-album-node
          wx:for="{{detail.nodes}}"
          wx:key="id"
          title="{{item.title}}"
          images="{{item.images}}"
          note="{{item.note}}"
          emptyText="该节点暂无图片"
        />
        <text wx:if="{{detail.storeNote}}" class="note-block text-caption">{{detail.storeNote}}</text>
      </view>
      <text class="note-block text-caption">私人分享内容，不代表平台公示案例。</text>
    </view>
  </block>
</view>
