<view class="page album-list">
  <view class="album-list__tabs page-content">
    <ui-tabs
      tabs="{{tabs}}"
      activeKey="{{activeTab}}"
      scrollable="{{true}}"
      bind:change="onTabChange"
    />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-list__list">
      <ui-skeleton wx:for="{{[1,2,3]}}" wx:key="*this" rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="page-content">
      <ui-empty
        title="{{needPhone ? '绑定手机号后查看' : '登录后查看服务相册'}}"
        description="{{needPhone ? '绑定后可查看门店为你创建的服务相册' : '登录后可查看门店为你创建的服务相册'}}"
        actionText="{{needPhone ? '绑定手机号' : '微信一键登录'}}"
        bind:action="onLoginTap"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="暂无服务相册"
        description="门店为你创建服务相册后，将在此展示六阶段过程记录"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content album-list__list">
      <ui-album-card
        wx:for="{{list}}"
        wx:key="albumId"
        item="{{item}}"
        bind:tap="onCardTap"
      />
    </view>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="album"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
