<view class="page album-list">
  <view class="album-list__tabs page-content">
    <ui-tabs
      tabs="{{tabs}}"
      activeKey="{{activeTab}}"
      scrollable="{{true}}"
      bind:change="onTabChange"
    />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-list__list">
      <ui-skeleton wx:for="{{[1,2,3]}}" wx:key="*this" rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="page-content">
      <ui-empty
        title="{{needPhone ? '绑定手机号后查看' : '登录后查看服务相册'}}"
        description="{{needPhone ? '绑定后可查看门店为你创建的服务相册' : '登录后可查看门店为你创建的服务相册'}}"
        actionText="{{needPhone ? '绑定手机号' : '微信一键登录'}}"
        bind:action="onLoginTap"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="{{activeTab === 'public' ? '暂无公开相册' : '暂无私密相册'}}"
        description="{{activeTab === 'public' ? '审核通过并公开展示的案例将出现在这里' : '门店为你创建的维修记录与尚未公开的案例将出现在这里'}}"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content album-list__list">
      <ui-album-card
        wx:for="{{list}}"
        wx:key="albumId"
        item="{{item}}"
        bind:tap="onCardTap"
      />
    </view>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="album"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
