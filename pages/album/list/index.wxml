<ui-tool-page-shell>
  <view class="album-list__tabs">
    <ui-tabs
      tabs="{{tabs}}"
      activeKey="{{activeTab}}"
      scrollable="{{true}}"
      bind:change="onTabChange"
    />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="album-list__catalog surface-album-catalog">
      <view class="album-list__catalog-head">
        <view class="album-list__catalog-accent" aria-hidden="true" />
        <text class="album-list__catalog-title text-album-display">档案目录</text>
      </view>
      <view class="album-list__catalog-divider" />
      <view class="album-list__list">
        <ui-skeleton theme="album" variant="album-card" wx:for="{{[1,2,3]}}" wx:key="*this" />
      </view>
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="album-list__state">
      <ui-empty
        theme="album"
        title="{{needPhone ? '绑定手机号后查看' : '登录后查看服务相册'}}"
        description="{{needPhone ? '绑定后可查看门店为你创建的服务相册' : '登录后可查看门店为你创建的服务相册'}}"
        actionText="{{needPhone ? '绑定手机号' : '微信一键登录'}}"
        bind:action="onLoginTap"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="album-list__state">
      <ui-empty
        theme="album"
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty' && activeTab === 'all'}}">
    <view class="album-list__state">
      <ui-empty
        theme="album"
        title="{{albumEmptyTitle}}"
        actionText="{{albumEmptyAction}}"
        bind:action="onOpenAlbumMerchants"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty' && activeTab === 'publishable'}}">
    <view class="album-list__state">
      <ui-empty
        theme="album"
        title="暂无可公示相册"
        description="相册完工且仍为私密记录时，可在此发起授权公示"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="album-list__state">
      <ui-empty
        theme="album"
        title="暂无已公示相册"
        description="提交授权公示后，审核中与已通过的案例会出现在这里"
      />
    </view>
  </block>

  <block wx:else>
    <view class="album-list__catalog surface-album-catalog">
      <view class="album-list__catalog-head">
        <view class="album-list__catalog-accent" aria-hidden="true" />
        <text class="album-list__catalog-title text-album-display">档案目录</text>
      </view>
      <view class="album-list__catalog-divider" />
      <view class="album-list__list">
        <ui-album-card
          wx:for="{{list}}"
          wx:key="albumId"
          item="{{item}}"
          showHeaderActions="{{false}}"
          bind:tap="onCardTap"
        />
      </view>
    </view>
  </block>
</ui-tool-page-shell>

<ui-bottom-sheet
  visible="{{authSheetVisible}}"
  title="发布到公开网站"
  showActions="{{false}}"
  scrollable="{{true}}"
  bind:close="onCloseAuthSheet"
>
  <ui-album-authorize-section
    title="发布到公开网站"
    confirmText="确认并进入脱敏预览"
    rejectText="暂不发布"
    checked="{{authChecked}}"
    authTier="{{authTier}}"
    submitting="{{authSubmitting}}"
    showActions="{{false}}"
    showRejectLink="{{true}}"
    bind:toggle="onAuthCheckToggle"
    bind:tierchange="onAuthTierChange"
    bind:reject="onRejectAuth"
    bind:policy="onOpenBenefitPolicy"
  />
  <view class="album-list__auth-submit">
    <ui-button
      type="primary"
      block
      disabled="{{authSubmitting}}"
      loading="{{authSubmitting}}"
      bind:btntap="onSubmitAuth"
    >确认并进入脱敏预览</ui-button>
  </view>
</ui-bottom-sheet>

<ui-share-sheet
  visible="{{shareSheetVisible}}"
  variant="owner"
  showOwnerShare="{{showShareEntry}}"
  shareIntent="{{shareSheetIntent}}"
  shareUseOriginal="{{shareUseOriginal}}"
  ownerSharePreparing="{{sharePreparing}}"
  actionsDisabled="{{shareActionsDisabled}}"
  honorHint="{{shareHonorHint}}"
  socialPlatform="{{socialPlatform}}"
  socialDraftText="{{socialDraftText}}"
  socialDraftLoading="{{socialDraftLoading}}"
  socialDraftWaitHint="{{socialDraftWaitHint}}"
  publishState="{{publishSheetState}}"
  publishDisabled="{{publishSheetDisabled}}"
  publishHint="{{publishSheetHint}}"
  showPublicWebLink="{{showPublicCaseShare}}"
  bind:close="onCloseShareSheet"
  bind:toggleoriginal="onShareOriginalToggle"
  bind:copyownerlink="onCopyOwnerShareLink"
  bind:copypublicweblink="onCopyPublicWebLink"
  bind:sharetimeline="onShareTimelineGuide"
  bind:socialplatformchange="onSocialPlatformChange"
  bind:copysocial="onCopySocialDraft"
  bind:publish="onSharePublish"
/>

<ui-login-sheet
  visible="{{loginSheetVisible}}"
  mode="{{loginSheetMode}}"
  bindContext="album"
  bind:close="closeLoginSheet"
  bind:cancel="closeLoginSheet"
  bind:success="onLoginSheetSuccess"
/>

<ui-bottom-sheet
  visible="{{withdrawSheetVisible}}"
  title="撤回授权"
  hint="撤回后公开案例将下架，已产生的传播数据保留后台记录。私密服务相册仍保留。"
  confirmText="确认撤回"
  cancelText="取消"
  loading="{{withdrawSheetLoading}}"
  bind:close="onWithdrawSheetClose"
  bind:cancel="onWithdrawSheetClose"
  bind:confirm="onWithdrawSheetConfirm"
/>
