<view class="page album-review-submit">
  <view class="page-content album-review-submit__body">
    <ui-card shadow="{{true}}" padding="{{true}}">
      <text class="album-review-submit__section-title text-h3">评价对象</text>
      <text class="text-body">{{albumTitle}}</text>
      <view wx:if="{{repairScore > 0 || albumScore > 0}}" class="album-review-submit__scores">
        <text wx:if="{{repairScore > 0}}" class="text-caption">维修服务 {{repairScore}}</text>
        <text wx:if="{{albumScore > 0}}" class="text-caption">相册记录 {{albumScore}}</text>
      </view>
    </ui-card>

    <block wx:for="{{reviewGroups}}" wx:key="key" wx:for-item="group">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <text class="album-review-submit__section-title text-h3">{{group.title}}</text>
        <ui-rating-dimensions
          values="{{scores}}"
          dimensions="{{group.dimensions}}"
          collapse-from="{{99}}"
          bind:change="onScoresChange"
        />
      </ui-card>
    </block>

    <ui-card shadow="{{true}}" padding="{{true}}">
      <text class="album-review-submit__section-title text-h3">可选标签</text>
      <view class="album-review-submit__tags">
        <ui-review-tag-chip
          wx:for="{{tagItems}}"
          wx:key="text"
          text="{{item.text}}"
          selected="{{item.selected}}"
          bind:tap="onTagTap"
        />
      </view>
    </ui-card>

    <ui-card shadow="{{true}}" padding="{{true}}">
      <text class="album-review-submit__section-title text-h3">文字评价（选填）</text>
      <textarea
        class="album-review-submit__textarea text-body"
        placeholder="可补充本次服务与相册记录体验，最多 300 字"
        value="{{content}}"
        maxlength="300"
        bindinput="onContentInput"
      />
      <text class="album-review-submit__counter text-caption">{{contentLength}}/300</text>
    </ui-card>

    <ui-card shadow="{{true}}" padding="{{true}}">
      <text class="album-review-submit__section-title text-h3">配图（选填）</text>
      <ui-image-uploader images="{{form.images}}" maxCount="{{3}}" bind:change="onImagesChange" />
      <view class="album-review-submit__notice">
        <ui-compliance-notice type="reviewImageTip" />
      </view>
    </ui-card>

    <ui-card shadow="{{true}}" padding="{{true}}">
      <view class="album-review-submit__consent">
        <ui-checkbox-row checked="{{form.consent}}" bind:toggle="toggleConsent">
          {{consentText}}
        </ui-checkbox-row>
      </view>
      <view class="album-review-submit__consent">
        <ui-checkbox-row checked="{{form.authorizePublic}}" bind:toggle="toggleAuthorizePublic">
          {{publicConsentText}}
        </ui-checkbox-row>
      </view>
    </ui-card>
  </view>

  <ui-fixed-bottom-bar>
    <ui-button
      type="primary"
      slot="right"
      block
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bind:btntap="onSubmit"
    >提交评价</ui-button>
  </ui-fixed-bottom-bar>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="auto"
    bindContext="album"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
  />
</view>
