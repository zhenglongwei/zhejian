<view class="page album-inspect-ai bg-album">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-inspect-ai__pad">
      <ui-skeleton rows="{{5}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content album-inspect-ai__pad">
      <ui-empty theme="album" title="无法打开 AI 分析" description="{{errorMessage}}" actionText="重试" bind:action="onRetry" />
    </view>
  </block>

  <block wx:else>
    <view class="page-content album-inspect-ai__body">
      <view class="surface-album-panel album-inspect-ai__hero">
        <text class="text-h3">{{albumTitle}}</text>
        <view class="album-inspect-ai__notice-wrap">
          <ui-compliance-notice type="aiInspection" />
        </view>
        <text
          wx:for="{{aiEvidenceLimitLines}}"
          wx:key="*this"
          class="text-caption album-inspect-ai__limit"
        >{{item}}</text>
        <text wx:if="{{!canRunAiAnalysis && reports.length}}" class="text-caption album-inspect-ai__hint">相册自上次分析后暂无更新，可直接查看下方记录。</text>
        <text wx:elif="{{!canRunAiAnalysis && !reports.length && !albumCompleted}}" class="text-caption album-inspect-ai__hint">施工节点留痕尚不足，请待相册内容更完整后再分析。</text>
        <text wx:elif="{{!canRunAiAnalysis && !reports.length && albumCompleted}}" class="text-caption album-inspect-ai__hint">可发起首次 AI 分析；留痕较少时结果可能较简略。</text>
      </view>

      <view wx:if="{{canRunAiAnalysis}}" class="album-inspect-ai__trigger">
        <ui-button
          type="secondary"
          block
          loading="{{aiLoading}}"
          disabled="{{aiLoading}}"
          bind:btntap="onRunAiCheck"
        >发起 AI 分析</ui-button>
      </view>

      <block wx:if="{{reports.length}}">
        <view
          wx:for="{{reports}}"
          wx:key="reportId"
          wx:for-item="report"
          class="surface-album-panel album-inspect-ai__report {{report.reportId === highlightReportId ? 'album-inspect-ai__report--highlight' : ''}}"
        >
          <view
            class="album-inspect-ai__report-head"
            bindtap="onToggleReport"
            data-id="{{report.reportId}}"
          >
            <view class="album-inspect-ai__report-head-main">
              <text class="text-body album-inspect-ai__report-time">{{report.createdAtText}}</text>
              <text wx:if="{{report.focusStageTitle}}" class="text-caption album-inspect-ai__report-focus">关注：{{report.focusStageTitle}}</text>
            </view>
            <view class="album-inspect-ai__report-head-side">
              <ui-tag variant="{{report.status === 'failed' ? 'warning' : 'info'}}" text="{{report.status === 'failed' ? '调用失败' : '已完成'}}" />
              <text class="album-inspect-ai__chevron">{{report.expanded ? '▾' : '▸'}}</text>
            </view>
          </view>

          <block wx:if="{{report.expanded}}">
            <block wx:if="{{report.status === 'failed'}}">
              <text class="text-body album-inspect-ai__fail-title">{{report.errorTitle || '调用失败'}}</text>
              <text class="text-body album-inspect-ai__fail-message">{{report.errorMessage}}</text>
            </block>

            <block wx:else>
              <block wx:if="{{report.advice.overallOpinion.summary}}">
                <text class="text-caption album-inspect-ai__label">整体意见</text>
                <text class="text-body album-inspect-ai__summary">{{report.advice.overallOpinion.summary}}</text>
              </block>

              <text wx:if="{{report.advice.overallOpinion.completeness}}" class="text-caption album-inspect-ai__process">{{report.advice.overallOpinion.completeness}}</text>

              <block wx:if="{{report.advice.overallOpinion.missingItems.length}}">
                <text class="text-caption album-inspect-ai__label">建议补齐</text>
                <text wx:for="{{report.advice.overallOpinion.missingItems}}" wx:key="*this" class="text-body album-inspect-ai__line">{{item}}</text>
              </block>

              <block wx:if="{{report.advice.overallOpinion.potentialIssues.length}}">
                <text class="text-caption album-inspect-ai__label">需留意</text>
                <text wx:for="{{report.advice.overallOpinion.potentialIssues}}" wx:key="*this" class="text-body album-inspect-ai__line">{{item}}</text>
              </block>

              <block wx:if="{{report.advice.overallOpinion.recommendedActions.length}}">
                <text class="text-caption album-inspect-ai__label">建议措施</text>
                <text wx:for="{{report.advice.overallOpinion.recommendedActions}}" wx:key="*this" class="text-body album-inspect-ai__line">{{item}}</text>
              </block>

              <block wx:if="{{report.advice.comparisons.length}}">
                <text class="text-caption album-inspect-ai__label">对比分析</text>
                <view
                  wx:for="{{report.advice.comparisons}}"
                  wx:key="title"
                  wx:for-item="cmp"
                  class="album-inspect-ai__compare"
                >
                  <text class="text-body album-inspect-ai__compare-title">{{cmp.title}}</text>
                  <text wx:if="{{cmp.process}}" class="text-body album-inspect-ai__line">{{cmp.process}}</text>
                  <text wx:if="{{cmp.conclusion}}" class="text-caption album-inspect-ai__compare-conclusion">{{cmp.conclusion}}</text>
                </view>
              </block>

              <block wx:if="{{report.advice.partVerifyReminders.length}}">
                <text class="text-caption album-inspect-ai__label">配件验真提醒</text>
                <view
                  wx:for="{{report.advice.partVerifyReminders}}"
                  wx:key="partName"
                  wx:for-item="reminder"
                  class="album-inspect-ai__verify"
                >
                  <text class="text-body album-inspect-ai__line">{{reminder.partName}}：{{reminder.reason}}</text>
                  <text wx:if="{{reminder.action}}" class="text-caption album-inspect-ai__action">{{reminder.action}}</text>
                </view>
              </block>

              <block wx:if="{{report.advice.limitationNote}}">
                <text class="text-caption album-inspect-ai__label">相册说明</text>
                <text class="text-caption album-inspect-ai__limit">{{report.advice.limitationNote}}</text>
              </block>

              <block wx:if="{{report.advice.photoAppendix.length}}">
                <view
                  class="album-inspect-ai__appendix-head"
                  bindtap="onToggleAppendix"
                  data-id="{{report.reportId}}"
                >
                  <text class="text-caption album-inspect-ai__label album-inspect-ai__appendix-label">照片附录</text>
                  <text class="album-inspect-ai__chevron">{{report.appendixExpanded ? '▾' : '▸'}}</text>
                </view>
                <block wx:if="{{report.appendixExpanded}}">
                  <view
                    wx:for="{{report.advice.photoAppendix}}"
                    wx:key="stageId"
                    wx:for-item="stageBlock"
                    class="album-inspect-ai__appendix-stage"
                  >
                    <text class="text-body album-inspect-ai__appendix-stage-title">{{stageBlock.stageTitle}}</text>
                    <view
                      wx:for="{{stageBlock.photos}}"
                      wx:key="label"
                      wx:for-item="photoRow"
                      class="album-inspect-ai__appendix-photo"
                    >
                      <text class="text-caption album-inspect-ai__appendix-photo-label">{{photoRow.label}}</text>
                      <text class="text-body album-inspect-ai__line {{photoRow.valid ? '' : 'album-inspect-ai__invalid'}}">{{photoRow.description}}</text>
                    </view>
                  </view>
                </block>
              </block>
            </block>
          </block>
        </view>
      </block>

      <view wx:else class="surface-album-panel album-inspect-ai__empty">
        <text class="text-body text-secondary">暂无 AI 分析记录。</text>
      </view>
    </view>
  </block>
</view>
