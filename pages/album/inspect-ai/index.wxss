.album-inspect-ai__pad {
  padding-top: var(--space-md);
}

.album-inspect-ai__body {
  padding-bottom: calc(env(safe-area-inset-bottom) + var(--space-lg));
}

.album-inspect-ai__hero {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
  padding: var(--space-md);
}

.album-inspect-ai__notice-wrap {
  margin-top: var(--space-sm);
}

.album-inspect-ai__notice-wrap .compliance-notice {
  white-space: normal;
  line-height: 1.55;
}

.album-inspect-ai__hint {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.album-inspect-ai__trigger {
  margin-bottom: var(--space-md);
  padding: 0 var(--page-padding-x);
}

.album-inspect-ai__report {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin: 0 var(--page-padding-x) var(--space-sm);
  padding: var(--space-md);
}

.album-inspect-ai__report--highlight {
  border: 1rpx solid var(--color-primary);
}

.album-inspect-ai__report-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
}

.album-inspect-ai__report-head-main {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: var(--space-xs);
  min-width: 0;
}

.album-inspect-ai__report-head-side {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: var(--space-xs);
}

.album-inspect-ai__report-time {
  font-weight: var(--font-weight-medium);
}

.album-inspect-ai__report-focus {
  color: var(--color-text-tertiary);
}

.album-inspect-ai__fail-title {
  display: block;
  margin-top: var(--space-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-warning);
}

.album-inspect-ai__fail-message {
  display: block;
  margin-top: var(--space-xs);
  line-height: 1.55;
  color: var(--color-text-primary);
}

.album-inspect-ai__limit {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
  line-height: 1.55;
}

.album-inspect-ai__summary {
  display: block;
  margin-top: var(--space-sm);
  font-weight: var(--font-weight-medium);
  line-height: 1.5;
}

.album-inspect-ai__process {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.album-inspect-ai__label {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.album-inspect-ai__line {
  display: block;
  margin-top: var(--space-xs);
  line-height: 1.5;
}

.album-inspect-ai__stage {
  margin-top: var(--space-xs);
}

.album-inspect-ai__concern {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-warning);
  line-height: 1.45;
}

.album-inspect-ai__verify {
  margin-top: var(--space-xs);
}

.album-inspect-ai__action {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.album-inspect-ai__empty {
  margin: 0 var(--page-padding-x);
  padding: var(--space-lg) var(--space-md);
  text-align: center;
}

.album-inspect-ai__chevron {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-caption);
  line-height: 1;
}

.album-inspect-ai__compare {
  margin-top: var(--space-xs);
  padding-top: var(--space-xs);
  border-top: 1rpx solid var(--color-border-light);
}

.album-inspect-ai__compare-title {
  display: block;
  font-weight: var(--font-weight-medium);
  line-height: 1.5;
}

.album-inspect-ai__compare-conclusion {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.album-inspect-ai__appendix-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-sm);
}

.album-inspect-ai__appendix-label {
  margin-top: 0;
}

.album-inspect-ai__appendix-stage {
  margin-top: var(--space-sm);
}

.album-inspect-ai__appendix-stage-title {
  display: block;
  font-weight: var(--font-weight-medium);
  line-height: 1.5;
}

.album-inspect-ai__appendix-photo {
  margin-top: var(--space-xs);
}

.album-inspect-ai__appendix-photo-label {
  display: block;
  color: var(--color-text-tertiary);
}

.album-inspect-ai__invalid {
  color: var(--color-text-tertiary);
}
