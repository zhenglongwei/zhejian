<ui-tool-page-shell>
  <block wx:if="{{status === 'loading'}}">
    <view class="album-authorize__list">
      <ui-skeleton wx:for="{{[1,2]}}" wx:key="*this" rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="album-authorize__state">
      <ui-empty
        theme="album"
        title="{{needPhone ? '绑定手机号后查看' : '登录后查看授权'}}"
        description="查看你的相册公开与审核状态"
        actionText="{{needPhone ? '绑定手机号' : '微信一键登录'}}"
        bind:action="onLoginTap"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="album-authorize__state">
      <ui-empty
        theme="album"
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="album-authorize__state">
      <ui-empty
        theme="album"
        title="暂无公开授权"
        description="相册完工后，可在服务相册中授权生成脱敏公开案例"
      />
    </view>
  </block>

  <block wx:else>
    <view class="album-authorize__list">
      <ui-authorization-card
        wx:for="{{list}}"
        wx:key="albumId"
        item="{{item}}"
        bind:view="onViewAlbum"
        bind:withdraw="onWithdraw"
      />
    </view>
  </block>
</ui-tool-page-shell>

<ui-login-sheet
  visible="{{loginSheetVisible}}"
  mode="{{loginSheetMode}}"
  bindContext="album"
  bind:close="closeLoginSheet"
  bind:cancel="closeLoginSheet"
  bind:success="onLoginSheetSuccess"
/>

<ui-bottom-sheet
  visible="{{withdrawSheetVisible}}"
  title="撤回授权"
  hint="撤回后公开案例将下架，已产生的传播数据保留后台记录。私密服务相册仍保留。"
  confirmText="确认撤回"
  cancelText="取消"
  loading="{{withdrawSheetLoading}}"
  bind:close="onWithdrawSheetClose"
  bind:cancel="onWithdrawSheetClose"
  bind:confirm="onWithdrawSheetConfirm"
/>
