<ui-tool-page-shell showBand="{{false}}" showCompliance="{{false}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="album-authorize__list">
      <ui-skeleton theme="album" variant="album-card" wx:for="{{[1,2]}}" wx:key="*this" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="album-authorize__state">
      <ui-empty
        theme="album"
        title="{{needPhone ? '绑定手机号后查看' : '登录后查看授权'}}"
        description="管理脱敏案例分享、审核与下架"
        actionText="{{needPhone ? '绑定手机号' : '微信一键登录'}}"
        bind:action="onLoginTap"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="album-authorize__state">
      <ui-empty
        theme="album"
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="album-authorize__state">
      <ui-empty
        theme="album"
        title="暂无授权记录"
        description="相册完工后可在此分享脱敏报告、查看审核结果或一键下架"
      />
    </view>
  </block>

  <block wx:else>
    <view class="album-authorize__list">
      <ui-album-card
        wx:for="{{list}}"
        wx:key="albumId"
        item="{{item}}"
        audience="user"
        showProgress="{{true}}"
        showHeaderActions="{{true}}"
        bind:tap="onCardTap"
        bind:authorize="onAuthorize"
        bind:withdraw="onWithdraw"
      />
    </view>
  </block>
</ui-tool-page-shell>

<ui-bottom-sheet
  visible="{{authSheetVisible}}"
  title="{{authSheetTitle}}"
  showActions="{{false}}"
  scrollable="{{true}}"
  bind:close="onCloseAuthSheet"
>
  <ui-album-authorize-section
    title="{{authSheetTitle}}"
    pitch="{{authPitch}}"
    benefitLine="{{authBenefitLine}}"
    controlLine="{{authControlLine}}"
    disclaimer="{{authDisclaimer}}"
    consentText="{{authConsentText}}"
    confirmText="{{authConfirmText}}"
    rejectText="{{authRejectText}}"
    checked="{{authChecked}}"
    authTier="{{authTier}}"
    submitting="{{authSubmitting}}"
    showActions="{{false}}"
    showRejectLink="{{true}}"
    bind:toggle="onAuthCheckToggle"
    bind:tierchange="onAuthTierChange"
    bind:reject="onRejectAuth"
    bind:policy="onOpenBenefitPolicy"
  />
  <view class="album-authorize__auth-submit">
    <ui-button
      type="primary"
      block
      disabled="{{authSubmitting}}"
      loading="{{authSubmitting}}"
      bind:btntap="onSubmitAuth"
    >{{authConfirmText}}</ui-button>
  </view>
</ui-bottom-sheet>

<ui-login-sheet
  visible="{{loginSheetVisible}}"
  mode="{{loginSheetMode}}"
  bindContext="album"
  bind:close="closeLoginSheet"
  bind:cancel="closeLoginSheet"
  bind:success="onLoginSheetSuccess"
/>

<ui-bottom-sheet
  visible="{{withdrawSheetVisible}}"
  title="撤回授权"
  hint="撤回后公开案例将下架，已产生的传播数据保留后台记录。私密服务相册仍保留。"
  confirmText="确认撤回"
  cancelText="取消"
  loading="{{withdrawSheetLoading}}"
  bind:close="onWithdrawSheetClose"
  bind:cancel="onWithdrawSheetClose"
  bind:confirm="onWithdrawSheetConfirm"
/>
