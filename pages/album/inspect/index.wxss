.album-inspect__pad {
  padding-top: var(--space-md);
}

.album-inspect__body {
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
}

.album-inspect__hero {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
  padding: var(--space-md);
}

.album-inspect__hero-store {
  margin-top: var(--space-xs);
}

.album-inspect__hero-store-link {
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.album-inspect__hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm) var(--space-md);
  margin-top: var(--space-xs);
}

.album-inspect__hero-meta-item {
  color: var(--color-text-tertiary);
  line-height: 1.45;
}

.album-inspect__tabs-wrap {
  margin-bottom: var(--space-sm);
  padding: var(--space-xs) var(--space-sm);
}

.album-inspect__summary {
  display: flex;
  align-items: baseline;
  gap: var(--space-sm);
  margin-bottom: var(--space-xs);
  padding: var(--space-sm) var(--space-md);
}

.album-inspect__hint {
  display: block;
  margin-bottom: var(--space-sm);
  padding: 0 var(--space-md);
  color: var(--color-text-tertiary);
  line-height: 1.45;
}

.album-inspect__disclaimer {
  display: none;
}

.album-inspect__method-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
  padding: var(--space-md);
}

.album-inspect__method-title {
  font-weight: var(--font-weight-semibold);
  line-height: 1.45;
}

.album-inspect__method-para {
  display: block;
  font-size: var(--font-body);
  line-height: 1.55;
  color: var(--color-text-secondary);
}

.album-inspect__method-para--issue {
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.album-inspect__method-para--action {
  color: var(--color-text-primary);
}

.album-inspect__outcome {
  margin-bottom: var(--space-md);
}

.album-inspect__outcome-title {
  display: block;
  margin-bottom: var(--space-xs);
  font-weight: var(--font-weight-medium);
}

.album-inspect__outcome-hint {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.album-inspect__ai-trigger {
  margin-top: var(--space-md);
  margin-bottom: var(--space-md);
}

.album-inspect__card {
  margin-bottom: var(--space-sm);
}

.album-inspect__actions {
  display: none;
}

.album-inspect__thumb-scroll {
  width: 100%;
}

.album-inspect__thumb-row {
  display: inline-flex;
  gap: var(--space-sm);
}

.album-inspect__thumb {
  flex-shrink: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-album-list-thumb);
  border: 1rpx solid var(--color-album-frame-line);
  background: var(--color-album-frame-inner);
}

.album-inspect__note {
  display: block;
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
}

.album-inspect__signal {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
}

.album-inspect__signal-label {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.album-inspect__action {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.album-inspect__compare-block {
  margin-top: var(--space-md);
}

.album-inspect__compare-block:first-child {
  margin-top: var(--space-sm);
}

.album-inspect__compare-label {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--color-text-tertiary);
}

.album-inspect__empty-section {
  padding: var(--space-md);
}

.album-inspect__ai {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
  padding: var(--space-md);
}

.album-inspect__ai-summary {
  display: block;
  margin-top: var(--space-sm);
  font-weight: var(--font-weight-medium);
  line-height: 1.5;
}

.album-inspect__ai-process {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.album-inspect__ai-stage {
  margin-top: var(--space-xs);
}

.album-inspect__ai-concern {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-warning);
  line-height: 1.45;
}

.album-inspect__ai-verify {
  margin-top: var(--space-xs);
}

.album-inspect__ai-action {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.album-inspect__ai-disclaimer {
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.album-inspect__ai-limit {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-tertiary);
  line-height: 1.55;
}

.album-inspect__ai-label {
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.album-inspect__ai-line {
  display: block;
  margin-top: var(--space-xs);
  line-height: 1.5;
}

.album-inspect__bottom {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: var(--z-fixed);
  background: var(--color-bg-album);
  border-top: 1rpx solid var(--color-album-frame-line);
}

.album-inspect__bottom-inner {
  padding: var(--space-sm) var(--page-padding-x);
}

.album-inspect__bottom-row {
  display: flex;
  gap: var(--space-sm);
}
