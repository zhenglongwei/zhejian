<view class="page album-inspect bg-album">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content album-inspect__pad">
      <ui-skeleton rows="{{5}}" title="{{true}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content album-inspect__pad">
      <ui-empty theme="album" title="无法打开检查" description="{{errorMessage}}" actionText="重试" bind:action="onRetry" />
    </view>
  </block>

  <block wx:else>
    <view class="page-content album-inspect__body">
      <view class="surface-album-panel album-inspect__hero">
        <text class="text-h3">{{albumTitle}}</text>
        <text wx:if="{{storeName}}" class="text-caption text-secondary">{{storeName}}</text>
      </view>

      <view class="album-inspect__tabs-wrap surface-album-inset">
        <ui-tabs tabs="{{inspectTabs}}" active-key="{{activeTab}}" bind:change="onTabChange" />
      </view>

      <block wx:if="{{activeTab === 'completeness'}}">
        <view class="album-inspect__summary surface-album-inset">
          <text class="text-body">{{completenessSummary.done}}/{{completenessSummary.total}} 已有</text>
          <text wx:if="{{completenessSummary.missing}}" class="text-caption text-secondary">缺 {{completenessSummary.missing}} 项</text>
        </view>
        <text class="text-caption album-inspect__hint">{{completenessHint}}</text>

        <album-inspection-matrix
          wx:for="{{completenessPanels}}"
          wx:key="id"
          wx:for-item="panel"
          title="{{panel.title}}"
          layout="inventory"
          rows="{{panel.rows}}"
          bind:preview="onPreviewImage"
        />
      </block>

      <block wx:elif="{{activeTab === 'method'}}">
        <text class="text-caption album-inspect__hint">{{methodHint}}</text>

        <view
          wx:for="{{methodSections}}"
          wx:key="id"
          wx:for-item="section"
          class="surface-album-panel album-inspect__method-section"
        >
          <text class="text-body album-inspect__method-title">{{section.title}}</text>
          <text
            wx:for="{{section.paragraphs}}"
            wx:key="text"
            wx:for-item="para"
            class="album-inspect__method-para album-inspect__method-para--{{para.tone}}"
          >{{para.text}}</text>
        </view>
      </block>

      <view class="album-inspect__ai-trigger">
        <ui-button
          type="secondary"
          block
          loading="{{aiLoading}}"
          disabled="{{aiLoading}}"
          bind:btntap="onGenerateAiAdvice"
        >AI检查</ui-button>
      </view>

      <view wx:if="{{aiAdviceVisible && aiAdvice}}" class="surface-album-panel album-inspect__ai">
        <text class="text-h3">AI检查结果</text>
        <text class="text-caption album-inspect__ai-disclaimer">{{aiDisclaimer}}</text>
        <text
          wx:for="{{aiEvidenceLimitLines}}"
          wx:key="*this"
          class="text-caption album-inspect__ai-limit"
        >{{item}}</text>

        <text wx:if="{{aiAdvice.summary}}" class="text-body album-inspect__ai-summary">{{aiAdvice.summary}}</text>
        <text wx:if="{{aiAdvice.processStatus}}" class="text-caption album-inspect__ai-process">{{aiAdvice.processStatus}}</text>

        <block wx:if="{{aiAdvice.focusAreas && aiAdvice.focusAreas.length}}">
          <text class="text-caption album-inspect__ai-label">建议关注</text>
          <text wx:for="{{aiAdvice.focusAreas}}" wx:key="*this" class="text-body album-inspect__ai-line">{{item}}</text>
        </block>

        <block wx:if="{{aiAdvice.stageObservations && aiAdvice.stageObservations.length}}">
          <text class="text-caption album-inspect__ai-label">各节点观察</text>
          <view
            wx:for="{{aiAdvice.stageObservations}}"
            wx:key="stageId"
            wx:for-item="stageRow"
            class="album-inspect__ai-stage"
          >
            <text class="text-body album-inspect__ai-line">{{stageRow.stageTitle}}：{{stageRow.observation}}</text>
            <text wx:if="{{stageRow.concern}}" class="text-caption album-inspect__ai-concern">{{stageRow.concern}}</text>
          </view>
        </block>

        <block wx:if="{{aiAdvice.suspectedIssues && aiAdvice.suspectedIssues.length}}">
          <text class="text-caption album-inspect__ai-label">可能的问题</text>
          <text wx:for="{{aiAdvice.suspectedIssues}}" wx:key="*this" class="text-body album-inspect__ai-line">{{item.text || item}}</text>
        </block>

        <block wx:if="{{aiAdvice.partVerifyReminders && aiAdvice.partVerifyReminders.length}}">
          <text class="text-caption album-inspect__ai-label">配件验真提醒</text>
          <view
            wx:for="{{aiAdvice.partVerifyReminders}}"
            wx:key="partName"
            wx:for-item="reminder"
            class="album-inspect__ai-verify"
          >
            <text class="text-body album-inspect__ai-line">{{reminder.partName}}：{{reminder.reason}}</text>
            <text wx:if="{{reminder.action}}" class="text-caption album-inspect__ai-action">{{reminder.action}}</text>
          </view>
        </block>

        <block wx:if="{{aiAdvice.suggestedPhotos && aiAdvice.suggestedPhotos.length}}">
          <text class="text-caption album-inspect__ai-label">建议补充的照片</text>
          <text wx:for="{{aiAdvice.suggestedPhotos}}" wx:key="*this" class="text-body album-inspect__ai-line">{{item}}</text>
        </block>

        <block wx:if="{{aiAdvice.nextSteps && aiAdvice.nextSteps.length}}">
          <text class="text-caption album-inspect__ai-label">下一步建议</text>
          <text wx:for="{{aiAdvice.nextSteps}}" wx:key="*this" class="text-body album-inspect__ai-line">{{item}}</text>
        </block>
      </view>
    </view>

    <view class="album-inspect__bottom safe-bottom">
      <view class="album-inspect__bottom-inner">
        <view class="album-inspect__bottom-row">
          <ui-button type="secondary" block bind:btntap="onOpenFeedback">反馈</ui-button>
          <ui-button wx:if="{{showPartVerifyEntry}}" type="secondary" block bind:btntap="onOpenPartVerify">配件验真</ui-button>
        </view>
      </view>
    </view>
  </block>
</view>
