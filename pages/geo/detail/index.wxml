<view class="page geo-detail">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content geo-detail__pad">
      <ui-skeleton rows="{{4}}" title="{{true}}" />
      <text class="geo-detail__hint text-caption">正在打开专题页…</text>
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="无法打开专题"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>
</view>
