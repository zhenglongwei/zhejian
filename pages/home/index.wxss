.tool-home__pad {
  padding-top: var(--space-md);
}

.tool-home__body {
  padding: var(--space-md) 0 var(--space-xl);
}

.tool-home__gap {
  margin-top: var(--space-lg);
}

.tool-home__hero {
  background: linear-gradient(
    165deg,
    var(--color-primary-light) 0%,
    var(--color-bg-card) 55%,
    var(--color-bg-card) 100%
  );
}

.tool-home__kicker {
  display: block;
  color: var(--color-primary);
  font-weight: 500;
}

.tool-home__title {
  display: block;
  margin-top: var(--space-sm);
}

.tool-home__subtitle {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.tool-home__identity {
  margin-top: var(--space-md);
}

.tool-home__actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  padding: var(--space-md);
}

.tool-home__section {
  margin-top: var(--space-md);
  padding: var(--space-sm) var(--space-md);
}

.tool-home__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.tool-home__section-title {
  display: block;
  color: var(--color-text-primary);
}

.tool-home__more {
  color: var(--color-primary);
}

.tool-home__album-list {
  display: flex;
  flex-direction: column;
}

.tool-home__album-row {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.tool-home__album-row:last-child {
  border-bottom: none;
}

.tool-home__album-title {
  display: block;
  color: var(--color-text-primary);
}

.tool-home__album-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.tool-home__empty-hint {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.tool-home__modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg);
  background-color: rgba(0, 0, 0, 0.45);
  box-sizing: border-box;
}

.tool-home__modal {
  width: 100%;
  max-width: 640rpx;
  padding: var(--space-lg);
  box-sizing: border-box;
}

.tool-home__modal-title {
  display: block;
}

.tool-home__modal-desc {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
}

.tool-home__modal-input {
  width: 100%;
  margin-top: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  background-color: var(--color-bg-muted);
}

.tool-home__modal-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.tool-home__modal-actions ui-button {
  flex: 1;
}
