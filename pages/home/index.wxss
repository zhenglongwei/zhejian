.tool-home__hero--band {
  padding: var(--space-lg) 0 var(--space-md);
  background: linear-gradient(
    180deg,
    var(--color-primary-light) 0%,
    rgba(232, 243, 255, 0.35) 55%,
    var(--color-bg-page) 100%
  );
}

.tool-home__hero-inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.tool-home__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding-top: var(--space-xs);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
}

.tool-home__kicker {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.tool-home__title {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}

.tool-home__subtitle {
  color: var(--color-text-secondary);
}

.tool-home__scan {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-lg);
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  box-shadow: 0 12rpx 32rpx rgba(22, 119, 255, 0.28);
}

.tool-home__scan--loading {
  opacity: var(--opacity-disabled);
  pointer-events: none;
}

.tool-home__scan-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  background-color: rgba(255, 255, 255, 0.18);
}

.tool-home__scan-icon-frame {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid var(--color-text-inverse);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.tool-home__scan-icon-frame::before,
.tool-home__scan-icon-frame::after {
  content: '';
  position: absolute;
  background-color: var(--color-text-inverse);
}

.tool-home__scan-icon-frame::before {
  left: 50%;
  top: 8rpx;
  width: 4rpx;
  height: 16rpx;
  margin-left: -2rpx;
  border-radius: 2rpx;
}

.tool-home__scan-icon-frame::after {
  left: 8rpx;
  top: 50%;
  width: 16rpx;
  height: 4rpx;
  margin-top: -2rpx;
  border-radius: 2rpx;
}

.tool-home__scan-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.tool-home__scan-title {
  color: var(--color-text-inverse);
  font-weight: var(--font-weight-semibold);
}

.tool-home__scan-desc {
  color: rgba(255, 255, 255, 0.82);
}

.tool-home__scan-arrow {
  flex-shrink: 0;
  color: rgba(255, 255, 255, 0.88);
  font-size: 40rpx;
  line-height: 1;
}

.tool-home__quick {
  display: flex;
  align-items: stretch;
  padding: 0;
  overflow: hidden;
}

.tool-home__quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: var(--space-md) var(--space-sm);
  box-sizing: border-box;
}

.tool-home__quick-item:active {
  background-color: var(--color-bg-active);
}

.tool-home__quick-split {
  flex-shrink: 0;
  width: 1rpx;
  background-color: var(--color-border);
}

.tool-home__quick-label {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  text-align: center;
}

.tool-home__quick-hint {
  color: var(--color-text-tertiary);
  text-align: center;
}

.tool-home__enter-code-input {
  width: 100%;
  margin-top: var(--space-xs);
  padding: var(--space-md);
  box-sizing: border-box;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-muted);
  border: 1rpx solid var(--color-border);
}
