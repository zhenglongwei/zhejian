<view class="page tool-home">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content tool-home__pad">
      <ui-skeleton rows="{{2}}" title="{{true}}" />
      <view class="tool-home__gap">
        <ui-skeleton rows="{{3}}" />
      </view>
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content tool-home__pad">
      <view class="tool-home__hero card card--shadow">
        <text class="tool-home__kicker text-caption">辙见 · 服务相册</text>
        <text class="tool-home__title text-h1">服务相册</text>
        <text class="tool-home__subtitle text-body">查看门店为你创建的维修服务记录</text>
        <ui-compliance-notice type="displayDisclaimer" text="{{platformIdentity}}" />
      </view>
      <view class="tool-home__actions">
        <ui-button type="primary" block="{{true}}" loading="{{scanning}}" bind:btntap="onScanTap">
          扫描门店二维码
        </ui-button>
        <ui-button type="default" block="{{true}}" bind:btntap="onEnterCodeTap">输入相册码</ui-button>
      </view>
      <ui-empty
        title="相册列表加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content tool-home__body">
      <view class="tool-home__hero card card--shadow">
        <text class="tool-home__kicker text-caption">辙见 · 服务相册</text>
        <text class="tool-home__title text-h1">服务相册</text>
        <text class="tool-home__subtitle text-body">查看门店为你创建的维修服务记录</text>
        <view class="tool-home__identity">
          <ui-compliance-notice type="displayDisclaimer" text="{{platformIdentity}}" />
        </view>
      </view>

      <view class="tool-home__actions card card--shadow">
        <ui-button type="primary" block="{{true}}" loading="{{scanning}}" bind:btntap="onScanTap">
          扫描门店二维码
        </ui-button>
        <ui-button type="default" block="{{true}}" bind:btntap="onEnterCodeTap">输入相册码</ui-button>
        <ui-button type="default" block="{{true}}" bind:btntap="onMyAlbumsTap">我的服务相册</ui-button>
      </view>

      <view wx:if="{{showAlbumPreview}}" class="tool-home__section card card--shadow">
        <view class="tool-home__section-head">
          <text class="tool-home__section-title text-h3">我的服务记录</text>
          <text class="tool-home__more text-caption" bindtap="onViewAllAlbums">查看全部</text>
        </view>
        <view class="tool-home__album-list">
          <view
            wx:for="{{albumPreview}}"
            wx:key="albumId"
            class="tool-home__album-row"
            data-album-id="{{item.albumId}}"
            bindtap="onAlbumPreviewTap"
          >
            <text class="tool-home__album-title text-body">{{item.title || item.serviceName || '服务相册'}}</text>
            <text class="tool-home__album-desc text-caption">{{item.storeName || '门店'}}</text>
          </view>
        </view>
      </view>

      <view wx:elif="{{isLoggedIn && showAlbumEmpty}}" class="tool-home__section card card--shadow">
        <text class="tool-home__section-title text-h3">我的服务记录</text>
        <text class="tool-home__empty-hint text-caption">暂无服务相册，请扫描门店二维码或输入相册码</text>
      </view>

      <view wx:if="{{showH5PublicCaseLink}}" class="tool-home__section card card--shadow">
        <ui-cell
          title="{{h5SiteLabel}}"
          arrow="{{true}}"
          border="{{false}}"
          bind:celltap="onH5SiteTap"
        />
      </view>

      <view class="tool-home__section card card--shadow">
        <ui-cell title="我是商家，进入工作台" arrow="{{true}}" bind:celltap="onMerchantTap" />
        <ui-cell title="使用说明" arrow="{{true}}" border="{{false}}" bind:celltap="onHelpTap" />
      </view>
    </view>
  </block>

  <view wx:if="{{enterCodeVisible}}" class="tool-home__modal-mask" catchtouchmove="true">
    <view class="tool-home__modal card card--shadow">
      <text class="tool-home__modal-title text-h3">输入相册码</text>
      <text class="tool-home__modal-desc text-caption">请输入门店提供的相册 ID（以 alb_ 开头）</text>
      <input
        class="tool-home__modal-input text-body"
        value="{{enterCodeValue}}"
        placeholder="例如 alb_svc_xxx"
        bindinput="onEnterCodeInput"
        confirm-type="done"
        bindconfirm="onEnterCodeConfirm"
      />
      <view class="tool-home__modal-actions">
        <ui-button type="default" bind:btntap="onEnterCodeClose">取消</ui-button>
        <ui-button type="primary" bind:btntap="onEnterCodeConfirm">确认</ui-button>
      </view>
    </view>
  </view>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="album"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
