<view class="page order-album {{showBottomBar ? 'order-album--with-bar' : ''}}">
  <block wx:if="{{status === 'loading'}}">
    <view class="page-content order-album__pad">
      <ui-skeleton rows="{{3}}" title="{{true}}" />
      <ui-skeleton rows="{{4}}" />
      <ui-skeleton rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content order-album__body">
      <view class="order-album__privacy">
        <ui-privacy-banner scene="album" />
      </view>
      <ui-empty
        title="无法加载维修相册"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content order-album__body">
      <view class="order-album__privacy">
        <ui-privacy-banner scene="album" />
      </view>
      <ui-empty
        title="门店暂未上传维修过程"
        description="如你对维修进度有疑问，可联系门店或平台客服。"
        actionText="联系门店"
        bind:action="onCallStore"
      />
      <view class="order-album__empty-actions">
        <ui-button type="secondary" size="sm" bind:tap="onBackOrder">返回订单</ui-button>
      </view>
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="page-content order-album__body">
      <ui-card shadow="{{true}}" padding="{{true}}">
        <view class="order-album__summary-head">
          <ui-order-status-badge status="{{detail.orderStatus}}" size="sm" />
          <ui-tag wx:if="{{albumStatusLabel}}" variant="info" text="{{albumStatusLabel}}" />
        </view>
        <ui-key-info-table rows="{{detail.summaryRows}}" />
      </ui-card>

      <view class="order-album__privacy">
        <ui-privacy-banner scene="album" />
      </view>

      <view class="order-album__section">
        <text class="order-album__section-title text-h3">维修过程</text>
        <ui-album-node
          wx:for="{{detail.nodes}}"
          wx:key="id"
          title="{{item.title}}"
          images="{{item.images}}"
          time="{{item.updatedAtText}}"
          note="{{item.note}}"
          emptyText="该节点暂无图片"
        />
        <text
          wx:if="{{detail.storeNote}}"
          class="order-album__store-note text-caption"
        >{{detail.storeNote}}</text>
      </view>

      <ui-card
        wx:if="{{showAuthSection}}"
        shadow="{{true}}"
        padding="{{true}}"
      >
        <view class="order-album__auth-card">
          <text class="order-album__section-title text-h3">公开为维修案例</text>
          <ui-compliance-notice type="authorize" />
          <ui-checkbox-row checked="{{authChecked}}" bind:toggle="onAuthCheckToggle">
            <text>我已核对公开内容，同意将本次维修档案公开为案例。</text>
            <text class="text-link" catchtap="onOpenBenefitPolicy">《利益共享政策》</text>
          </ui-checkbox-row>
          <view class="order-album__auth-actions">
            <view class="order-album__auth-action">
              <ui-button
                type="ghost"
                size="sm"
                block="{{true}}"
                disabled="{{authSubmitting}}"
                bind:tap="onRejectAuth"
              >拒绝公开</ui-button>
            </view>
            <view class="order-album__auth-action">
              <ui-button
                type="primary"
                size="sm"
                block="{{true}}"
                disabled="{{!authChecked || authSubmitting}}"
                bind:tap="onSubmitAuth"
              >确认公开为案例</ui-button>
            </view>
          </view>
        </view>
      </ui-card>

      <view wx:elif="{{publicCaseHint}}" class="order-album__section">
        <text class="order-album__public-hint text-caption">{{publicCaseHint}}</text>
      </view>

      <view class="order-album__feedback">
        <text class="order-album__feedback-link text-caption text-link" bindtap="onFeedback">对此相册有疑问？</text>
      </view>
    </view>

    <ui-fixed-bottom-bar>
      <ui-button type="secondary" size="sm" slot="left" bind:tap="onCallStore">联系门店</ui-button>
      <ui-button type="secondary" size="sm" slot="right" bind:tap="onSupport">联系客服</ui-button>
    </ui-fixed-bottom-bar>
  </block>
</view>
