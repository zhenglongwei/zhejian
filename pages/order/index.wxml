<view class="page order-page">
  <view class="order-page__tabs page-content">
    <ui-tabs
      tabs="{{tabs}}"
      activeKey="{{activeTab}}"
      scrollable="{{true}}"
      bind:change="onTabChange"
    />
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="page-content order-page__list">
      <ui-skeleton wx:for="{{[1,2,3]}}" wx:key="*this" rows="{{4}}" />
    </view>
  </block>

  <block wx:elif="{{status === 'unauthenticated'}}">
    <view class="page-content order-page__guest">
      <ui-empty
        title="登录后查看订单"
        description="登录后可查看预约、支付与维修进度"
        actionText="微信一键登录"
        bind:action="onLoginTap"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="page-content">
      <ui-empty
        title="加载失败"
        description="{{errorMessage}}"
        actionText="重试"
        bind:action="onRetry"
      />
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="page-content">
      <ui-empty
        title="还没有订单"
        description="下单或预约后，可在此查看状态与维修进度"
        actionText="去首页"
        bind:action="onGoHome"
      />
    </view>
  </block>

  <block wx:else>
    <view class="page-content order-page__list">
      <ui-order-card
        wx:for="{{list}}"
        wx:key="id"
        item="{{item}}"
        audience="user"
        bind:tap="onCardTap"
        bind:action="onPrimaryAction"
      />
    </view>
  </block>

  <ui-login-sheet
    visible="{{loginSheetVisible}}"
    mode="{{loginSheetMode}}"
    bindContext="order"
    bind:close="closeLoginSheet"
    bind:cancel="closeLoginSheet"
    bind:success="onLoginSheetSuccess"
  />
</view>
