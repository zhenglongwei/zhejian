generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String          @id
  openid    String?         @unique
  unionid   String?
  nickname  String          @default("")
  avatarUrl String          @default("") @map("avatar_url") @db.VarChar(512)
  phone     String          @default("")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  orders    Order[]
  leads     ConsultLead[]
  staff     MerchantStaff[]
  reports   ContentReport[]
  searchHistory UserSearchHistory[]
  albumFeedback ServiceAlbumFeedback[]
  favorites   UserFavorite[]
  vehicles    UserVehicle[]

  @@index([unionid])
  @@map("users")
}

model Merchant {
  id                String          @id
  name              String          @default("")
  status            String          @default("DRAFT")
  ownerUserId       String          @default("") @map("owner_user_id")
  contactName       String          @default("") @map("contact_name")
  contactPhone      String          @default("") @map("contact_phone")
  legalName         String          @default("") @map("legal_name")
  creditCode        String          @default("") @map("credit_code")
  licensePhotoUrl   String          @default("") @map("license_photo_url") @db.VarChar(512)
  contactEmail      String          @default("") @map("contact_email")
  qualificationJson Json            @default("{}") @map("qualification_json")
  rejectReason      String          @default("") @map("reject_reason")
  agreedAt          DateTime?       @map("agreed_at")
  submittedAt       DateTime?       @map("submitted_at")
  approvedAt        DateTime?       @map("approved_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  stores            Store[]
  staff             MerchantStaff[]

  @@index([ownerUserId])
  @@index([status])
  @@map("merchants")
}

model Store {
  id            String   @id
  merchantId    String   @map("merchant_id")
  name          String   @default("")
  address       String   @default("")
  phone         String   @default("")
  latitude      Float?
  longitude     Float?
  businessHours String   @default("") @map("business_hours")
  intro         String   @default("") @db.Text
  photosJson    Json     @default("{}") @map("photos_json")
  servicesJson  Json     @default("[]") @map("services_json")
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  merchant      Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@map("stores")
}

model MerchantStaff {
  id          String   @id
  merchantId  String   @map("merchant_id")
  userId      String?  @map("user_id")
  invitePhone String   @default("") @map("invite_phone")
  storeId     String   @default("") @map("store_id")
  role        String   @default("owner")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([merchantId, userId])
  @@unique([merchantId, invitePhone])
  @@index([userId])
  @@index([invitePhone])
  @@map("merchant_staff")
}

model Order {
  id          String   @id
  userId      String   @map("user_id")
  status      String
  serviceName String   @default("") @map("service_name")
  storeId     String   @default("") @map("store_id")
  storeName   String   @default("") @map("store_name")
  vehicleJson Json?    @map("vehicle_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])
  album       Album?

  @@index([userId])
  @@map("orders")
}

/// V2.0 统一服务相册：orderId 可选（遗留订单相册）；主路径不依赖 order
model Album {
  id                  String              @id
  orderId             String?             @unique @map("order_id")
  userId              String              @default("") @map("user_id")
  merchantId          String              @default("") @map("merchant_id")
  storeId             String              @default("") @map("store_id")
  storeName           String              @default("") @map("store_name")
  serviceId           String              @default("") @map("service_id")
  serviceName         String              @default("") @map("service_name")
  userPhone           String              @default("") @map("user_phone")
  leadId              String              @default("") @map("lead_id")
  complexityLevel     String              @default("L1") @map("complexity_level")
  vehicleJson         Json?               @map("vehicle_json")
  priceMode           String              @default("") @map("price_mode")
  minAmount           Int?                @map("min_amount")
  maxAmount           Int?                @map("max_amount")
  partsJson           Json                @default("[]") @map("parts_json")
  pendingConfirmsJson Json                @default("[]") @map("pending_confirms_json")
  status              String              @default("draft")
  templateId          String              @default("") @map("template_id")
  templateName        String              @default("") @map("template_name")
  storeNote           String              @default("") @map("store_note") @db.Text
  fingerprint         String              @default("") @db.Text
  publicCaseStatus    String              @default("private") @map("public_case_status")
  authorizationTier   String              @default("private") @map("authorization_tier")
  imageCount          Int                 @default(0) @map("image_count")
  completedAt         DateTime?           @map("completed_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  order               Order?              @relation(fields: [orderId], references: [id])
  nodes               AlbumNode[]
  images              AlbumImage[]
  authorization       AlbumAuthorization?
  publicCase          PublicCase?
  shareTokens         AlbumShareToken[]

  @@index([merchantId, status])
  @@index([userPhone])
  @@index([storeId])
  @@map("albums")
}

model AlbumNode {
  albumId   String       @map("album_id")
  nodeId    String       @map("node_id")
  title     String
  sortOrder Int          @default(0) @map("sort_order")
  status    String       @default("pending")
  note      String       @default("") @db.Text
  updatedAt DateTime?    @map("updated_at")
  album     Album        @relation(fields: [albumId], references: [id], onDelete: Cascade)
  images    AlbumImage[]

  @@id([albumId, nodeId])
  @@map("album_nodes")
}

model AlbumImage {
  id        String    @id
  albumId   String    @map("album_id")
  nodeId    String    @map("node_id")
  idx       Int       @default(0)
  rawUrl    String    @map("raw_url") @db.VarChar(512)
  createdAt DateTime  @default(now()) @map("created_at")
  album     Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)
  node      AlbumNode @relation(fields: [albumId, nodeId], references: [albumId, nodeId], onDelete: Cascade)

  @@index([albumId, nodeId])
  @@map("album_images")
}

model ConsultLead {
  id              String          @id
  userId          String          @map("user_id")
  status          String          @default("SUBMITTED")
  serviceId       String          @default("") @map("service_id")
  serviceName     String          @default("") @map("service_name")
  storeId         String          @map("store_id")
  storeName       String          @default("") @map("store_name")
  storePhone      String          @default("") @map("store_phone")
  caseId          String          @default("") @map("case_id")
  sourcePage      String          @default("") @map("source_page")
  leadType        String          @default("message") @map("lead_type")
  vehicleJson     Json?           @map("vehicle_json")
  description     String          @default("") @db.Text
  imagesJson      Json            @default("[]") @map("images_json")
  appointmentJson Json?           @map("appointment_json")
  contactJson     Json?           @map("contact_json")
  isAccident      Boolean         @default(false) @map("is_accident")
  priceMode       String          @default("") @map("price_mode")
  platformConsent Boolean         @default(false) @map("platform_consent")
  closeReason     String?         @map("close_reason")
  closeNote       String          @default("") @map("close_note") @db.Text
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  user            User            @relation(fields: [userId], references: [id])
  statusLogs      LeadStatusLog[]

  @@index([userId, status])
  @@index([storeId, status])
  @@map("consult_leads")
}

model LeadStatusLog {
  id           String      @id @default(cuid())
  leadId       String      @map("lead_id")
  fromStatus   String?     @map("from_status")
  toStatus     String      @map("to_status")
  operatorType String      @map("operator_type")
  operatorId   String      @default("") @map("operator_id")
  reason       String      @default("") @db.Text
  createdAt    DateTime    @default(now()) @map("created_at")
  lead         ConsultLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_status_logs")
}

model PublicCase {
  id                  String    @id
  albumId             String    @unique @map("album_id")
  status              String    @default("pending_review")
  authorizationTier   String    @default("named") @map("authorization_tier")
  title               String    @default("")
  summary             String    @default("") @db.Text
  coverImage          String    @default("") @map("cover_image") @db.VarChar(512)
  contentJson         Json?     @map("content_json")
  storeId             String    @default("") @map("store_id")
  storeName           String    @default("") @map("store_name")
  serviceName         String    @default("") @map("service_name")
  city                String    @default("")
  minAmount           Int?      @map("min_amount")
  maxAmount           Int?      @map("max_amount")
  priceMode           String    @default("") @map("price_mode")
  publishedAt         DateTime? @map("published_at")
  slug                String?   @unique @db.VarChar(255)
  seoTitle            String    @default("") @map("seo_title") @db.VarChar(160)
  seoDescription      String    @default("") @map("seo_description") @db.VarChar(300)
  aiSummary           String    @default("") @map("ai_summary") @db.Text
  articleBody         String    @default("") @map("article_body") @db.Text
  articleStatus       String    @default("pending") @map("article_status") @db.VarChar(32)
  articleVersion      Int       @default(0) @map("article_version")
  articleGeneratedAt  DateTime? @map("article_generated_at")
  seoNoindex          Boolean   @default(false) @map("seo_noindex")
  canonicalPath       String    @default("") @map("canonical_path") @db.VarChar(512)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  album               Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([articleStatus])
  @@map("public_cases")
}

model CaseReviewLog {
  id             String   @id
  caseId         String   @map("case_id")
  reviewerId     String   @default("system") @map("reviewer_id")
  reviewAction   String   @map("review_action")
  reviewComment  String   @default("") @map("review_comment") @db.Text
  beforeStatus   String   @default("") @map("before_status")
  afterStatus    String   @default("") @map("after_status")
  riskLevel      String   @default("") @map("risk_level")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([caseId])
  @@map("case_review_log")
}

model ContentReport {
  id           String   @id
  userId       String   @map("user_id")
  targetType   String   @map("target_type")
  targetId     String   @map("target_id")
  targetTitle  String   @default("") @map("target_title")
  reportType   String   @map("report_type")
  description  String   @db.Text
  imagesJson   Json     @default("[]") @map("images_json")
  contactPhone String   @default("") @map("contact_phone")
  status       String   @default("pending")
  resolution   String   @default("") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])
  handleLogs   ReportHandleLog[]

  @@index([userId, targetType, targetId])
  @@index([status, createdAt])
  @@map("content_reports")
}

model ReportHandleLog {
  id           String        @id
  reportId     String        @map("report_id")
  reviewerId   String        @default("admin_system") @map("reviewer_id")
  handleAction String        @map("handle_action")
  handleComment String       @default("") @map("handle_comment") @db.Text
  beforeStatus String        @default("") @map("before_status")
  afterStatus  String        @default("") @map("after_status")
  createdAt    DateTime      @default(now()) @map("created_at")
  report       ContentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_handle_log")
}

model UserSearchHistory {
  id        String   @id
  userId    String   @map("user_id")
  keyword   String   @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
  @@index([userId, updatedAt])
  @@map("user_search_history")
}

model UserFavorite {
  id         String   @id
  userId     String   @map("user_id")
  targetType String   @map("target_type") @db.VarChar(16)
  targetId   String   @map("target_id") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType, createdAt])
  @@map("user_favorites")
}

model UserVehicle {
  id           String    @id
  userId       String    @map("user_id")
  brand        String    @default("") @db.VarChar(64)
  series       String    @default("") @db.VarChar(64)
  modelYear    String    @default("") @map("model_year") @db.VarChar(16)
  plateDisplay String    @default("") @map("plate_display") @db.VarChar(32)
  isDefault    Boolean   @default(false) @map("is_default")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
  @@map("user_vehicles")
}

model ServiceAlbumFeedback {
  id           String   @id
  userId       String   @map("user_id")
  albumId      String   @map("album_id")
  storeId      String   @default("") @map("store_id")
  nodeId       String   @default("") @map("node_id")
  nodeTitle    String   @default("") @map("node_title")
  feedbackType String   @map("feedback_type")
  description  String   @db.Text
  imagesJson   Json     @default("[]") @map("images_json")
  contactPhone String   @default("") @map("contact_phone")
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])

  @@index([albumId])
  @@index([userId, albumId, nodeId])
  @@index([status, createdAt])
  @@map("service_album_feedback")
}

model MerchantReviewLog {
  id            String   @id
  merchantId    String   @map("merchant_id")
  storeId       String   @default("") @map("store_id")
  reviewerId    String   @default("system") @map("reviewer_id")
  reviewAction  String   @map("review_action")
  reviewComment String   @default("") @map("review_comment") @db.Text
  beforeStatus  String   @default("") @map("before_status")
  afterStatus   String   @default("") @map("after_status")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([merchantId])
  @@map("merchant_review_log")
}

/// 商家服务方案（卷二 B-SVC-01）
model MerchantServicePlan {
  id                String   @id
  merchantId        String   @map("merchant_id")
  storeId           String   @map("store_id")
  serviceItemId     String   @map("service_item_id")
  categoryId        String   @default("") @map("category_id")
  name              String   @default("")
  summary           String   @default("") @db.Text
  detail            String   @default("") @db.Text
  priceMode         String   @map("price_mode")
  amount            Int?
  minAmount         Int?     @map("min_amount")
  maxAmount         Int?     @map("max_amount")
  priceFactors      Json     @default("[]") @map("price_factors")
  includedItems     Json     @default("[]") @map("included_items")
  excludedItems     Json     @default("[]") @map("excluded_items")
  appointmentJson   Json     @default("{}") @map("appointment_json")
  coverUrl          String   @default("") @map("cover_url") @db.VarChar(512)
  auditStatus       String   @default("DRAFT") @map("audit_status")
  saleStatus        String   @default("OFFLINE") @map("sale_status")
  acceptAppointment Boolean  @default(true) @map("accept_appointment")
  rejectReason      String   @default("") @map("reject_reason") @db.Text
  submittedAt       DateTime? @map("submitted_at")
  approvedAt        DateTime? @map("approved_at")
  publishedAt       DateTime? @map("published_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([merchantId])
  @@index([storeId])
  @@index([auditStatus])
  @@index([saleStatus])
  @@map("merchant_service_plans")
}

model ServiceReviewLog {
  id            String   @id
  planId        String   @map("plan_id")
  merchantId    String   @default("") @map("merchant_id")
  storeId       String   @default("") @map("store_id")
  reviewerId    String   @default("system") @map("reviewer_id")
  reviewAction  String   @map("review_action")
  reviewComment String   @default("") @map("review_comment") @db.Text
  beforeStatus  String   @default("") @map("before_status")
  afterStatus   String   @default("") @map("after_status")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([planId])
  @@map("service_review_log")
}

model DesensitizeTask {
  taskId             String             @id @map("task_id")
  bizType            String             @map("biz_type")
  bizId              String             @map("biz_id")
  orderId            String?            @map("order_id")
  operatorRole       String             @map("operator_role")
  liabilityType      String             @map("liability_type")
  preMaskStatus      String?            @map("pre_mask_status")
  preMaskVersion     Int                @default(0) @map("pre_mask_version")
  preMaskTaskId      String?            @map("pre_mask_task_id")
  fingerprint        String             @default("") @db.Text
  fromPreMask        Boolean            @default(false) @map("from_pre_mask")
  maskingConfirmed   Boolean            @default(false) @map("masking_confirmed")
  maskingConfirmedAt DateTime?          @map("masking_confirmed_at")
  preMaskedAt        DateTime?          @map("pre_masked_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  assets             DesensitizeAsset[]

  @@index([bizId, bizType])
  @@map("desensitize_tasks")
}

model DesensitizeAsset {
  taskId       String          @map("task_id")
  assetId      String          @map("asset_id")
  mediaId      String          @default("") @map("media_id")
  nodeId       String          @map("node_id")
  nodeTitle    String          @map("node_title")
  idx          Int             @default(0)
  rawUrl       String          @map("raw_url") @db.VarChar(512)
  maskedUrl    String          @default("") @map("masked_url") @db.VarChar(512)
  preMaskedUrl String          @default("") @map("pre_masked_url") @db.VarChar(512)
  status       String
  previewed    Boolean         @default(false)
  riskTags     Json            @default("[]") @map("risk_tags")
  riskLevel    String          @default("") @map("risk_level")
  task         DesensitizeTask @relation(fields: [taskId], references: [taskId], onDelete: Cascade)

  @@id([taskId, assetId])
  @@index([mediaId])
  @@map("desensitize_assets")
}

model MediaAsset {
  id                String   @id
  objectKey         String   @map("object_key") @db.VarChar(512)
  url               String   @db.VarChar(512)
  desensitizedKey   String   @default("") @map("desensitized_key") @db.VarChar(512)
  desensitizedUrl   String   @default("") @map("desensitized_url") @db.VarChar(512)
  desensitizeStatus String   @default("pending") @map("desensitize_status")
  privacyRiskLevel  String   @default("") @map("privacy_risk_level")
  riskTags          Json     @default("[]") @map("risk_tags")
  engineVersion     String   @default("") @map("engine_version")
  privacyDetectedAt DateTime? @map("privacy_detected_at")
  uploaderId        String   @default("") @map("uploader_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([objectKey])
  @@map("media_assets")
}

/// PRD 06 §17.3：单图隐私检测记录（按 detect_type 分行）
model PrivacyDetectionResult {
  id          String   @id
  imageId     String   @map("image_id")
  caseId      String   @default("") @map("case_id")
  detectType  String   @map("detect_type")
  resultJson  Json     @map("result_json")
  riskLevel   String   @default("") @map("risk_level")
  maskedPath  String   @default("") @map("masked_path") @db.VarChar(512)
  status      String   @default("success")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([imageId, caseId, detectType])
  @@index([imageId])
  @@index([caseId])
  @@map("privacy_detection_result")
}

model AlbumAuthorization {
  albumId   String   @id @map("album_id")
  agreed    Boolean
  status    String
  tier      String   @default("named")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("album_authorizations")
}

model AlbumShareToken {
  id        String   @id
  albumId   String   @map("album_id")
  userId    String   @map("user_id")
  mode      String   @default("desensitized")
  channel   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@index([userId])
  @@map("album_share_tokens")
}

/// 卷二 B-STATS：商家门店日指标（T+1 聚合）
model MerchantDailyStats {
  id                  String   @id
  merchantId          String   @map("merchant_id")
  storeId             String   @map("store_id")
  statDate            DateTime @map("stat_date") @db.Date
  storeViewCount      Int      @default(0) @map("store_view_count")
  serviceViewCount    Int      @default(0) @map("service_view_count")
  caseViewCount       Int      @default(0) @map("case_view_count")
  h5CaseViewCount     Int      @default(0) @map("h5_case_view_count")
  mpCaseViewCount     Int      @default(0) @map("mp_case_view_count")
  geoViewCount        Int      @default(0) @map("geo_view_count")
  crawlerViewCount    Int      @default(0) @map("crawler_view_count")
  phoneClickCount     Int      @default(0) @map("phone_click_count")
  leadSubmitCount     Int      @default(0) @map("lead_submit_count")
  leadContactedCount  Int      @default(0) @map("lead_contacted_count")
  leadClosedCount     Int      @default(0) @map("lead_closed_count")
  caseConsultCount    Int      @default(0) @map("case_consult_count")
  albumCreatedCount   Int      @default(0) @map("album_created_count")
  albumCompletedCount Int      @default(0) @map("album_completed_count")
  albumCompleteRate   Float?   @map("album_complete_rate")
  transparencyScore   Int      @default(0) @map("transparency_score")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([merchantId, storeId, statDate])
  @@index([merchantId, statDate])
  @@index([storeId, statDate])
  @@map("merchant_daily_stats")
}

/// 卷五 B-TRACK：站外/H5 行为埋点（浏览、电话、咨询点击等）
model EventTrackingLog {
  id          String   @id
  eventId     String   @unique @map("event_id")
  eventName   String   @map("event_name")
  userId      String   @default("") @map("user_id")
  role        String   @default("user")
  sessionId   String   @default("") @map("session_id")
  pagePath    String   @default("") @map("page_path") @db.VarChar(512)
  referrer    String   @default("") @db.VarChar(512)
  source      String   @default("") @db.VarChar(128)
  channel     String   @default("") @db.VarChar(64)
  city        String   @default("") @db.VarChar(64)
  eventParams Json     @default("{}") @map("event_params")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventName, createdAt])
  @@index([createdAt])
  @@map("event_tracking_log")
}

model NotificationMessage {
  id           String    @id
  receiverType String    @map("receiver_type")
  receiverId   String    @map("receiver_id")
  messageType  String    @map("message_type")
  title        String    @default("")
  content      String    @default("") @db.Text
  refType      String    @default("") @map("ref_type")
  refId        String    @default("") @map("ref_id")
  jumpPath     String    @default("") @map("jump_path") @db.VarChar(256)
  channel      String    @default("in_app")
  status       String    @default("sent")
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  sendLogs     NotificationSendLog[]

  @@index([receiverType, receiverId, readAt])
  @@index([receiverType, receiverId, createdAt])
  @@index([refType, refId, messageType])
  @@map("notification_messages")
}

model NotificationSendLog {
  id         String              @id
  messageId  String              @map("message_id")
  channel    String              @default("wechat")
  templateId String              @default("") @map("template_id")
  sendStatus String              @default("pending") @map("send_status")
  failReason String              @default("") @map("fail_reason") @db.VarChar(512)
  retryCount Int                 @default(0) @map("retry_count")
  sentAt     DateTime?           @map("sent_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  message    NotificationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("notification_send_logs")
}

model NotificationSubscription {
  id           String   @id
  userId       String   @map("user_id")
  templateKey  String   @map("template_key")
  templateId   String   @default("") @map("template_id")
  status       String   @default("accept")
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, templateKey])
  @@index([userId])
  @@map("notification_subscriptions")
}

/// GEO-TOPIC-A01 · 意图专题页（替代 mock/geo-pages）
model GeoPage {
  id                  String    @id
  slug                String    @unique @db.VarChar(128)
  title               String    @default("")
  summary             String    @default("") @db.Text
  coverImage          String    @default("") @map("cover_image") @db.VarChar(512)
  pageType            String    @default("city_service") @map("page_type") @db.VarChar(32)
  city                String    @default("")
  serviceId           String    @default("") @map("service_id")
  faultTag            String    @default("") @map("fault_tag")
  vehicleSeries       String    @default("") @map("vehicle_series")
  keywordsJson        Json      @default("[]") @map("keywords_json")
  scenariosJson       Json      @default("[]") @map("scenarios_json")
  priceFactorsJson    Json      @default("[]") @map("price_factors_json")
  faqJson             Json      @default("[]") @map("faq_json")
  faqLinksJson        Json      @default("[]") @map("faq_links_json")
  relatedCaseIdsJson  Json      @default("[]") @map("related_case_ids_json")
  relatedStoreIdsJson Json      @default("[]") @map("related_store_ids_json")
  primaryStoreId      String    @default("") @map("primary_store_id")
  relatedServiceId    String    @default("") @map("related_service_id")
  seoTitle            String    @default("") @map("seo_title") @db.VarChar(160)
  seoDescription      String    @default("") @map("seo_description") @db.VarChar(300)
  aiSummary           String    @default("") @map("ai_summary") @db.Text
  serviceMetaJson     Json      @default("{}") @map("service_meta_json")
  status              String    @default("draft") @db.VarChar(32)
  publishedAt         DateTime? @map("published_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([city])
  @@index([pageType])
  @@map("geo_pages")
}

/// GEO-OBS-A01 · 爬虫 URL 日聚合
model CrawlerUrlDaily {
  id        String   @id
  statDate  DateTime @map("stat_date") @db.Date
  url       String   @db.VarChar(512)
  pageType  String   @default("") @map("page_type") @db.VarChar(32)
  botType   String   @default("") @map("bot_type") @db.VarChar(64)
  hitCount  Int      @default(0) @map("hit_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([statDate, url, botType])
  @@index([statDate])
  @@index([pageType, statDate])
  @@map("crawler_url_daily")
}

/// GEO-OBS-B01 · Prompt 探测词库
model GeoPromptProbe {
  id         String   @id
  promptId   String   @unique @map("prompt_id") @db.VarChar(64)
  prompt     String   @db.Text
  city       String   @default("")
  service    String   @default("")
  fault      String   @default("")
  topicSlug  String   @default("") @map("topic_slug") @db.VarChar(128)
  pageType   String   @default("") @map("page_type") @db.VarChar(32)
  promptType String   @default("B") @map("prompt_type") @db.VarChar(8)
  source     String   @default("seed") @db.VarChar(32)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@index([topicSlug])
  @@map("geo_prompt_probe")
}

/// GEO-OBS-B05 · Prompt 探测结果
model GeoPromptProbeResult {
  id                  String   @id
  promptId            String   @map("prompt_id") @db.VarChar(64)
  engine              String   @default("default") @db.VarChar(32)
  mentioned           Boolean  @default(false)
  citedUrl            String   @default("") @map("cited_url") @db.VarChar(512)
  citedUrlsJson       Json     @default("[]") @map("cited_urls_json")
  externalDomainsJson Json     @default("[]") @map("external_domains_json")
  rawHash             String   @default("") @map("raw_hash") @db.VarChar(64)
  status              String   @default("ok") @db.VarChar(32)
  errorMessage        String   @default("") @map("error_message") @db.VarChar(512)
  probedAt            DateTime @default(now()) @map("probed_at")

  @@index([promptId, probedAt])
  @@index([probedAt])
  @@index([engine, probedAt])
  @@map("geo_prompt_probe_result")
}
