# 复制为 .env 后修改
NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# PostgreSQL（本地 docker-compose 默认值）
DATABASE_URL=postgresql://zhejian:zhejian_dev_pass@127.0.0.1:5432/zhejian?schema=public

# 开发联调：允许固定 token（生产务必关闭或换 JWT）
DEV_AUTH_ENABLED=true
DEV_USER_TOKEN=dev_user_token_change_me
DEV_MERCHANT_TOKEN=dev_merchant_token_change_me
DEV_SYSTEM_TOKEN=dev_system_token_change_me

# 对外域名（生成脱敏占位 URL、CORS）
PUBLIC_BASE_URL=https://geo.simplewin.cn
