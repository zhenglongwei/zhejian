# 复制为 .env 后修改
NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# MySQL（生产：填阿里云服务器上已有 MySQL 的连接信息）
# 格式：mysql://用户名:密码@主机:3306/数据库名
DATABASE_URL=mysql://zhejian:YOUR_PASSWORD@127.0.0.1:3306/zhejian

# 开发联调：允许固定 token（生产关闭；真微信登录见下方 WECHAT_* + JWT_SECRET）
DEV_AUTH_ENABLED=true
DEV_USER_TOKEN=dev_user_token_change_me
DEV_MERCHANT_TOKEN=dev_merchant_token_change_me
DEV_SYSTEM_TOKEN=dev_system_token_change_me

# JWT（真机微信登录必填；生产务必使用强随机串）
JWT_SECRET=change_me_to_random_secret_in_production
JWT_EXPIRES_IN=7d

# 微信小程序（B-AUTH-02/03；与 project.config.json appid 一致）
WECHAT_APP_ID=wx54cc6c18cc01b815
WECHAT_APP_SECRET=

# 订阅消息模板 ID（公众平台 → 功能 → 订阅消息；字段名默认 thing1/thing2/time3，可用 WECHAT_TMPL_*_FIELD_* 覆盖）
# 订阅消息：相册完工 + 用户咨询（被联系/已关闭）共用「服务进度通知」
WECHAT_TMPL_CONSULT=Vn2wSg-awTJf_JHz-HGCGwK2A9Plhv4FUszMRQBaTzA
WECHAT_TMPL_CONSULT_FIELD_SERVICE=thing1
WECHAT_TMPL_CONSULT_FIELD_STATUS=thing2
WECHAT_TMPL_CONSULT_FIELD_TIPS=thing6
# 相册完工 · 同上模板
WECHAT_TMPL_ALBUM=Vn2wSg-awTJf_JHz-HGCGwK2A9Plhv4FUszMRQBaTzA
WECHAT_TMPL_ALBUM_FIELD_SERVICE=thing1
WECHAT_TMPL_ALBUM_FIELD_STATUS=thing2
WECHAT_TMPL_ALBUM_FIELD_TIPS=thing6
# 授权/案例/入驻审核 · 审核结果通知（phrase1/character_string14/date2/thing3）
WECHAT_TMPL_AUDIT=C3yoxdol46FV756VQr91Em63Cj4vBEF9u9NLVNXelfI
WECHAT_TMPL_AUDIT_FIELD_STATUS=phrase1
WECHAT_TMPL_AUDIT_FIELD_CASE_NO=character_string14
WECHAT_TMPL_AUDIT_FIELD_TIME=date2
WECHAT_TMPL_AUDIT_FIELD_REMARK=thing3
# 商家新线索 · 新留言通知（选用后按「我的模板」详情填 key）
WECHAT_TMPL_LEAD=
# WECHAT_TMPL_LEAD_FIELD_SENDER=name1
# WECHAT_TMPL_LEAD_FIELD_TIME=time1
# WECHAT_TMPL_LEAD_FIELD_TIPS=thing2

# MVP：提交入驻后自动审核通过（运营后台就绪后设为 false；staging/prod 务必 false）
MERCHANT_AUTO_APPROVE=false

# TEST-ONLY: 允许商家手填车主手机号（与小程序 services/config.js ALLOW_TEST_OWNER_PHONE 配套）
MERCHANT_OWNER_PHONE_TEST=true

# 对外域名（上传返回 URL、相册读图、脱敏引擎拉原图）
# 本地联调务必与小程序 services/config.js ACTIVE_ENV=local 一致，例如：
# PUBLIC_BASE_URL=http://127.0.0.1:3000
# 生产：PUBLIC_BASE_URL=https://geo.simplewin.cn
# 未设置时：development 默认 http://HOST:PORT，production 默认 geo.simplewin.cn
PUBLIC_BASE_URL=http://127.0.0.1:3000

# 媒体文件本地存储目录（B-MEDIA；生产建议挂载持久盘）
MEDIA_STORAGE_DIR=./data/media

# B-MASK-03 脱敏引擎（生产 ECS 绑 RAM 角色，勿配主账号 Key）
DESENSITIZE_ENGINE=aliyun
ALIYUN_REGION=cn-shanghai
# 本地开发用 RAM 子用户 Key（生产 ECS 留空，走实例角色）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# 若自动取角色失败，可显式指定 ECS RAM 角色名（与控制台一致）
# ECS_RAM_ROLE_NAME=ZhejianEcsDesensitizeRole
# ALIYUN_OCR_API_ENDPOINT=ocr-api.cn-shanghai.aliyuncs.com
# ALIYUN_VIAPI_OCR_ENDPOINT=ocr.cn-shanghai.aliyuncs.com
# DESENSITIZE_ENGINE=dev
# DESENSITIZE_API_TIMEOUT_MS=15000
# DESENSITIZE_MAX_FACE_NUMBER=10
# 车辆接车图默认不做人脸检测；需检测时设为 true
# DESENSITIZE_DETECT_FACE=false
# ECS 上 ocr-api 不可达时默认 viapi；可改为 auto 先走 ocr-api
# DESENSITIZE_PLATE_PROVIDER=viapi
# 引擎升级时递增，使旧 pre-mask 缓存失效
# DESENSITIZE_CACHE_VERSION=aliyun-v7

# ── 百炼千问 · GEO 探测 / 案例润色 / 图说（OpenAI 兼容接口）──
# API Key：https://bailian.console.aliyun.com → API-KEY 管理（北京地域）
# 文档：https://help.aliyun.com/zh/model-studio/qwen-api-via-openai-chat-completions
# DASHSCOPE_API_KEY=sk-xxx

# GEO 探测（运营台「运行探测」· cron 周频 · 仅联网 API，模拟用户开启联网问答）
# GEO_PROBE_ENABLED=true
# GEO_PROBE_DRY_RUN=false
# GEO_PROBE_ENGINES=qwen,doubao,kimi,wenxin
# GEO_PROBE_BATCH_LIMIT=20
# GEO_PROBE_TIMEOUT_MS=120000
#
# ── 通义千问（Tier 1 · 北极星主曲线 · enable_search）──
# GEO_PROBE_QWEN_API_KEY=sk-xxx          # 或 GEO_PROBE_API_KEY / DASHSCOPE_API_KEY
# GEO_PROBE_QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# GEO_PROBE_QWEN_MODEL=qwen-plus
# GEO_PROBE_QWEN_BATCH_LIMIT=20
# GEO_PROBE_QWEN_ENABLE_THINKING=false
#
# ── 豆包 · 火山方舟 Responses API + web_search（Tier 2）──
# GEO_PROBE_DOUBAO_API_KEY=xxx           # 或 ARK_API_KEY
# GEO_PROBE_DOUBAO_RESPONSES_API_URL=https://ark.cn-beijing.volces.com/api/v3/responses
# GEO_PROBE_DOUBAO_MODEL=doubao-1-5-pro-32k-250115   # 或方舟推理接入点 ep-xxx
# GEO_PROBE_DOUBAO_BATCH_LIMIT=10
#
# ── Kimi · Moonshot builtin $web_search（Tier 2）──
# GEO_PROBE_KIMI_API_KEY=sk-xxx
# GEO_PROBE_KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
# GEO_PROBE_KIMI_MODEL=kimi-k2-turbo-preview
# GEO_PROBE_KIMI_BATCH_LIMIT=10
#
# ── 百度文心 · 千帆 v2 web_search.enable（Tier 2）──
# GEO_PROBE_WENXIN_API_KEY=xxx           # 千帆 API Key（Bearer）
# GEO_PROBE_WENXIN_API_URL=https://qianfan.baidubce.com/v2/chat/completions
# GEO_PROBE_WENXIN_MODEL=ernie-4.5-turbo-32k
# GEO_PROBE_WENXIN_BATCH_LIMIT=10
#
# 暂不可用：TokenHub hy3-preview 实测 enable_enhancement 无 search_info（2026-06-21）
# GEO_PROBE_YUANBAO_API_KEY=sk-xxx
# GEO_PROBE_YUANBAO_MODEL=hy3-preview
#
# 已移除：DeepSeek 官方 API 无联网搜索
# GEO_PROBE_ENGINES=qwen,doubao,kimi,wenxin
# GEO_PROBE_ENGINE=qwen                              # 遗留单引擎；勿写 qwen,doubao（请用 ENGINES）

# 案例 GEO 文本润色（运营审核台 LLM 草稿）
# GEO_LLM_ENABLED=true
# GEO_LLM_DRY_RUN=false
# GEO_LLM_API_KEY=sk-xxx
# GEO_LLM_MODEL=qwen3.6-plus
# GEO_LLM_ENABLE_THINKING=false

# 案例脱敏图图说（qwen3.6-plus 多模态；图 URL 须公网可访问）
# GEO_VISION_ENABLED=true
# GEO_VISION_DRY_RUN=false
# GEO_VISION_API_KEY=sk-xxx
# GEO_VISION_MODEL=qwen3.6-plus
