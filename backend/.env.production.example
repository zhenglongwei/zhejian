NODE_ENV=production
# simplewin.cn 官网占 3000；辙见 API 用 PM2 时建议 3100（与 geo Nginx 一致）
PORT=3100
HOST=127.0.0.1

# 【必改】服务器 MySQL（与 API 同机时用 127.0.0.1）
DATABASE_URL=mysql://zhejian:YOUR_PASSWORD@127.0.0.1:3306/zhejian

DEV_AUTH_ENABLED=true
DEV_USER_TOKEN=请改成随机长字符串
DEV_MERCHANT_TOKEN=请改成随机长字符串
DEV_SYSTEM_TOKEN=请改成随机长字符串

# 运营后台登录密码（/admin/）
ADMIN_PASSWORD=请改成强密码

# 【必改】小程序 JWT + 运营后台登录签发（须与生产 .env 一致）
JWT_SECRET=请改成随机长字符串

# 【可选】Nginx SSL 路径（部署脚本未自动检测到时填写）
# SSL_CERTIFICATE=/etc/letsencrypt/live/geo.simplewin.cn/fullchain.pem
# SSL_CERTIFICATE_KEY=/etc/letsencrypt/live/geo.simplewin.cn/privkey.pem

# ── 百炼千问 · GEO（生产 ECS backend/.env）──
# DASHSCOPE_API_KEY=sk-xxx
# GEO_PROBE_ENABLED=true
# GEO_PROBE_DRY_RUN=false
# GEO_PROBE_API_KEY=sk-xxx
# GEO_PROBE_MODEL=qwen-plus
# GEO_PROBE_ENGINE=qwen
# GEO_LLM_ENABLED=true
# GEO_LLM_DRY_RUN=false
# GEO_LLM_MODEL=qwen3.6-plus
# GEO_VISION_ENABLED=true
# GEO_VISION_DRY_RUN=false
# GEO_VISION_MODEL=qwen3.6-plus

# ── 微信支付 V3（商家套餐 JSAPI）──
# 商户平台下载的 API 证书：仅用 apiclient_key.pem + apiclient_cert.pem（勿提交仓库）
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_CERT_SERIAL=
# WECHAT_PAY_PRIVATE_KEY_PATH=/var/www/zhejian/backend/secrets/apiclient_key.pem
# WECHAT_PAY_NOTIFY_URL=https://geo.simplewin.cn/api/v1/pay/wechat/notify
# 公钥模式（商户平台「微信支付公钥」页）
# WECHAT_PAY_PUBLIC_KEY_ID=PUB_KEY_ID_01167592714420260321001922
# WECHAT_PAY_PUBLIC_KEY_PATH=/var/www/zhejian/backend/secrets/wechat_pub_key.pem
# 联调：套餐实付 1 分（勿在生产长期开启）
# WECHAT_PAY_SUBSCRIPTION_TEST_AMOUNT_CENTS=1
